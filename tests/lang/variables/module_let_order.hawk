//! spec: module-let-order
//! mode: run

// Initializers run in dependency order, not declaration order: a global may
// reference one declared later, and the linker reorders so the dependency is
// computed first. See docs/language.md.
let DERIVED: Int = BASE * 2;   // references a global declared below
let BASE: Int = 21;

fn main() -> Int {
    println('${DERIVED}');   // expect: 42
    return 0;
}
