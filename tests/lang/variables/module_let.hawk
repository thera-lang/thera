//! spec: module-let
//! mode: run

// A module-level `let` is computed once at load into a stored global slot;
// referencing it reads the stored value (a computed initializer, unlike `const`).
let BASE: Int = 6;
let ANSWER: Int = BASE * 7;   // a later global may reference an earlier one

fn main() -> Int {
    println('${ANSWER}');   // expect: 42
    return 0;
}
