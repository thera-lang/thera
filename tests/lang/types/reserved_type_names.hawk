//! spec: type-reserved-names
//! mode: check

// The type names the language itself speaks are reserved (language.md "Reserved
// type names"): declaring them in user code is a check error, whatever the
// declaration kind. Utility types that merely live in core (BytesBuilder,
// Args, Indexed, ...) are NOT reserved — semantics attach to the core types by
// identity, so redeclaring those is ordinary owner-correct shadowing.

struct Result {    // expect error: `Result` is a reserved type name
    x: Int,
}

enum Option {      // expect error: `Option` is a reserved type name
    A,
    B,
}

interface Iterator {   // expect error: `Iterator` is a reserved type name
    fn next(self) -> Int;
}

struct Error {     // expect error: `Error` is a reserved type name
    message: String,
}

struct Void {      // expect error: `Void` is a reserved type name
    x: Int,
}

// A type *parameter* declares a type name for its scope, so the reservation
// applies there too (a `<Result>` param would otherwise pass the `?` and
// implicit-`Ok` checks by spelling).
fn pick<Result>(_ x: Result) -> Result {   // expect error: `Result` is a reserved type name
    return x;
}

struct Box<List> {   // expect error: `List` is a reserved type name
    value: List,
}

// The core-semantic interfaces are reserved too (decision 2026-07): `Eq`,
// `Ord`, `Display`, and `Debug` carry language semantics (`==`, sorting,
// `${}` rendering, the structural derives), so a user declaration would be
// ambiguous at every use site.
interface Display {   // expect error: `Display` is a reserved type name
    fn show(self) -> String;
}

struct Ord {   // expect error: `Ord` is a reserved type name
    v: Int,
}

// Not reserved: a utility type that happens to share a core name.
struct Args {
    values: List<String>,
}

// Not reserved: an ordinary user name.
struct Config {
    x: Int,
}

fn main() -> Void { }
