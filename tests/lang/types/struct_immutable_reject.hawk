//! spec: type-struct-immut
//! mode: check

type Point = {
    x: Int,
    y: Int,
}

fn main() -> Int {
    let p = Point { x: 1, y: 2 };
    // Struct fields are immutable by default; `x` is not `mut`, so assigning it
    // is an error.
    p.x = 9;   // expect error: cannot assign to field `x`
    return 0;
}
