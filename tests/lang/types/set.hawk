//! spec: type-set
//! mode: run

fn main() -> Int {
    // Set.from de-duplicates: six items, three distinct.
    let s = Set.from([1, 2, 2, 3, 3, 3]);
    println('${s.len()}');     // expect: 3
    println('${s.has(2)}');    // expect: true
    println('${s.has(9)}');    // expect: false
    return 0;
}
