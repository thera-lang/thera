//! spec: type-impl-param-bare
//! mode: check

// The `<…>` of an inherent `impl Type<…>` declares the impl type's own
// parameters, so each element must be a bare name. A type expression here
// used to lower its head as a parameter and silently drop the arguments
// (PA10: `impl Box<Indexed<T>>` became `impl Box<Indexed>`).

struct Box<T> { v: T }
struct Pair<T> { a: T, b: T }

impl Box<Pair<T>> { // expect error: an impl type parameter must be a bare name
    fn first(self) -> T { return self.v.a; }
}

fn main() -> Void {}
