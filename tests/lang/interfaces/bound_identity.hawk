//! spec: iface-bound-identity
//! mode: check

import 'libshape_a' as a;
import 'libshape_b' as b;

// A type-parameter bound resolves in its *declaring* file's scope and is
// satisfied by identity: libshape_a's `a_bounded<T: Shape>` names a's Shape,
// so a conformer to a's Shape satisfies it while a conformer to b's same-named
// Shape does not. (The core-semantic interfaces — Eq/Ord/Display/Debug — are
// reserved names, so their intrinsics can't even be shadowed; see
// types/reserved_type_names.hawk.)

fn f() -> Int {
    let ok = a.a_bounded(a.CircleA { r: 1 });
    return a.a_bounded(b.SquareB { side: 2 }) + ok; // expect error: type argument `SquareB` for `T` does not implement `Shape` (required by "a_bounded")
}
