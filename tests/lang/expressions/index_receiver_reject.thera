//! spec: expr-index-receiver
//! mode: check

// Only `List` and `Map` are indexable; `a[i]` (and `a[i] = v`) on any other
// receiver is a check error (was emit-only). `String` keeps its tailored hint
// (spec type-string-noindex).

struct P {
    let x: Int;
}

fn f() -> Int {
    let p = P { x: 1 };
    return p[0];   // expect error: indexing on P is not supported
}

fn g() {
    let p = P { x: 1 };
    p[0] = 2;   // expect error: indexing on P is not supported
}

fn h() -> Int {
    let n = 5;
    return n[0];   // expect error: indexing on Int is not supported
}

// Fine: list and map indexing, both directions.
fn ok() -> Int {
    let xs = [1, 2, 3];
    xs[0] = 9;
    let m = ['a': 1];
    return xs[0] + m['a'];
}

fn main() -> Int {
    println('${ok()}');
    return 0;
}
