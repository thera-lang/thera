//! spec: cf-match-nested
//! mode: run

enum Op {
    Add,
    Sub,
}

enum Expr {
    Num(Int),
    Bin(Op, Expr, Expr),
}

// Patterns nest to any depth and bind at the leaves: `Bin(Add, l, r)` tests the
// `Bin` tag and the nested zero-arg `Add`/`Sub` tag, binding `l` and `r`.
fn eval(_ e: Expr) -> Int {
    return match e {
        Num(n) => n,
        Bin(Add, l, r) => eval(l) + eval(r),
        Bin(Sub, l, r) => eval(l) - eval(r),
    };
}

// Nested patterns through a *generic* payload: the inner constructor resolves
// against the instantiated payload type (`Some(Num(...))` on an `Option<Expr>`
// substitutes the subject's type argument), previously an 'unknown variant'
// compile error.
fn eval_opt(_ e: Option<Expr>) -> Int {
    return match e {
        Some(Num(n)) => n * 2,
        Some(other) => eval(other),
        None => -1,
    };
}

fn main() -> Int {
    let sum = Expr.Bin(Op.Add, Expr.Num(2), Expr.Num(3));
    println('${eval(sum)}');   // expect: 5
    let diff = Expr.Bin(Op.Sub, Expr.Num(10), Expr.Num(4));
    println('${eval(diff)}');  // expect: 6
    println('${eval_opt(Option.Some(Expr.Num(21)))}');  // expect: 42
    println('${eval_opt(Option.Some(sum))}');           // expect: 5
    println('${eval_opt(Option.None)}');                // expect: -1
    return 0;
}
