//! spec: grammar.md#not-yet-in-the-grammar
//! mode: run
//! xfail: `break` is not yet implemented (lexes as an ordinary identifier)

fn main() -> Int {
    let mut sum = 0;
    for i in 0..10 {
        if i == 5 {
            break;
        }
        sum = sum + i;
    }
    println('${sum}');           // expect: 10
    return 0;
}
