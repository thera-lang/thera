//! spec: cf-for-iterable
//! mode: check

// A `for` iterable must be a range, a `List`, or conform to `Iterator` — the
// same set codegen lowers, enforced at check (was an emit-only error).

import std.iter

fn f() {
    for x in 5 {   // expect error: cannot iterate Int (only ranges, lists, and Iterators are supported)
        println('${x}');
    }
}

fn g() {
    for x in 'abc' {   // expect error: cannot iterate String (only ranges, lists, and Iterators are supported)
        println(x);
    }
}

// Fine: a range, a list, and a lazy iterator chain.
fn ok() {
    for i in 0..3 {
        println('${i}');
    }
    for x in [1, 2, 3] {
        println('${x}');
    }
    for y in iter.range(0, 3).map((n) => n * 10) {
        println('${y}');
    }
}

fn main() -> Int {
    ok();
    return 0;
}
