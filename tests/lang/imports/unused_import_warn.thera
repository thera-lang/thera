//! spec: warn-unused-import
//! mode: check

// An import whose namespace is never referenced is a warning — reported by
// `thera check` (with its rule name) but not compile-blocking. Any identifier
// occurrence of the namespace counts as a use (qualified calls, qualified
// types). A `// ignore: unused-import` comment on the import's line, or the
// line above, suppresses it at that site.

import std.fs;   // expect warning: unused import: `std.fs` is never referenced
import std.path;
import std.time;

// ignore: unused-import
import std.math;

fn tick(_ c: time.Clock) -> Int {
    return c.now_millis();
}

fn main() -> Int {
    println(path.join('a', 'b'));
    return 0;
}
