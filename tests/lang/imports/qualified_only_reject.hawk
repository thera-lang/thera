//! spec: mod-qualified-only
//! mode: check

import std.math;

fn main() -> Int {
    // `sqrt` belongs to `math`; a bare reference to it is rejected — it must be
    // written `math.sqrt` (or the library imported `as _`).
    let r = sqrt(16.0);   // expect error: bare reference to `sqrt`
    println('${r}');
    return 0;
}
