// Support library: `Point` (lat/lng) and `Label` — the same two type names
// libpoint_a defines, with disjoint fields (`lng`/`b_id` vs `y`/`a_id`). A
// qualified `b.Point` / `b.Label` reaches this one; the disjoint fields make a
// wrong owner fail to compile rather than silently pick the other library's type.

pub struct Label {
    b_id: Int,
}

pub struct Point {
    lat: Int,
    lng: Int,
    label: Label,
}

pub fn total(_ p: Point) -> Int {
    return p.lat + p.lng + p.label.b_id;
}
