// Support library: `Point` (lat/lng) and `Label` — the same two type names
// libpoint_a defines, with disjoint fields (`lng`/`b_id` vs `y`/`a_id`) and its own
// `scaled` / `Display`. A qualified `b.Point` reaches this one; the disjoint fields
// and distinct method bodies make a wrong owner mis-dispatch rather than silently
// pick the other library's type.

pub struct Label {
    let b_id: Int;
}

pub struct Point {
    let lat: Int;
    let lng: Int;
    let label: Label;
}

impl Point {
    pub fn scaled(self) -> Int {
        return self.lat * 100 + self.lng;
    }
}

impl Display for Point {
    pub fn display(self) -> String {
        return 'b:${self.lat},${self.lng}';
    }
}

pub fn total(_ p: Point) -> Int {
    return p.lat + p.lng + p.label.b_id;
}

// The same-named generic type as libpoint_a's `Pair<T>`, picking the other way.
pub struct Pair<T> {
    let first: T;
    let second: T;
}

impl Pair<T> {
    pub fn pick(self) -> T {
        return self.second;
    }
}
