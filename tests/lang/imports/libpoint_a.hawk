// Support library: `Point` (x/y) plus a second type `Label` — BOTH names are also
// defined by libpoint_b, with different fields. Owner-correct resolution (Phase 1)
// keeps them distinct; a qualified `a.Point` / `a.Label` reaches this library's.
// Exercises the collision-sensitive resolution paths: a function signature (`sum`'s
// `Point` param), a struct field's declared type (`Point.label: Label`, itself a
// collided name), an inherent method (`scaled`), and an interface impl (`Display`).

pub struct Label {
    a_id: Int,
}

pub struct Point {
    x: Int,
    y: Int,
    label: Label,
}

impl Point {
    pub fn scaled(self) -> Int {
        return self.x * 10 + self.y;
    }
}

impl Display for Point {
    pub fn display(self) -> String {
        return 'a:${self.x},${self.y}';
    }
}

pub fn sum(_ p: Point) -> Int {
    return p.x + p.y + p.label.a_id;
}

// A *generic* collided type: libpoint_b declares `Pair<T>` too, with the
// opposite `pick`. Member typing on a collided generic type must bind `T`
// against THIS library's def (owner-correct `receiver_bindings`).
pub struct Pair<T> {
    first: T,
    second: T,
}

impl Pair<T> {
    pub fn pick(self) -> T {
        return self.first;
    }
}
