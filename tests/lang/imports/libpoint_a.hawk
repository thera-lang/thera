// Support library: `Point` (x/y) plus a second type `Label` — BOTH names are also
// defined by libpoint_b, with different fields. Owner-correct resolution (Phase 1)
// keeps them distinct; a qualified `a.Point` / `a.Label` reaches this library's.
// This library exercises two collision-sensitive resolution paths: a function
// signature (`sum`'s `Point` param) and a struct field's declared type
// (`Point.label: Label`, itself a collided name), both resolved when the library
// element is built.

pub struct Label {
    a_id: Int,
}

pub struct Point {
    x: Int,
    y: Int,
    label: Label,
}

pub fn sum(_ p: Point) -> Int {
    return p.x + p.y + p.label.a_id;
}
