//! spec: mod-shared-type-name
//! mode: run

import 'libpoint_a' as a;
import 'libpoint_b' as b;

// Two libraries each define `pub struct Point` (and `pub struct Label`), with
// *different* fields. Under owner-correct type resolution (Phase 1) they coexist
// with no collision: a qualified `a.Point` / `b.Point` resolves to — and
// constructs — its own library's type, and the two are distinct (an `Interface`'s
// identity includes its owning library, `TypeId`). This exercises every resolution
// path that keys on a type name, each of which must pick the *owner* the file sees:
//
//   * a function signature — `a.sum(_ p: Point)`'s param type (resolved when the
//     library element is built), matched against a scope-typed argument;
//   * a struct field's declared type — `Point.label: Label` (a collided name), so
//     `pa.label.a_id` must read `a.Label`, not `b.Label`;
//   * an inherent method on a collided type — `a`'s `Point.scaled` vs `b`'s;
//   * an interface method (`Display`) dispatched on a collided type — `'${pa}'`;
//   * a qualified param annotation here — `diff_a(_ p: a.Point)`.
fn diff_a(_ p: a.Point) -> Int {
    return p.x - p.y;
}

fn diff_b(_ p: b.Point) -> Int {
    return p.lat - p.lng;
}

fn main() -> Int {
    let pa = a.Point { x: 30, y: 4, label: a.Label { a_id: 1 } };
    let pb = b.Point { lat: 10, lng: 25, label: b.Label { b_id: 2 } };
    println('${a.sum(pa)}');       // expect: 35
    println('${b.total(pb)}');     // expect: 37
    println('${pa.label.a_id}');   // expect: 1
    println('${pb.label.b_id}');   // expect: 2
    println('${pa.scaled()}');     // expect: 304
    println('${pb.scaled()}');     // expect: 1025
    println('${pa}');              // expect: a:30,4
    println('${pb}');              // expect: b:10,25
    println('${diff_a(pa)}');      // expect: 26
    println('${diff_b(pb)}');      // expect: -15

    // A collided *generic* type: `T` binds against the owning library's def, so
    // each `pick` types (and dispatches) through its own `Pair<T>` — and the
    // result is usable as the instantiated `T` (Int arithmetic below).
    let ga = a.Pair { first: 10, second: 20 };
    let gb = b.Pair { first: 10, second: 20 };
    println('${ga.pick() + 1}');   // expect: 11
    println('${gb.pick() + 1}');   // expect: 21
    return 0;
}
