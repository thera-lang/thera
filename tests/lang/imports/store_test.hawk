//! spec: mod-whitebox-same-dir
//! mode: check

import 'wb/store' as s;

// The white-box exception is same-directory only (LD9): this file's basename
// matches `wb/store.hawk`, but that file lives elsewhere — its private surface
// stays private (a basename match alone used to grant private access to any
// imported `store.hawk` from any directory).

fn main() -> Int {
    println('${s.get()}');
    return secret(); // expect error: undefined name: secret
}
