// Support library for the import/visibility conformance tests. It has no `//!`
// directive block, so the harness treats it as a support file (not a test) and
// the sibling tests `import 'greeter'`.

pub fn hello() -> String {
    return 'hello';
}

// Not `pub`: visible only within this file (and to greeter_test.hawk).
fn secret() -> Int {
    return 42;
}
