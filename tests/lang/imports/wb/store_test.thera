//! spec: mod-whitebox-same-dir
//! mode: run

import 'store' as s;

// The white-box exception: a `<base>_test.thera` sees the private top-level
// names of the `<base>.thera` in its own directory bare, in addition to the
// import's public surface.

fn main() -> Int {
    println('${secret()}'); // expect: 7
    println('${s.get()}');  // expect: 7
    return 0;
}
