//! Tests for std.iter — the Iterator<T> sources, plus the prelude's adapters
//! and consumers (default methods on Iterator).

import std.testing;

import 'iter' as _;

@test
fn test_range_next_then_exhausts() -> Result<Void, Error> {
    let it = iter.range(0, 3);
    testing.assert_eq(actual: it.next(), expected: Option.Some(0))?;
    testing.assert_eq(actual: it.next(), expected: Option.Some(1))?;
    testing.assert_eq(actual: it.next(), expected: Option.Some(2))?;
    testing.assert_eq(actual: it.next(), expected: Option.None)?;
    // Stays exhausted.
    testing.assert_eq(actual: it.next(), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_range_empty() -> Result<Void, Error> {
    testing.assert_eq(actual: iter.range(5, 5).count(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_collect_range() -> Result<Void, Error> {
    testing.assert_eq(actual: iter.range(1, 4).collect(), expected: [1, 2, 3])?;
    return Result.Ok(void);
}

@test
fn test_collect_from_list_roundtrips() -> Result<Void, Error> {
    let xs = ['a', 'b', 'c'];
    testing.assert_eq(actual: iter.from_list(xs).collect(), expected: xs)?;
    return Result.Ok(void);
}

@test
fn test_from_list_empty() -> Result<Void, Error> {
    let empty: List<Int> = [];
    testing.assert_eq(actual: iter.from_list(empty).count(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_count_drains() -> Result<Void, Error> {
    testing.assert_eq(actual: iter.range(0, 10).count(), expected: 10)?;
    return Result.Ok(void);
}

// --- adapters (default methods on Iterator) ---

@test
fn test_map_squares() -> Result<Void, Error> {
    let out = iter.range(1, 5).map((n) => n * n).collect();
    testing.assert_eq(actual: out, expected: [1, 4, 9, 16])?;
    return Result.Ok(void);
}

@test
fn test_map_changes_element_type() -> Result<Void, Error> {
    let out = iter.range(0, 3).map((n) => 'n${n}').collect();
    testing.assert_eq(actual: out, expected: ['n0', 'n1', 'n2'])?;
    return Result.Ok(void);
}

@test
fn test_filter_keeps_matching() -> Result<Void, Error> {
    let out = iter.range(0, 10).filter((n) => n % 2 == 0).collect();
    testing.assert_eq(actual: out, expected: [0, 2, 4, 6, 8])?;
    return Result.Ok(void);
}

@test
fn test_take_limits() -> Result<Void, Error> {
    let out = iter.range(0, 100).take(3).collect();
    testing.assert_eq(actual: out, expected: [0, 1, 2])?;
    return Result.Ok(void);
}

@test
fn test_take_more_than_available() -> Result<Void, Error> {
    let out = iter.range(0, 2).take(5).collect();
    testing.assert_eq(actual: out, expected: [0, 1])?;
    return Result.Ok(void);
}

@test
fn test_enumerate_pairs_index_and_value() -> Result<Void, Error> {
    let pairs = iter.from_list(['a', 'b', 'c']).enumerate().collect();
    testing.assert_eq(actual: pairs.len(), expected: 3)?;
    testing.assert_eq(actual: pairs[0].index, expected: 0)?;
    testing.assert_eq(actual: pairs[0].value, expected: 'a')?;
    testing.assert_eq(actual: pairs[2].index, expected: 2)?;
    testing.assert_eq(actual: pairs[2].value, expected: 'c')?;
    return Result.Ok(void);
}

@test
fn test_enumerate_empty() -> Result<Void, Error> {
    testing.assert_eq(actual: iter.range(0, 0).enumerate().count(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_enumerate_composes_with_adapters() -> Result<Void, Error> {
    // index every element, keep the even-indexed ones, project to the value.
    let out = iter.from_list(['a', 'b', 'c', 'd'])
        .enumerate()
        .filter((p) => p.index % 2 == 0)
        .map((p) => p.value)
        .collect();
    testing.assert_eq(actual: out, expected: ['a', 'c'])?;
    return Result.Ok(void);
}

@test
fn test_chained_filter_map_take() -> Result<Void, Error> {
    // evens -> squared -> first 3
    let out = iter.range(0, 100)
        .filter((n) => n % 2 == 0)
        .map((n) => n * n)
        .take(3)
        .collect();
    testing.assert_eq(actual: out, expected: [0, 4, 16])?;
    return Result.Ok(void);
}

@test
fn test_adapters_are_lazy() -> Result<Void, Error> {
    // `take(4)` over a huge range only pulls what it needs — eager evaluation
    // would be ruinous. That it terminates quickly *is* the laziness assertion.
    let n = iter.range(0, 1000000).take(4).count();
    testing.assert_eq(actual: n, expected: 4)?;
    return Result.Ok(void);
}

@test
fn test_for_loop_over_range() -> Result<Void, Error> {
    let mut sum = 0;
    for n in iter.range(1, 5) { // 1 + 2 + 3 + 4
        sum = sum + n;
    }
    testing.assert_eq(actual: sum, expected: 10)?;
    return Result.Ok(void);
}

@test
fn test_for_loop_over_adapter() -> Result<Void, Error> {
    let out = [];
    for n in iter.range(0, 6).filter((n) => n % 2 == 1) {
        out.push(n);
    }
    testing.assert_eq(actual: out, expected: [1, 3, 5])?;
    return Result.Ok(void);
}

@test
fn test_for_loop_over_list_iter() -> Result<Void, Error> {
    let out = [];
    for s in iter.from_list(['a', 'b', 'c']) {
        out.push(s);
    }
    testing.assert_eq(actual: out, expected: ['a', 'b', 'c'])?;
    return Result.Ok(void);
}

/// A user-defined iterator, looped over by its *concrete* type (not the
/// Iterator interface) — exercises the concrete-conformer dispatch path.
struct Doubler {
    let mut next_val: Int;
    let limit: Int;
}

impl Iterator<Int> for Doubler {
    pub fn next(self) -> Option<Int> {
        if self.next_val >= self.limit {
            return Option.None;
        }
        let v = self.next_val;
        self.next_val = self.next_val * 2;
        return Option.Some(v);
    }
}

@test
fn test_for_loop_over_concrete_iterator() -> Result<Void, Error> {
    let d = Doubler { next_val: 1, limit: 20 }; // 1, 2, 4, 8, 16
    let out = [];
    for v in d {
        out.push(v);
    }
    testing.assert_eq(actual: out, expected: [1, 2, 4, 8, 16])?;
    return Result.Ok(void);
}

@test
fn test_concrete_iterator_uses_default_adapters() -> Result<Void, Error> {
    // A user iterator gets `map`/`collect` for free from the interface default.
    let d = Doubler { next_val: 1, limit: 20 };
    let out = d.map((n) => n + 1).collect();
    testing.assert_eq(actual: out, expected: [2, 3, 5, 9, 17])?;
    return Result.Ok(void);
}

@test
fn test_for_loop_empty_iterator() -> Result<Void, Error> {
    let mut ran = false;
    for _ in iter.range(3, 3) {
        ran = true;
    }
    testing.assert_eq(actual: ran, expected: false)?;
    return Result.Ok(void);
}
