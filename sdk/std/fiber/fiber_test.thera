import std.testing;

import std.fiber;
import std.time;
import std.fs;
import std.path;
import std.process;
import std.io;

/// A spawned fiber runs and `join` returns its result.
@test
fn test_spawn_join_returns_value() -> Result<Void, Error> {
    let f = fiber.spawn(() => 6 * 7);
    testing.assert_eq(actual: f.join(), expected: 42)?;
    return Result.Ok(void);
}

/// Several fibers run; each `join` blocks until that fiber finishes.
@test
fn test_many_fibers_each_join() -> Result<Void, Error> {
    let a = fiber.spawn(() => 1);
    let b = fiber.spawn(() => 2);
    let c = fiber.spawn(() => 3);
    testing.assert_eq(actual: a.join() + b.join() + c.join(), expected: 6)?;
    return Result.Ok(void);
}

/// `yield` cedes the thread, so two fibers interleave — and the cooperative,
/// FIFO scheduling makes the interleaving deterministic.
@test
fn test_yield_interleaves_deterministically() -> Result<Void, Error> {
    let log: List<String> = [];
    let a = fiber.spawn(() => {
        log.push('a1'); fiber.yield();
        log.push('a2'); fiber.yield();
        log.push('a3');
        return 0;
    });
    let b = fiber.spawn(() => {
        log.push('b1'); fiber.yield();
        log.push('b2');
        return 0;
    });
    a.join();
    b.join();
    testing.assert_eq(actual: log.join(','), expected: 'a1,b1,a2,b2,a3')?;
    return Result.Ok(void);
}

/// A fiber can spawn and join another fiber (the scheduler is re-entrant across
/// fibers, not just the main one).
@test
fn test_fiber_spawns_fiber() -> Result<Void, Error> {
    let outer = fiber.spawn(() => fiber.spawn(() => 10).join() + 5);
    testing.assert_eq(actual: outer.join(), expected: 15)?;
    return Result.Ok(void);
}

/// `time.sleep` parks the calling fiber on a scheduler timer rather than blocking
/// the thread, so a ready fiber runs to completion while the sleeper waits — and
/// the sleeper still resumes after its deadline. The interleaving is deterministic
/// regardless of the sleep duration: the parked sleeper cannot run until its timer
/// fires, so `quick` always finishes first.
@test
fn test_sleep_parks_letting_others_run() -> Result<Void, Error> {
    let log: List<String> = [];
    let sleeper = fiber.spawn(() => {
        time.sleep(time.Duration.millis(5));
        log.push('slept');
        return 0;
    });
    let quick = fiber.spawn(() => {
        log.push('quick');
        return 0;
    });
    sleeper.join();
    quick.join();
    testing.assert_eq(actual: log.join(','), expected: 'quick,slept')?;
    return Result.Ok(void);
}

/// A blocking `fs` read parks the calling fiber on the worker pool rather than
/// blocking the whole thread, so a ready fiber runs to completion while the read is
/// in flight — and the reader still gets the file contents when the syscall lands.
/// Deterministic: the worker's completion is only awaited once every ready fiber
/// has run, so `quick` always finishes before the reader resumes.
@test
fn test_blocking_read_parks_letting_others_run() -> Result<Void, Error> {
    let dir = path.join(fs.temp_dir(), 'thera_fiber_io');
    fs.create_dir_all(dir)?;
    let file = path.join(dir, 'data.txt');
    fs.write_text(file, 'payload')?;

    let log: List<String> = [];
    let reader = fiber.spawn(() => {
        let contents = fs.read_text(file);
        log.push('read:${contents.unwrap_or('?')}');
        return 0;
    });
    let quick = fiber.spawn(() => {
        log.push('quick');
        return 0;
    });
    reader.join();
    quick.join();
    fs.remove_dir_all(dir)?;

    testing.assert_eq(actual: log.join(','), expected: 'quick,read:payload')?;
    return Result.Ok(void);
}

/// Running a child process (`process.run`) parks the fiber on the worker pool
/// until the child exits, so a ready fiber runs while the child is running — and
/// the runner still gets the captured output. Deterministic: the child's completion
/// is awaited only once every ready fiber has run, so `quick` finishes first.
@test
fn test_process_run_parks_letting_others_run() -> Result<Void, Error> {
    let log: List<String> = [];
    let runner = fiber.spawn(() => {
        match process.run('echo', args: ['payload']) {
            Ok(r) => log.push('ran:${r.stdout.trim()}'),
            Err(_) => log.push('ran:err'),
        }
        return 0;
    });
    let quick = fiber.spawn(() => {
        log.push('quick');
        return 0;
    });
    runner.join();
    quick.join();
    testing.assert_eq(actual: log.join(','), expected: 'quick,ran:payload')?;
    return Result.Ok(void);
}

/// One fiber feeds a child's stdin while another drains its stdout, concurrently.
/// The payload is larger than the OS pipe buffer, so a single blocking thread that
/// wrote it all before reading would deadlock. Because stdin and stdout park on the
/// worker pool independently (they're separate handles), both fibers make progress
/// and the round-trip completes — the pattern the worker pool exists to enable.
@test
fn test_pipe_streams_across_fibers_without_deadlock() -> Result<Void, Error> {
    let child = process.start('cat')?;

    let mut payload = '';
    let mut i = 0;
    while i < 8000 {
        payload = payload + 'abcdefghijklmnopqrstuvwxyz0123456789\n';
        i = i + 1;
    }
    let sent = payload.bytes().len();

    // The writer reports how many bytes it wrote (−1 on any failure), so a
    // failed pipe write fails the test instead of silently dropping its
    // `Result` — the unused-`Result` diagnostic caught the original bare calls.
    let writer = fiber.spawn(() => {
        let wrote = child.stdin().write(payload.bytes()).unwrap_or(0 - 1);
        if child.close_stdin().is_err() {
            return 0 - 1;
        }
        return wrote;
    });
    let reader = fiber.spawn(() => io.read_all(child.stdout()));

    testing.assert_eq(actual: writer.join(), expected: sent)?;
    let got = reader.join()?;
    child.wait()?;

    testing.assert_eq(actual: got.len(), expected: sent)?;
    return Result.Ok(void);
}

/// A buffered channel preserves FIFO order; a closed channel drains its buffer
/// then yields `None`.
@test
fn test_channel_buffer_and_drain() -> Result<Void, Error> {
    let ch: fiber.Channel<Int> = fiber.channel(8);
    ch.send(1);
    ch.send(2);
    ch.send(3);
    ch.close();
    let got: List<String> = [];
    let mut going = true;
    while going {
        match ch.receive() {
            Some(v) => { got.push('${v}'); },
            None => { going = false; },
        }
    }
    testing.assert_eq(actual: got.join(','), expected: '1,2,3')?;
    return Result.Ok(void);
}

/// A producer fiber and the consumer hand off through a small buffer: the sender
/// blocks when the buffer is full, the receiver blocks when it is empty.
@test
fn test_channel_producer_consumer() -> Result<Void, Error> {
    let ch: fiber.Channel<Int> = fiber.channel(2);
    let producer = fiber.spawn(() => {
        let mut i = 1;
        while i <= 5 {
            ch.send(i);
            i = i + 1;
        }
        ch.close();
        return 0;
    });
    let mut sum = 0;
    let mut going = true;
    while going {
        match ch.receive() {
            Some(v) => { sum = sum + v; },
            None => { going = false; },
        }
    }
    producer.join();
    testing.assert_eq(actual: sum, expected: 15)?;
    return Result.Ok(void);
}
