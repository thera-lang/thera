//! Tests for std.char.
//!
//! Written ahead of the `@test` runner (see docs/roadmap.md); they type-check
//! today (`thera check`). A sibling `_test.thera` with white-box access to its
//! library — constants and functions are referenced unqualified.

import std.testing;

import 'char' as _;

@test
fn test_constants() -> Result<Void, Error> {
    testing.assert_eq(actual: SPACE, expected: 32)?;
    testing.assert_eq(actual: LF, expected: 10)?;
    testing.assert_eq(actual: DIGIT_0, expected: 48)?;
    testing.assert_eq(actual: UPPER_A, expected: 65)?;
    testing.assert_eq(actual: LOWER_A, expected: 97)?;
    return Result.Ok(void);
}

@test
fn test_is_digit() -> Result<Void, Error> {
    testing.assert(is_digit(DIGIT_0))?;
    testing.assert(is_digit(DIGIT_9))?;
    testing.assert(!is_digit(SPACE))?;
    testing.assert(!is_digit(UPPER_A))?;
    return Result.Ok(void);
}

@test
fn test_is_hex_digit() -> Result<Void, Error> {
    testing.assert(is_hex_digit(DIGIT_0))?;
    testing.assert(is_hex_digit(LOWER_A))?;    // a
    testing.assert(is_hex_digit(UPPER_A))?;    // A
    testing.assert(!is_hex_digit(LOWER_Z))?;   // z is past f
    return Result.Ok(void);
}

@test
fn test_is_alpha_and_alphanumeric() -> Result<Void, Error> {
    testing.assert(is_alpha(UPPER_A))?;
    testing.assert(is_alpha(LOWER_Z))?;
    testing.assert(!is_alpha(DIGIT_0))?;
    testing.assert(is_alphanumeric(DIGIT_0))?;
    testing.assert(!is_alphanumeric(SPACE))?;
    return Result.Ok(void);
}

@test
fn test_is_whitespace() -> Result<Void, Error> {
    testing.assert(is_whitespace(SPACE))?;
    testing.assert(is_whitespace(TAB))?;
    testing.assert(is_whitespace(LF))?;
    testing.assert(!is_whitespace(DIGIT_0))?;
    return Result.Ok(void);
}

@test
fn test_case_conversion() -> Result<Void, Error> {
    testing.assert_eq(actual: to_lower(UPPER_A), expected: LOWER_A)?;
    testing.assert_eq(actual: to_upper(LOWER_A), expected: UPPER_A)?;
    // Non-letters pass through unchanged.
    testing.assert_eq(actual: to_lower(DIGIT_0), expected: DIGIT_0)?;
    testing.assert_eq(actual: to_upper(SPACE), expected: SPACE)?;
    return Result.Ok(void);
}

@test
fn test_digit_value() -> Result<Void, Error> {
    testing.assert_eq(actual: digit_value(DIGIT_0), expected: Option.Some(0))?;
    testing.assert_eq(actual: digit_value(DIGIT_9), expected: Option.Some(9))?;
    testing.assert_eq(actual: digit_value(SPACE), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_hex_digit_value() -> Result<Void, Error> {
    testing.assert_eq(actual: hex_digit_value(DIGIT_0), expected: Option.Some(0))?;
    testing.assert_eq(actual: hex_digit_value(DIGIT_9), expected: Option.Some(9))?;
    testing.assert_eq(actual: hex_digit_value(UPPER_A), expected: Option.Some(10))?;
    testing.assert_eq(actual: hex_digit_value(UPPER_A + 5), // 'F'
        expected: Option.Some(15))?;
    testing.assert_eq(actual: hex_digit_value(LOWER_A), expected: Option.Some(10))?;
    testing.assert_eq(actual: hex_digit_value(LOWER_A + 5), // 'f'
        expected: Option.Some(15))?;
    // 'g' and 'G' are past the hex range; SPACE is not a digit.
    testing.assert_eq(actual: hex_digit_value(LOWER_A + 6), expected: Option.None)?;
    testing.assert_eq(actual: hex_digit_value(UPPER_A + 6), expected: Option.None)?;
    testing.assert_eq(actual: hex_digit_value(SPACE), expected: Option.None)?;
    return Result.Ok(void);
}
