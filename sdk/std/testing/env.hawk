//! std.testing environment double — a test substitute for the std.env `Env`
//! capability.
//!
//! A fake environment is almost purely a test affordance, so it lives in
//! std.testing rather than beside std.env (the same call as `fixed_clock`; see
//! docs/stdlib.md § Cross-cutting #7).

import std.env;

/// An `env.Env` backed by an in-memory map and argument list, for deterministic
/// tests of code that reads the environment through an `Env` capability.
///
/// ```hawk
/// let environment = testing.fixed_env({ 'PORT': '8080' }, ['serve']);
/// testing.assert_eq(actual: chosen_port(environment), expected: 8080)?;
/// ```
struct FixedEnv {
    vars: Map<String, String>,
    arguments: List<String>,
}

impl env.Env for FixedEnv {
    fn get(self, _ name: String) -> Option<String> {
        return self.vars.get(name);
    }

    fn args(self) -> List<String> {
        return self.arguments;
    }
}

pub fn fixed_env(_ vars: Map<String, String>, _ args: List<String>) -> env.Env {
    return FixedEnv { vars: vars, arguments: args };
}
