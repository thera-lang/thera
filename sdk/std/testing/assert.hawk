//! std.testing assertions — for use in *_test.hawk files.
//!
//! Assertions return Result<Void, Error>. A failure throws `error(...)` (the
//! general-purpose `Error`) that propagates out of the test function via ?. Test
//! functions must therefore return Result<Void, Error> and call each assertion
//! with ?. `hawk test` catches that `Err` and renders the message.
//!
//! Eq, Display, and Debug are defined in std.core, which is auto-imported.
//!
//! Each assertion takes a trailing `at: SourceLoc = #loc` parameter. Callers never
//! pass it: `#loc` is a compiler metaconstant whose default is filled in **at the
//! call site**, so a failure names the line the assertion was written on. The
//! message is prefixed `file:line:column:` — the same shape `hawk check` prints —
//! so test failures and compiler diagnostics share one format.
//!
//! All assertion functions are plain functions — not built-in statements —
//! so they cannot be silently disabled by a build flag.

/// Assert that `condition` is true.
///
/// ```hawk
/// testing.assert(x > 0)?;
/// testing.assert(x > 0, message: 'must be positive')?;
/// ```
pub fn assert(_ condition: Bool, message: String = 'assertion failed', at: SourceLoc = #loc) -> Result<Void, Error> {
    if !condition {
        throw error('${at}: ${message}');
    }
    return Result.Ok(void);
}

/// Assert that `actual` equals `expected`.
///
/// ```hawk
/// testing.assert_eq(actual: result, expected: 5)?;
/// ```
pub fn assert_eq<T: Eq + Debug>(actual: T, expected: T, at: SourceLoc = #loc) -> Result<Void, Error> {
    if actual != expected {
        throw error('${at}: assert_eq failed\n  actual:   ${actual.debug()}\n  expected: ${expected.debug()}');
    }
    return Result.Ok(void);
}

/// Assert that `actual` does not equal `unexpected`.
///
/// ```hawk
/// testing.assert_ne(actual: result, unexpected: 0)?;
/// ```
pub fn assert_ne<T: Eq + Debug>(actual: T, unexpected: T, at: SourceLoc = #loc) -> Result<Void, Error> {
    if actual == unexpected {
        throw error('${at}: assert_ne failed: both values were ${actual.debug()}');
    }
    return Result.Ok(void);
}

/// Assert that `result` is Ok, and return the inner value.
/// Useful for unwrapping in a test without a manual match.
///
/// ```hawk
/// let value = testing.assert_ok(some_result)?;
/// ```
pub fn assert_ok<T, E: Debug>(_ result: Result<T, E>, at: SourceLoc = #loc) -> Result<T, Error> {
    match result {
        Ok(value) => return Result.Ok(value),
        Err(e) => throw error('${at}: assert_ok failed: got Err(${e.debug()})'),
    }
}

/// Assert that `result` is Err.
///
/// ```hawk
/// testing.assert_err(parse_port('99999'))?;
/// ```
pub fn assert_err<T, E>(_ result: Result<T, E>, at: SourceLoc = #loc) -> Result<Void, Error> {
    match result {
        Ok(_) => throw error('${at}: assert_err failed: got Ok'),
        Err(_) => return Result.Ok(void),
    }
}
