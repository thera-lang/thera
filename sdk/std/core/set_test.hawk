//! Tests for Set<T> (implemented in Hawk over Map).

import std.testing;

@test
fn test_from_collapses_duplicates() -> Result<Void, Error> {
    let s = Set.from([1, 2, 2, 3, 3, 3]);
    testing.assert_eq(actual: s.len(), expected: 3)?;
    testing.assert(s.has(1))?;
    testing.assert(s.has(2))?;
    testing.assert(s.has(3))?;
    testing.assert(!s.has(9))?;
    return Result.Ok(void);
}

@test
fn test_empty() -> Result<Void, Error> {
    let s: Set<Int> = Set.new();
    testing.assert(s.is_empty())?;
    testing.assert_eq(actual: s.len(), expected: 0)?;
    testing.assert(!s.has(1))?;
    return Result.Ok(void);
}

@test
fn test_add_is_idempotent() -> Result<Void, Error> {
    let s: Set<Int> = Set.new();
    s.add(5);
    s.add(5);
    s.add(7);
    testing.assert_eq(actual: s.len(), expected: 2)?;
    testing.assert(s.has(5))?;
    testing.assert(!s.is_empty())?;
    return Result.Ok(void);
}

@test
fn test_remove_reports_presence() -> Result<Void, Error> {
    let s = Set.from([1, 2, 3]);
    testing.assert(s.remove(2))?;       // was present
    testing.assert(!s.remove(2))?;      // already gone
    testing.assert(!s.has(2))?;
    testing.assert_eq(actual: s.len(), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_to_list_round_trips() -> Result<Void, Error> {
    let s = Set.from(['a', 'b', 'c']);
    let list = s.to_list();
    testing.assert_eq(actual: list.len(), expected: 3)?;
    // Rebuilding from the listed elements gives the same membership.
    let again = Set.from(list);
    testing.assert(again.has('a'))?;
    testing.assert(again.has('c'))?;
    return Result.Ok(void);
}

@test
fn test_works_with_strings() -> Result<Void, Error> {
    let seen = Set.from(['x', 'y', 'x']);
    testing.assert_eq(actual: seen.len(), expected: 2)?;
    testing.assert(seen.has('y'))?;
    return Result.Ok(void);
}
