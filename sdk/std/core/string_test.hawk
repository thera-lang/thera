//! Tests for the built-in String methods.
//!
//! Written ahead of the `@test` runner (see docs/roadmap.md); they type-check
//! today (`hawk check`). String's methods are in the auto-imported core prelude,
//! so they're used unqualified — no sibling import needed.

import std.testing;

@test
fn test_to_int() -> Result<Void, Error> {
    testing.assert_eq(actual: '42'.to_int(), expected: Option.Some(42))?;
    testing.assert_eq(actual: '-7'.to_int(), expected: Option.Some(-7))?;
    testing.assert_eq(actual: 'oops'.to_int(), expected: Option.None)?;
    testing.assert_eq(actual: ''.to_int(), expected: Option.None)?;
    // The whole string must be the number — no surrounding space, not a Double.
    testing.assert_eq(actual: '42 '.to_int(), expected: Option.None)?;
    testing.assert_eq(actual: '4.5'.to_int(), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_replace() -> Result<Void, Error> {
    testing.assert_eq(actual: 'a-b-c'.replace('-', '_'), expected: 'a_b_c')?;
    testing.assert_eq(actual: 'hello'.replace('l', 'L'), expected: 'heLLo')?;
    testing.assert_eq(actual: 'abc'.replace('x', 'y'), expected: 'abc')?; // no match
    testing.assert_eq(actual: 'foofoo'.replace('foo', 'bar'), expected: 'barbar')?;
    testing.assert_eq(actual: 'abc'.replace('', 'x'), expected: 'abc')?; // empty from: no-op
    return Result.Ok(void);
}

@test
fn test_repeat() -> Result<Void, Error> {
    testing.assert_eq(actual: 'ab'.repeat(3), expected: 'ababab')?;
    testing.assert_eq(actual: 'x'.repeat(0), expected: '')?;
    testing.assert_eq(actual: 'x'.repeat(-1), expected: '')?; // non-positive -> empty
    testing.assert_eq(actual: '-'.repeat(5), expected: '-----')?;
    return Result.Ok(void);
}

@test
fn test_reverse() -> Result<Void, Error> {
    testing.assert_eq(actual: 'abc'.reverse(), expected: 'cba')?;
    testing.assert_eq(actual: ''.reverse(), expected: '')?;
    testing.assert_eq(actual: 'x'.reverse(), expected: 'x')?;
    // Reversing twice is the identity (code-point order).
    testing.assert_eq(actual: 'hello'.reverse().reverse(), expected: 'hello')?;
    return Result.Ok(void);
}

@test
fn test_find() -> Result<Void, Error> {
    testing.assert_eq(actual: 'hello'.find('ll'), expected: Option.Some(2))?;
    testing.assert_eq(actual: 'hello'.find('h'), expected: Option.Some(0))?;
    testing.assert_eq(actual: 'hello'.find('o'), expected: Option.Some(4))?;
    testing.assert_eq(actual: 'hello'.find('z'), expected: Option.None)?;
    testing.assert_eq(actual: 'hello'.find(''), expected: Option.Some(0))?; // empty matches at 0
    testing.assert_eq(actual: 'aaa'.find('aa'), expected: Option.Some(0))?; // first occurrence
    return Result.Ok(void);
}

@test
fn test_pad() -> Result<Void, Error> {
    testing.assert_eq(actual: '7'.pad_start(3, '0'), expected: '007')?;
    testing.assert_eq(actual: '7'.pad_end(3, '.'), expected: '7..')?;
    testing.assert_eq(actual: 'abc'.pad_start(2, '0'), expected: 'abc')?;  // already wide
    testing.assert_eq(actual: 'abc'.pad_start(3, '0'), expected: 'abc')?;  // exactly wide
    testing.assert_eq(actual: 'x'.pad_start(5, 'ab'), expected: 'ababx')?; // multi-char pad truncates
    testing.assert_eq(actual: 'x'.pad_end(4, 'ab'), expected: 'xaba')?;
    testing.assert_eq(actual: 'x'.pad_start(3, ''), expected: 'x')?;       // empty pad: unchanged
    return Result.Ok(void);
}

@test
fn test_trim_start_end() -> Result<Void, Error> {
    testing.assert_eq(actual: '  hi  '.trim_start(), expected: 'hi  ')?;
    testing.assert_eq(actual: '  hi  '.trim_end(), expected: '  hi')?;
    testing.assert_eq(actual: 'hi'.trim_start(), expected: 'hi')?;     // nothing to strip
    testing.assert_eq(actual: '\t\nhi'.trim_start(), expected: 'hi')?; // tabs/newlines too
    return Result.Ok(void);
}

@test
fn test_to_double() -> Result<Void, Error> {
    testing.assert_eq(actual: '3.5'.to_double(), expected: Option.Some(3.5))?;
    testing.assert_eq(actual: '10'.to_double(), expected: Option.Some(10.0))?;
    testing.assert_eq(actual: 'x'.to_double(), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_chars_and_bytes() -> Result<Void, Error> {
    testing.assert_eq(actual: 'abc'.chars().len(), expected: 3)?;
    testing.assert_eq(actual: 'abc'.bytes().len(), expected: 3)?;
    // 'É' is one code point but two UTF-8 bytes.
    testing.assert_eq(actual: 'É'.chars().len(), expected: 1)?;
    testing.assert_eq(actual: 'É'.bytes().len(), expected: 2)?;
    // chars() round-trips through from_chars.
    testing.assert_eq(actual: String.from_chars('hi'.chars()), expected: 'hi')?;
    return Result.Ok(void);
}

@test
fn test_from_chars_is_total() -> Result<Void, Error> {
    // A non-scalar code point (a lone surrogate) becomes U+FFFD, not a crash.
    let s = String.from_chars([72, 55296, 105]); // H, D800, i
    testing.assert_eq(actual: s.chars().len(), expected: 3)?;
    // The middle char is the replacement character, U+FFFD (65533).
    testing.assert_eq(actual: s, expected: String.from_chars([72, 65533, 105]))?;
    return Result.Ok(void);
}

@test
fn test_slice() -> Result<Void, Error> {
    testing.assert_eq(actual: 'hello'.slice(1, 4), expected: 'ell')?;
    testing.assert_eq(actual: 'hello'.slice(0, 5), expected: 'hello')?;
    testing.assert_eq(actual: 'hello'.slice(0, 99), expected: 'hello')?;   // clamps high
    testing.assert_eq(actual: 'hello'.slice(-3, 2), expected: 'he')?;      // clamps low
    testing.assert_eq(actual: 'hello'.slice(3, 1), expected: '')?;         // reversed -> empty
    testing.assert_eq(actual: 'hello'.slice(2, 2), expected: '')?;         // empty range
    // Code-point indices, not bytes: 'É' is one code point.
    testing.assert_eq(actual: 'Éa'.slice(1, 2), expected: 'a')?;
    return Result.Ok(void);
}

@test
fn test_numeric_escapes() -> Result<Void, Error> {
    // \xNN (a byte) and \u{...} (a Unicode scalar) decode to code points.
    testing.assert_eq(actual: '\x41', expected: 'A')?;
    testing.assert_eq(actual: '\u{48}\u{69}', expected: 'Hi')?;
    testing.assert_eq(actual: '\u{1F600}'.chars(), expected: [128512])?; // 😀
    testing.assert_eq(actual: '\u{FFFD}'.chars(), expected: [65533])?;   // replacement char
    return Result.Ok(void);
}

@test
fn test_try_from_chars() -> Result<Void, Error> {
    testing.assert_eq(actual: String.try_from_chars([72, 105]), expected: Option.Some('Hi'))?;
    testing.assert_eq(actual: String.try_from_chars([55296]), expected: Option.None)?;   // lone surrogate
    testing.assert_eq(actual: String.try_from_chars([-1]), expected: Option.None)?;      // negative
    testing.assert_eq(actual: String.try_from_chars([1114112]), expected: Option.None)?; // > U+10FFFF
    return Result.Ok(void);
}

@test
fn test_to_int_radix() -> Result<Void, Error> {
    // Hex (the front-end's `0x…` literal case).
    testing.assert_eq(actual: 'FF'.to_int_radix(16), expected: Option.Some(255))?;
    testing.assert_eq(actual: '1a'.to_int_radix(16), expected: Option.Some(26))?;
    // Binary and decimal, with an optional sign.
    testing.assert_eq(actual: '1010'.to_int_radix(2), expected: Option.Some(10))?;
    testing.assert_eq(actual: '-7f'.to_int_radix(16),
        expected: Option.Some(0 - 127))?;
    // A full-width pattern wraps two's-complement to its signed value (the
    // SplitMix64 gamma; matches BigInt.parse(radix:16).toSigned(64)).
    testing.assert_eq(actual: '9E3779B97F4A7C15'.to_int_radix(16),
        expected: Option.Some(0 - 7046029254386353131))?;
    // Invalid: a digit beyond the radix, a non-digit, empty, and a lone sign.
    testing.assert_eq(actual: '2'.to_int_radix(2), expected: Option.None)?;
    testing.assert_eq(actual: 'xz'.to_int_radix(16), expected: Option.None)?;
    testing.assert_eq(actual: ''.to_int_radix(10), expected: Option.None)?;
    testing.assert_eq(actual: '-'.to_int_radix(10), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_concat_operator() -> Result<Void, Error> {
    testing.assert_eq(actual: 'foo' + 'bar', expected: 'foobar')?;
    // Left-associative, chains.
    testing.assert_eq(actual: 'a' + 'b' + 'c', expected: 'abc')?;
    // Composes with variables and interpolation.
    let name = 'main';
    testing.assert_eq(actual: name + '.hawk', expected: 'main.hawk')?;
    testing.assert_eq(actual: '' + name, expected: 'main')?;
    return Result.Ok(void);
}
