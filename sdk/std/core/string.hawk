// std.core — the built-in String type's methods (auto-imported with the
// prelude).
//
// Methods on string *values* (len, trim, split, …) are declared here as
// `native fn`s backed by runtime natives, plus named constructors as static
// methods. A String value is a primitive, but methods resolve through its
// element like any other type (see docs/roadmap.md, "primitives").

impl String {
    // Number of Unicode code points.
    @extern('str_len')
    pub native fn len(self) -> Int

    // Number of UTF-8 bytes.
    @extern('str_byte_len')
    pub native fn byte_len(self) -> Int

    // True if the string is empty.
    pub fn is_empty(self) -> Bool {
        return self.len() == 0;
    }

    // The substring of the code points in the half-open range `[start, end)`,
    // by code-point index (not byte offset). Indices are clamped to the string's
    // length, so out-of-range or reversed ranges yield a shorter or empty string.
    //
    //   'hello'.slice(1, 4)   // 'ell'
    pub fn slice(self, _ start: Int, _ end: Int) -> String {
        return String.from_chars(self.chars().slice(start, end));
    }

    // A copy with leading and trailing whitespace removed.
    @extern('str_trim')
    pub native fn trim(self) -> String

    // Substring / prefix / suffix tests.
    @extern('str_contains')
    pub native fn contains(self, _ needle: String) -> Bool

    @extern('str_starts_with')
    pub native fn starts_with(self, _ prefix: String) -> Bool

    @extern('str_ends_with')
    pub native fn ends_with(self, _ suffix: String) -> Bool

    // Case conversion.
    @extern('str_to_uppercase')
    pub native fn to_uppercase(self) -> String

    @extern('str_to_lowercase')
    pub native fn to_lowercase(self) -> String

    // Split into lines (on '\n', dropping a trailing empty line).
    @extern('str_lines')
    pub native fn lines(self) -> List<String>

    // Split on runs of whitespace, dropping empty pieces.
    @extern('str_split_whitespace')
    pub native fn split_whitespace(self) -> List<String>

    // Split on each occurrence of `sep`.
    @extern('str_split')
    pub native fn split(self, _ sep: String) -> List<String>

    // The Unicode scalar values (code points) of the string, as Int. The
    // inverse of `String.from_chars`:
    //
    //   let cps = source.chars();
    //   let same = String.from_chars(cps);
    @extern('str_chars')
    pub native fn chars(self) -> List<Int>

    // The string's UTF-8 encoding as a `Bytes` buffer — for hashing, transport,
    // or byte-level work. Use `s.bytes().to_list()` for the raw byte values.
    @extern('str_bytes')
    pub native fn bytes(self) -> Bytes

    // Parse the whole string as a base-10 Int, or None if it isn't one. The
    // entire string must be the number (no surrounding whitespace) — call
    // `s.trim()` first if needed.
    //
    //   '42'.to_int()    // Some(42)
    //   'x'.to_int()     // None
    @extern('str_to_int')
    pub native fn to_int(self) -> Option<Int>

    // Parse the whole string as a Double, or None if it isn't one.
    //
    //   '3.14'.to_double()   // Some(3.14)
    @extern('str_to_double')
    pub native fn to_double(self) -> Option<Double>

    // Construct a String from a list of Unicode code points (as Int). The
    // inverse of `s.chars()`. This is total: a value that is not a valid Unicode
    // scalar (a surrogate, out of range, or negative) becomes U+FFFD (�). Use
    // `try_from_chars` to reject such input instead.
    @extern('str_from_chars')
    pub native fn from_chars(_ cps: List<Int>) -> String

    // Like `from_chars`, but returns None if any element is not a valid Unicode
    // scalar value — for callers that must reject malformed input rather than
    // substitute the replacement character.
    //
    //   String.try_from_chars([72, 105])    // Some('Hi')
    //   String.try_from_chars([0xD800])     // None (a lone surrogate)
    @extern('str_try_from_chars')
    pub native fn try_from_chars(_ cps: List<Int>) -> Option<String>
}
