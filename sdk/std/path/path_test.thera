//! Tests for std.path.
//!
//! These are written ahead of the `@test` runner being reimplemented on the
//! bytecode pipeline (`hawk test` is a stub today — see docs/roadmap.md). They
//! follow the `_test.thera` convention: a sibling test file with white-box access
//! to its library, `@test` functions taking no arguments and returning
//! `Result<Void, Error>`.

import std.testing;

import 'path' as _;

@test
fn test_join() -> Result<Void, Error> {
    testing.assert_eq(actual: join('src', 'main.thera'), expected: 'src/main.thera')?;
    testing.assert_eq(actual: join('src/', 'main.thera'), expected: 'src/main.thera')?;
    testing.assert_eq(actual: join('', 'main.thera'), expected: 'main.thera')?;
    testing.assert_eq(actual: join('src', ''), expected: 'src')?;
    // An absolute second component replaces the base entirely.
    testing.assert_eq(actual: join('src', '/etc/hosts'), expected: '/etc/hosts')?;
    return Result.Ok(void);
}

@test
fn test_join_all() -> Result<Void, Error> {
    testing.assert_eq(actual: join_all(['usr', 'local', 'bin']), expected: 'usr/local/bin')?;
    testing.assert_eq(actual: join_all(['a']), expected: 'a')?;
    testing.assert_eq(actual: join_all([]), expected: '')?;
    // Empty segments are absorbed; an absolute segment resets the path.
    testing.assert_eq(actual: join_all(['a', '', 'b']), expected: 'a/b')?;
    testing.assert_eq(actual: join_all(['x', '/abs', 'y']), expected: '/abs/y')?;
    return Result.Ok(void);
}

// `separator`/`to_native`/`from_native` exercise the module initializer and the
// OS boundary. Written platform-independently: the round-trip and the
// separatorless cases hold on POSIX and Windows alike.
@test
fn test_platform_separator() -> Result<Void, Error> {
    testing.assert(separator == '/' || separator == '\\')?;
    // A slash path round-trips through the native form on any platform.
    testing.assert_eq(actual: from_native(to_native('a/b/c')), expected: 'a/b/c')?;
    // A separatorless name is unchanged either way.
    testing.assert_eq(actual: to_native('file'), expected: 'file')?;
    testing.assert_eq(actual: from_native('file'), expected: 'file')?;
    // to_native places the host separator between components.
    testing.assert_eq(actual: to_native('a/b'), expected: 'a${separator}b')?;
    return Result.Ok(void);
}

@test
fn test_dirname() -> Result<Void, Error> {
    testing.assert_eq(actual: dirname('src/main.thera'), expected: 'src')?;
    testing.assert_eq(actual: dirname('main.thera'), expected: '.')?;
    testing.assert_eq(actual: dirname('/usr/bin/hawk'), expected: '/usr/bin')?;
    testing.assert_eq(actual: dirname('/file'), expected: '/')?;
    return Result.Ok(void);
}

@test
fn test_basename() -> Result<Void, Error> {
    testing.assert_eq(actual: basename('src/main.thera'), expected: 'main.thera')?;
    testing.assert_eq(actual: basename('/usr/bin/thera'), expected: 'thera')?;
    testing.assert_eq(actual: basename('thera'), expected: 'thera')?;
    return Result.Ok(void);
}

@test
fn test_extension() -> Result<Void, Error> {
    testing.assert_eq(actual: extension('src/main.thera'), expected: '.thera')?;
    testing.assert_eq(actual: extension('archive.tar.gz'), expected: '.gz')?;
    testing.assert_eq(actual: extension('Makefile'), expected: '')?;
    // A leading-dot name is hidden, not all-extension.
    testing.assert_eq(actual: extension('.bashrc'), expected: '')?;
    return Result.Ok(void);
}

@test
fn test_stem() -> Result<Void, Error> {
    testing.assert_eq(actual: stem('src/main.thera'), expected: 'main')?;
    testing.assert_eq(actual: stem('archive.tar.gz'), expected: 'archive.tar')?;
    testing.assert_eq(actual: stem('Makefile'), expected: 'Makefile')?;
    return Result.Ok(void);
}

@test
fn test_with_extension() -> Result<Void, Error> {
    testing.assert_eq(actual: with_extension('src/main.thera', 'md'), expected: 'src/main.md')?;
    testing.assert_eq(actual: with_extension('main.thera', '.txt'), expected: 'main.txt')?;
    testing.assert_eq(actual: with_extension('main.thera', ''), expected: 'main')?;
    return Result.Ok(void);
}

@test
fn test_is_absolute() -> Result<Void, Error> {
    testing.assert(is_absolute('/usr/bin'))?;
    testing.assert(!is_absolute('src/main'))?;
    return Result.Ok(void);
}

@test
fn test_normalize() -> Result<Void, Error> {
    // Drop `.`, collapse `//`, resolve `..`.
    testing.assert_eq(actual: normalize('a/./b/../c'), expected: 'a/c')?;
    testing.assert_eq(actual: normalize('a//b/'), expected: 'a/b')?;
    testing.assert_eq(actual: normalize('/usr/../bin'), expected: '/bin')?;
    // Leading `..` is kept in a relative path; an absolute `..` at root is dropped.
    testing.assert_eq(actual: normalize('a/../../b'), expected: '../b')?;
    testing.assert_eq(actual: normalize('../a'), expected: '../a')?;
    testing.assert_eq(actual: normalize('/..'), expected: '/')?;
    testing.assert_eq(actual: normalize('/a/../..'), expected: '/')?;
    // Reductions to nothing become '.'; the roots are fixpoints.
    testing.assert_eq(actual: normalize(''), expected: '.')?;
    testing.assert_eq(actual: normalize('.'), expected: '.')?;
    testing.assert_eq(actual: normalize('a/..'), expected: '.')?;
    testing.assert_eq(actual: normalize('/'), expected: '/')?;
    testing.assert_eq(actual: normalize('./a/b'), expected: 'a/b')?;
    return Result.Ok(void);
}

@test
fn test_relative() -> Result<Void, Error> {
    // Sibling, descend, ascend, and same-location.
    testing.assert_eq(actual: relative(from: '/a/b', to: '/a/c'), expected: Result.Ok('../c'))?;
    testing.assert_eq(actual: relative(from: '/a', to: '/a/b/c'), expected: Result.Ok('b/c'))?;
    testing.assert_eq(actual: relative(from: '/a/b/c', to: '/a/b'), expected: Result.Ok('..'))?;
    testing.assert_eq(actual: relative(from: '/a/b', to: '/c/d'), expected: Result.Ok('../../c/d'))?;
    testing.assert_eq(actual: relative(from: '/a/b', to: '/a/b'), expected: Result.Ok('.'))?;
    // Relative inputs work too; the result joins back onto `from`.
    testing.assert_eq(actual: relative(from: 'x/y', to: 'x/z'), expected: Result.Ok('../z'))?;
    // Normalizes its inputs first.
    testing.assert_eq(actual: relative(from: '/a/./b', to: '/a/c/../d'), expected: Result.Ok('../d'))?;
    return Result.Ok(void);
}

@test
fn test_relative_incomparable() -> Result<Void, Error> {
    // Mixed absolute/relative cannot be related.
    testing.assert_err(relative(from: '/abs', to: 'rel'))?;
    // A leading `..` in `from` that `to` does not share is undefined.
    testing.assert_err(relative(from: '..', to: 'a'))?;
    return Result.Ok(void);
}

@test
fn test_components() -> Result<Void, Error> {
    testing.assert_eq(actual: components('src/main.thera').join(','), expected: 'src,main.thera')?;
    // A leading '/' is preserved as an empty root component.
    testing.assert_eq(actual: components('/usr/bin').join(','), expected: ',usr,bin')?;
    // Interior and trailing empty components are dropped.
    testing.assert_eq(actual: components('a//b/').join(','), expected: 'a,b')?;
    return Result.Ok(void);
}
