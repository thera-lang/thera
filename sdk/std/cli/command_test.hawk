//! Tests for std.cli's declarative Command parser.

import std.testing;

import 'command' as _;

/// A representative command reused across the parsing tests.
fn sample() -> Command {
    return Command.new('tool')
        .about('frobs the widgets')
        .flag('verbose', abbr: 'v', help: 'noisy output')
        .flag('color', abbr: 'c', negatable: true, default: true)
        .option('out', abbr: 'o', help: 'output path')
        .positional('input', help: 'the input file');
}

@test
fn test_flag_long_and_short() -> Result<Void, Error> {
    let m1 = testing.assert_ok(sample().parse(['--verbose']))?;
    testing.assert_eq(actual: m1.flag('verbose'), expected: true)?;

    let m2 = testing.assert_ok(sample().parse(['-v']))?;
    testing.assert_eq(actual: m2.flag('verbose'), expected: true)?;

    // Absent flag is false by default.
    let m3 = testing.assert_ok(sample().parse([]))?;
    testing.assert_eq(actual: m3.flag('verbose'), expected: false)?;
    return Result.Ok(void);
}

@test
fn test_flag_default_and_negation() -> Result<Void, Error> {
    // `color` defaults to true...
    let m1 = testing.assert_ok(sample().parse([]))?;
    testing.assert_eq(actual: m1.flag('color'), expected: true)?;

    // ...and `--no-color` turns it off.
    let m2 = testing.assert_ok(sample().parse(['--no-color']))?;
    testing.assert_eq(actual: m2.flag('color'), expected: false)?;
    return Result.Ok(void);
}

@test
fn test_option_forms() -> Result<Void, Error> {
    // Space-separated.
    let m1 = testing.assert_ok(sample().parse(['--out', 'result.txt']))?;
    testing.assert_eq(actual: m1.option('out'), expected: Option.Some('result.txt'))?;

    // Joined with '='.
    let m2 = testing.assert_ok(sample().parse(['--out=result.txt']))?;
    testing.assert_eq(actual: m2.option('out'), expected: Option.Some('result.txt'))?;

    // By abbreviation, both forms.
    let m3 = testing.assert_ok(sample().parse(['-o', 'a.txt']))?;
    testing.assert_eq(actual: m3.option('out'), expected: Option.Some('a.txt'))?;
    let m4 = testing.assert_ok(sample().parse(['-o=b.txt']))?;
    testing.assert_eq(actual: m4.option('out'), expected: Option.Some('b.txt'))?;

    // A value containing '=' survives the split.
    let m5 = testing.assert_ok(sample().parse(['--out=k=v']))?;
    testing.assert_eq(actual: m5.option('out'), expected: Option.Some('k=v'))?;

    // Absent option is None.
    let m6 = testing.assert_ok(sample().parse([]))?;
    testing.assert_eq(actual: m6.option('out'), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_positionals() -> Result<Void, Error> {
    let m = testing.assert_ok(sample().parse(['--verbose', 'a.in', 'b.in']))?;
    testing.assert_eq(actual: m.positional(0), expected: Option.Some('a.in'))?;
    testing.assert_eq(actual: m.positional(1), expected: Option.Some('b.in'))?;
    testing.assert_eq(actual: m.positional(2), expected: Option.None)?;
    testing.assert_eq(actual: m.positionals().len(), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_errors() -> Result<Void, Error> {
    // Undeclared flag.
    testing.assert_err(sample().parse(['--bogus']))?;
    // Option with no value.
    testing.assert_err(sample().parse(['--out']))?;
    // A value attached to a flag.
    testing.assert_err(sample().parse(['--verbose=loud']))?;
    return Result.Ok(void);
}

@test
fn test_auto_help_flag() -> Result<Void, Error> {
    // `--help` / `-h` are always available without being declared.
    let m1 = testing.assert_ok(sample().parse(['--help']))?;
    testing.assert_eq(actual: m1.flag('help'), expected: true)?;
    let m2 = testing.assert_ok(sample().parse(['-h']))?;
    testing.assert_eq(actual: m2.flag('help'), expected: true)?;
    return Result.Ok(void);
}

@test
fn test_subcommands() -> Result<Void, Error> {
    let cmd = Command.new('git')
        .subcommand(Command.new('commit').flag('amend', abbr: 'a'))
        .subcommand(Command.new('push'));

    let m = testing.assert_ok(cmd.parse(['commit', '--amend']))?;
    testing.assert_eq(actual: m.subcommand(), expected: Option.Some('commit'))?;

    // The subcommand's own matches carry its parsed flags.
    let sub = testing.assert_ok(m.matches().ok_or(error('no submatches')))?;
    testing.assert_eq(actual: sub.flag('amend'), expected: true)?;

    // An unknown subcommand is rejected.
    testing.assert_err(cmd.parse(['rebase']))?;
    return Result.Ok(void);
}

@test
fn test_clierror_implements_error() -> Result<Void, Error> {
    // A real parse failure renders its kind via message() (the parser stores the
    // bare name, without the leading dashes)...
    let e = expect_err(sample().parse(['--bogus']))?;
    testing.assert_eq(actual: e.message(), expected: 'unknown flag: bogus')?;
    // ...and the cause is matchable via kind().
    let named = match e.kind() {
        UnknownFlag(name) => name,
        UnexpectedValue(_) => '?',
        MissingValue(_) => '?',
        UnknownSubcommand(_) => '?',
    };
    testing.assert_eq(actual: named, expected: 'bogus')?;

    // A CliError also flows where the common Error interface is expected.
    let msg = match boundary() {
        Ok(_) => 'ok',
        Err(err) => err.message(),
    };
    testing.assert_eq(actual: msg, expected: 'missing value for option: out')?;
    return Result.Ok(void);
}

/// Returns the common Error interface, carrying a concrete CliError from a real
/// parse failure (a missing option value).
fn boundary() -> Result<Int, Error> {
    return match sample().parse(['--out']) {
        Ok(_) => Result.Err(error('expected a parse error')),
        Err(e) => Result.Err(e),
    };
}

/// Unwrap the `Err` of a parse `Result`, or fail the test with its `Ok` side.
fn expect_err(_ r: Result<Matches, CliError>) -> Result<CliError, Error> {
    return match r {
        Ok(_) => Result.Err(error('expected a parse error')),
        Err(e) => Result.Ok(e),
    };
}

@test
fn test_help_text() -> Result<Void, Error> {
    let text = sample().help();
    testing.assert(text.contains('frobs the widgets'), message: 'about line')?;
    testing.assert(text.contains('Usage: tool'), message: 'usage line')?;
    testing.assert(text.contains('--verbose, -v'), message: 'flag with abbr')?;
    testing.assert(text.contains('--out, -o <value>'), message: 'option with value')?;
    testing.assert(text.contains('--help, -h'), message: 'auto help flag')?;
    return Result.Ok(void);
}

@test
fn test_details_progressive_disclosure() -> Result<Void, Error> {
    let leaf = Command.new('do')
        .about('do the thing')
        .details('Long form.\nExit code: 0 on success, 1 otherwise.');
    let leaf_help = leaf.help();
    // The command's own help shows both the one-line about and the details.
    testing.assert(leaf_help.contains('do the thing'), message: 'about in own help')?;
    testing.assert(leaf_help.contains('Exit code: 0 on success'), message: 'details in own help')?;

    // A parent's command list shows only the one-line about, never the details.
    let parent = Command.new('tool').subcommand(leaf);
    let parent_help = parent.help();
    testing.assert(parent_help.contains('do the thing'), message: 'about in parent list')?;
    testing.assert(!parent_help.contains('Exit code'), message: 'details hidden in parent list')?;
    return Result.Ok(void);
}

@test
fn test_trailing_var_arg() -> Result<Void, Error> {
    let cmd = Command.new('run')
        .positional('file')
        .trailing_var_arg(true);

    // The first positional and everything after it (flags included) are captured
    // verbatim — no `--` separator, no "unknown flag" error.
    let m = testing.assert_ok(cmd.parse(['foo.hawk', '--bar', '--baz=qux', '-v']))?;
    testing.assert_eq(actual: m.positionals(),
        expected: ['foo.hawk', '--bar', '--baz=qux', '-v'])?;

    // The command's own flags still parse when they precede the first positional.
    let m2 = testing.assert_ok(cmd.parse(['--help', 'foo.hawk', '--bar']))?;
    testing.assert_eq(actual: m2.flag('help'), expected: true)?;
    testing.assert_eq(actual: m2.positionals(), expected: ['foo.hawk', '--bar'])?;
    return Result.Ok(void);
}

/// An app with subcommands, for the dispatch/adapter tests.
fn app() -> Command {
    return Command.new('tool')
        .subcommand(Command.new('build').about('compile the project').flag('release', abbr: 'r'))
        .subcommand(Command.new('serve').about('run a server'));
}

@test
fn test_command_path_in_error() -> Result<Void, Error> {
    // An error inside `build` records the subcommand as the failure path...
    let e = expect_err(app().parse(['build', '--bogus']))?;
    testing.assert_eq(actual: e.command_path(), expected: ['build'])?;
    // ...while an unknown top-level subcommand stays at the root.
    let e2 = expect_err(app().parse(['bogus']))?;
    testing.assert_eq(actual: e2.command_path().len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_selected_pairs_name_and_matches() -> Result<Void, Error> {
    let m = testing.assert_ok(app().parse(['build', '--release']))?;
    let sel = testing.assert_ok(m.selected().ok_or(error('no selection')))?;
    testing.assert_eq(actual: sel.name, expected: 'build')?;
    testing.assert_eq(actual: sel.matches.flag('release'), expected: true)?;

    // No subcommand -> no selection (the pair is present or absent together).
    let m2 = testing.assert_ok(app().parse([]))?;
    testing.assert(m2.selected().is_none(), message: 'no subcommand -> None')?;
    return Result.Ok(void);
}

@test
fn test_help_for_selected_subcommand() -> Result<Void, Error> {
    let sub_help = app().help_for('build');
    testing.assert(sub_help.contains('Usage: build'), message: 'shows the subcommand usage')?;
    testing.assert(sub_help.contains('--release, -r'), message: 'shows the subcommand flags')?;
    // An unknown name falls back to the parent's own help.
    testing.assert(app().help_for('nope').contains('Usage: tool'), message: 'fallback to parent')?;
    return Result.Ok(void);
}

@test
fn test_help_columns_align() -> Result<Void, Error> {
    let cmd = Command.new('tool')
        .flag('a', help: 'first')
        .flag('bbbbbb', help: 'second');
    let text = cmd.help();
    // Both descriptions start at the same column, regardless of head width...
    let c1 = testing.assert_ok(column_of(text, 'first'))?;
    let c2 = testing.assert_ok(column_of(text, 'second'))?;
    testing.assert_eq(actual: c1, expected: c2)?;
    // ...and the short head is padded past the old fixed 4-space gap (column 9).
    testing.assert(c1 > 9, message: 'short head is padded to the shared column')?;
    return Result.Ok(void);
}

@test
fn test_run_proceeds_on_a_subcommand() -> Result<Void, Error> {
    // A normal invocation hands back the matches for the client to dispatch.
    match app().run(['build', '--release']) {
        Proceed(m) => {
            let sel = testing.assert_ok(m.selected().ok_or(error('no selection')))?;
            testing.assert_eq(actual: sel.name, expected: 'build')?;
            testing.assert_eq(actual: sel.matches.flag('release'), expected: true)?;
        },
        Exit(_) => { testing.assert(false, message: 'expected Proceed')?; },
    }
    return Result.Ok(void);
}

@test
fn test_run_exit_codes() -> Result<Void, Error> {
    // --help on a subcommand / at the top level: handled, exit 0.
    testing.assert_eq(actual: exit_code(app().run(['build', '--help'])), expected: 0)?;
    testing.assert_eq(actual: exit_code(app().run(['--help'])), expected: 0)?;
    // A command that expects a subcommand, invoked bare: usage error, exit 1.
    testing.assert_eq(actual: exit_code(app().run([])), expected: 1)?;
    // A parse error: exit 2.
    testing.assert_eq(actual: exit_code(app().run(['build', '--bogus'])), expected: 2)?;
    testing.assert_eq(actual: exit_code(app().run(['bogus'])), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_run_flat_command_proceeds() -> Result<Void, Error> {
    // A command with no subcommands reads its own flags — a bare invocation is
    // not a usage error; only a parse error or --help short-circuits.
    let flat = Command.new('greet').flag('loud', abbr: 'l');
    match flat.run(['--loud']) {
        Proceed(m) => {
            testing.assert_eq(actual: m.flag('loud'), expected: true)?;
            testing.assert(m.selected().is_none(), message: 'flat command has no selection')?;
        },
        Exit(_) => { testing.assert(false, message: 'expected Proceed')?; },
    }
    return Result.Ok(void);
}

/// The exit code an `Action` carries, or -1 when it is `Proceed` (test-only).
fn exit_code(_ a: Action) -> Int {
    return match a {
        Proceed(_) => -1,
        Exit(code) => code,
    };
}

/// The column (offset within its line) of `needle`'s first occurrence in `text`,
/// or an error if absent — for asserting help columns line up.
fn column_of(_ text: String, _ needle: String) -> Result<Int, Error> {
    for line in text.lines() {
        match line.find(needle) {
            Some(col) => return Result.Ok(col),
            None => {},
        }
    }
    return Result.Err(error('needle not found: ${needle}'));
}
