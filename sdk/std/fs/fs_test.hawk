//! Tests for std.fs. These touch the real filesystem under a unique workspace
//! directory inside the system temp dir, cleaning up as they go.

import std.testing;
import std.path;
import std.io;
import std.process;

import 'fs' as _;

/// A fresh, empty workspace directory under the system temp dir. Pre-cleans any
/// leftovers from an earlier run.
fn workspace(_ name: String) -> Result<String, Error> {
    let dir = path.join(fs.temp_dir(), name);
    match fs.remove_dir_all(dir) {
        Ok(_) => {},
        Err(_) => {}, // didn't exist — fine
    }
    fs.create_dir_all(dir)?;
    return Result.Ok(dir);
}

fn is_not_found(_ e: FsError) -> Bool {
    return match e {
        NotFound(_) => true,
        _ => false,
    };
}

@test
fn test_write_then_read_text() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_text')?;
    let file = path.join(dir, 'hello.txt');
    fs.write_text(file, 'hello, fs')?;
    testing.assert_eq(actual: fs.read_text(file)?, expected: 'hello, fs')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_write_then_read_bytes() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_bytes')?;
    let file = path.join(dir, 'data.bin');
    let data = Bytes.from_list([0, 1, 2, 255])?;
    fs.write_bytes(file, data)?;
    testing.assert_eq(actual: fs.read_bytes(file)?.to_list(), expected: [0, 1, 2, 255])?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_exists() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_exists')?;
    let file = path.join(dir, 'f.txt');
    testing.assert_eq(actual: fs.exists(file), expected: false)?;
    fs.write_text(file, 'x')?;
    testing.assert_eq(actual: fs.exists(file), expected: true)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_read_missing_is_not_found() -> Result<Void, Error> {
    let missing = path.join(fs.temp_dir(), 'hawk_fs_definitely_absent_42');
    let classified = match fs.read_text(missing) {
        Ok(_) => false,
        Err(e) => is_not_found(e),
    };
    testing.assert(classified, message: 'expected a NotFound FsError')?;
    return Result.Ok(void);
}

@test
fn test_list_dir() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_list')?;
    fs.write_text(path.join(dir, 'a.txt'), '1')?;
    fs.write_text(path.join(dir, 'b.txt'), '2')?;
    let names = fs.list_dir(dir)?;
    testing.assert_eq(actual: names.len(), expected: 2)?;
    let joined = names.join(',');
    testing.assert(joined.contains('a.txt'), message: 'a.txt listed')?;
    testing.assert(joined.contains('b.txt'), message: 'b.txt listed')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_metadata_file() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_meta')?;
    let file = path.join(dir, 'sized.txt');
    fs.write_text(file, 'hello')?; // 5 bytes
    let md = fs.metadata(file)?;
    testing.assert_eq(actual: md.size, expected: 5)?;
    testing.assert_eq(actual: md.kind, expected: FileKind.File)?;
    // A freshly-written file reports a last-modified time (a `DateTime`, not a
    // raw millis Int). It should be a plausible, positive instant.
    match md.modified {
        Some(dt) => { testing.assert(dt.unix_millis() > 0, message: 'modified time is set')?; },
        None => { testing.assert(false, message: 'expected a modified time')?; },
    }
    let dir_md = fs.metadata(dir)?;
    testing.assert_eq(actual: dir_md.kind, expected: FileKind.Dir)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_temp_file() -> Result<Void, Error> {
    let f = fs.temp_file(prefix: 'hawk_fs_tmp_')?;
    let p = f.path();
    testing.assert(fs.exists(p), message: 'temp file exists on disk')?;
    testing.assert(path.basename(p).starts_with('hawk_fs_tmp_'), message: 'name uses the prefix')?;

    // It's a real, writable File; what we write reads back from its path.
    f.write('scratch'.bytes())?;
    f.close()?;
    testing.assert_eq(actual: fs.read_text(p)?, expected: 'scratch')?;

    // Each call yields a distinct file (atomic, unique).
    let f2 = fs.temp_file(prefix: 'hawk_fs_tmp_')?;
    testing.assert(f2.path() != p, message: 'temp files get unique names')?;
    f2.close()?;

    fs.remove(p)?;
    fs.remove(f2.path())?;
    testing.assert(!fs.exists(p), message: 'removed after cleanup')?;
    return Result.Ok(void);
}

@test
fn test_symlink_metadata_detects_a_link() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_symlink')?;
    let target = path.join(dir, 'target.txt');
    fs.write_text(target, 'hi')?;
    let link = path.join(dir, 'link.txt');
    // Create a symlink with POSIX `ln -s`; if it isn't available, skip the
    // symlink-specific assertions (still exercises the non-symlink path below).
    match process.run('ln', args: ['-s', target, link]) {
        Ok(_) => {
            // symlink_metadata inspects the link itself...
            testing.assert_eq(actual: fs.symlink_metadata(link)?.kind, expected: FileKind.Symlink)?;
            // ...while metadata follows it through to the target file.
            testing.assert_eq(actual: fs.metadata(link)?.kind, expected: FileKind.File)?;
        },
        Err(_) => {},
    }
    // For a plain file, symlink_metadata agrees with metadata.
    testing.assert_eq(actual: fs.symlink_metadata(target)?.kind, expected: FileKind.File)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_create_and_remove_dir() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_mkdir')?;
    let nested = path.join(path.join(dir, 'a'), 'b');
    fs.create_dir_all(nested)?;
    testing.assert_eq(actual: fs.exists(nested), expected: true)?;
    fs.remove_dir_all(dir)?;
    testing.assert_eq(actual: fs.exists(dir), expected: false)?;
    return Result.Ok(void);
}

@test
fn test_rename() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_rename')?;
    let a = path.join(dir, 'a.txt');
    let b = path.join(dir, 'b.txt');
    fs.write_text(a, 'move me')?;
    fs.rename(from: a, to: b)?;
    testing.assert_eq(actual: fs.exists(a), expected: false)?;
    testing.assert_eq(actual: fs.read_text(b)?, expected: 'move me')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_copy() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_copy')?;
    let a = path.join(dir, 'a.txt');
    let b = path.join(dir, 'b.txt');
    fs.write_text(a, 'duplicate')?;
    fs.copy(from: a, to: b)?;
    testing.assert_eq(actual: fs.read_text(a)?, expected: 'duplicate')?;
    testing.assert_eq(actual: fs.read_text(b)?, expected: 'duplicate')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

// --- streaming files ---

@test
fn test_file_write_read_roundtrip() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_file_rw')?;
    let p = path.join(dir, 'data.txt');
    let w = fs.create(p)?;
    let n = w.write('hello, file'.bytes())?;
    w.close()?;
    testing.assert_eq(actual: n, expected: 11)?;
    let f = fs.open(p)?;
    let content = io.read_all(f)?;
    f.close()?;
    testing.assert_eq(actual: content.to_string()?, expected: 'hello, file')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_file_lines_streamed() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_file_lines')?;
    let p = path.join(dir, 'lines.txt');
    fs.write_text(p, 'a\nb\nc\n')?;
    let f = fs.open(p)?;
    let got = io.lines(f).collect(); // streams the real file handle, no read-all
    testing.assert_eq(actual: got, expected: ['a', 'b', 'c'])?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_file_seek() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_file_seek')?;
    let p = path.join(dir, 'seek.txt');
    fs.write_text(p, '0123456789')?;
    let f = fs.open(p)?;
    testing.assert_eq(actual: f.seek(io.SeekFrom.Start(4))?, expected: 4)?;
    testing.assert_eq(actual: f.read(max: 3)?.to_string()?, expected: '456')?;
    testing.assert_eq(actual: f.seek(io.SeekFrom.End(-2))?, expected: 8)?;
    testing.assert_eq(actual: f.read(max: 10)?.to_string()?, expected: '89')?;
    f.close()?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_file_use_after_close_errors() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_file_closed')?;
    let p = path.join(dir, 'c.txt');
    fs.write_text(p, 'x')?;
    let f = fs.open(p)?;
    f.close()?;
    testing.assert_err(f.read(max: 1))?; // reading a closed handle is an error
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_open_missing_is_not_found() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_open_missing')?;
    let is_nf = match fs.open(path.join(dir, 'nope.txt')) {
        Ok(_)  => false,
        Err(e) => is_not_found(e),
    };
    testing.assert(is_nf, message: 'opening a missing file should be NotFound')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

// --- walk ---

// Build dir/{a.txt, sub/{b.txt, deep/c.txt}} and return the dir.
fn build_tree(_ name: String) -> Result<String, Error> {
    let dir = workspace(name)?;
    let sub = path.join(dir, 'sub');
    let deep = path.join(sub, 'deep');
    fs.create_dir_all(deep)?;
    fs.write_text(path.join(dir, 'a.txt'), 'a')?;
    fs.write_text(path.join(sub, 'b.txt'), 'b')?;
    fs.write_text(path.join(deep, 'c.txt'), 'c')?;
    return Result.Ok(dir);
}

@test
fn test_walk_recurses_files_and_dirs() -> Result<Void, Error> {
    let dir = build_tree('hawk_fs_walk_all')?;
    let got = fs.walk(dir).collect(); // order is unspecified — check membership
    let sub = path.join(dir, 'sub');
    let deep = path.join(sub, 'deep');
    testing.assert_eq(actual: got.len(), expected: 5)?;
    testing.assert(got.contains(path.join(dir, 'a.txt')), message: 'missing a.txt')?;
    testing.assert(got.contains(sub), message: 'missing sub')?;
    testing.assert(got.contains(path.join(sub, 'b.txt')), message: 'missing sub/b.txt')?;
    testing.assert(got.contains(deep), message: 'missing sub/deep')?;
    testing.assert(got.contains(path.join(deep, 'c.txt')), message: 'missing sub/deep/c.txt')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_walk_filter_to_files() -> Result<Void, Error> {
    let dir = build_tree('hawk_fs_walk_files')?;
    let files = fs.walk(dir).filter((p) => p.ends_with('.txt')).collect();
    testing.assert_eq(actual: files.len(), expected: 3)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_walk_empty_dir() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_walk_empty')?;
    testing.assert_eq(actual: fs.walk(dir).count(), expected: 0)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_walk_for_loop() -> Result<Void, Error> {
    let dir = build_tree('hawk_fs_walk_for')?;
    let mut n = 0;
    for _ in fs.walk(dir) {
        n = n + 1;
    }
    testing.assert_eq(actual: n, expected: 5)?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}

@test
fn test_walk_missing_root_records_error() -> Result<Void, Error> {
    let dir = workspace('hawk_fs_walk_missing')?;
    let w = fs.walk(path.join(dir, 'does_not_exist'));
    testing.assert_eq(actual: w.collect().len(), expected: 0)?;
    let is_nf = match w.error() {
        Some(e) => is_not_found(e),
        None    => false,
    };
    testing.assert(is_nf, message: 'expected a NotFound error from walking a missing root')?;
    fs.remove_dir_all(dir)?;
    return Result.Ok(void);
}
