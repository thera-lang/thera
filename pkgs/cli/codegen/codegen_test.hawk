// Tests for the bytecode emitter, diffed byte-for-byte against the Dart oracle.
//
// Each golden is the output of the Dart `compileProgram(program, imports: [])`
// + `encodeModule` for the same source (core-free, so the two compilers compile
// exactly the same units). A match means the Hawk front-end lowers the program
// to byte-identical `.hawkbc` — the end-to-end self-hosting check.

import std.testing;

import '../ast/ast' as _;
import '../lexer/lexer' as _;
import '../parser/parser' as _;
import '../bytecode/instr' as _;
import '../bytecode/module' as _;
import '../bytecode/encoder' as _;
import 'codegen' as _;

fn emit_bytes(_ src: String) -> List<Int> {
    let result = compile_program(parse_tokens(tokenize(src).tokens).program, [], {}, {});
    return encode_module(result.module).to_list();
}

fn errors_of(_ src: String) -> Int {
    return compile_program(parse_tokens(tokenize(src).tokens).program, [], {}, {}).errors.len();
}

// --- instruction-level lowering inspection ---
//
// These tests assert *which* instruction a construct lowers to (rather than
// pinning the whole byte stream against a golden), so a regression in a specific
// lowering — e.g. a call-resolution branch picking the wrong opcode — fails here
// with a located, readable assertion instead of only as a fixpoint/example break.

fn module_of(_ src: String) -> Module {
    return compile_program(parse_tokens(tokenize(src).tokens).program, [], {}, {}).module;
}

// The instruction stream of the unit named `fn_name` (a free function's bare
// name, a method's `Type.method`), or empty if there's no such unit.
fn code_of(_ src: String, _ fn_name: String) -> List<Instr> {
    for f in module_of(src).functions {
        if f.name == fn_name {
            return f.code;
        }
    }
    return [];
}

// The code of the first lifted-lambda unit (`__lambda_*`), or empty.
fn lambda_code(_ src: String) -> List<Instr> {
    for f in module_of(src).functions {
        if f.name.starts_with('__lambda') {
            return f.code;
        }
    }
    return [];
}

// A short tag for an instruction, for readable structural assertions. Operand-less
// `Simple` ops are tagged by their opcode byte (`simple_<n>`); call/field
// instructions get a name, and native/virtual calls carry their selector.
fn instr_tag(_ i: Instr) -> String {
    return match i {
        Simple(op) => 'simple_${op.byte()}',
        Call(_, _) => 'call',
        CallNative(name, _) => 'call_native:${name}',
        EnumNew(_, _, _) => 'enum_new',
        CallVirtual(sel, _) => 'call_virtual:${sel}',
        CallIndirect(_) => 'call_indirect',
        FieldGet(_) => 'field_get',
        FieldSet(_) => 'field_set',
        StructNew(_) => 'struct_new',
        ClosureNew(_, _) => 'closure_new',
        GlobalGet(_) => 'global_get',
        GlobalSet(_) => 'global_set',
        _ => 'other',
    };
}

fn count_tag(_ code: List<Instr>, _ tag: String) -> Int {
    let mut n = 0;
    for i in code {
        if instr_tag(i) == tag {
            n = n + 1;
        }
    }
    return n;
}

// The argument count of the first `Call` (a method's `self` counts as an
// argument), or -1 if there is none — distinguishes an instance call from a
// static one of the same shape.
fn first_call_argc(_ code: List<Instr>) -> Int {
    for i in code {
        match i {
            Call(_, argc) => { return argc; },
            _ => {},
        }
    }
    return -1;
}

fn enum_tag_tag() -> String { return 'simple_${Op.EnumTag.byte()}'; }

@test
fn test_arithmetic_and_control_flow_byte_identical() -> Result<Void, Error> {
    let src = 'fn add(_ a: Int, _ b: Int) -> Int { return a + b; }\n'
        + 'fn main() -> Int {\n'
        + '    let x = add(2, 3);\n'
        + '    let mut sum = 0;\n'
        + '    let mut i = 0;\n'
        + '    while i < x {\n'
        + '        sum = sum + i;\n'
        + '        i = i + 1;\n'
        + '    }\n'
        + '    return sum;\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 65, 2, 3, 97, 100, 100,
        2, 2, 4, 6, 0, 6, 1, 8, 45, 4, 109, 97, 105, 110, 0, 3, 23, 1, 2, 1, 3,
        36, 0, 2, 7, 0, 1, 0, 7, 1, 1, 0, 7, 2, 6, 2, 6, 0, 21, 44, 21, 6, 1, 6,
        2, 8, 7, 1, 6, 2, 1, 1, 8, 7, 2, 42, 8, 6, 1, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_bool_equality_byte_identical() -> Result<Void, Error> {
    // Regression: Bool is a distinct runtime value, so `==`/`!=` lower to the
    // structural `eq` native (the `101, 113` = "eq" in the pool), not `eqI64`.
    let src = 'fn main() -> Bool {\n'
        + '    let a = true;\n'
        + '    let b = false;\n'
        + '    return a != b;\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 4, 1, 2, 101, 113, 3, 1, 0, 1, 26, 1, 4,
        109, 97, 105, 110, 0, 2, 9, 3, 1, 7, 0, 3, 0, 7, 1, 6, 0, 6, 1, 37, 0,
        2, 31, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_if_else_and_double_byte_identical() -> Result<Void, Error> {
    // `if`-statement early return, an `if`-expression tail, comparisons, a Bool
    // local, and Double arithmetic (the F64 opcode + the 8-byte float constant).
    let src = 'fn classify(_ n: Int) -> Int {\n'
        + '    if n < 0 { return -1; }\n'
        + '    let big = n > 100;\n'
        + '    return if big { 2 } else { 1 };\n'
        + '}\n'
        + 'fn scale(_ x: Double) -> Double { return x * 2.0; }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 65, 2, 8, 99, 108, 97,
        115, 115, 105, 102, 121, 1, 2, 17, 6, 0, 1, 0, 21, 44, 7, 1, 1, 13, 45,
        6, 0, 1, 228, 0, 23, 7, 1, 6, 1, 44, 15, 1, 2, 42, 16, 1, 1, 45, 5, 115,
        99, 97, 108, 101, 1, 1, 4, 6, 0, 2, 0, 0, 0, 0, 0, 0, 0, 64, 16, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_list_and_for_loop_byte_identical() -> Result<Void, Error> {
    // A `for x in list` index loop (the `list_len`/`list.get` lowering) and a
    // list literal — exercising the native-symbol pool and `list.new`.
    let src = 'fn sum_list(_ xs: List<Int>) -> Int {\n'
        + '    let mut total = 0;\n'
        + '    for v in xs {\n'
        + '        total = total + v;\n'
        + '    }\n'
        + '    return total;\n'
        + '}\n'
        + 'fn triples() -> List<Int> {\n'
        + '    return [1, 2, 3];\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    // `for v in xs` and the implicit length check lower to the `list.len` opcode
    // (61), not a `call.native 'list_len'` — so the native-symbol pool no longer
    // carries "list_len" for a list-only program.
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 79, 2, 8, 115, 117, 109,
        95, 108, 105, 115, 116, 1, 5, 26, 1, 0, 7, 1, 6, 0, 7, 2, 1, 0, 7, 3, 6,
        3, 6, 2, 61, 21, 44, 24, 6, 2, 6, 3, 52, 7, 4, 6, 1, 6, 4, 8, 7, 1, 6, 3,
        1, 1, 8, 7, 3, 42, 6, 6, 1, 45, 7, 116, 114, 105, 112, 108, 101, 115, 0,
        0, 5, 1, 1, 1, 2, 1, 3, 41, 3, 45,
    ])?;
    return Result.Ok(void);
}

fn program_of(_ src: String, _ path: String) -> Program {
    let prog = parse_tokens(tokenize(src).tokens).program;
    prog.file_path = Option.Some(path);
    return prog;
}

@test
fn test_same_file_first_resolution_byte_identical() -> Result<Void, Error> {
    // Two co-loaded files each define a private `combine` with different arity.
    // Same-file-first resolution links each call to its *own* file's `combine`
    // (main's 1-arg in `use_both`, lib's 2-arg in `lib_pick`) — byte-identical to
    // the Dart oracle, which compiles the same two files distinctly.
    let lib = program_of(
        'pub fn lib_pick(_ a: Int, _ b: Int) -> Int { return combine(a, b); }\n'
        + 'fn combine(_ x: Int, _ y: Int) -> Int { return x + y; }', 'lib.hawk');
    let main_prog = program_of(
        'fn combine(_ x: Int) -> Int { return x * 100; }\n'
        + 'fn use_both() -> Int { return combine(3) + lib_pick(4, 5); }', 'main.hawk');
    let result = compile_program(main_prog, [lib], {}, {});
    testing.assert_eq(actual: result.errors.len(), expected: 0)?;
    testing.assert_eq(actual: encode_module(result.module).to_list(), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 82, 4, 8, 108, 105, 98,
        95, 112, 105, 99, 107, 2, 2, 4, 6, 0, 6, 1, 36, 1, 2, 45, 7, 99, 111, 109,
        98, 105, 110, 101, 2, 2, 4, 6, 0, 6, 1, 8, 45, 7, 99, 111, 109, 98, 105,
        110, 101, 1, 1, 4, 6, 0, 1, 228, 0, 10, 45, 8, 117, 115, 101, 95, 98, 111,
        116, 104, 0, 0, 7, 1, 3, 36, 2, 1, 1, 4, 1, 5, 36, 0, 2, 8, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_match_byte_identical() -> Result<Void, Error> {
    // A linear `match`: constructor patterns with payload extraction, a
    // payload-free variant, a wildcard arg, a nested constructor pattern
    // (`Node(l, r)`), and recursion inside arms.
    let src = 'enum Shape { Circle(Int), Square(Int), Point }\n'
        + 'fn area(_ s: Shape) -> Int {\n'
        + '    return match s {\n'
        + '        Circle(r) => r * r * 3,\n'
        + '        Square(w) => w * w,\n'
        + '        Point => 0,\n'
        + '    };\n'
        + '}\n'
        + 'enum Tree { Leaf(Int), Node(Tree, Tree) }\n'
        + 'fn depth(_ t: Tree) -> Int {\n'
        + '    return match t {\n'
        + '        Leaf(_) => 1,\n'
        + '        Node(l, r) => 1 + max2(depth(l), depth(r)),\n'
        + '    };\n'
        + '}\n'
        + 'fn max2(_ a: Int, _ b: Int) -> Int {\n'
        + '    return if a > b { a } else { b };\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 137, 1, 3, 4, 97, 114,
        101, 97, 1, 4, 30, 6, 0, 7, 1, 6, 1, 39, 1, 0, 19, 44, 16, 6, 1, 40, 0,
        7, 2, 6, 2, 6, 2, 10, 1, 3, 10, 42, 29, 6, 1, 39, 1, 1, 19, 44, 28, 6, 1,
        40, 0, 7, 3, 6, 3, 6, 3, 10, 42, 29, 1, 0, 45, 5, 100, 101, 112, 116,
        104, 1, 4, 23, 6, 0, 7, 1, 6, 1, 39, 1, 0, 19, 44, 9, 1, 1, 42, 22, 6, 1,
        40, 0, 7, 2, 6, 1, 40, 1, 7, 3, 1, 1, 6, 2, 36, 1, 1, 6, 3, 36, 1, 1, 36,
        2, 2, 8, 45, 4, 109, 97, 120, 50, 2, 2, 8, 6, 0, 6, 1, 23, 44, 6, 6, 0,
        42, 7, 6, 1, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_match_dispatch_byte_identical() -> Result<Void, Error> {
    // A large flat-constructor match (7 cases + a default): the subject's tag is
    // hoisted once and dispatched via a balanced binary search (`<`/`>` branches)
    // instead of the linear chain.
    let src = 'enum Dir { N, NE, E, SE, S, SW, W, NW }\n'
        + 'fn turns(_ d: Dir) -> Int {\n'
        + '    return match d {\n'
        + '        N => 0,\n'
        + '        NE => 1,\n'
        + '        E => 2,\n'
        + '        SE => 3,\n'
        + '        S => 4,\n'
        + '        SW => 5,\n'
        + '        W => 6,\n'
        + '        _ => 7,\n'
        + '    };\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 120, 1, 5, 116, 117,
        114, 110, 115, 1, 3, 61, 6, 0, 7, 1, 6, 1, 39, 7, 2, 6, 2, 1, 3, 21, 43,
        15, 6, 2, 1, 3, 23, 43, 37, 1, 3, 42, 60, 6, 2, 1, 1, 21, 43, 25, 6, 2,
        1, 1, 23, 43, 31, 1, 1, 42, 60, 6, 2, 1, 0, 19, 44, 59, 1, 0, 42, 60, 6,
        2, 1, 2, 19, 44, 59, 1, 2, 42, 60, 6, 2, 1, 5, 21, 43, 47, 6, 2, 1, 5,
        23, 43, 53, 1, 5, 42, 60, 6, 2, 1, 4, 19, 44, 59, 1, 4, 42, 60, 6, 2, 1,
        6, 19, 44, 59, 1, 6, 42, 60, 1, 7, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_method_calls_nondispatch_byte_identical() -> Result<Void, Error> {
    // Non-dispatch method calls: an enum payload constructor (`Shape.Circle(r)`),
    // a payload-free constructor (`Shape.Point`), `s.name()` (the tag→name
    // chain), and an instance `native fn` (`s.sides()` → the receiver pushed as
    // the native's first argument).
    let src = 'enum Shape { Circle(Int), Square(Int), Point }\n'
        + 'fn make_circle(_ r: Int) -> Shape { return Shape.Circle(r); }\n'
        + 'fn make_point() -> Shape { return Shape.Point; }\n'
        + 'fn label(_ s: Shape) -> String { return s.name(); }\n'
        + 'impl Shape {\n'
        + '    @extern(\'shape_sides\') native fn sides(self) -> Int\n'
        + '}\n'
        + 'fn sides_of(_ s: Shape) -> Int { return s.sides(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 33, 4, 6, 67, 105, 114, 99, 108, 101, 6,
        83, 113, 117, 97, 114, 101, 5, 80, 111, 105, 110, 116, 11, 115, 104, 97,
        112, 101, 95, 115, 105, 100, 101, 115, 3, 1, 0, 1, 99, 4, 11, 109, 97,
        107, 101, 95, 99, 105, 114, 99, 108, 101, 1, 1, 3, 6, 0, 38, 3, 0, 1, 45,
        10, 109, 97, 107, 101, 95, 112, 111, 105, 110, 116, 0, 0, 2, 38, 3, 2, 0,
        45, 5, 108, 97, 98, 101, 108, 1, 2, 17, 6, 0, 39, 7, 1, 6, 1, 1, 0, 19,
        44, 9, 5, 0, 42, 16, 6, 1, 1, 1, 19, 44, 15, 5, 1, 42, 16, 5, 2, 45, 8,
        115, 105, 100, 101, 115, 95, 111, 102, 1, 1, 3, 6, 0, 37, 3, 1, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_method_calls_dispatch_byte_identical() -> Result<Void, Error> {
    // Dynamic-dispatch method calls: a user instance method (`p.sum()` → `call`
    // with self), a static method (`Point.origin()`), `call.virtual` on an
    // interface-typed receiver (`g.greet()`), and a function-valued struct field
    // invoked like a method (`b.run()` → `call.indirect`).
    let src = 'struct Point { x: Int, y: Int }\n'
        + 'impl Point {\n'
        + '    fn sum(self) -> Int { return self.x + self.y; }\n'
        + '    fn origin() -> Point { return Point { x: 0, y: 0 }; }\n'
        + '}\n'
        + 'fn use_point(_ p: Point) -> Int { return p.sum(); }\n'
        + 'fn make() -> Point { return Point.origin(); }\n'
        + 'interface Greeter { fn greet(self) -> Int; }\n'
        + 'fn dispatch(_ g: Greeter) -> Int { return g.greet(); }\n'
        + 'struct Box { run: () -> Int }\n'
        + 'fn call_it(_ b: Box) -> Int { return b.run(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 17, 3, 5, 80, 111, 105, 110, 116, 3, 66,
        111, 120, 5, 103, 114, 101, 101, 116, 3, 5, 2, 0, 2, 1, 1, 1, 114, 6, 9,
        80, 111, 105, 110, 116, 46, 115, 117, 109, 1, 1, 6, 6, 0, 47, 0, 6, 0,
        47, 1, 8, 45, 12, 80, 111, 105, 110, 116, 46, 111, 114, 105, 103, 105,
        110, 0, 0, 4, 1, 0, 1, 0, 46, 0, 45, 9, 117, 115, 101, 95, 112, 111, 105,
        110, 116, 1, 1, 3, 6, 0, 36, 0, 1, 45, 4, 109, 97, 107, 101, 0, 0, 2, 36,
        1, 0, 45, 8, 100, 105, 115, 112, 97, 116, 99, 104, 1, 1, 3, 6, 0, 51, 2,
        1, 45, 7, 99, 97, 108, 108, 95, 105, 116, 1, 1, 4, 6, 0, 47, 0, 50, 0, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_lambdas_byte_identical() -> Result<Void, Error> {
    // Plain lambdas: a non-capturing lambda passed to a higher-order function
    // (its un-annotated `v` typed bidirectionally from the param signature),
    // a capturing lambda returned as a closure (`(x) => x + n` captures `n`),
    // and calling a closure held in a local (`add5(10)` → call.indirect). Each
    // lambda lifts to a `__lambda_N` unit whose body types via the param stash.
    let src = 'fn apply(_ f: (Int) -> Int, _ x: Int) -> Int { return f(x); }\n'
        + 'fn double_it(_ n: Int) -> Int { return apply((v) => v * 2, n); }\n'
        + 'fn adder(_ n: Int) -> (Int) -> Int { return (x) => x + n; }\n'
        + 'fn use_adder() -> Int {\n'
        + '    let add5 = adder(5);\n'
        + '    return add5(10);\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 121, 6, 5, 97, 112, 112,
        108, 121, 2, 2, 4, 6, 0, 6, 1, 50, 1, 45, 9, 100, 111, 117, 98, 108, 101,
        95, 105, 116, 1, 1, 4, 49, 4, 0, 6, 0, 36, 0, 2, 45, 5, 97, 100, 100, 101,
        114, 1, 1, 3, 6, 0, 49, 5, 1, 45, 9, 117, 115, 101, 95, 97, 100, 100, 101,
        114, 0, 1, 7, 1, 5, 36, 2, 1, 7, 0, 6, 0, 1, 10, 50, 1, 45, 10, 95, 95,
        108, 97, 109, 98, 100, 97, 95, 52, 1, 1, 4, 6, 0, 1, 2, 10, 45, 10, 95,
        95, 108, 97, 109, 98, 100, 97, 95, 53, 2, 2, 4, 6, 1, 6, 0, 8, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_lambda_mut_capture_byte_identical() -> Result<Void, Error> {
    // A lambda that captures and mutates a `mut` local of the enclosing function:
    // `total` is boxed in a one-field `<cell>` (struct.new), the closure captures
    // the cell itself, and the lifted unit reads/writes through it (field.get /
    // field.set) so the closure and a later call share the running state.
    let src = 'fn counter() -> (Int) -> Int {\n'
        + '    let mut total = 0;\n'
        + '    return (delta) => {\n'
        + '        total = total + delta;\n'
        + '        return total;\n'
        + '    };\n'
        + '}\n'
        + 'fn use_counter() -> Int {\n'
        + '    let bump = counter();\n'
        + '    let a = bump(5);\n'
        + '    let b = bump(3);\n'
        + '    return a + b;\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: emit_bytes(src), expected: [
        72, 65, 87, 75, 1, 0, 0, 0, 2, 8, 1, 6, 60, 99, 101, 108, 108, 62, 3, 3,
        1, 0, 1, 1, 98, 3, 7, 99, 111, 117, 110, 116, 101, 114, 0, 1, 6, 1, 0,
        46, 0, 7, 0, 6, 0, 49, 2, 1, 45, 11, 117, 115, 101, 95, 99, 111, 117,
        110, 116, 101, 114, 0, 3, 14, 36, 0, 0, 7, 0, 6, 0, 1, 5, 50, 1, 7, 1, 6,
        0, 1, 3, 50, 1, 7, 2, 6, 1, 6, 2, 8, 45, 10, 95, 95, 108, 97, 109, 98,
        100, 97, 95, 50, 2, 2, 11, 6, 0, 6, 0, 47, 0, 6, 1, 8, 48, 0, 6, 0, 47,
        0, 45, 4, 45,
    ])?;
    return Result.Ok(void);
}

@test
fn test_lowering_enum_ctor_emits_enum_new() -> Result<Void, Error> {
    let src = 'enum Shape { Circle(Int), Square }\n'
        + 'fn make() -> Shape { return Shape.Circle(3); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: count_tag(code_of(src, 'make'), 'enum_new'), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_lowering_enum_name_hoists_one_tag() -> Result<Void, Error> {
    let src = 'enum Color { Red, Green, Blue }\n'
        + 'fn label(_ c: Color) -> String { return c.name(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: count_tag(code_of(src, 'label'), enum_tag_tag()), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_lowering_user_static_method_emits_receiverless_call() -> Result<Void, Error> {
    let src = 'struct Box { v: Int }\n'
        + 'impl Box { fn zero() -> Box { return Box { v: 0 }; } }\n'
        + 'fn make() -> Box { return Box.zero(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    // A direct call with no receiver pushed: argc is the user-arg count (0).
    testing.assert_eq(actual: count_tag(code_of(src, 'make'), 'call'), expected: 1)?;
    testing.assert_eq(actual: first_call_argc(code_of(src, 'make')), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_lowering_user_instance_method_pushes_self() -> Result<Void, Error> {
    let src = 'struct Box { v: Int }\n'
        + 'impl Box { fn get(self) -> Int { return self.v; } }\n'
        + 'fn read(_ b: Box) -> Int { return b.get(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    // Same `Call` shape as the static case, but `self` makes argc 1.
    testing.assert_eq(actual: count_tag(code_of(src, 'read'), 'call'), expected: 1)?;
    testing.assert_eq(actual: first_call_argc(code_of(src, 'read')), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_lowering_native_instance_method_emits_call_native() -> Result<Void, Error> {
    let src = 'struct Buf { n: Int }\n'
        + 'impl Buf { native fn size(self) -> Int; }\n'
        + 'fn go(_ b: Buf) -> Int { return b.size(); }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: count_tag(code_of(src, 'go'), 'call_native:size'), expected: 1)?;
    return Result.Ok(void);
}

