@test
fn test_lowering_match_bisection_hoists_tag_vs_linear() -> Result<Void, Error> {
    // A small `match` lowers to a linear chain that re-reads the subject's tag for
    // each arm; a large flat-constructor `match` bisects, hoisting the tag once
    // into a slot and branching on it (a balanced binary search).
    let small = 'enum Tri { A, B, C }\n'
        + 'fn pick(_ t: Tri) -> Int { return match t { A => 0, B => 1, C => 2 }; }';
    testing.assert_eq(actual: errors_of(small), expected: 0)?;
    testing.assert(count_tag(code_of(small, 'pick'), enum_tag_tag()) > 1,
        message: 'a linear match re-reads the tag per arm')?;

    let big = 'enum Dir { N, NE, E, SE, S, SW, W, NW }\n'
        + 'fn turns(_ d: Dir) -> Int {\n'
        + '    return match d { N => 0, NE => 1, E => 2, SE => 3, S => 4, SW => 5, W => 6, _ => 7 };\n'
        + '}';
    testing.assert_eq(actual: errors_of(big), expected: 0)?;
    testing.assert_eq(actual: count_tag(code_of(big, 'turns'), enum_tag_tag()), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_lowering_mut_capture_boxes_into_a_cell() -> Result<Void, Error> {
    // A `mut` local captured by a lambda is boxed into a one-field cell: the
    // enclosing fn builds the cell (struct_new) and the closure (closure_new); the
    // lambda body reads/writes the captured value through the cell's field.
    let src = 'fn counter() -> (Int) -> Int {\n'
        + '    let mut total = 0;\n'
        + '    return (delta) => {\n'
        + '        total = total + delta;\n'
        + '        return total;\n'
        + '    };\n'
        + '}';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    let outer = code_of(src, 'counter');
    testing.assert_eq(actual: count_tag(outer, 'closure_new'), expected: 1)?;
    testing.assert(count_tag(outer, 'struct_new') >= 1, message: 'expected a cell allocation')?;
    let body = lambda_code(src);
    testing.assert(count_tag(body, 'field_get') >= 1, message: 'expected a boxed read')?;
    testing.assert(count_tag(body, 'field_set') >= 1, message: 'expected a boxed write')?;
    return Result.Ok(void);
}

// --- module-level `let` (globals; docs/module_init.md) ---

@test
fn test_module_let_emits_init_thunk_and_global_count() -> Result<Void, Error> {
    // Two globals -> global_count 2, an `<init>` thunk that sets both slots, and a
    // `main` that reads the global from its slot (not by inlining the initializer).
    let src = 'let A: Int = 10;\n'
        + 'let B: Int = A + 5;\n'
        + 'fn main() -> Int { return B; }';
    testing.assert_eq(actual: errors_of(src), expected: 0)?;
    testing.assert_eq(actual: module_of(src).global_count, expected: 2)?;
    testing.assert_eq(actual: count_tag(code_of(src, 'main'), 'global_get'), expected: 1)?;
    testing.assert_eq(actual: count_tag(code_of(src, '<init>'), 'global_set'), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_module_let_initializer_cycle_is_an_error() -> Result<Void, Error> {
    // A.init references B and B.init references A — a dependency cycle, reported
    // as a located codegen error (cf. the cyclic-`const` guard).
    let src = 'let A: Int = B + 1;\n'
        + 'let B: Int = A + 1;\n'
        + 'fn main() -> Int { return 0; }';
    testing.assert(errors_of(src) > 0, message: 'an initializer cycle should be a codegen error')?;
    return Result.Ok(void);
}

@test
fn test_module_let_rejects_effectful_native() -> Result<Void, Error> {
    // A time-varying native (here a stand-in wired to `time_now_millis` via
    // `@extern`) is forbidden in an initializer — it would capture a stale
    // load-time snapshot. The denylist matches the resolved runtime symbol.
    let bad = '@extern(\'time_now_millis\')\n'
        + 'native fn clock() -> Int\n'
        + 'let T: Int = clock();\n'
        + 'fn main() -> Int { return T; }';
    testing.assert(errors_of(bad) > 0, message: 'a time-varying native in an initializer should be rejected')?;
    // The same native called from a normal function is fine — only initializer
    // position is restricted.
    let ok = '@extern(\'time_now_millis\')\n'
        + 'native fn clock() -> Int\n'
        + 'fn main() -> Int { return clock(); }';
    testing.assert_eq(actual: errors_of(ok), expected: 0)?;
    return Result.Ok(void);
}
