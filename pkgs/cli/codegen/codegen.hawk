// The bytecode emitter — the Hawk mirror of the `_FnCompiler` half of the Dart
// toolchain's codegen/codegen.dart. Walks a type-checked AST and emits the
// runtime's stack-based instructions.
//
// The Dart compiler reads `Expr.resolvedType` (annotated up front by the
// inferrer) for opcode/dispatch selection. Hawk's inference is pure, so this
// compiler calls `infer_expr` on demand against a `type_scope: Map<String, Type>`
// it maintains in parallel with the local `slots` — every binding records both
// its slot and its type. The compiler is a mutable struct: its `impl` methods
// grow `code`/`slots`/… in place (Hawk structs are references).
//
// Stage 1 covers functions, control flow, primitives, calls (free + native),
// strings, lists/maps, indexing, fields, and propagation. Struct/enum
// construction, `match`, method calls, and lambdas are staged follow-ups — they
// record a `CodegenError` if reached.

import '../ast/ast' as _;
import '../lexer/token' as _; // SourceSpan
import '../bytecode/instr' as _;
import '../bytecode/module' as _;
import '../element/types' as _;
import '../element/element';
import '../element/scope' as _;
import '../element/resolver';
import '../element/inference' as _;
import 'module_scope' as _;
import std.env;   // the differential inference oracle (HAWK_INFER_ORACLE) reads a flag

// A construct codegen does not yet handle (or an invariant a checked program
// should already guarantee). Collected rather than thrown — Hawk has no
// exceptions, and a fully-ported codegen produces none for a valid program.
pub struct CodegenError {
    message: String,
    span: SourceSpan,
}

pub struct CodegenResult {
    module: Module,
    errors: List<CodegenError>,
}

// The three jump kinds the backpatcher emits.
pub enum Jk {
    Jump,
    IfTrue,
    IfFalse,
}

// A placeholder jump awaiting its target: the instruction position to patch, the
// label it targets, and which jump opcode to emit.
pub struct Fixup {
    pos: Int,
    label: Int,
    kind: Jk,
}

// The lexical maps saved at a scope boundary (a block, a match arm, a for loop).
// Codegen applies the checker's `copy_scope` discipline to its slot and type
// maps in tandem: entering copies both (inner declarations and pattern bindings
// stay inner), exiting swaps the saved maps back. Slot *numbers* are never
// reused — only name visibility restores — so a shadowed outer binding reads its
// own slot again after the block instead of the inner one's.
struct SavedScope {
    slots: Map<String, Int>,
    types: Map<String, Type>,
}

// The compiler's full per-position context, saved when compilation crosses into
// another file's code mid-unit (a const initializer inlined at a use site):
// the file bare references resolve against, the inference context (whose
// `current_file` must move in tandem with `file` — this and `enter_file_context`
// are the one seam that moves them), and the lexical maps and type-parameter
// bounds, which a top-level initializer must not see.
struct FileContext {
    file: Option<String>,
    ctx: InferCtx,
    slots: Map<String, Int>,
    types: Map<String, Type>,
    bounds: Map<String, List<String>>,
}

// --- entry point ---

// Compile `program` plus any `imports` into one module. All modules' functions,
// types, and methods register into a single scope (so cross-module references
// resolve), then every unit is compiled.
pub fn compile_program(_ program: Program, _ imports: List<Program>,
    _ file_namespaces: Map<String, Map<String, element.LibraryNamespace>>,
    _ file_bare_surface: Map<String, Map<String, String>>) -> CodegenResult {
    let library = resolver.build_library(program, imports, file_namespaces, file_bare_surface);
    // Namespace resolution is the element-model FileScope's job (each unit resolves
    // qualifiers against its own file's imports via `library.file_namespaces`) — no
    // codegen-local copy of the per-file namespace sets.
    let scope = new_module_scope(library);

    let modules: List<Program> = [];
    for ip in imports {
        modules.push(ip);
    }
    modules.push(program);
    for m in modules {
        register_module(scope, m);
    }
    scope.flatten_interfaces();
    // Point each implementing type's dispatch at the interface's default-method
    // units (for methods it doesn't override). Done before unit compilation so a
    // concrete-receiver call to a default resolves to the shared unit, and before
    // `build_dispatch` so the rows are in the table.
    scope.wire_default_methods();

    let errors: List<CodegenError> = [];
    let functions: List<FuncDef> = [];
    let mut i = 0;
    // Re-read `units.len()` each iteration: lifted lambdas append units that are
    // themselves compiled by this same loop.
    while i < scope.units.len() {
        functions.push(new_fn_compiler(scope, errors).compile(i));
        i = i + 1;
    }

    // The program-init thunk (module-global initializers; see docs/module_init.md)
    // is synthesized after the real units and appended LAST, so it never shifts
    // the unit -> function-index mapping. Synthesizing it may itself lift lambda
    // units (an initializer containing a lambda); drain those into the table
    // before appending the thunk so their `closure.new` indices stay correct.
    let init_thunk = if scope.global_inits.len() != 0 {
        Option.Some(new_fn_compiler(scope, errors).compile_init_thunk())
    } else {
        Option.None
    };
    while i < scope.units.len() {
        functions.push(new_fn_compiler(scope, errors).compile(i));
        i = i + 1;
    }
    if let Some(f) = init_thunk { functions.push(f); }
    // Differential inference oracle (opt-in via HAWK_INFER_ORACLE): report units
    // whose codegen inference context diverges from the checker-correct one — the
    // root of the checker/codegen inference-disagreement bug class.
    if let Some(_) = env.get('HAWK_INFER_ORACLE') { run_infer_oracle(scope); }

    return CodegenResult {
        module: Module {
            functions: functions,
            types: scope.types,
            dispatch: scope.build_dispatch(),
            global_count: scope.next_global_slot,
        },
        errors: errors,
    };
}

// The reserved name of the program-init thunk the runtime runs once before the
// entry (see docs/module_init.md). Angle-bracketed so it can't collide with a
// user identifier. Must match the runtime's `interp::INIT_THUNK`.
const INIT_THUNK_NAME: String = '<init>';

// Register one module's declarations into the shared scope.
fn register_module(_ scope: ModuleScope, _ program: Program) -> Void {
    let file = program.file_path;
    for decl in program.decls {
        match decl {
            Fn(x) => {
                if x.is_native {
                    scope.add_native(x);
                } else {
                    scope.add_function(x, file);
                }
            },
            // A `native type` has no struct layout / runtime type-table entry — its
            // representation lives in the runtime. Methods come from `impl` blocks.
            Type(x) => { if !x.is_native { scope.add_struct(x, file); } },
            Enum(x) => { scope.add_enum(x, file); },
            Const(x) => { scope.add_const(x, file); },
            // Module-level `let`: a global slot computed once in the `<init>`
            // thunk (see docs/module_init.md).
            Let(x) => { scope.add_global(x, file); },
            Interface(x) => {
                scope.add_interface(x);
                // A default method (interface method with a body) compiles once
                // as a shared unit with `self` typed as the interface; each
                // implementing type that doesn't override it dispatches here
                // (wired by `wire_default_methods`).
                for method in x.methods {
                    if !method.is_native && has_self_param(method.params) && method.body.is_some() {
                        // An interface default keys the method table by the plain
                        // interface name (its key space is disjoint from concrete
                        // types' owner-qualified keys).
                        scope.add_method(x.name, x.name, method, file);
                    }
                }
            },
            Impl(x) => {
                // The receiver type owner-qualified as this file sees it, so a method
                // impl'd on a name two libraries share binds to this library's type.
                let owner = scope.owner_of(x.type_name, file);
                if let Some(iface) = x.interface_name { scope.add_interface_impl(owner, x.type_name, iface); }
                for method in x.methods {
                    let is_static = !has_self_param(method.params);
                    if method.is_native && is_static {
                        scope.add_native_static_method(x.type_name, method);
                    } else if method.is_native {
                        scope.add_native_instance_method(x.type_name, method);
                    } else {
                        if let Some(_) = method.body { scope.add_method(type_key(owner, x.type_name), x.type_name, method, file); }
                    }
                    if let Some(_) = x.interface_name {
                        if !is_static && !method.is_native {
                            scope.add_dispatch(owner, x.type_name, method.name);
                        }
                    }
                }
            },
            Import(x) => {},
        }
    }
}

// --- the per-function compiler ---

pub struct FnCompiler {
    scope: ModuleScope,
    code: List<Instr>,
    mut slots: Map<String, Int>,
    mut type_scope: Map<String, Type>,
    mut type_param_bounds: Map<String, List<String>>,
    consts_in_progress: Set<String>,
    boxed_locals: Set<String>,
    mut local_count: Int,
    mut param_count: Int,
    mut returns_result: Bool,
    labels: List<Option<Int>>,
    fixups: List<Fixup>,
    mut ctx: InferCtx,
    // The file this unit was declared in — the scope a bare free-function
    // reference resolves against (same-file-first).
    mut file: Option<String>,
    errors: List<CodegenError>,
}

pub fn new_fn_compiler(_ scope: ModuleScope, _ errors: List<CodegenError>) -> FnCompiler {
    return FnCompiler {
        scope: scope,
        code: [],
        slots: {},
        type_scope: {},
        type_param_bounds: {},
        consts_in_progress: Set.new(),
        boxed_locals: Set.new(),
        local_count: 0,
        param_count: 0,
        returns_result: false,
        labels: [],
        fixups: [],
        ctx: new_ctx(scope.library),
        file: Option.None,
        errors: errors,
    };
}

impl FnCompiler {
    // Compile the unit at `index` in the module scope.
    pub fn compile(self, _ index: Int) -> FuncDef {
        let fn_decl = self.scope.units[index];
        self.file = self.scope.unit_files[index];
        self.returns_result = type_ref_name(fn_decl.return_type) == Option.Some('Result');
        for tp in fn_decl.type_params {
            self.type_param_bounds[tp.name] = tp.bounds;
        }
        // A lifted lambda has no type params of its own, but inherits its
        // enclosing function's bounds (stashed at lift time) so a bound method on
        // a `T`-typed param resolves when the lambda is compiled as its own unit.
        if let Some(b) = self.scope.lambda_bounds.get(index) {
            for k in b.keys() {
                self.type_param_bounds[k] = b[k];
            }
        }

        // Build the inference context for this unit, matching the checker's: the
        // receiver type carries its parameters (`List<T>`, not bare `List`) and
        // those owner parameters join the in-scope type-parameter set, so codegen
        // and the checker infer every expression in the body to the same type.
        // (The unit table holds only the receiver's name; its parameters come from
        // the type definition.) The chosen `self_type` is recorded for the oracle.
        let self_type = self.scope.unit_self_types[index].map((name) => named_self_type(name, self.scope.library, self.scope.unit_files[index]));
        self.scope.unit_ctx_self[index] = self_type;
        let type_params: Set<String> = Set.new();
        if let Some(st) = self_type {
            for n in self_type_param_names(st) {
                type_params.add(n);
            }
        }
        for tp in fn_decl.type_params {
            type_params.add(tp.name);
        }
        let return_type = fn_decl.return_type.map((ref) => resolver.resolve_type_ref_in(ref, file_scope(self.scope.library, self.file), type_params, self_type));
        self.ctx = InferCtx {
            library: self.scope.library,
            type_params: type_params,
            self_type: self_type,
            return_type: return_type,
            type_param_bounds: self.type_param_bounds,
            current_file: self.file,
        };

        // Boxed cells: capture params arriving boxed, plus this function's own
        // `mut` locals that some lambda captures — both read/written through a cell.
        if let Some(bp) = self.scope.boxed_params.get(index) {
            for b in bp.to_list() {
                self.boxed_locals.add(b);
            }
        }
        if let Some(body) = fn_decl.body {
            for b in boxed_mut_locals(body).to_list() {
                self.boxed_locals.add(b);
            }
        }

        // Seed the type scope: a lifted lambda uses its stashed param types; a
        // normal function/method resolves its parameter annotations.
        let lambda_types = self.scope.lambda_param_types.get(index);
        for p in fn_decl.params {
            self.declare_local(p.name);
            self.param_count = self.param_count + 1;
            let pt = if p.is_self {
                self_type.unwrap_or(Type.Unknown)
            } else {
                match lambda_types {
                    Some(lt) => lt.get(p.name).unwrap_or(Type.Unknown),
                    None => resolver.resolve_opt_in(p.type_ann, file_scope(self.scope.library, self.file), type_params, self_type),
                }
            };
            self.type_scope[p.name] = pt;
        }

        if let Some(body) = fn_decl.body { self.block(body); }
        // Guarantee the stream ends with a return (a Void fall-through returns Unit).
        if self.code.len() == 0 || !self.ends_in_return() {
            self.emit(Instr.Simple(Op.ConstUnit));
            self.emit(Instr.Simple(Op.Return));
        }
        self.resolve_jumps();
        return FuncDef {
            name: self.scope.unit_names[index],
            param_count: self.param_count,
            local_count: self.local_count,
            code: self.code,
        };
    }

    // Synthesize the `<init>` thunk: evaluate each module-global initializer and
    // `global.set` its slot, in `global_inits` order, then return Unit. Each
    // initializer is compiled in its declaring file's scope (so its references
    // resolve same-file-first, like a normal unit). See docs/module_init.md.
    pub fn compile_init_thunk(self) -> FuncDef {
        for init in order_global_inits(self.scope, self.errors) {
            self.file = init.file;
            self.ctx.current_file = init.file;
            // Each initializer compiles in a fresh lexical scope — a binding from
            // one initializer's pattern/block must not leak into the next.
            self.slots = {};
            self.type_scope = {};
            let start = self.code.len();
            self.expr(init.value);
            self.reject_effectful_natives(start, init.span);
            self.emit(Instr.GlobalSet(init.slot));
        }
        self.emit(Instr.Simple(Op.ConstUnit));
        self.emit(Instr.Simple(Op.Return));
        self.resolve_jumps();
        return FuncDef {
            name: INIT_THUNK_NAME,
            param_count: 0,
            local_count: self.local_count,
            code: self.code,
        };
    }

    // Reject time-varying / I/O natives called directly in a module-`let`
    // initializer (scanning the code emitted since `start`). The result would be
    // a stale load-time snapshot; see docs/module_init.md. A lambda *value* in an
    // initializer is fine — its body is a separate unit, not run at load.
    fn reject_effectful_natives(self, _ start: Int, _ span: SourceSpan) -> Void {
        let mut i = start;
        while i < self.code.len() {
            if let CallNative(name, _) = self.code[i] {
                if forbidden_in_initializer(name) {
                    self.error('a module-level `let` initializer may not call '
                        + '`${name}` (time-varying or I/O); see docs/module_init.md', span);
                }
            }
            i = i + 1;
        }
    }

    // --- low-level emit / labels / slots ---

    fn emit(self, _ instr: Instr) -> Void {
        self.code.push(instr);
    }

    fn error(self, _ message: String, _ span: SourceSpan) -> Void {
        self.errors.push(CodegenError { message: message, span: span });
    }

    fn new_label(self) -> Int {
        self.labels.push(Option.None);
        return self.labels.len() - 1;
    }

    fn bind(self, _ label: Int) -> Void {
        self.labels[label] = Option.Some(self.code.len());
    }

    fn emit_jump(self, _ kind: Jk, _ label: Int) -> Void {
        self.fixups.push(Fixup { pos: self.code.len(), label: label, kind: kind });
        self.emit(Instr.Jump(0)); // placeholder, replaced during resolution
    }

    fn resolve_jumps(self) -> Void {
        for f in self.fixups {
            let target = self.labels[f.label].unwrap_or(0);
            self.code[f.pos] = match f.kind {
                Jump => Instr.Jump(target),
                IfTrue => Instr.JumpIfTrue(target),
                IfFalse => Instr.JumpIfFalse(target),
            };
        }
    }

    fn fresh_slot(self) -> Int {
        let s = self.local_count;
        self.local_count = self.local_count + 1;
        return s;
    }

    fn declare_local(self, _ name: String) -> Int {
        let slot = self.local_count;
        self.local_count = self.local_count + 1;
        self.slots[name] = slot;
        return slot;
    }

    fn enter_scope(self) -> SavedScope {
        let saved = SavedScope { slots: self.slots, types: self.type_scope };
        self.slots = copy_slots(self.slots);
        self.type_scope = copy_scope(self.type_scope);
        return saved;
    }

    fn exit_scope(self, _ saved: SavedScope) -> Void {
        self.slots = saved.slots;
        self.type_scope = saved.types;
    }

    // Emit a statement block in its own lexical scope.
    fn scoped_block(self, _ b: Block) -> Void {
        let saved = self.enter_scope();
        self.block(b);
        self.exit_scope(saved);
    }

    // Enter the top-level compile context of `file` — the scope a declaration
    // belonging to `file` compiles in when reached mid-unit (a const initializer
    // inlined at a use site): no locals, no type params, no self. Keeps
    // `self.file` and `ctx.current_file` in tandem.
    fn enter_file_context(self, _ file: Option<String>) -> FileContext {
        let saved = FileContext {
            file: self.file,
            ctx: self.ctx,
            slots: self.slots,
            types: self.type_scope,
            bounds: self.type_param_bounds,
        };
        self.file = file;
        let ctx = new_ctx(self.scope.library);
        ctx.current_file = file;
        self.ctx = ctx;
        self.slots = {};
        self.type_scope = {};
        self.type_param_bounds = {};
        return saved;
    }

    fn restore_file_context(self, _ saved: FileContext) -> Void {
        self.file = saved.file;
        self.ctx = saved.ctx;
        self.slots = saved.slots;
        self.type_scope = saved.types;
        self.type_param_bounds = saved.bounds;
    }

    fn ends_in_return(self) -> Bool {
        return match self.code[self.code.len() - 1] {
            Simple(op) => op == Op.Return,
            _ => false,
        };
    }

    fn is_namespace(self, _ name: String) -> Bool {
        return !self.slots.has(name) && self.scope.file_has_namespace(self.file, name);
    }

    // Push the value of local `name`; a boxed local holds a one-field cell.
    fn load_local_value(self, _ name: String, _ span: SourceSpan) -> Void {
        match self.slots.get(name) {
            Some(slot) => {
                self.emit(Instr.Load(slot));
                if self.boxed_locals.has(name) {
                    self.emit(Instr.FieldGet(0));
                }
            },
            None => {
                match self.scope.resolve_const_owner(self.file, name) {
                    Some(owner) => { self.emit_const(owner, name, span); },
                    None => {
                        match self.scope.resolve_global_owner(self.file, name) {
                            Some(owner) => { self.emit_global(owner, name); },
                            None => { self.error('not a local variable: ${name}', span); },
                        }
                    },
                }
            },
        }
    }

    // Load a module global (top-level `let`) by its owner-resolved slot.
    fn emit_global(self, _ owner: String, _ name: String) -> Void {
        if let Some(slot) = self.scope.global_in_file(owner, name) { self.emit(Instr.GlobalGet(slot)); }
    }

    // Inline the top-level constant `owner`/`name` by compiling its initializer
    // at the use site. The initializer is `owner`'s code, so it compiles in that
    // file's top-level context: a consumer local can't be captured, and the
    // initializer's own references (another const, a namespace) resolve against
    // its declaring file. Cycle detection keys by owner too, so two libraries'
    // same-named consts referencing each other aren't a false cycle.
    fn emit_const(self, _ owner: String, _ name: String, _ span: SourceSpan) -> Void {
        let key = type_key(owner, name);
        if self.consts_in_progress.has(key) {
            self.error('cyclic constant: ${name}', span);
            return;
        }
        self.consts_in_progress.add(key);
        if let Some(e) = self.scope.const_in_file(owner, name) {
            let saved = self.enter_file_context(file_of_key(owner));
            self.expr(e);
            self.restore_file_context(saved);
        }
        self.consts_in_progress.remove(key);
    }

    // The static type *name* of an expression, for opcode/dispatch selection.
    // None for Unit and anything without a usable concrete name.
    fn type_of(self, _ e: Expr) -> Option<String> {
        return name_of_type(infer_expr(e, self.type_scope, self.ctx, Option.None));
    }

    // The owner-qualified identity of `e`'s inferred type, when it names a
    // struct/enum — so a field/variant/method lookup keys the codegen type table
    // by the type's *owner*, not its bare name (Phase 1 T3).
    fn type_id_of(self, _ e: Expr) -> Option<TypeId> {
        return type_id_of_type(infer_expr(e, self.type_scope, self.ctx, Option.None));
    }

    // --- statements ---

    fn block(self, _ block: Block) -> Void {
        for p in block.stmts.enumerate() {
            self.stmt(p.value, block.stmts, p.index);
        }
    }

    fn stmt(self, _ stmt: Stmt, _ stmts: List<Stmt>, _ index: Int) -> Void {
        match stmt {
            Let(x) => {
                // Evaluate before declaring, so the initializer can't see the
                // not-yet-bound name. A captured `mut` local is boxed.
                let annotated = x.type_ann.map((ref) => resolver.resolve_type_ref_in(ref, file_scope(self.scope.library, self.file), self.ctx.type_params, self.ctx.self_type));
                self.expr_expecting(x.value, annotated);
                // An explicit annotation is the binding's type (matching the
                // inference engine); fall back to the initializer's inferred type.
                let ty = annotated.unwrap_or_else(() => refine_binding_type(x.name,
                    infer_expr(x.value, self.type_scope, self.ctx, Option.None),
                    stmts, index + 1, self.type_scope, self.ctx));
                if self.boxed_locals.has(x.name) {
                    self.emit(Instr.StructNew(self.scope.cell_type_index()));
                }
                let slot = self.declare_local(x.name);
                self.type_scope[x.name] = ty;
                self.emit(Instr.Store(slot));
            },
            Assign(span, target, value) => {
                self.assign(target, value, span);
            },
            If(x) => {
                self.expr(x.condition);
                match x.else_block {
                    None => {
                        let end = self.new_label();
                        self.emit_jump(Jk.IfFalse, end);
                        self.scoped_block(x.then_block);
                        self.bind(end);
                    },
                    Some(eb) => {
                        let else_label = self.new_label();
                        let end = self.new_label();
                        self.emit_jump(Jk.IfFalse, else_label);
                        self.scoped_block(x.then_block);
                        self.emit_jump(Jk.Jump, end);
                        self.bind(else_label);
                        self.scoped_block(eb);
                        self.bind(end);
                    },
                }
            },
            While(x) => {
                let start = self.new_label();
                let end = self.new_label();
                self.bind(start);
                self.expr(x.condition);
                self.emit_jump(Jk.IfFalse, end);
                self.scoped_block(x.body);
                self.emit_jump(Jk.Jump, start);
                self.bind(end);
            },
            For(x) => {
                // The loop variable and body bindings are scoped to the loop.
                let saved = self.enter_scope();
                self.for_stmt(x.pattern, x.iterable, x.body);
                self.exit_scope(saved);
            },
            Return(_, value) => {
                self.emit_return(value);
            },
            Throw(_, value) => {
                self.emit_throw(value);
            },
            Expr(_, e) => {
                // The result of an expression statement is discarded.
                self.expr(e);
                self.emit(Instr.Simple(Op.Pop));
            },
        }
    }

    fn assign(self, _ target: Expr, _ value: Expr, _ span: SourceSpan) -> Void {
        match target {
            Ident(_, name) => {
                match self.slots.get(name) {
                    Some(slot) => {
                        if self.boxed_locals.has(name) {
                            // Write into the cell, not the slot.
                            self.emit(Instr.Load(slot));
                            self.expr(value);
                            self.emit(Instr.FieldSet(0));
                        } else {
                            self.expr(value);
                            self.emit(Instr.Store(slot));
                        }
                    },
                    None => { self.error('assignment to unknown local: ${name}', span); },
                }
            },
            Field(_, object, field) => {
                if let Some(info) = self.struct_of(object, span) {
                    self.expr(object);
                    self.expr(value);
                    self.emit(Instr.FieldSet(self.field_index(info, field, span)));
                }
            },
            Index(_, object, index) => {
                self.expr(object);
                self.expr(index);
                self.expr(value);
                match self.type_of(object) {
                    Some(t) => {
                        if t == 'List' {
                            self.emit(Instr.Simple(Op.ListSet));
                        } else if t == 'Map' {
                            self.emit(Instr.CallNative('map_set', 3));
                            self.emit(Instr.Simple(Op.Pop));
                        } else {
                            self.error('indexed assignment on ${t} is not supported', span);
                        }
                    },
                    None => { self.error('indexed assignment on unknown type', span); },
                }
            },
            _ => { self.error('unsupported assignment target', span); },
        }
    }

    // Emit a `return`, applying implicit `Ok` wrapping when the function returns
    // `Result` and the value isn't already a `Result`.
    fn emit_return(self, _ value: Option<Expr>) -> Void {
        match value {
            None => { self.emit(Instr.Simple(Op.ConstUnit)); },
            Some(v) => {
                self.expr_expecting(v, self.ctx.return_type);
                if self.returns_result && self.type_of(v) != Option.Some('Result') {
                    self.emit(Instr.EnumNew(TY_RESULT, TAG_OK, 1));
                }
            },
        }
        self.emit(Instr.Simple(Op.Return));
    }

    // `throw e` is sugar for `return Err(e)` in a `Result`-returning function.
    fn emit_throw(self, _ value: Expr) -> Void {
        self.expr(value);
        self.emit(Instr.EnumNew(TY_RESULT, TAG_ERR, 1));
        self.emit(Instr.Simple(Op.Return));
    }

    fn for_stmt(self, _ pattern: Pattern, _ iterable: Expr, _ body: Block) -> Void {
        let var_name = match pattern {
            Ident(_, name) => Option.Some(name),
            Wildcard(_) => Option.None,
            _ => {
                self.error('unsupported for-loop pattern', expr_span(iterable));
                Option.None
            },
        };
        match iterable {
            Range(_, _, _) => { self.range_for(var_name, iterable, body); },
            _ => {
                match self.type_of(iterable) {
                    Some(t) => {
                        if t == 'List' {
                            self.list_for(var_name, iterable, body);
                        } else if self.is_iterator(iterable) {
                            self.iterator_for(var_name, iterable, body);
                        } else {
                            self.error('cannot iterate ${t} (only ranges, lists, and Iterators are supported)', expr_span(iterable));
                        }
                    },
                    None => { self.error('cannot iterate this value', expr_span(iterable)); },
                }
            },
        }
    }

    fn is_iterator(self, _ e: Expr) -> Bool {
        match self.type_id_of(e) {
            Some(id) => {
                if id.name == 'Iterator' {
                    return true;
                }
                return match self.scope.interface_impls.get(type_key(id.owner, id.name)) {
                    Some(info) => info.interfaces.has('Iterator'),
                    None => false,
                };
            },
            None => { return false; },
        }
    }

    // Bind a for-loop variable into the type scope (the element type), parallel
    // to its slot. Reuses inference's element-typing.
    fn bind_loop_var(self, _ var_name: Option<String>, _ iter: Expr) -> Int {
        let iter_type = infer_expr(iter, self.type_scope, self.ctx, Option.None);
        let element = for_element_type(iter_type, self.ctx);
        return match var_name {
            Some(name) => {
                self.type_scope[name] = element;
                self.declare_local(name)
            },
            None => self.fresh_slot(),
        };
    }

    fn range_for(self, _ var_name: Option<String>, _ range: Expr, _ body: Block) -> Void {
        if let Range(_, start_e, end_e) = range {
            self.expr(start_e);
            let counter = match var_name {
                Some(name) => {
                    self.type_scope[name] = Type.Primitive(Primitive.Int);
                    self.declare_local(name)
                },
                None => self.fresh_slot(),
            };
            self.emit(Instr.Store(counter));
            self.expr(end_e);
            let limit = self.fresh_slot();
            self.emit(Instr.Store(limit));

            let start = self.new_label();
            let end = self.new_label();
            self.bind(start);
            self.emit(Instr.Load(counter));
            self.emit(Instr.Load(limit));
            self.emit(Instr.Simple(Op.LtI64));
            self.emit_jump(Jk.IfFalse, end);
            self.block(body);
            self.emit(Instr.Load(counter));
            self.emit(Instr.ConstInt(1));
            self.emit(Instr.Simple(Op.AddI64));
            self.emit(Instr.Store(counter));
            self.emit_jump(Jk.Jump, start);
            self.bind(end);
        }
    }

    fn list_for(self, _ var_name: Option<String>, _ list_expr: Expr, _ body: Block) -> Void {
        self.expr(list_expr);
        let list = self.fresh_slot();
        self.emit(Instr.Store(list));
        let i = self.fresh_slot();
        self.emit(Instr.ConstInt(0));
        self.emit(Instr.Store(i));

        let start = self.new_label();
        let end = self.new_label();
        self.bind(start);
        self.emit(Instr.Load(i));
        self.emit(Instr.Load(list));
        self.emit(Instr.Simple(Op.ListLen));
        self.emit(Instr.Simple(Op.LtI64));
        self.emit_jump(Jk.IfFalse, end);
        let elem = self.bind_loop_var(var_name, list_expr);
        self.emit(Instr.Load(list));
        self.emit(Instr.Load(i));
        self.emit(Instr.Simple(Op.ListGet));
        self.emit(Instr.Store(elem));
        self.block(body);
        self.emit(Instr.Load(i));
        self.emit(Instr.ConstInt(1));
        self.emit(Instr.Simple(Op.AddI64));
        self.emit(Instr.Store(i));
        self.emit_jump(Jk.Jump, start);
        self.bind(end);
    }

    fn iterator_for(self, _ var_name: Option<String>, _ iter_expr: Expr, _ body: Block) -> Void {
        self.expr(iter_expr);
        let it = self.fresh_slot();
        self.emit(Instr.Store(it));

        let start = self.new_label();
        let end = self.new_label();
        self.bind(start);
        self.emit(Instr.Load(it));
        self.emit(Instr.CallVirtual('next', 1)); // Option<T> on the stack
        let opt = self.fresh_slot();
        self.emit(Instr.Store(opt));
        self.emit(Instr.Load(opt));
        self.emit(Instr.Simple(Op.EnumTag));
        self.emit(Instr.ConstInt(TAG_NONE));
        self.emit(Instr.Simple(Op.EqI64));
        self.emit_jump(Jk.IfTrue, end); // None: exhausted
        let elem = self.bind_loop_var(var_name, iter_expr);
        self.emit(Instr.Load(opt));
        self.emit(Instr.EnumGet(0));
        self.emit(Instr.Store(elem));
        self.block(body);
        self.emit_jump(Jk.Jump, start);
        self.bind(end);
    }

    // --- expressions ---

    // Emit an expression, discarding any contextual `expected` type. Most
    // positions use this; the few that carry a known expected (a `let` value, a
    // `return` value, a struct-field value, a call argument) use `expr_expecting`
    // so a lambda there can type its un-annotated parameters bidirectionally.
    fn expr(self, _ e: Expr) -> Void {
        self.expr_expecting(e, Option.None);
    }

    fn expr_expecting(self, _ e: Expr, _ expected: Option<Type>) -> Void {
        match e {
            Int(_, v) => { self.emit(Instr.ConstInt(v)); },
            Float(_, v) => { self.emit(Instr.ConstDouble(v)); },
            Bool(_, v) => { self.emit(Instr.ConstBool(v)); },
            Unit(_) => { self.emit(Instr.Simple(Op.ConstUnit)); },
            Str(_, _) => { self.string_expr(e); },
            Ident(span, name) => { self.load_local_value(name, span); },
            Unary(span, op, operand) => { self.unary_expr(op, operand, span); },
            Binary(span, left, op, right) => { self.binary_expr(left, op, right, span); },
            ListLit(_, items) => {
                for item in items {
                    self.expr(item);
                }
                self.emit(Instr.ListNew(items.len()));
            },
            MapLit(_, entries) => {
                for entry in entries {
                    self.expr(entry.key);
                    self.expr(entry.value);
                }
                self.emit(Instr.CallNative('map_new', entries.len() * 2));
            },
            Index(span, object, index) => {
                self.expr(object);
                self.expr(index);
                self.emit_index_get(object, span);
            },
            Field(span, object, field) => { self.field_expr(object, field, span); },
            Struct(x) => { self.struct_expr(x); },
            Call(x) => { self.call_expr(x); },
            Propagate(_, inner) => { self.propagate_expr(inner); },
            Match(x) => { self.match_expr(x); },
            Block(_, block) => { self.emit_block_value(block); },
            If(x) => { self.if_expr(x.condition, x.then_block, x.else_block); },
            Return(_, value) => { self.emit_return(value); },
            Throw(_, value) => { self.emit_throw(value); },
            Lambda(x) => { self.lambda_expr(x, expected); },
            Range(span, _, _) => { self.error('a range is only valid as a for-loop iterable', span); },
            Loc(span) => { self.emit_source_loc(span); },
        }
    }

    // Lower the `#loc` metaconstant to a `SourceLoc { file, line, column }` value.
    // `span` is the location to report: for a `#loc` written directly, its own
    // site; for one materialized from a default parameter, the call site (the span
    // `resolve_args` stamps in). The file is the unit currently being compiled —
    // which, for a default expanded at a call, is the *caller's* file.
    fn emit_source_loc(self, _ span: SourceSpan) -> Void {
        let file = self.file.unwrap_or('');
        let fields: List<FieldInit> = [
            FieldInit { name: 'file', value: Expr.Str(span, [StringPart.Text(span, file)]) },
            FieldInit { name: 'line', value: Expr.Int(span, span.line) },
            FieldInit { name: 'column', value: Expr.Int(span, span.column) },
        ];
        self.struct_expr(StructExpr {
            span: span,
            type_name: 'SourceLoc',
            namespace: Option.None,
            fields: fields,
        });
    }

    // Emit a block in value position: statements for effect, then the tail value
    // (or Unit when there's no tail). Leaves exactly one value. The tail is part
    // of the block's scope (it sees the block's bindings), so the scope spans both.
    fn emit_block_value(self, _ block: Block) -> Void {
        let saved = self.enter_scope();
        self.block(block);
        match block.tail {
            Some(tail) => { self.expr(tail); },
            None => { self.emit(Instr.Simple(Op.ConstUnit)); },
        }
        self.exit_scope(saved);
    }

    fn if_expr(self, _ condition: Expr, _ then_block: Block, _ else_block: Option<Block>) -> Void {
        self.expr(condition);
        let else_label = self.new_label();
        let end = self.new_label();
        self.emit_jump(Jk.IfFalse, else_label);
        self.emit_block_value(then_block);
        self.emit_jump(Jk.Jump, end);
        self.bind(else_label);
        match else_block {
            Some(eb) => { self.emit_block_value(eb); },
            None => { self.emit(Instr.Simple(Op.ConstUnit)); },
        }
        self.bind(end);
    }

    // `expr?` — propagate Err/None. The failing tag is 1 for each and the
    // payload to unwrap is field 0, so one lowering serves Result and Option.
    fn propagate_expr(self, _ inner: Expr) -> Void {
        self.expr(inner);
        self.emit(Instr.Simple(Op.Dup));
        self.emit(Instr.Simple(Op.EnumTag));
        self.emit(Instr.ConstInt(TAG_ERR));
        self.emit(Instr.Simple(Op.EqI64));
        let ok = self.new_label();
        self.emit_jump(Jk.IfFalse, ok);
        self.emit(Instr.Simple(Op.Return)); // failing: return the value as-is
        self.bind(ok);
        self.emit(Instr.EnumGet(0)); // success: unwrap the payload
    }

    // --- lambdas / closures ---

    // A lambda: lift its body to a synthetic top-level function whose leading
    // parameters are its captured variables, push the captured values, and build
    // a closure value `{ func, captures }`. `expected` lets an un-annotated
    // parameter take its type from the surrounding function type.
    fn lambda_expr(self, _ x: LambdaExpr, _ expected: Option<Type>) -> Void {
        // Free variables that name an enclosing local are the captures;
        // references to functions/types/namespaces resolve the same way in the
        // lifted unit and need no capture.
        let captures: List<String> = [];
        for name in free_variables(x) {
            if self.slots.has(name) {
                captures.push(name);
            }
        }
        let boxed_captures: Set<String> = Set.new();
        for name in captures {
            if self.boxed_locals.has(name) {
                boxed_captures.add(name);
            }
        }

        // The lifted unit's parameter types (captures + lambda params), stashed
        // so its body can be inferred when compiled as its own unit. The lambda's
        // own param types come from its full inferred function type (annotation
        // or the expected function type); captures keep their enclosing types.
        let param_types = match infer_expr(Expr.Lambda(x), self.type_scope, self.ctx, expected) {
            Function(ps, _) => ps,
            _ => [],
        };
        let stash: Map<String, Type> = {};
        for c in captures {
            stash[c] = self.type_scope.get(c).unwrap_or(Type.Unknown);
        }
        for p in x.params.enumerate() {
            let pt = if p.index < param_types.len() {
                param_types[p.index]
            } else {
                Type.Unknown
            };
            stash[p.value.name] = pt;
        }

        let lifted = lift_lambda(x, captures);
        // The lifted unit resolves bare names in the enclosing unit's file, and
        // inherits the enclosing function's type-parameter bounds so a bound
        // method on a `T`-typed param still resolves inside the lambda.
        let index = self.scope.add_lambda(lifted, boxed_captures, stash,
            self.type_param_bounds, self.file);
        // Push the captured values (in capture order), then bundle the closure. A
        // boxed capture pushes the cell itself (Load, no field.get) so it's shared.
        for name in captures {
            self.emit(Instr.Load(self.slots[name]));
        }
        self.emit(Instr.ClosureNew(index, captures.len()));
    }

    // --- match ---

    // `match` on an enum (Result/Option or a user enum): store the subject, then
    // a tag-check chain. The final arm is the fall-through (matches always, given
    // exhaustiveness). A large enum match dispatches on a hoisted tag (computed
    // once) via a balanced binary search instead of the linear chain.
    fn match_expr(self, _ e: MatchExpr) -> Void {
        let subject_ty = infer_expr(e.subject, self.type_scope, self.ctx, Option.None);
        // Owner-qualified: enum dispatch resolves the codegen type table by the
        // subject's owning library, not its bare name (T3).
        let subject_type = type_id_of_type(subject_ty);
        self.expr(e.subject);
        let subject = self.fresh_slot();
        self.emit(Instr.Store(subject));
        let end = self.new_label();

        let is_enum = match subject_type {
            Some(t) => self.scope.resolve_enum(t.owner, t.name).is_some(),
            None => false,
        };
        let dispatch = if is_enum {
            self.plan_dispatch(e, subject_type)
        } else {
            Option.None
        };

        // Hoist the subject's tag into a slot when a dispatch plan exists or the
        // linear chain would emit enough top-level tag tests to pay for it.
        let has_dispatch = match dispatch {
            Some(_) => true,
            None => false,
        };
        let tag_slot = if is_enum && (has_dispatch || top_level_tag_tests(e) >= MATCH_DISPATCH_MIN_CASES) {
            self.emit(Instr.Load(subject));
            self.emit(Instr.Simple(Op.EnumTag));
            let ts = self.fresh_slot();
            self.emit(Instr.Store(ts));
            Option.Some(ts)
        } else {
            Option.None
        };

        if let Some(plan) = dispatch {
            self.emit_dispatch(plan, subject, subject_ty, subject_type, tag_slot.unwrap_or(0), end);
            self.bind(end);
            return;
        }

        let mut i = 0;
        let mut going = true;
        while going && i < e.arms.len() {
            let arm = e.arms[i];
            let is_last = i == e.arms.len() - 1;
            // An arm's pattern bindings are scoped to its body.
            let saved = self.enter_scope();
            // Bind the arm's pattern variables' *types* (parallel to emit_pattern's
            // slots), so the arm body can be inferred for opcode selection.
            bind_match_pattern(arm.pattern, subject_ty, self.type_scope, self.ctx);

            // An irrefutable pattern (or the final arm — arms are exhaustive) is
            // taken to match: emit its bindings, run the body, and stop (later
            // arms are unreachable).
            if is_last || is_irrefutable(arm.pattern) {
                self.emit_pattern(arm.pattern, subject, subject_type, Option.None, Option.None);
                self.arm_body(arm.body, end, false);
                going = false;
            } else {
                let next = self.new_label();
                self.emit_pattern(arm.pattern, subject, subject_type, Option.Some(next), tag_slot);
                self.arm_body(arm.body, end, true);
                self.bind(next);
                i = i + 1;
            }
            self.exit_scope(saved);
        }
        self.bind(end);
    }

    // Plan a binary-search dispatch over enum `enum_type`, or None when it
    // doesn't qualify: too few cases, a non-flat / refutable sub-pattern, a
    // literal/irrefutable mid-arm, or a duplicate or unknown tag. Every non-final
    // arm must be a constructor whose arguments are all irrefutable, so the tag
    // alone decides the arm. The final arm is the catch-all default.
    fn plan_dispatch(self, _ e: MatchExpr, _ enum_type: Option<TypeId>) -> Option<DispatchPlan> {
        let info = match enum_type {
            Some(t) => self.scope.resolve_enum(t.owner, t.name),
            None => Option.None,
        };
        if let Some(ei) = info {
            if e.arms.len() - 1 < MATCH_DISPATCH_MIN_CASES {
                return Option.None;
            }
            let cases: Map<Int, MatchArm> = {};
            let mut i = 0;
            let mut ok = true;
            while ok && i < e.arms.len() - 1 {
                match e.arms[i].pattern {
                    Constructor(_, name, args) => {
                        if !all_irrefutable_args(args) {
                            ok = false; // a nested refutable sub-pattern needs the chain
                        } else {
                            let tag = tag_of(ei, name);
                            if tag < 0 || cases.has(tag) {
                                ok = false; // unknown / duplicate
                            } else {
                                cases[tag] = e.arms[i];
                            }
                        }
                    },
                    _ => { ok = false; }, // literal / wildcard mid-match
                }
                i = i + 1;
            }
            if !ok {
                return Option.None;
            }
            return Option.Some(DispatchPlan {
                cases: cases,
                default_arm: e.arms[e.arms.len() - 1],
            });
        }
        return Option.None;
    }

    // Emit a balanced binary search over the (distinct, sorted) case tags, with
    // every miss routed to a single shared default.
    fn emit_dispatch(self, _ plan: DispatchPlan, _ subject: Int, _ subject_ty: Type,
        _ subject_type: Option<TypeId>, _ tag_slot: Int, _ end: Int) -> Void {
        let tags = sorted_keys(plan.cases);
        let default_label = self.new_label();
        self.emit_bisect(0, tags.len() - 1, tags, plan.cases, default_label,
            subject, subject_ty, subject_type, tag_slot, end);
        self.bind(default_label);
        self.emit_leaf(plan.default_arm, subject, subject_ty, subject_type, end, false);
    }

    fn emit_bisect(self, _ lo: Int, _ hi: Int, _ tags: List<Int>, _ cases: Map<Int, MatchArm>,
        _ default_label: Int, _ subject: Int, _ subject_ty: Type, _ subject_type: Option<TypeId>,
        _ tag_slot: Int, _ end: Int) -> Void {
        let mid = (lo + hi) / 2;
        let t = tags[mid];
        let has_left = lo <= mid - 1;
        let has_right = mid + 1 <= hi;
        if !has_left && !has_right {
            self.emit(Instr.Load(tag_slot));
            self.emit(Instr.ConstInt(t));
            self.emit(Instr.Simple(Op.EqI64));
            self.emit_jump(Jk.IfFalse, default_label);
            self.emit_leaf(get_case(cases, t), subject, subject_ty, subject_type, end, true);
            return;
        }
        // Absent subranges route their branch straight to the default.
        let left_target = if has_left { self.new_label() } else { default_label };
        let right_target = if has_right { self.new_label() } else { default_label };
        self.emit(Instr.Load(tag_slot));
        self.emit(Instr.ConstInt(t));
        self.emit(Instr.Simple(Op.LtI64));
        self.emit_jump(Jk.IfTrue, left_target);
        self.emit(Instr.Load(tag_slot));
        self.emit(Instr.ConstInt(t));
        self.emit(Instr.Simple(Op.GtI64));
        self.emit_jump(Jk.IfTrue, right_target);
        self.emit_leaf(get_case(cases, t), subject, subject_ty, subject_type, end, true); // equal
        if has_left {
            self.bind(left_target);
            self.emit_bisect(lo, mid - 1, tags, cases, default_label,
                subject, subject_ty, subject_type, tag_slot, end);
        }
        if has_right {
            self.bind(right_target);
            self.emit_bisect(mid + 1, hi, tags, cases, default_label,
                subject, subject_ty, subject_type, tag_slot, end);
        }
    }

    // The tag is already known at a leaf, so only bind fields (fail = None), then
    // run the body. The pattern's bindings are scoped to the arm.
    fn emit_leaf(self, _ arm: MatchArm, _ subject: Int, _ subject_ty: Type,
        _ subject_type: Option<TypeId>, _ end: Int, _ jump_to_end: Bool) -> Void {
        let saved = self.enter_scope();
        bind_match_pattern(arm.pattern, subject_ty, self.type_scope, self.ctx);
        self.emit_pattern(arm.pattern, subject, subject_type, Option.None, Option.None);
        self.arm_body(arm.body, end, jump_to_end);
        self.exit_scope(saved);
    }

    // Match `pattern` against the value in `value_slot` (whose enum type name,
    // when known, is `value_type`) and bind the variables it introduces. When
    // `fail` is set, any mismatch jumps there; when None the pattern is taken to
    // match (only bindings are emitted). `tag_slot`, when set, holds a precomputed
    // `enum.tag` reused at this level instead of recomputing.
    fn emit_pattern(self, _ pattern: Pattern, _ value_slot: Int, _ value_type: Option<TypeId>,
        _ fail: Option<Int>, _ tag_slot: Option<Int>) -> Void {
        match pattern {
            Wildcard(_) => {}, // matches anything, binds nothing
            Ident(_, name) => { self.slots[name] = value_slot; }, // bind the whole value
            Literal(_, literal) => {
                if let Some(f) = fail {
                    self.emit(Instr.Load(value_slot));
                    self.expr(literal);
                    self.emit(Instr.CallNative('eq', 2)); // structural equality
                    self.emit_jump(Jk.IfFalse, f);
                }
            },
            Constructor(span, name, args) => {
                let info = match value_type {
                    Some(t) => self.scope.resolve_enum(t.owner, t.name),
                    None => Option.None,
                };
                let tag = match info {
                    Some(ei) => tag_of(ei, name),
                    None => -1,
                };
                if let Some(f) = fail {
                    match tag_slot {
                        Some(ts) => { self.emit(Instr.Load(ts)); }, // reuse the hoisted tag
                        None => {
                            self.emit(Instr.Load(value_slot));
                            self.emit(Instr.Simple(Op.EnumTag));
                        },
                    }
                    self.emit(Instr.ConstInt(self.variant_tag(value_type, name, span)));
                    self.emit(Instr.Simple(Op.EqI64));
                    self.emit_jump(Jk.IfFalse, f);
                }
                for p in args.enumerate() {
                    let arg = p.value;
                    match arg {
                        Wildcard(_) => {}, // field ignored; skip extraction
                        _ => {
                            let field_slot = self.fresh_slot();
                            self.emit(Instr.Load(value_slot));
                            self.emit(Instr.EnumGet(p.index));
                            self.emit(Instr.Store(field_slot));
                            self.emit_pattern(arg, field_slot, enum_field_type_id(self.scope, info, tag, p.index), fail, Option.None);
                        },
                    }
                }
            },
        }
    }

    // A match arm body either yields a value (and jumps to the merge point) or
    // transfers control out of the function (return/throw).
    fn arm_body(self, _ body: Expr, _ end: Int, _ jump_to_end: Bool) -> Void {
        match body {
            Return(_, value) => { self.emit_return(value); },
            Throw(_, value) => { self.emit_throw(value); },
            _ => {
                self.expr(body);
                if jump_to_end {
                    self.emit_jump(Jk.Jump, end);
                }
            },
        }
    }

    // The variant tag for a constructor `name` within enum `enum_type`.
    fn variant_tag(self, _ enum_type: Option<TypeId>, _ name: String, _ span: SourceSpan) -> Int {
        let tag = match enum_type {
            Some(t) => match self.scope.resolve_enum(t.owner, t.name) {
                Some(ei) => tag_of(ei, name),
                None => -1,
            },
            None => -1,
        };
        if tag >= 0 {
            return tag;
        }
        self.error('unknown variant `${name}`', span);
        return 0;
    }

    fn unary_expr(self, _ op: String, _ operand: Expr, _ span: SourceSpan) -> Void {
        self.expr(operand);
        if op == '-' {
            self.emit(Instr.Simple(if self.is_double(operand) { Op.NegF64 } else { Op.NegI64 }));
        } else if op == '!' {
            self.emit(Instr.Simple(Op.Not));
        } else if op == '~' {
            self.emit(Instr.Simple(Op.BnotI64));
        } else {
            self.error('unsupported unary operator: ${op}', span);
        }
    }

    fn binary_expr(self, _ left: Expr, _ op: String, _ right: Expr, _ span: SourceSpan) -> Void {
        if op == '&&' || op == '||' {
            self.logical_expr(left, op, right);
            return;
        }
        let operand_type = self.type_of(left);
        let is_primitive = operand_type == Option.Some('Int')
            || operand_type == Option.Some('Double')
            || operand_type == Option.Some('Bool');

        // `==`/`!=`: an explicit `impl Eq`, else dynamic dispatch, else the
        // structural `eq` native (non-primitives, and Bool — which has no typed
        // equality opcode) or a typed opcode (Int/Double).
        if op == '==' || op == '!=' {
            if self.dispatches_via(operand_type, 'eq') {
                self.expr(left);
                self.expr(right);
                self.emit(Instr.CallVirtual('eq', 2));
                if op == '!=' {
                    self.emit(Instr.Simple(Op.Not));
                }
                return;
            }
            if let Some(eq_idx) = self.interface_method(self.type_id_of(left), 'Eq', 'eq') {
                self.expr(left);
                self.expr(right);
                self.emit(Instr.Call(eq_idx, 2));
                if op == '!=' {
                    self.emit(Instr.Simple(Op.Not));
                }
                return;
            }
            // Non-primitives use the structural `eq` native; so does Bool, which
            // the runtime keeps distinct from Int (the `eqI64` opcode rejects it).
            if !is_primitive || operand_type == Option.Some('Bool') {
                self.expr(left);
                self.expr(right);
                self.emit(Instr.CallNative('eq', 2));
                if op == '!=' {
                    self.emit(Instr.Simple(Op.Not));
                }
                return;
            }
        }

        // String concatenation via the `str_concat` native.
        if op == '+' && operand_type == Option.Some('String') {
            self.expr(left);
            self.expr(right);
            self.emit(Instr.CallNative('str_concat', 2));
            return;
        }

        if !is_primitive {
            self.error('operator `${op}` on ${operand_type.unwrap_or('unknown type')} not yet supported', span);
            return;
        }
        let is_double = operand_type == Option.Some('Double');

        self.expr(left);
        self.expr(right);
        if is_arithmetic(op) {
            if op == '%' && is_double {
                self.error('`%` is not defined for Double', span);
            } else {
                self.emit(Instr.Simple(arith_op(op, is_double)));
            }
        } else if is_comparison_op(op) {
            self.emit(Instr.Simple(cmp_op(op, is_double)));
        } else if is_bitwise(op) {
            if is_double {
                self.error('bitwise operator `${op}` requires Int operands', span);
            } else {
                self.emit(Instr.Simple(bitwise_op(op)));
            }
        } else {
            self.error('unsupported operator: ${op}', span);
        }
    }

    // `&&` / `||` short-circuit via branches (no and/or opcode).
    fn logical_expr(self, _ left: Expr, _ op: String, _ right: Expr) -> Void {
        let is_and = op == '&&';
        let short_circuit = self.new_label();
        let end = self.new_label();
        self.expr(left);
        self.emit_jump(if is_and { Jk.IfFalse } else { Jk.IfTrue }, short_circuit);
        self.expr(right);
        self.emit_jump(Jk.Jump, end);
        self.bind(short_circuit);
        self.emit(Instr.ConstBool(!is_and)); // && → false, || → true
        self.bind(end);
    }

    fn is_double(self, _ e: Expr) -> Bool {
        return self.type_of(e) == Option.Some('Double');
    }

    // --- strings ---

    fn string_expr(self, _ e: Expr) -> Void {
        if let Str(span, parts) = e {
            if parts.len() == 0 {
                self.emit(Instr.ConstStr(''));
                return;
            }
            self.string_piece(parts[0], span);
            let mut i = 1;
            while i < parts.len() {
                self.string_piece(parts[i], span);
                self.emit(Instr.CallNative('str_concat', 2));
                i = i + 1;
            }
        }
    }

    fn string_piece(self, _ part: StringPart, _ span: SourceSpan) -> Void {
        match part {
            Text(_, text) => { self.emit(Instr.ConstStr(text)); },
            Interp(_, e) => { self.emit_as_string(e, span); },
        }
    }

    // Evaluate `value` and leave its `String` rendering on the stack: a value
    // already typed `String` needs no conversion; otherwise it is rendered through
    // its `Display.display` method. The shared lowering behind both interpolation
    // and `println`/`print`/`eprintln`/`eprint`.
    fn emit_as_string(self, _ value: Expr, _ span: SourceSpan) -> Void {
        let ty_name = self.type_of(value);
        let ty_id = self.type_id_of(value);
        self.expr(value);
        if ty_name != Option.Some('String') {
            self.emit_display(ty_name, ty_id, span);
        }
    }

    // Render the value on top of the stack to a `String` via its `Display.display`
    // method, resolved like any method call: a native instance method (the
    // primitives' `display` → their per-type native, e.g. `int_to_string`), a
    // virtual dispatch (an interface-typed or bounded-generic value), or a concrete
    // impl method. Errors when the type has no `Display`.
    fn emit_display(self, _ ty_name: Option<String>, _ ty_id: Option<TypeId>, _ span: SourceSpan) -> Void {
        if let Some(symbol) = self.native_instance_method_symbol(ty_name, 'display') { self.emit(Instr.CallNative(symbol, 1)); return; }
        if self.dispatches_via(ty_name, 'display') {
            self.emit(Instr.CallVirtual('display', 1));
            return;
        }
        match self.interface_method(ty_id, 'Display', 'display') {
            Some(display_idx) => { self.emit(Instr.Call(display_idx, 1)); },
            None => {
                // Total rendering: no static `Display` impl, so dispatch `display`
                // virtually. The runtime renders via the type's `Display` if it has
                // one, else its auto-derived `Debug` (Debug-fallback) — so this works
                // for any value, including an unbounded type parameter.
                self.emit(Instr.CallVirtual('display', 1));
            },
        }
    }

    // The runtime native symbol backing `ty_name`'s native instance `method`, if it
    // has one (e.g. the primitives' `display` → `int_to_string`); None otherwise.
    fn native_instance_method_symbol(self, _ ty_name: Option<String>, _ method: String) -> Option<String> {
        if let Some(t) = ty_name { if let Some(m) = self.scope.native_instance_methods.get(t) { return m.get(method); } }
        return Option.None;
    }

    // --- structs / fields / indexing ---

    fn struct_expr(self, _ x: StructExpr) -> Void {
        // Owner-correct (Phase 1 T4): resolve the constructed type's owner from this
        // file's scope, honoring a `ns.Point` qualifier, so two libraries' same-named
        // structs get their own layout and field defaults.
        let fs = file_scope(self.scope.library, self.file);
        let owner = fs.resolve_type_owner(x.type_name, x.namespace);
        match self.scope.resolve_struct(owner, x.type_name) {
            Some(info) => {
                let declared = fs.resolve_type_def(TypeId { owner: owner, name: x.type_name }).map((def) => def.fields);
                for field_name in info.field_names {
                    match find_field_init(x.fields, field_name) {
                        Some(value) => {
                            let exp = match declared {
                                Some(fields) => fields.get(field_name),
                                None => Option.None,
                            };
                            self.expr_expecting(value, exp);
                        },
                        None => { self.error('missing field `${field_name}` in ${x.type_name} literal', x.span); },
                    }
                }
                self.emit(Instr.StructNew(info.index));
            },
            None => { self.error('unknown struct type: ${x.type_name}', x.span); },
        }
    }

    fn field_expr(self, _ object: Expr, _ field: String, _ span: SourceSpan) -> Void {
        // A namespace-qualified constant or global: `ns.NAME` → inline the const
        // initializer, or load the global slot. Resolved within `ns`'s owning
        // library (owner-correct): the member must be on the namespace's own
        // surface, so two libraries' same-named consts inline their own values.
        if let Ident(_, ns_name) = object {
            if self.is_namespace(ns_name) {
                if let Some(owner) = file_scope(self.scope.library, self.file).member_owner(ns_name, field) {
                    if self.scope.const_in_file(owner, field).is_some() {
                        self.emit_const(owner, field, span);
                        return;
                    }
                    if self.scope.global_in_file(owner, field).is_some() {
                        self.emit_global(owner, field);
                        return;
                    }
                }
            }
        }
        // A bare `Enum.Variant` is a zero-field enum constructor.
        match self.enum_variant(object, field) {
            Some(ev) => {
                if field_count_of(ev.info, field) != 0 {
                    self.error('enum variant `${field}` takes arguments', span);
                } else {
                    self.emit(Instr.EnumNew(ev.info.ty, ev.tag, 0));
                }
            },
            None => {
                if let Some(info) = self.struct_of(object, span) {
                    self.expr(object);
                    self.emit(Instr.FieldGet(self.field_index(info, field, span)));
                }
            },
        }
    }

    fn struct_of(self, _ object: Expr, _ span: SourceSpan) -> Option<StructInfo> {
        if let Some(id) = self.type_id_of(object) {
            if let Some(info) = self.scope.resolve_struct(id.owner, id.name) { return Option.Some(info); }
        }
        self.error('field access on non-struct value', span);
        return Option.None;
    }

    fn field_index(self, _ info: StructInfo, _ field: String, _ span: SourceSpan) -> Int {
        let idx = field_index_of(info, field);
        if idx < 0 {
            self.error('no such field: ${field}', span);
        }
        return idx;
    }

    fn emit_index_get(self, _ object: Expr, _ span: SourceSpan) -> Void {
        match self.type_of(object) {
            Some(t) => {
                if t == 'List' {
                    self.emit(Instr.Simple(Op.ListGet));
                } else if t == 'Map' {
                    self.emit(Instr.CallNative('map_index', 2));
                } else {
                    self.error('indexing on ${t} is not supported', span);
                }
            },
            None => { self.error('indexing on unknown type', span); },
        }
    }

    // --- enums ---

    // If `object` names a user enum (Enum or ns.Enum, not a local) and `name` is
    // one of its variants, the enum info and the variant's tag.
    fn enum_variant(self, _ object: Expr, _ name: String) -> Option<EnumVariantRef> {
        if let Some(id) = self.static_type_id(object) {
            if let Some(info) = self.scope.resolve_enum(id.owner, id.name) {
                let tag = tag_of(info, name);
                if tag < 0 {
                    return Option.None;
                }
                return Option.Some(EnumVariantRef { info: info, tag: tag });
            }
        }
        return Option.None;
    }

    // The bare type name a (possibly namespace-qualified) type expression refers
    // to, when it names a struct/enum/built-in type and isn't shadowed by a local.
    fn static_type_name(self, _ e: Expr) -> Option<String> {
        match e {
            Ident(_, name) => {
                if !self.slots.has(name) && self.is_type_name(name) {
                    return Option.Some(name);
                }
            },
            Field(_, inner, field) => {
                if let Ident(_, ns_name) = inner {
                    if self.is_namespace(ns_name) && self.is_type_name(field) {
                        return Option.Some(field);
                    }
                }
            },
            _ => {},
        }
        return Option.None;
    }

    // The owner-correct identity of a static type-name receiver — a bare `Type` or
    // a qualified `ns.Type` — resolved through this file's scope so a name two
    // libraries share reaches the one this file sees (Phase 1 T4 follow-up). The
    // owner-carrying analogue of `static_type_name`, used to key the type table.
    fn static_type_id(self, _ e: Expr) -> Option<TypeId> {
        let fs = file_scope(self.scope.library, self.file);
        match e {
            Ident(_, name) => {
                if !self.slots.has(name) && self.is_type_name(name) {
                    return Option.Some(TypeId { owner: fs.resolve_type_owner(name, Option.None), name: name });
                }
            },
            Field(_, inner, field) => {
                if let Ident(_, ns_name) = inner {
                    if self.is_namespace(ns_name) && self.is_type_name(field) {
                        return Option.Some(TypeId { owner: fs.resolve_type_owner(field, Option.Some(ns_name)), name: field });
                    }
                }
            },
            _ => {},
        }
        return Option.None;
    }

    fn is_type_name(self, _ name: String) -> Bool {
        return self.scope.has_struct_or_enum(name)
            || is_builtin_type_name(name);
    }

    // --- calls ---

    fn call_expr(self, _ x: CallExpr) -> Void {
        let callee = x.callee;
        match callee {
            Field(_, obj, field) => {
                self.method_call(x, obj, field);
                return;
            },
            Ident(_, name) => {
                // A call through a function value in a local (a let-bound lambda
                // or a function-typed parameter) shadows a same-named function.
                if self.slots.has(name) {
                    self.load_local_value(name, x.span);
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    self.emit(Instr.CallIndirect(x.args.len()));
                    return;
                }
                if let Some(fn_index) = self.scope.resolve_function(self.file, name) {
                    let ordered = self.resolve_args(self.scope.units[fn_index].params, x.args, x.span);
                    self.emit_ordered_args(x.callee, x.args, ordered);
                    self.emit(Instr.Call(fn_index, ordered.len()));
                    return;
                }
                if let Some(native_fn) = self.scope.native_fns.get(name) {
                    // `println`/`print`/`eprintln`/`eprint` render their argument
                    // to a `String` via `Display`, then pass it to the native
                    // (which just writes the string).
                    if is_print_native(native_fn) && x.args.len() == 1 {
                        self.emit_as_string(x.args[0].value, x.span);
                        self.emit(Instr.CallNative(native_fn, 1));
                        return;
                    }
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    self.emit(Instr.CallNative(native_fn, x.args.len()));
                    return;
                }
                self.error('unknown function: ${name}', x.span);
            },
            _ => { self.error('unsupported call target', x.span); },
        }
    }

    // `recv.method(args)` / `Type.method(args)`. The element model
    // (`infer_callee_kind`) is the single source of truth for *which* kind of
    // callee a site is — codegen no longer re-derives that classification, it
    // dispatches on it and only chooses the backend lowering (native symbol vs.
    // unit index vs. virtual selector) for the resolved kind.
    fn method_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Void {
        let emitted = match infer_callee_kind(obj, field, x.args.len(), self.type_scope, self.ctx) {
            EnumCtor => self.emit_enum_ctor(x, obj, field),
            EnumName => self.emit_enum_name_call(x, obj),
            Namespace => self.emit_namespace_call(x, obj, field),
            StaticMethod => self.emit_static_method_call(x, obj, field),
            InstanceMethod => self.emit_instance_method_call(x, obj, field),
            Virtual => self.emit_virtual_call(x, obj, field),
            FieldCall => self.emit_field_call(x, obj, field),
            Unresolved => false,
        };
        if !emitted {
            self.error('no method "${field}" on ${self.type_of(obj).unwrap_or('unknown type')}', x.span);
        }
    }

    // Enum payload constructor: `Shape.Circle(5)`.
    fn emit_enum_ctor(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        match self.enum_variant(obj, field) {
            Some(ev) => {
                for arg in x.args {
                    self.expr(arg.value);
                }
                self.emit(Instr.EnumNew(ev.info.ty, ev.tag, x.args.len()));
                return true;
            },
            None => { return false; },
        }
    }

    // `e.name()` on an enum value → the variant name (from its tag).
    fn emit_enum_name_call(self, _ x: CallExpr, _ obj: Expr) -> Bool {
        match self.type_id_of(obj) {
            Some(id) => {
                match self.scope.resolve_enum(id.owner, id.name) {
                    Some(info) => { self.enum_name(obj, info); return true; },
                    None => { return false; },
                }
            },
            None => { return false; },
        }
    }

    // Namespace-qualified call: `ns.fn(...)`. A `native fn` lowers to a receiver-
    // less native; an ordinary free function to a direct call.
    fn emit_namespace_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        if let Ident(_, ns_name) = obj {
            if self.is_namespace(ns_name) {
                if let Some(native_sym) = self.scope.native_fns.get(field) {
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    self.emit(Instr.CallNative(native_sym, x.args.len()));
                    return true;
                }
                // Resolve the qualified function within `ns`'s owning library
                // (owner-correct), not a last-wins global table — so two
                // libraries' same-named functions emit calls to distinct units.
                if let Some(owner) = file_scope(self.scope.library, self.file).member_owner(ns_name, field) {
                    if let Some(fn_idx) = self.scope.function_in_file(owner, field) {
                        let ordered = self.resolve_args(self.scope.units[fn_idx].params, x.args, x.span);
                        // Thread expected arg types (like the bare-call path), so a
                        // qualified call passing an un-annotated lambda types it
                        // bidirectionally — making `ns.fn(...)` byte-identical to `fn(...)`.
                        self.emit_ordered_args(x.callee, x.args, ordered);
                        self.emit(Instr.Call(fn_idx, ordered.len()));
                        return true;
                    }
                }
            }
        }
        return false;
    }

    // Static method on a type: `String.from_chars(...)` (a runtime native) or a
    // user `fn` with no `self` (a direct call, no receiver pushed).
    fn emit_static_method_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        if let Some(static_type) = self.static_type_name(obj) {
            if let Some(m) = self.scope.native_static_methods.get(static_type) {
                if let Some(native_sym) = m.get(field) {
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    self.emit(Instr.CallNative(native_sym, x.args.len()));
                    return true;
                }
            }
        }
        match self.resolve_method(obj, field) {
            Some(idx) => {
                let ordered = self.resolve_args(self.scope.units[idx].params, x.args, x.span);
                self.emit_ordered_args(x.callee, x.args, ordered);
                self.emit(Instr.Call(idx, ordered.len()));
                return true;
            },
            None => { return false; },
        }
    }

    // Instance method on a concrete receiver: a built-in `native fn` (the receiver
    // is the native's first argument) or a user method (self pushed first).
    fn emit_instance_method_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        if let Some(t) = self.type_of(obj) {
            if let Some(m) = self.scope.native_instance_methods.get(t) {
                if let Some(instance_native) = m.get(field) {
                    self.expr(obj);
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    // `list.len()` lowers to the `ListLen` primitive
                    // (the receiver is on the stack) rather than a
                    // native round-trip — it is by far the hottest
                    // native. Other instance natives stay `call.native`.
                    if instance_native == 'list_len' {
                        self.emit(Instr.Simple(Op.ListLen));
                    } else {
                        self.emit(Instr.CallNative(instance_native, x.args.len() + 1));
                    }
                    return true;
                }
            }
        }
        match self.resolve_method(obj, field) {
            Some(idx) => {
                self.expr(obj); // self → local slot 0 of the callee
                let ordered = self.resolve_args(self.scope.units[idx].params, x.args, x.span);
                self.emit_ordered_args(x.callee, x.args, ordered);
                self.emit(Instr.Call(idx, ordered.len() + 1));
                return true;
            },
            None => { return false; },
        }
    }

    // Dynamic dispatch: the receiver is interface-typed (`x: Display`) or a
    // generic parameter bound by an interface. The concrete type isn't known
    // here, so dispatch on the runtime type id. False (→ a "no method" error)
    // when the selector isn't declared by any candidate interface — except the
    // universal `display`/`debug` selectors, which dispatch on any receiver
    // (total rendering: the runtime resolves the value's impl or its auto-derived
    // fallback).
    fn emit_virtual_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        if field != 'display' && field != 'debug' {
            // A non-universal selector must be declared by a candidate interface.
            let declared = match self.dispatch_interfaces(self.type_of(obj)) {
                Some(ifaces) => {
                    let mut found = false;
                    for i in ifaces {
                        if let Some(s) = self.scope.interface_methods.get(i) { if s.has(field) { found = true; } }
                    }
                    found
                },
                None => false,
            };
            if !declared {
                return false;
            }
        }
        self.expr(obj);
        // Thread each argument's expected type (the interface method's parameter
        // types, instantiated with the receiver's type args) so a lambda argument
        // types its un-annotated parameters bidirectionally — matching the
        // instance-method path. Without this, a lambda passed to a virtual call
        // (e.g. `it.map((x) => …)`) would lose its param type in codegen.
        let expected = expected_arg_types(x.callee, x.args, self.type_scope, self.ctx);
        for p in x.args.enumerate() {
            let exp = match expected {
                Some(eps) => if p.index < eps.len() { Option.Some(eps[p.index]) } else { Option.None },
                None => Option.None,
            };
            self.expr_expecting(p.value.value, exp);
        }
        self.emit(Instr.CallVirtual(field, x.args.len() + 1));
        return true;
    }

    // A function-valued struct field invoked like a method: `c.now()` where `now`
    // is a field holding a closure (no method by that name).
    fn emit_field_call(self, _ x: CallExpr, _ obj: Expr, _ field: String) -> Bool {
        if let Some(id) = self.type_id_of(obj) {
            if let Some(struct_info) = self.scope.resolve_struct(id.owner, id.name) {
                let fi = field_index_of(struct_info, field);
                if fi >= 0 {
                    self.expr(obj);
                    self.emit(Instr.FieldGet(fi));
                    for arg in x.args {
                        self.expr(arg.value);
                    }
                    self.emit(Instr.CallIndirect(x.args.len()));
                    return true;
                }
            }
        }
        return false;
    }

    // The unit index of method `name` on receiver `receiver`, or None. A type
    // name (`Type` or `ns.Type`, not a local) selects a static method; otherwise
    // the receiver's static type does.
    fn resolve_method(self, _ receiver: Expr, _ name: String) -> Option<Int> {
        // Key the method table by the receiver's owner-qualified identity — a
        // static type-name receiver (`Type`/`ns.Type`) or the receiver value's
        // inferred type — so two libraries' same-named types keep distinct methods.
        let id = match self.static_type_id(receiver) {
            Some(t) => Option.Some(t),
            None => match self.type_id_of(receiver) {
                Some(t) => Option.Some(t),
                // A primitive receiver carries no `Interface` TypeId; key it by its
                // registry owner (`type_id_for`), which matches how `impl Int`/… was
                // registered (`owner_of` resolves the same owner for a primitive).
                None => self.type_of(receiver).map((n) => self.scope.type_id_for(n)),
            },
        };
        if let Some(t) = id {
            if let Some(m) = self.scope.method_table.get(type_key(t.owner, t.name)) { return m.get(name); }
        }
        return Option.None;
    }

    // `e.name()` — the variant name, looked up from the enum tag (a tag-check
    // chain; the last variant is the fall-through).
    fn enum_name(self, _ receiver: Expr, _ info: EnumInfo) -> Void {
        self.expr(receiver);
        self.emit(Instr.Simple(Op.EnumTag));
        let tag = self.fresh_slot();
        self.emit(Instr.Store(tag));
        let end = self.new_label();
        for p in info.variants.enumerate() {
            let name = p.value.name;
            if p.index == info.variants.len() - 1 {
                self.emit(Instr.ConstStr(name)); // last variant: fall through
            } else {
                let next = self.new_label();
                self.emit(Instr.Load(tag));
                self.emit(Instr.ConstInt(p.index));
                self.emit(Instr.Simple(Op.EqI64));
                self.emit_jump(Jk.IfFalse, next);
                self.emit(Instr.ConstStr(name));
                self.emit_jump(Jk.Jump, end);
                self.bind(next);
            }
        }
        self.bind(end);
    }

    // Emit the parameter-ordered argument values, each with its expected type
    // (the callee's parameter types, instantiated) so a lambda argument types its
    // un-annotated parameters bidirectionally. `expected_arg_types` returns one
    // entry per non-self parameter, aligned with `ordered`.
    fn emit_ordered_args(self, _ callee: Expr, _ args: List<CallArg>, _ ordered: List<Expr>) -> Void {
        let expected = expected_arg_types(callee, args, self.type_scope, self.ctx);
        for p in ordered.enumerate() {
            let exp = match expected {
                Some(eps) => if p.index < eps.len() { Option.Some(eps[p.index]) } else { Option.None },
                None => Option.None,
            };
            self.expr_expecting(p.value, exp);
        }
    }

    // Match call arguments to a callee's (non-self) parameters, returning the
    // value expressions in parameter order (named-argument + default resolution).
    fn resolve_args(self, _ params: List<Param>, _ call_args: List<CallArg>, _ span: SourceSpan) -> List<Expr> {
        let positional: List<Expr> = [];
        let named: Map<String, Expr> = {};
        for a in call_args {
            match a.label {
                Some(l) => { named[l] = a.value; },
                None => { positional.push(a.value); },
            }
        }
        let ordered: List<Expr> = [];
        let mut pi = 0;
        for p in params {
            if !p.is_self {
                let value = match p.label {
                    None => {
                        // Suppressed external label (`_`): positional only.
                        if pi < positional.len() {
                            let v = positional[pi];
                            pi = pi + 1;
                            Option.Some(v)
                        } else {
                            self.relocate_loc_default(p.default_value, span)
                        }
                    },
                    Some(label) => {
                        match named.get(label) {
                            Some(v) => Option.Some(v),
                            None => {
                                if pi < positional.len() && label == p.name {
                                    let v = positional[pi];
                                    pi = pi + 1;
                                    Option.Some(v)
                                } else {
                                    self.relocate_loc_default(p.default_value, span)
                                }
                            },
                        }
                    },
                };
                match value {
                    Some(v) => { ordered.push(v); },
                    None => { self.error('missing argument for parameter `${p.name}`', span); },
                }
            }
        }
        return ordered;
    }

    // A `#loc` default value captures the *call site*, not its definition site:
    // when an omitted parameter defaults to `#loc`, re-stamp it with the call's
    // span so codegen reports where the call was written (the file is the caller's,
    // since this default is emitted while compiling the calling unit).
    fn relocate_loc_default(self, _ d: Option<Expr>, _ call_span: SourceSpan) -> Option<Expr> {
        match d {
            Some(e) => {
                return match e {
                    Loc(_) => Option.Some(Expr.Loc(call_span)),
                    _ => Option.Some(e),
                };
            },
            None => { return Option.None; },
        }
    }

    // --- dispatch helpers ---

    fn interface_method(self, _ ty: Option<TypeId>, _ interface_name: String, _ method: String) -> Option<Int> {
        if let Some(t) = ty {
            let key = type_key(t.owner, t.name);
            let implements = match self.scope.interface_impls.get(key) {
                Some(info) => info.interfaces.has(interface_name),
                None => false,
            };
            if implements {
                if let Some(m) = self.scope.method_table.get(key) { return m.get(method); }
            }
        }
        return Option.None;
    }

    fn dispatch_interfaces(self, _ name: Option<String>) -> Option<List<String>> {
        if let Some(n) = name {
            if self.scope.interface_methods.has(n) {
                return Option.Some([n]);
            }
            if let Some(bounds) = self.type_param_bounds.get(n) {
                let ifaces: List<String> = [];
                for b in bounds {
                    if self.scope.interface_methods.has(b) {
                        ifaces.push(b);
                    }
                }
                if ifaces.len() > 0 {
                    return Option.Some(ifaces);
                }
            }
        }
        return Option.None;
    }

    fn dispatches_via(self, _ ty_name: Option<String>, _ method: String) -> Bool {
        if let Some(ifaces) = self.dispatch_interfaces(ty_name) {
            for i in ifaces {
                if let Some(s) = self.scope.interface_methods.get(i) {
                    if s.has(method) {
                        return true;
                    }
                }
            }
        }
        return false;
    }
}

// A resolved enum variant reference (its enum info and the variant's tag).
pub struct EnumVariantRef {
    info: EnumInfo,
    tag: Int,
}

// A match large enough to dispatch on a hoisted enum tag rather than the per-arm
// tag recompute + linear chain. Below this many non-final cases the simple chain
// is smaller, so small matches lower byte-for-byte as the plain chain.
pub const MATCH_DISPATCH_MIN_CASES: Int = 6;

// A planned binary-search dispatch: each non-final arm keyed by its variant tag,
// plus the final catch-all arm.
pub struct DispatchPlan {
    cases: Map<Int, MatchArm>,
    default_arm: MatchArm,
}

// The number of non-final arms that emit a top-level tag test in the linear
// scheme — the constructor-pattern arms. Drives whether hoisting the tag pays.
fn top_level_tag_tests(_ e: MatchExpr) -> Int {
    let mut n = 0;
    let mut i = 0;
    while i < e.arms.len() - 1 {
        if let Constructor(_, _, _) = e.arms[i].pattern { n = n + 1; }
        i = i + 1;
    }
    return n;
}

fn all_irrefutable_args(_ args: List<Pattern>) -> Bool {
    for a in args {
        match a {
            Wildcard(_) => {},
            Ident(_, _) => {},
            _ => { return false; },
        }
    }
    return true;
}

fn get_case(_ cases: Map<Int, MatchArm>, _ tag: Int) -> MatchArm {
    return cases[tag];
}

// The case tags, ascending (selection sort over the distinct map keys).
fn sorted_keys(_ cases: Map<Int, MatchArm>) -> List<Int> {
    let keys = cases.keys();
    let used: Set<Int> = Set.new();
    let sorted: List<Int> = [];
    let mut count = 0;
    while count < keys.len() {
        let mut best: Option<Int> = Option.None;
        for k in keys {
            if !used.has(k) {
                match best {
                    None => { best = Option.Some(k); },
                    Some(b) => {
                        if k < b {
                            best = Option.Some(k);
                        }
                    },
                }
            }
        }
        if let Some(b) = best {
            sorted.push(b);
            used.add(b);
        }
        count = count + 1;
    }
    return sorted;
}

// --- free helpers ---

// The receiver type a method's `self` denotes: a primitive, or the named type
// with its declared parameters applied (`List` -> `List<T>`). This is codegen's
// inference-context construction; it matches the checker's `impl_self_type` so
// the two infer a method body identically.
fn named_self_type(_ name: String, _ library: element.LibraryElement, _ file: Option<String>) -> Type {
    if let Some(p) = primitive_type(name) {
        return p;
    }
    // Owner-correct: type `self` against the receiver the method's own file sees,
    // so a method impl'd on a name two libraries share binds to *its* type — the
    // self-type analogue of the method-table's owner keying.
    let fs = file_scope(library, file);
    let owner = fs.resolve_type_owner(name, Option.None);
    return match fs.resolve_type_def(TypeId { owner: owner, name: name }) {
        Some(def) => Type.Interface(TypeId { owner: owner, name: name }, def.type_parameters.map((p) => Type.TypeParameter(p))),
        None => Type.Interface(TypeId { owner: '', name: name }, []),
    };
}

// The type-parameter names of a receiver type (`List<T>` -> `[T]`) — the owner
// parameters that join a method unit's in-scope type-parameter set.
fn self_type_param_names(_ t: Type) -> List<String> {
    let out = [];
    if let Interface(_, args) = t {
        for a in args {
            if let TypeParameter(n) = a { out.push(n); }
        }
    }
    return out;
}

// --- differential inference oracle ---
//
// Inference is one pure `infer_expr` query, but the checker and codegen build its
// `InferCtx` independently. This pass observes the `self_type` codegen actually
// recorded for each unit (`unit_ctx_self`) and compares it to an independently
// computed checker reference (`checker_self_type`, mirroring the checker's
// `impl_self_type`) — a real differential, since the two are built by separate
// code. A mismatch is a place the two stages could infer the same expression to
// different types; once the construction is unified this reports zero. Opt-in via
// `HAWK_INFER_ORACLE`; prints to stderr.

// The checker's receiver type for a unit — the oracle's reference, kept separate
// from codegen's `named_self_type` so the comparison is a genuine differential.
fn checker_self_type(_ self_name: Option<String>, _ library: element.LibraryElement,
    _ file: Option<String>) -> Option<Type> {
    return match self_name {
        Some(n) => match primitive_type(n) {
            Some(p) => Option.Some(p),
            None => {
                // Resolved owner-correct (like `named_self_type`), but via its own
                // path so the oracle stays a genuine differential.
                let fs = file_scope(library, file);
                let owner = fs.resolve_type_owner(n, Option.None);
                match fs.resolve_type_def(TypeId { owner: owner, name: n }) {
                    Some(def) => Option.Some(
                        Type.Interface(TypeId { owner: owner, name: n }, def.type_parameters.map((p) => Type.TypeParameter(p)))),
                    None => Option.Some(Type.Interface(TypeId { owner: '', name: n }, [])),
                }
            },
        },
        None => Option.None,
    };
}

fn describe_self(_ t: Option<Type>) -> String {
    return match t {
        Some(ty) => type_to_string(ty),
        None => '(none)',
    };
}

// The `self_type` codegen recorded for unit `i` (None if it never compiled it).
fn recorded_self(_ scope: ModuleScope, _ i: Int) -> Option<Type> {
    return scope.unit_ctx_self.get(i).unwrap_or(Option.None);
}

fn run_infer_oracle(_ scope: ModuleScope) -> Void {
    let library = scope.library;
    let mut diverged = 0;
    let mut checked = 0;
    let mut lambdas = 0;
    eprintln('infer-oracle: checker/codegen inference-context divergence');
    for p in scope.units.enumerate() {
        let name = scope.unit_names[p.index];
        if name.starts_with('__lambda_') {
            lambdas = lambdas + 1;
        } else {
            checked = checked + 1;
            // What codegen actually built (recorded during compilation) vs the
            // independent checker reference.
            let cg = describe_self(recorded_self(scope, p.index));
            let ck = describe_self(checker_self_type(scope.unit_self_types[p.index], library, scope.unit_files[p.index]));
            if cg != ck {
                diverged = diverged + 1;
                eprintln('  ${name}  [${file_label(scope.unit_files[p.index])}]');
                eprintln('      self_type:   codegen=${cg}   checker=${ck}');
            }
        }
    }
    eprintln('infer-oracle: ${diverged}/${checked} non-lambda unit(s) diverge; '
        + '${lambdas} lambda unit(s) skipped (context inherited via snapshot)');
}

fn file_label(_ f: Option<String>) -> String {
    return f.unwrap_or('(no file)');
}

fn type_ref_name(_ t: Option<TypeRef>) -> Option<String> {
    return match t {
        Some(r) => match r {
            Named(nt) => Option.Some(nt.name),
            Function(_) => Option.None,
        },
        None => Option.None,
    };
}

fn name_of_type(_ t: Type) -> Option<String> {
    return match t {
        Primitive(p) => match p {
            Int => Option.Some('Int'),
            Double => Option.Some('Double'),
            Bool => Option.Some('Bool'),
            Str => Option.Some('String'),
            Unit => Option.None,
        },
        Interface(name, _) => Option.Some(name.name),
        TypeParameter(name) => Option.Some(name),
        _ => Option.None,
    };
}

// The `TypeId` of an interface (struct/enum) type, or None for primitives / type
// parameters / unknowns — the owner-carrying analogue of `name_of_type` used to
// key the codegen type table.
fn type_id_of_type(_ t: Type) -> Option<TypeId> {
    return match t {
        Interface(id, _) => Option.Some(id),
        _ => Option.None,
    };
}

// Build the synthetic FnDecl a lambda lowers to: its parameters are the captured
// variables (leading, in capture order) followed by the lambda's own parameters;
// its body returns the lambda's body expression.
fn lift_lambda(_ x: LambdaExpr, _ captures: List<String>) -> FnDecl {
    let body = Block {
        start_span: x.span,
        end_span: x.span,
        stmts: [Stmt.Return(x.span, Option.Some(x.body))],
        tail: Option.None,
    };
    let params: List<Param> = [];
    for c in captures {
        params.push(Param {
            span: x.span,
            label: Option.Some(c),
            is_self: false,
            name: c,
            name_span: x.span,
            type_ann: Option.None,
            default_value: Option.None,
        });
    }
    for p in x.params {
        params.push(Param {
            span: p.span,
            label: Option.Some(p.name),
            is_self: false,
            name: p.name,
            name_span: p.span,
            type_ann: p.type_ann,
            default_value: Option.None,
        });
    }
    return FnDecl {
        span: x.span,
        decorators: [],
        is_pub: false,
        is_native: false,
        name: '<lambda>',
        name_span: x.span,
        type_params: [],
        params: params,
        return_type: Option.None,
        body: Option.Some(body),
    };
}

// The free variables of `lambda`: identifiers referenced in its body that it
// does not itself bind. Its own parameters, and names introduced by nested
// lambdas, match patterns, block lets, and for loops, are bound (not free).
// Listed in first-reference order so the capture layout is deterministic.
fn free_variables(_ lambda: LambdaExpr) -> List<String> {
    let free: List<String> = [];
    let seen: Set<String> = Set.new();
    let bound: Set<String> = Set.new();
    for p in lambda.params {
        bound.add(p.name);
    }
    fv_visit(lambda.body, bound, free, seen);
    return free;
}

fn copy_set(_ s: Set<String>) -> Set<String> {
    let out: Set<String> = Set.new();
    for x in s.to_list() {
        out.add(x);
    }
    return out;
}

// The Option-file for a file key — the inverse of `element.file_key` ('' denotes
// the primary/anonymous program).
fn file_of_key(_ key: String) -> Option<String> {
    return if key == '' { Option.None } else { Option.Some(key) };
}

// The slot-map analogue of inference's `copy_scope`.
fn copy_slots(_ m: Map<String, Int>) -> Map<String, Int> {
    let out: Map<String, Int> = {};
    for k in m.keys() {
        if let Some(v) = m.get(k) { out[k] = v; }
    }
    return out;
}

fn fv_ref(_ name: String, _ bound: Set<String>, _ free: List<String>, _ seen: Set<String>) -> Void {
    if !bound.has(name) && !seen.has(name) {
        seen.add(name);
        free.push(name);
    }
}

fn fv_pattern_bindings(_ p: Pattern, _ into: Set<String>) -> Void {
    match p {
        Ident(_, name) => { into.add(name); },
        Constructor(_, _, args) => {
            for a in args {
                fv_pattern_bindings(a, into);
            }
        },
        Wildcard(_) => {},
        Literal(_, _) => {},
    }
}

fn fv_visit_block(_ b: Block, _ bound: Set<String>, _ free: List<String>, _ seen: Set<String>) -> Void {
    let local = copy_set(bound);
    for s in b.stmts {
        fv_stmt(s, local, free, seen);
    }
    if let Some(t) = b.tail { fv_visit(t, local, free, seen); }
}

fn fv_visit(_ e: Expr, _ bound: Set<String>, _ free: List<String>, _ seen: Set<String>) -> Void {
    match e {
        Ident(_, name) => { fv_ref(name, bound, free, seen); },
        Int(_, _) => {},
        Float(_, _) => {},
        Bool(_, _) => {},
        Unit(_) => {},
        Loc(_) => {}, // a leaf metaconstant — no free variables
        Str(_, parts) => {
            for p in parts {
                if let Interp(_, ie) = p { fv_visit(ie, bound, free, seen); }
            }
        },
        ListLit(_, items) => {
            for it in items {
                fv_visit(it, bound, free, seen);
            }
        },
        MapLit(_, entries) => {
            for en in entries {
                fv_visit(en.key, bound, free, seen);
                fv_visit(en.value, bound, free, seen);
            }
        },
        Struct(x) => {
            for f in x.fields {
                fv_visit(f.value, bound, free, seen);
            }
        },
        Call(x) => {
            fv_visit(x.callee, bound, free, seen);
            for a in x.args {
                fv_visit(a.value, bound, free, seen);
            }
        },
        Field(_, obj, _) => { fv_visit(obj, bound, free, seen); },
        Index(_, obj, idx) => {
            fv_visit(obj, bound, free, seen);
            fv_visit(idx, bound, free, seen);
        },
        Binary(_, l, _, r) => {
            fv_visit(l, bound, free, seen);
            fv_visit(r, bound, free, seen);
        },
        Unary(_, _, operand) => { fv_visit(operand, bound, free, seen); },
        Propagate(_, inner) => { fv_visit(inner, bound, free, seen); },
        Range(_, s, en) => {
            fv_visit(s, bound, free, seen);
            fv_visit(en, bound, free, seen);
        },
        Match(x) => {
            fv_visit(x.subject, bound, free, seen);
            for arm in x.arms {
                let arm_bound = copy_set(bound);
                fv_pattern_bindings(arm.pattern, arm_bound);
                fv_visit(arm.body, arm_bound, free, seen);
            }
        },
        Lambda(x) => {
            let inner = copy_set(bound);
            for p in x.params {
                inner.add(p.name);
            }
            fv_visit(x.body, inner, free, seen);
        },
        Block(_, block) => { fv_visit_block(block, bound, free, seen); },
        If(x) => {
            fv_visit(x.condition, bound, free, seen);
            fv_visit_block(x.then_block, bound, free, seen);
            if let Some(eb) = x.else_block { fv_visit_block(eb, bound, free, seen); }
        },
        Return(_, value) => {
            if let Some(v) = value { fv_visit(v, bound, free, seen); }
        },
        Throw(_, value) => { fv_visit(value, bound, free, seen); },
    }
}

fn fv_stmt(_ s: Stmt, _ bound: Set<String>, _ free: List<String>, _ seen: Set<String>) -> Void {
    match s {
        Let(x) => {
            fv_visit(x.value, bound, free, seen);
            bound.add(x.name); // visible to later statements in the block
        },
        Assign(_, target, value) => {
            fv_visit(target, bound, free, seen);
            fv_visit(value, bound, free, seen);
        },
        Expr(_, e) => { fv_visit(e, bound, free, seen); },
        Return(_, value) => {
            if let Some(v) = value { fv_visit(v, bound, free, seen); }
        },
        Throw(_, value) => { fv_visit(value, bound, free, seen); },
        If(x) => {
            fv_visit(x.condition, bound, free, seen);
            fv_visit_block(x.then_block, bound, free, seen);
            if let Some(eb) = x.else_block { fv_visit_block(eb, bound, free, seen); }
        },
        While(x) => {
            fv_visit(x.condition, bound, free, seen);
            fv_visit_block(x.body, bound, free, seen);
        },
        For(x) => {
            fv_visit(x.iterable, bound, free, seen);
            let loop_bound = copy_set(bound);
            fv_pattern_bindings(x.pattern, loop_bound);
            fv_visit_block(x.body, loop_bound, free, seen);
        },
    }
}

// --- module-global initialization order (docs/module_init.md) ---

// Order the module globals so each initializer runs after the globals it
// references: a depth-first post-order over the reference graph. A back edge is
// an initializer cycle — a located compile error (cf. the cyclic-`const` guard).
// Cross-module order falls out of registration order (imports before importers),
// which the post-order preserves for globals with no edge between them.
fn order_global_inits(_ scope: ModuleScope, _ errors: List<CodegenError>) -> List<GlobalInit> {
    let ordered: List<GlobalInit> = [];
    let state: Map<String, Int> = {}; // keyed like `global_key`; 1 = visiting, 2 = done
    let by_key: Map<String, GlobalInit> = {};
    for g in scope.global_inits {
        by_key[global_key(g)] = g;
    }
    for g in scope.global_inits {
        visit_global_init(g, scope, by_key, state, ordered, errors);
    }
    return ordered;
}

// A global's owner-qualified identity (two libraries' same-named globals are
// distinct nodes in the initializer-order graph).
fn global_key(_ g: GlobalInit) -> String {
    return type_key(element.file_key(g.file), g.name);
}

fn visit_global_init(_ g: GlobalInit, _ scope: ModuleScope, _ by_key: Map<String, GlobalInit>,
    _ state: Map<String, Int>, _ ordered: List<GlobalInit>, _ errors: List<CodegenError>) -> Void {
    let key = global_key(g);
    if let Some(s) = state.get(key) {
        if s == 1 {
            errors.push(CodegenError {
                message: 'module-level `let` initializer cycle through `${g.name}`',
                span: g.span,
            });
        }
        return; // already done, or a cycle just reported
    }
    state[key] = 1;
    for dep in global_init_deps(g, scope) {
        if let Some(dg) = by_key.get(dep) { visit_global_init(dg, scope, by_key, state, ordered, errors); }
    }
    state[key] = 2;
    ordered.push(g);
}

// Natives a module-`let` initializer may not call: time-varying or I/O
// operations whose result would be a stale load-time snapshot (docs/module_init.md
// "Which initializer expressions"). Process-stable reads (env queries, the OS,
// the path separator) are allowed. A cheap denylist, not a purity analysis —
// matched on the resolved runtime symbol, so namespace aliasing can't evade it.
fn forbidden_in_initializer(_ sym: String) -> Bool {
    return sym.starts_with('time_')
        || sym.starts_with('fs_')
        || sym == 'random_seed_entropy'
        || sym == 'env_set'
        || sym == 'env_set_current_dir'
        || sym == 'env_exit';
}

// The module globals an initializer references directly: bare identifiers that
// resolve to a global from the initializer's own file (same-file first, then
// its bare surface), returned as owner-qualified `global_key`s. Names bound
// inside the initializer (lambda params, block lets, match/for patterns) are
// excluded by the free-variable walk. Indirect dependencies through a called
// function's body are not tracked — initializers should reference their
// dependencies directly.
fn global_init_deps(_ g: GlobalInit, _ scope: ModuleScope) -> List<String> {
    let free: List<String> = [];
    let seen: Set<String> = Set.new();
    fv_visit(g.value, Set.new(), free, seen);
    let deps: List<String> = [];
    for n in free {
        if let Some(owner) = scope.resolve_global_owner(g.file, n) {
            deps.push(type_key(owner, n));
        }
    }
    return deps;
}

// The `mut` locals of the function with body `body` that are captured by a
// lambda, and therefore need boxing. One walk gathers this function's own `mut`
// declarations (not descending into lambda bodies — those belong to the lifted
// unit) and its top-level lambdas; a captured-and-mutable local is the
// intersection.
fn boxed_mut_locals(_ body: Block) -> Set<String> {
    let muts: Set<String> = Set.new();
    let lambdas: List<LambdaExpr> = [];
    bml_block(body, muts, lambdas);
    let result: Set<String> = Set.new();
    if muts.len() == 0 || lambdas.len() == 0 {
        return result;
    }
    let captured: Set<String> = Set.new();
    for l in lambdas {
        for name in free_variables(l) {
            captured.add(name);
        }
    }
    for name in muts.to_list() {
        if captured.has(name) {
            result.add(name);
        }
    }
    return result;
}

fn bml_block(_ b: Block, _ muts: Set<String>, _ lambdas: List<LambdaExpr>) -> Void {
    for s in b.stmts {
        bml_stmt(s, muts, lambdas);
    }
    if let Some(t) = b.tail { bml_expr(t, muts, lambdas); }
}

fn bml_expr(_ e: Expr, _ muts: Set<String>, _ lambdas: List<LambdaExpr>) -> Void {
    match e {
        Lambda(x) => { lambdas.push(x); }, // a lambda of this function; don't descend
        Ident(_, _) => {},
        Int(_, _) => {},
        Float(_, _) => {},
        Bool(_, _) => {},
        Unit(_) => {},
        Loc(_) => {}, // a leaf metaconstant
        Str(_, parts) => {
            for p in parts {
                if let Interp(_, ie) = p { bml_expr(ie, muts, lambdas); }
            }
        },
        ListLit(_, items) => {
            for it in items {
                bml_expr(it, muts, lambdas);
            }
        },
        MapLit(_, entries) => {
            for en in entries {
                bml_expr(en.key, muts, lambdas);
                bml_expr(en.value, muts, lambdas);
            }
        },
        Struct(x) => {
            for f in x.fields {
                bml_expr(f.value, muts, lambdas);
            }
        },
        Call(x) => {
            bml_expr(x.callee, muts, lambdas);
            for a in x.args {
                bml_expr(a.value, muts, lambdas);
            }
        },
        Field(_, obj, _) => { bml_expr(obj, muts, lambdas); },
        Index(_, obj, idx) => {
            bml_expr(obj, muts, lambdas);
            bml_expr(idx, muts, lambdas);
        },
        Binary(_, l, _, r) => {
            bml_expr(l, muts, lambdas);
            bml_expr(r, muts, lambdas);
        },
        Unary(_, _, operand) => { bml_expr(operand, muts, lambdas); },
        Propagate(_, inner) => { bml_expr(inner, muts, lambdas); },
        Range(_, s, en) => {
            bml_expr(s, muts, lambdas);
            bml_expr(en, muts, lambdas);
        },
        Match(x) => {
            bml_expr(x.subject, muts, lambdas);
            for arm in x.arms {
                bml_expr(arm.body, muts, lambdas);
            }
        },
        Block(_, block) => { bml_block(block, muts, lambdas); },
        If(x) => {
            bml_expr(x.condition, muts, lambdas);
            bml_block(x.then_block, muts, lambdas);
            if let Some(eb) = x.else_block { bml_block(eb, muts, lambdas); }
        },
        Return(_, value) => {
            if let Some(v) = value { bml_expr(v, muts, lambdas); }
        },
        Throw(_, value) => { bml_expr(value, muts, lambdas); },
    }
}

fn bml_stmt(_ s: Stmt, _ muts: Set<String>, _ lambdas: List<LambdaExpr>) -> Void {
    match s {
        Let(x) => {
            bml_expr(x.value, muts, lambdas);
            if x.is_mut {
                muts.add(x.name);
            }
        },
        Assign(_, target, value) => {
            bml_expr(target, muts, lambdas);
            bml_expr(value, muts, lambdas);
        },
        Expr(_, e) => { bml_expr(e, muts, lambdas); },
        Return(_, value) => {
            if let Some(v) = value { bml_expr(v, muts, lambdas); }
        },
        Throw(_, value) => { bml_expr(value, muts, lambdas); },
        If(x) => {
            bml_expr(x.condition, muts, lambdas);
            bml_block(x.then_block, muts, lambdas);
            if let Some(eb) = x.else_block { bml_block(eb, muts, lambdas); }
        },
        While(x) => {
            bml_expr(x.condition, muts, lambdas);
            bml_block(x.body, muts, lambdas);
        },
        For(x) => {
            bml_expr(x.iterable, muts, lambdas);
            bml_block(x.body, muts, lambdas);
        },
    }
}

// Whether `p` always matches, so it needs no test: a wildcard or a bare variable
// binding. (A constructor or literal pattern — even nested — is refutable.)
fn is_irrefutable(_ p: Pattern) -> Bool {
    return match p {
        Wildcard(_) => true,
        Ident(_, _) => true,
        _ => false,
    };
}

// The type id of field `k` of variant `tag` in enum `info` — the enum to match a
// nested constructor pattern against — or None if not resolvable. The field's
// source type name is owner-qualified through the registry (T3); scope-aware
// source resolution is T4.
fn enum_field_type_id(_ scope: ModuleScope, _ info: Option<EnumInfo>, _ tag: Int, _ k: Int) -> Option<TypeId> {
    if let Some(ei) = info {
        if tag >= 0 && tag < ei.variants.len() {
            let fields = ei.variants[tag].fields;
            if k < fields.len() {
                return match fields[k] {
                    Named(nt) => Option.Some(scope.type_id_for(nt.name)),
                    Function(_) => Option.None,
                };
            }
        }
    }
    return Option.None;
}

fn find_field_init(_ fields: List<FieldInit>, _ name: String) -> Option<Expr> {
    for f in fields {
        if f.name == name {
            return Option.Some(f.value);
        }
    }
    return Option.None;
}

fn is_builtin_type_name(_ name: String) -> Bool {
    return name == 'String' || name == 'Bytes' || name == 'BytesBuilder'
        || name == 'Int' || name == 'Bool' || name == 'Double' || name == 'Float'
        || name == 'Void' || name == 'List' || name == 'Map' || name == 'Set'
        || name == 'Result' || name == 'Option';
}

fn is_arithmetic(_ op: String) -> Bool {
    return op == '+' || op == '-' || op == '*' || op == '/' || op == '%';
}

// The `Display`-bounded console natives: codegen renders their argument to a
// `String` (via `Display`) before the call, so the native is a plain writer.
fn is_print_native(_ name: String) -> Bool {
    return name == 'println' || name == 'print' || name == 'eprintln' || name == 'eprint';
}

fn is_comparison_op(_ op: String) -> Bool {
    return op == '==' || op == '!=' || op == '<' || op == '<=' || op == '>' || op == '>=';
}

fn is_bitwise(_ op: String) -> Bool {
    return op == '&' || op == '|' || op == '^' || op == '<<' || op == '>>' || op == '>>>';
}

fn arith_op(_ op: String, _ is_double: Bool) -> Op {
    if op == '+' {
        return if is_double { Op.AddF64 } else { Op.AddI64 };
    }
    if op == '-' {
        return if is_double { Op.SubF64 } else { Op.SubI64 };
    }
    if op == '*' {
        return if is_double { Op.MulF64 } else { Op.MulI64 };
    }
    if op == '/' {
        return if is_double { Op.DivF64 } else { Op.DivI64 };
    }
    return Op.ModI64; // `%` (Int only; the Double case is rejected by the caller)
}

fn cmp_op(_ op: String, _ is_double: Bool) -> Op {
    if op == '==' {
        return if is_double { Op.EqF64 } else { Op.EqI64 };
    }
    if op == '!=' {
        return if is_double { Op.NeF64 } else { Op.NeI64 };
    }
    if op == '<' {
        return if is_double { Op.LtF64 } else { Op.LtI64 };
    }
    if op == '<=' {
        return if is_double { Op.LeF64 } else { Op.LeI64 };
    }
    if op == '>' {
        return if is_double { Op.GtF64 } else { Op.GtI64 };
    }
    return if is_double { Op.GeF64 } else { Op.GeI64 };
}

fn bitwise_op(_ op: String) -> Op {
    if op == '&' {
        return Op.AndI64;
    }
    if op == '|' {
        return Op.OrI64;
    }
    if op == '^' {
        return Op.XorI64;
    }
    if op == '<<' {
        return Op.ShlI64;
    }
    if op == '>>' {
        return Op.ShrI64;
    }
    return Op.UShrI64; // `>>>`
}
