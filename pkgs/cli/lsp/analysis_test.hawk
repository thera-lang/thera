// Tests for the analysis session — specifically the open-buffer overlay
// contract: an *imported* file that is open in the editor is analyzed as the
// user sees it (unsaved edits included), not as last saved to disk.

import std.testing;
import std.fs;
import std.json as _;

import 'analysis' as _;
import 'paths';
import '../loader';

// `a.hawk` imports `b.hawk` and calls `b.helper()`. On disk, `b` exports
// `helper`; the open (unsaved) buffer for `b` removes it. Analyzing `a` must
// see the buffer — an "not a public member" diagnostic — not the disk content.
@test
fn test_imported_open_buffer_overlays_disk() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_overlay_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    if let Err(e) = fs.create_dir_all(dir) {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    if let Err(e) = fs.write_text(dir + '/b.hawk', 'pub fn helper() -> Int { return 1; }\n') {
        return Result.Err(error('write b: ${e.message()}'));
    }
    let a_text = 'import \'b\';\nfn use_it() -> Int { return b.helper(); }\n';
    if let Err(e) = fs.write_text(dir + '/a.hawk', a_text) {
        return Result.Err(error('write a: ${e.message()}'));
    }

    let analysis = new_analysis(Option.None);
    let a_uri = paths.path_to_uri(dir + '/a.hawk');
    let b_uri = paths.path_to_uri(dir + '/b.hawk');
    analysis.set_document(a_uri, a_text, Option.None);

    // Both files as saved: clean.
    let clean = analysis.diagnostics(a_uri, a_text);
    testing.assert_eq(actual: clean.as_array().map((xs) => xs.len()).unwrap_or(-1), expected: 0)?;

    // Open `b` with an unsaved edit that removes `helper`: `a`'s analysis must
    // see the buffer, not the stale disk content.
    analysis.set_document(b_uri, 'pub fn renamed() -> Int { return 1; }\n', Option.None);
    let stale = analysis.diagnostics(a_uri, a_text);
    testing.assert(stale.as_array().map((xs) => xs.len()).unwrap_or(0) > 0,
        message: 'a sees b\'s unsaved edit (helper gone)')?;

    // Close `b` (buffer discarded): back to the disk content — clean again.
    analysis.close_document(b_uri);
    let reverted = analysis.diagnostics(a_uri, a_text);
    testing.assert_eq(actual: reverted.as_array().map((xs) => xs.len()).unwrap_or(-1), expected: 0)?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// References span the whole project: with workspace roots announced, a use in a
// *closed* on-disk file is found, not just the open documents. `a.hawk` declares
// `foo`; `b.hawk` (never opened) calls it. A references request on the
// declaration returns both occurrences.
@test
fn test_references_scan_on_disk_workspace_files() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_xref_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let a_text = 'pub fn foo() -> Int { return 1; }\n';
    fs.write_text(dir + '/a.hawk', a_text)?;
    fs.write_text(dir + '/b.hawk', 'import \'a\';\nfn use_it() -> Int { return a.foo(); }\n')?;

    let analysis = new_analysis(Option.None);
    analysis.set_roots([dir]);
    let a_uri = paths.path_to_uri(dir + '/a.hawk');
    let b_uri = paths.path_to_uri(dir + '/b.hawk');
    // Only `a` is open; `b` stays closed on disk and must still be scanned.
    analysis.set_document(a_uri, a_text, Option.None);

    // References on `foo`'s declaration name (line 0, inside `foo` at char 8).
    let pos = obj(['line': int(0), 'character': int(8)]);
    let locs = analysis.references_at(a_uri, pos, true).as_array().unwrap_or([]);
    testing.assert_eq(actual: locs.len(), expected: 2)?;
    let uris: Set<String> = Set.new();
    for l in locs {
        if let Some(u) = l.get('uri').as_string() { uris.add(u); }
    }
    testing.assert(uris.has(a_uri), message: 'declaration in a.hawk')?;
    testing.assert(uris.has(b_uri), message: 'use in the closed b.hawk')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// Rename is likewise project-wide: renaming `foo` rewrites both `a.hawk` (the
// declaration) and the closed `b.hawk` (a caller), so the edit is complete.
@test
fn test_rename_scans_on_disk_workspace_files() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_rename_scan_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let a_text = 'pub fn foo() -> Int { return 1; }\n';
    fs.write_text(dir + '/a.hawk', a_text)?;
    fs.write_text(dir + '/b.hawk', 'import \'a\';\nfn use_it() -> Int { return a.foo(); }\n')?;

    let analysis = new_analysis(Option.None);
    analysis.set_roots([dir]);
    let a_uri = paths.path_to_uri(dir + '/a.hawk');
    let b_uri = paths.path_to_uri(dir + '/b.hawk');
    analysis.set_document(a_uri, a_text, Option.None);

    let pos = obj(['line': int(0), 'character': int(8)]);
    let changes = match analysis.rename_at(a_uri, pos, 'bar') {
        Edit(e) => e.get('changes'),
        _ => return Result.Err(error('expected a WorkspaceEdit')),
    };
    testing.assert(!changes.is_null(), message: 'a WorkspaceEdit is produced')?;
    testing.assert(!changes.get(a_uri).is_null(), message: 'edits a.hawk (the declaration)')?;
    testing.assert(!changes.get(b_uri).is_null(), message: 'edits the closed b.hawk (a caller)')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// References/rename scope to the target's dependency cone but stay complete: a
// closed importer that was never loaded is still found (the forward graph is
// indexed over the whole scan before it's reversed), while an unrelated file that
// declares a same-named symbol without importing the target is excluded.
@test
fn test_references_cover_the_dependency_cone() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_cone_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let a_text = 'pub fn foo() -> Int { return 1; }\n';
    fs.write_text(dir + '/a.hawk', a_text)?;
    // b imports a and calls foo (a real reference in a never-opened file).
    fs.write_text(dir + '/b.hawk', 'import \'a\';\nfn use_it() -> Int { return a.foo(); }\n')?;
    // d declares its own `foo` and never imports a — a different symbol that must
    // not appear (it's outside the cone, and a distinct SymbolId regardless).
    fs.write_text(dir + '/d.hawk', 'fn foo() -> Int { return 2; }\n')?;

    let analysis = new_analysis(Option.None);
    analysis.set_roots([dir]);
    let a_uri = paths.path_to_uri(dir + '/a.hawk');
    let b_uri = paths.path_to_uri(dir + '/b.hawk');
    let d_uri = paths.path_to_uri(dir + '/d.hawk');
    analysis.set_document(a_uri, a_text, Option.None); // only a is open

    // References on `foo`'s declaration (line 0, char 8): the decl in a + the call
    // in the closed b — two occurrences — and nothing from d.
    let pos = obj(['line': int(0), 'character': int(8)]);
    let refs = analysis.references_at(a_uri, pos, true).as_array().unwrap_or([]);
    let uris: Set<String> = Set.new();
    for loc in refs {
        uris.add(loc.get('uri').as_string().unwrap_or(''));
    }
    testing.assert_eq(actual: refs.len(), expected: 2)?;
    testing.assert(uris.has(a_uri), message: 'includes the declaration in a.hawk')?;
    testing.assert(uris.has(b_uri), message: 'includes the closed importer b.hawk (cone is complete)')?;
    testing.assert(!uris.has(d_uri), message: 'excludes d.hawk (a same-named symbol outside the cone)')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The SDK is read-only to rename: renaming a symbol declared under `sdk/std`
// (reached by `import std.*`) is refused with a null result rather than a
// partial edit that rewrites callers but not the trusted library declaration.
@test
fn test_rename_of_an_sdk_symbol_is_refused() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_sdk_rename_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir + '/sdk/std/core')?;
    fs.create_dir_all(dir + '/sdk/std/mylib')?;
    fs.write_text(dir + '/sdk/std/core/core.hawk', '// empty prelude\n')?;
    fs.write_text(dir + '/sdk/std/mylib/mylib.hawk', 'pub fn thing() -> Int { return 1; }\n')?;
    let main_text = 'import std.mylib;\nfn f() -> Int { return mylib.thing(); }\n';
    fs.write_text(dir + '/main.hawk', main_text)?;

    let analysis = new_analysis(Option.Some(dir + '/sdk'));
    analysis.set_roots([dir]);
    let main_uri = paths.path_to_uri(dir + '/main.hawk');
    analysis.set_document(main_uri, main_text, Option.None);

    // Rename on `thing` in `mylib.thing()` (line 1, inside the name at char 31).
    let pos = obj(['line': int(1), 'character': int(31)]);
    match analysis.rename_at(main_uri, pos, 'renamed') {
        Decline => void,
        _ => return Result.Err(error('renaming an SDK symbol should be declined')),
    }

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The pre-flight collision check: renaming a top-level symbol onto a name already
// bound in the same file's one name space is a `Collision` (the checker would
// reject the edit on the next publish), while a fresh name is a clean `Edit`.
@test
fn test_rename_collision_is_flagged() -> Result<Void, Error> {
    let analysis = new_analysis(Option.None);
    let uri = 'file:///c.hawk';
    let text = 'fn foo() -> Int { return 1; }\nfn bar() -> Int { return 2; }\n';
    analysis.set_document(uri, text, Option.None);

    // Rename `foo` (line 0, inside its name at char 4) onto the existing `bar`.
    let pos = obj(['line': int(0), 'character': int(4)]);
    match analysis.rename_at(uri, pos, 'bar') {
        Collision(_) => void,
        _ => return Result.Err(error('renaming onto an existing top-level name should collide')),
    }
    // A fresh name has no clash — a normal edit.
    match analysis.rename_at(uri, pos, 'baz') {
        Edit(_) => void,
        _ => return Result.Err(error('renaming to a fresh name should produce an edit')),
    }
    return Result.Ok(void);
}

// An edit to an open dependency marks its open importers dirty (LD14 batch A):
// the server's next flush re-publishes `a`'s diagnostics after a `b` edit.
@test
fn test_dependency_edit_marks_importer_dirty() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_lsp_dirty_cone_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    if let Err(e) = fs.create_dir_all(dir) {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    let b_text = 'pub fn helper() -> Int { return 1; }\n';
    if let Err(e) = fs.write_text(dir + '/b.hawk', b_text) {
        return Result.Err(error('write b: ${e.message()}'));
    }
    let a_text = 'import \'b\';\nfn use_it() -> Int { return b.helper(); }\n';
    if let Err(e) = fs.write_text(dir + '/a.hawk', a_text) {
        return Result.Err(error('write a: ${e.message()}'));
    }

    let analysis = new_analysis(Option.None);
    let a_uri = paths.path_to_uri(dir + '/a.hawk');
    let b_uri = paths.path_to_uri(dir + '/b.hawk');
    analysis.set_document(a_uri, a_text, Option.None);
    analysis.set_document(b_uri, b_text, Option.None);
    // Analyze once so the session's import graph knows a -> b, then drain.
    let _seed = analysis.diagnostics(a_uri, a_text);
    let _drained = analysis.take_dirty();

    // Editing `b` dirties both `b` and its open importer `a`.
    analysis.set_document(b_uri, 'pub fn renamed() -> Int { return 1; }\n', Option.None);
    let dirty = analysis.take_dirty();
    testing.assert(dirty.contains(b_uri), message: 'edited doc is dirty')?;
    testing.assert(dirty.contains(a_uri), message: 'open importer is dirty')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}
