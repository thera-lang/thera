// Tests for the LSP dispatch: drive `Server.handle` with a request/notification
// body and capture the framed output through an in-memory `StringWriter`, so the
// real JSON-RPC + diagnostics path runs end to end without a process or sockets.

import std.testing;
import std.io;

import 'server' as _;
import 'jsonrpc';
import 'paths';
import '../ast/ast' as _; // Decl
import '../loader';
import '../lexer/lexer';
import '../parser/parser';

// A one-shot in-memory `Reader`: hands out `data` in `max`-sized chunks, then
// EOF — so `serve`'s read loop can be driven without a real stream.
struct BurstReader { let data: Bytes; let mut pos: Int; }
impl io.Reader for BurstReader {
    pub fn read(self, max: Int) -> Result<Bytes, Error> {
        let end = (self.pos + max).min(self.data.len());
        let chunk = self.data.slice(self.pos, end);
        self.pos = end;
        return Result.Ok(chunk);
    }
}

// Count non-overlapping occurrences of `needle` in `haystack`.
fn count_substr(_ haystack: String, _ needle: String) -> Int {
    if needle.is_empty() {
        return 0;
    }
    let mut count = 0;
    let mut hay = haystack;
    let mut going = true;
    while going {
        match hay.find(needle) {
            Some(i) => {
                count = count + 1;
                hay = hay.slice(i + needle.len(), hay.len());
            },
            None => { going = false; },
        }
    }
    return count;
}

// Run one message through a fresh server and return everything it wrote.
fn handled(_ body: String) -> String {
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, body);
    return out.into_string().unwrap_or('');
}

@test
fn test_initialize_advertises_capabilities() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    testing.assert(out.contains('Content-Length:'), message: 'framed reply')?;
    testing.assert(out.contains('"capabilities"'), message: 'has capabilities')?;
    testing.assert(out.contains('textDocumentSync'), message: 'declares document sync')?;
    testing.assert(out.contains('"id":1') || out.contains('"id": 1'), message: 'echoes the id')?;
    return Result.Ok(void);
}

@test
fn test_initialize_captures_workspace_folders() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"workspaceFolders":[{"uri":"file:///home/proj","name":"proj"},'
        + '{"uri":"file:///home/lib","name":"lib"}]}}');
    let roots = server.analysis.roots();
    testing.assert_eq(actual: roots.len(), expected: 2)?;
    testing.assert_eq(actual: roots[0], expected: '/home/proj')?;
    testing.assert_eq(actual: roots[1], expected: '/home/lib')?;
    return Result.Ok(void);
}

@test
fn test_initialize_falls_back_to_root_uri() -> Result<Void, Error> {
    // A folder-less/older client sends `rootUri` instead of `workspaceFolders`.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file:///home/proj"}}');
    let roots = server.analysis.roots();
    testing.assert_eq(actual: roots.len(), expected: 1)?;
    testing.assert_eq(actual: roots[0], expected: '/home/proj')?;
    return Result.Ok(void);
}

@test
fn test_initialize_without_folders_has_no_roots() -> Result<Void, Error> {
    // A loose single file (no folder) sends neither — references/rename stay
    // scoped to the open documents.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    testing.assert_eq(actual: server.analysis.roots().len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_did_open_publishes_diagnostics() -> Result<Void, Error> {
    // The program references an undefined name, which the checker flags even
    // without the prelude linked (a pure scope check).
    let body = '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///x.hawk","text":"fn f() -> Int { return missing; }"}}}';
    let out = handled(body);
    testing.assert(out.contains('textDocument/publishDiagnostics'), message: 'publishes diagnostics')?;
    testing.assert(out.contains('undefined name: missing'), message: 'reports the error')?;
    testing.assert(out.contains('file:///x.hawk'), message: 'for the right document')?;
    return Result.Ok(void);
}

@test
fn test_clean_document_publishes_empty_diagnostics() -> Result<Void, Error> {
    let body = '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///ok.hawk","text":"fn add(_ a: Int, _ b: Int) -> Int { return a + b; }"}}}';
    let out = handled(body);
    testing.assert(out.contains('textDocument/publishDiagnostics'), message: 'still publishes')?;
    testing.assert(out.contains('"diagnostics":[]') || out.contains('"diagnostics": []'),
        message: 'with no diagnostics')?;
    return Result.Ok(void);
}

@test
fn test_document_symbol_outline() -> Result<Void, Error> {
    // didOpen populates the document store; documentSymbol then reads it back.
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///s.hawk",'
        + '"text":"pub fn greet() -> Int { return 1; }\\nenum Color { Red, Green }"}}}');

    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":3,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///s.hawk"}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('selectionRange'), message: 'is a symbol response')?;
    testing.assert(out.contains('"greet"'), message: 'has the function')?;
    testing.assert(out.contains('"Color"'), message: 'has the enum')?;
    testing.assert(out.contains('"Red"'), message: 'nests the enum variant')?;
    return Result.Ok(void);
}

@test
fn test_document_symbol_unknown_doc_is_empty() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":4,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///nope.hawk"}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'empty outline for an unopened document')?;
    return Result.Ok(void);
}

@test
fn test_hover_shows_declaration_signature() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///h.hawk",'
        + '"text":"pub fn greet(_ n: String) -> String { return n; }"}}}');

    // Hover on `greet` (line 0, character 8 falls inside the name).
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":5,"method":"textDocument/hover","params":'
        + '{"textDocument":{"uri":"file:///h.hawk"},"position":{"line":0,"character":8}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('fn greet'), message: 'shows the signature')?;
    testing.assert(out.contains('String'), message: 'shows the types')?;
    return Result.Ok(void);
}

@test
fn test_hover_on_a_keyword_is_null() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///h.hawk","text":"pub fn greet() -> Int { return 1; }"}}}');

    // Character 0 is the `pub` keyword — not an identifier, so no hover.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":6,"method":"textDocument/hover","params":'
        + '{"textDocument":{"uri":"file:///h.hawk"},"position":{"line":0,"character":0}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'no hover on a keyword')?;
    return Result.Ok(void);
}

@test
fn test_definition_jumps_to_declaration() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///d.hawk",'
        + '"text":"fn helper() -> Int { return 1; }\\nfn main() -> Int { return helper(); }"}}}');

    // Go-to-definition on the `helper` call (line 1, inside the name) lands on
    // the `helper` declaration up on line 0.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":7,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///d.hawk"},"position":{"line":1,"character":28}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('file:///d.hawk'), message: 'returns a location in the file')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'points at the declaration on line 0')?;
    return Result.Ok(void);
}

@test
fn test_definition_on_unknown_is_null() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///d.hawk","text":"fn main() -> Int { return 1; }"}}}');
    // Character 0 is the `fn` keyword — no identifier, no definition.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":8,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///d.hawk"},"position":{"line":0,"character":0}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'no definition for a keyword')?;
    return Result.Ok(void);
}

@test
fn test_references_are_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    // Two functions, each with a local `x`; `f`'s `x` is used twice, `g`'s once.
    // A references request on `f`'s `x` must return only `f`'s three occurrences
    // (decl + 2 uses) — NOT `g`'s, which a lexical match would wrongly include.
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.hawk",'
        + '"text":"fn f() -> Int { let x = 1; return x + x; }\\nfn g() -> Int { let x = 9; return x; }"}}}');

    // References on `f`'s `x` in `return x + x` (line 0, character 34).
    let with_decl = io.StringWriter.new();
    server.handle(with_decl, '{"jsonrpc":"2.0","id":20,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":34},'
        + '"context":{"includeDeclaration":true}}}');
    let out = with_decl.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(out, '"range"'), expected: 3)?;

    // Excluding the declaration: the two uses only.
    let no_decl = io.StringWriter.new();
    server.handle(no_decl, '{"jsonrpc":"2.0","id":21,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":34},'
        + '"context":{"includeDeclaration":false}}}');
    testing.assert_eq(actual: count_substr(no_decl.into_string().unwrap_or(''), '"range"'), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_rename_is_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.hawk",'
        + '"text":"fn f() -> Int { let x = 1; return x + x; }\\nfn g() -> Int { let x = 9; return x; }"}}}');

    // Rename `f`'s `x` (line 0, character 34) to `y`: its declaration + two uses
    // = three edits; `g`'s `x` is a different binding and must be untouched.
    let renamed = io.StringWriter.new();
    server.handle(renamed, '{"jsonrpc":"2.0","id":30,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":34},"newName":"y"}}');
    let out = renamed.into_string().unwrap_or('');
    testing.assert(out.contains('"changes"'), message: 'returns a WorkspaceEdit')?;
    testing.assert_eq(actual: count_substr(out, '"newText"'), expected: 3)?;
    return Result.Ok(void);
}

@test
fn test_definition_navigates_to_a_field() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///f.hawk",'
        + '"text":"struct S { let n: Int; }\\nimpl S { fn get(self) -> Int { return self.n; } }"}}}');
    // Go-to-definition on the `n` of `self.n` (line 1, char 43) lands on the field
    // declaration up on line 0.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":40,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///f.hawk"},"position":{"line":1,"character":43}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('file:///f.hawk'), message: 'returns a location in the file')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'points at the field declaration on line 0')?;
    return Result.Ok(void);
}

@test
fn test_rename_renames_a_field() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///f.hawk",'
        + '"text":"struct S { let n: Int; }\\nfn mk() -> S { return S { n: 1 }; }'
        + '\\nimpl S { fn get(self) -> Int { return self.n; } }"}}}');
    // A field now has full symbol identity, so renaming one rewrites its whole
    // identity in one edit: the declaration (line 0), the `S { n: … }` literal use
    // (line 1), and the `self.n` member access (line 2) — no longer declined.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":41,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///f.hawk"},"position":{"line":2,"character":43},"newName":"m"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(!out.contains('"result":null') && !out.contains('"result": null'),
        message: 'a field rename is not declined')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'rewrites the field declaration on line 0')?;
    testing.assert(out.contains('"line":1') || out.contains('"line": 1'),
        message: 'rewrites the struct-literal field on line 1')?;
    testing.assert(out.contains('"line":2') || out.contains('"line": 2'),
        message: 'rewrites the member access on line 2')?;
    return Result.Ok(void);
}

@test
fn test_references_to_a_field_are_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    // Two structs each with a field `n`; only `A`'s is referenced (`a.n`). A
    // references request on `A.n` must return just `A`'s occurrences (decl + the
    // member access) — NOT `B.n`, which a lexical match would wrongly include.
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.hawk",'
        + '"text":"struct A { let n: Int; }\\nstruct B { let n: Int; }'
        + '\\nfn use_a(_ a: A) -> Int { return a.n; }"}}}');
    // References on `A`'s field declaration (line 0, character 15 — the `n` in
    // `struct A { let n: Int; }`).
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":22,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":15},'
        + '"context":{"includeDeclaration":true}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(out, '"range"'), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_rename_collision_is_an_error() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.hawk",'
        + '"text":"fn foo() -> Int { return 1; }\\nfn bar() -> Int { return 2; }"}}}');
    // Rename the top-level `foo` (line 0, character 4) onto the existing `bar`:
    // an error response, not a silent null result, so the editor shows the reason.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":32,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":4},"newName":"bar"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"error"'), message: 'a collision is an error response')?;
    testing.assert(!out.contains('"result"'), message: 'no WorkspaceEdit result is emitted')?;
    testing.assert(out.contains('already bound'), message: 'the reason names the collision')?;
    return Result.Ok(void);
}

@test
fn test_rename_to_a_keyword_is_rejected() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.hawk","text":"fn f() -> Int { let x = 1; return x; }"}}}');
    // `x`'s declaration is at line 0, character 20; renaming it to `fn` is invalid.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":31,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.hawk"},"position":{"line":0,"character":20},"newName":"fn"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'renaming to a keyword yields no edit')?;
    return Result.Ok(void);
}

@test
fn test_shutdown_responds_null() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":9,"method":"shutdown"}');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'null result')?;
    return Result.Ok(void);
}

// Handle one message on an existing server (preserving its document state) and
// return everything it wrote — for multi-message flows (open, then edit/close).
fn capture(_ server: Server, _ body: String) -> String {
    let out = io.StringWriter.new();
    server.handle(out, body);
    return out.into_string().unwrap_or('');
}

@test
fn test_did_change_republishes_diagnostics() -> Result<Void, Error> {
    // Open a clean document, then edit it (full-sync `didChange`) to introduce an
    // error; the server must re-check and publish the new diagnostic.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///e.hawk","text":"fn add(_ a: Int, _ b: Int) -> Int { return a + b; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///e.hawk"},'
        + '"contentChanges":[{"text":"fn f() -> Int { return missing; }"}]}}');
    testing.assert(out.contains('textDocument/publishDiagnostics'), message: 'republishes on edit')?;
    testing.assert(out.contains('undefined name: missing'), message: 'reflects the new text')?;
    return Result.Ok(void);
}

@test
fn test_publish_echoes_the_document_version() -> Result<Void, Error> {
    // A client-supplied document version is echoed on publishDiagnostics so the
    // client can discard results for a superseded revision (LS9). didChange with
    // a newer version updates the echo.
    let server = new_server(Option.None);
    let opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///v.hawk","version":3,"text":"fn f() -> Int { return 1; }"}}}');
    testing.assert(opened.contains('"version":3') || opened.contains('"version": 3'),
        message: 'echoes the didOpen version')?;
    let changed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///v.hawk","version":7},'
        + '"contentChanges":[{"text":"fn f() -> Int { return missing; }"}]}}');
    testing.assert(changed.contains('"version":7') || changed.contains('"version": 7'),
        message: 'echoes the newer didChange version')?;
    return Result.Ok(void);
}

@test
fn test_did_close_removes_document() -> Result<Void, Error> {
    // After `didClose` the document is forgotten, so a later documentSymbol over
    // it yields the empty (unknown-document) outline.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///g.hawk","text":"fn solo() -> Int { return 1; }"}}}');
    let _closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"file:///g.hawk"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":10,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///g.hawk"}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'closed document has no outline')?;
    return Result.Ok(void);
}

@test
fn test_exit_stops_the_serve_loop() -> Result<Void, Error> {
    // The `exit` notification returns false, which is how `serve` leaves its loop.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    let keep_going = server.handle(out, '{"jsonrpc":"2.0","method":"exit"}');
    testing.assert(!keep_going, message: 'exit stops serving')?;
    return Result.Ok(void);
}

@test
fn test_serve_coalesces_a_burst_of_edits() -> Result<Void, Error> {
    // A didOpen plus five didChange for one document, all delivered in a single
    // read. `serve` drains the whole burst, applying each edit but deferring
    // diagnostics, then publishes once — not once per message.
    let uri = 'file:///burst.hawk';
    let mut stream = jsonrpc.frame('{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"' + uri + '","text":"fn f() -> Int { return 0; }"}}}');
    let mut i = 1;
    while i <= 5 {
        stream = stream + jsonrpc.frame('{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
            + '{"textDocument":{"uri":"' + uri + '"},'
            + '"contentChanges":[{"text":"fn f() -> Int { return ${i}; }"}]}}');
        i = i + 1;
    }
    let reader = BurstReader { data: stream.bytes(), pos: 0 };
    let out = io.StringWriter.new();
    serve(reader, out, Option.None);
    let text = out.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(text, 'textDocument/publishDiagnostics'), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_did_change_evicts_the_parse_cache() -> Result<Void, Error> {
    // The cross-request parse cache keeps imported files parsed across keystrokes,
    // but an edited file's entry must be dropped so a later check (where the file
    // is someone's import) sees the change. Seed the cache as if `c.hawk` had been
    // loaded as an import, then edit it: the stale seed must be gone — the entry
    // the diagnostics flush re-caches holds the *edit's* parse (R1: the primary
    // parses through the cache).
    let server = new_server(Option.None);
    let path = paths.uri_to_path('file:///c.hawk');
    let prog = parser.parse_tokens(lexer.tokenize('fn g() -> Int { return 1; }').tokens).program;
    server.analysis.session.parse_cache[path] = loader.ParsedFile { program: prog, diagnostics: [] };
    testing.assert(server.analysis.session.parse_cache.get(path).is_some(), message: 'seed is cached')?;

    server.handle(io.StringWriter.new(),
        '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///c.hawk"},'
        + '"contentChanges":[{"text":"fn h() -> Int { return 2; }"}]}}');
    match server.analysis.session.parse_cache.get(path) {
        Some(pf) => {
            testing.assert_eq(actual: pf.program.decls.len(), expected: 1)?;
            match pf.program.decls[0] {
                Fn(f) => { testing.assert_eq(actual: f.name, expected: 'h')?; },
                _ => { testing.assert(false, message: 'expected a fn decl')?; },
            }
        },
        None => { testing.assert(false, message: 'the flush re-caches the new parse')?; },
    }
    return Result.Ok(void);
}

@test
fn test_unknown_request_gets_method_not_found() -> Result<Void, Error> {
    // An unhandled *request* (has an id) gets a MethodNotFound error, so the
    // client never hangs waiting (and never mistakes it for a null result);
    // a notification (no id) is silently dropped.
    let out = handled('{"jsonrpc":"2.0","id":11,"method":"textDocument/completion","params":{}}');
    testing.assert(out.contains('"id":11') || out.contains('"id": 11'), message: 'echoes the id')?;
    testing.assert(out.contains('-32601'), message: 'replies with MethodNotFound')?;
    testing.assert(out.contains('textDocument/completion'), message: 'names the method')?;
    let dropped = handled('{"jsonrpc":"2.0","method":"textDocument/somethingNew","params":{}}');
    testing.assert_eq(actual: dropped, expected: '')?;
    return Result.Ok(void);
}

@test
fn test_unparseable_body_gets_parse_error() -> Result<Void, Error> {
    // A body that isn't JSON gets a ParseError response (id null) rather than
    // a silent drop.
    let out = handled('{oops');
    testing.assert(out.contains('-32700'), message: 'replies with ParseError')?;
    testing.assert(out.contains('"id":null') || out.contains('"id": null'),
        message: 'null id: the request id is unknowable')?;
    return Result.Ok(void);
}

@test
fn test_requests_after_shutdown_are_rejected() -> Result<Void, Error> {
    // Between `shutdown` and `exit` only `exit` is meaningful: further
    // requests are answered with InvalidRequest, and `exit` still stops the
    // loop.
    let server = new_server(Option.None);
    let _down = capture(server, '{"jsonrpc":"2.0","id":12,"method":"shutdown"}');
    let out = capture(server, '{"jsonrpc":"2.0","id":13,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///x.hawk"}}}');
    testing.assert(out.contains('-32600'), message: 'request after shutdown is invalid')?;
    let keep_going = server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","method":"exit"}');
    testing.assert(!keep_going, message: 'exit still stops serving')?;
    return Result.Ok(void);
}

@test
fn test_did_close_clears_diagnostics() -> Result<Void, Error> {
    // Closing a document publishes an empty diagnostics array for it — the
    // editor releases its squiggles (previously they persisted forever).
    let server = new_server(Option.None);
    let opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///stale.hawk","text":"fn f() -> Int { return missing; }"}}}');
    testing.assert(opened.contains('undefined name: missing'), message: 'opens with an error')?;
    let closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"file:///stale.hawk"}}}');
    testing.assert(closed.contains('textDocument/publishDiagnostics'), message: 'publishes on close')?;
    testing.assert(closed.contains('file:///stale.hawk'), message: 'for the closed document')?;
    testing.assert(closed.contains('"diagnostics":[]') || closed.contains('"diagnostics": []'),
        message: 'with no diagnostics')?;
    return Result.Ok(void);
}

@test
fn test_code_action_offers_if_let() -> Result<Void, Error> {
    // A convertible `match` in the range yields a `refactor.rewrite` code action
    // whose workspace edit rewrites it to `if let`.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///a.hawk","text":'
        + '"fn f(_ o: Option<Int>) { match o { Some(v) => { g(v); }, None => {} } }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":20,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///a.hawk"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('Convert `match` to `if let`'), message: 'offers the rewrite')?;
    testing.assert(out.contains('refactor.rewrite'), message: 'is a rewrite action')?;
    testing.assert(out.contains('if let Some(v) = o'), message: 'edit rewrites to if let')?;
    return Result.Ok(void);
}

@test
fn test_code_action_empty_when_nothing_convertible() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///b.hawk","text":"fn f() -> Int { return 1; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":21,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///b.hawk"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":20}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'no actions offered')?;
    return Result.Ok(void);
}

@test
fn test_code_action_offers_unwrap_or() -> Result<Void, Error> {
    // A value-fallback `match` yields an `unwrap_or` rewrite.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///c.hawk","text":'
        + '"fn f(_ o: Option<Int>) -> Int { return match o { Some(v) => v, None => 0 }; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":22,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///c.hawk"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('Convert `match` to `unwrap_or`'), message: 'offers unwrap_or')?;
    testing.assert(out.contains('o.unwrap_or(0)'), message: 'edit rewrites to unwrap_or')?;
    return Result.Ok(void);
}

// A convertible document + a codeAction request narrowed by `context.only`.
fn code_action_with_only(_ only: String) -> String {
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///only.hawk","text":'
        + '"fn f(_ o: Option<Int>) { match o { Some(v) => { g(v); }, None => {} } }"}}}');
    return capture(server, '{"jsonrpc":"2.0","id":30,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///only.hawk"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[],"only":[' + only + ']}}}');
}

@test
fn test_code_action_only_refactor_ancestor_offers() -> Result<Void, Error> {
    // `refactor` is a `.`-separated ancestor of our `refactor.rewrite` kind.
    let out = code_action_with_only('"refactor"');
    testing.assert(out.contains('refactor.rewrite'), message: 'ancestor kind admits the rewrite')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_exact_kind_offers() -> Result<Void, Error> {
    let out = code_action_with_only('"refactor.rewrite"');
    testing.assert(out.contains('refactor.rewrite'), message: 'exact kind admits the rewrite')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_quickfix_is_empty() -> Result<Void, Error> {
    // An unrelated requested kind filters out our refactor.
    let out = code_action_with_only('"quickfix"');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'quickfix-only request offers nothing')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_sibling_kind_is_empty() -> Result<Void, Error> {
    // A sibling under `refactor` is not an ancestor of `refactor.rewrite`.
    let out = code_action_with_only('"refactor.extract"');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'sibling refactor kind offers nothing')?;
    return Result.Ok(void);
}
