// Tests for the LSP's minimal glob matcher (glob.hawk).

import std.testing;

import 'glob';

@test
fn test_double_star_matches_across_segments() -> Result<Void, Error> {
    testing.assert(glob.matches('tests/lang/**', 'tests/lang/foo.hawk'),
        message: 'a file directly under the dir')?;
    testing.assert(glob.matches('tests/lang/**', 'tests/lang/sub/bar.hawk'),
        message: 'a file in a nested dir (** crosses /)')?;
    testing.assert(!glob.matches('tests/lang/**', 'pkgs/cli/foo.hawk'),
        message: 'an unrelated path does not match')?;
    testing.assert(!glob.matches('tests/lang/**', 'tests/langx/foo.hawk'),
        message: 'a sibling prefix does not match')?;
    return Result.Ok(void);
}

/// `prunes_dir` decides whether a whole subtree can be skipped. Its safety
/// property: it may only say yes when *every* path under the directory matches
/// the pattern, so pruning drops exactly what filtering would have dropped.
@test
fn test_prunes_dir_only_for_whole_subtree_patterns() -> Result<Void, Error> {
    testing.assert(glob.prunes_dir('runtime/target/**', 'runtime/target'),
        message: 'a `<base>/**` pattern excludes everything under base')?;
    testing.assert(glob.prunes_dir('**/target/**', 'runtime/target'),
        message: 'the base itself may contain wildcards')?;
    testing.assert(!glob.prunes_dir('runtime/target/**', 'runtime'),
        message: 'a parent of the excluded dir is not pruned')?;
    testing.assert(!glob.prunes_dir('runtime/target/**', 'runtime/targetx'),
        message: 'a sibling prefix is not pruned')?;

    // The conservative half: these exclude *some* files under the directory, so
    // pruning it would hide files the filter keeps. Better to walk and filter.
    testing.assert(!glob.prunes_dir('tests/lang/*.hawk', 'tests/lang'),
        message: 'a per-file pattern must not prune the directory')?;
    testing.assert(!glob.prunes_dir('tests/lang', 'tests/lang'),
        message: 'a bare dir pattern matches no file, so it prunes nothing')?;
    return Result.Ok(void);
}

/// The property that makes pruning safe, checked directly: everything under a
/// pruned directory is excluded by the same pattern anyway.
@test
fn test_prunes_dir_agrees_with_matches() -> Result<Void, Error> {
    let pattern = 'runtime/target/**';
    testing.assert(glob.prunes_dir(pattern, 'runtime/target'), message: 'prunes')?;
    for p in ['runtime/target/a.hawk', 'runtime/target/deps/b.hawk',
        'runtime/target/x/y/z/c.hawk'] {
        testing.assert(glob.matches(pattern, p),
            message: 'a pruned subtree file is excluded anyway: ' + p)?;
    }
    return Result.Ok(void);
}

@test
fn test_single_star_stops_at_separator() -> Result<Void, Error> {
    testing.assert(glob.matches('src/*.hawk', 'src/main.hawk'),
        message: '* matches within a segment')?;
    testing.assert(!glob.matches('src/*.hawk', 'src/sub/main.hawk'),
        message: '* does not cross /')?;
    return Result.Ok(void);
}

@test
fn test_question_and_literals() -> Result<Void, Error> {
    testing.assert(glob.matches('a?c', 'abc'), message: '? matches one char')?;
    testing.assert(!glob.matches('a?c', 'a/c'), message: '? does not match /')?;
    testing.assert(glob.matches('exact/name.hawk', 'exact/name.hawk'),
        message: 'a literal path matches itself')?;
    testing.assert(!glob.matches('exact/name.hawk', 'exact/other.hawk'),
        message: 'a literal path is exact')?;
    return Result.Ok(void);
}

@test
fn test_double_star_middle() -> Result<Void, Error> {
    testing.assert(glob.matches('a/**/b.hawk', 'a/b.hawk'),
        message: 'the spanned segment is optional')?;
    testing.assert(glob.matches('a/**/b.hawk', 'a/x/y/b.hawk'),
        message: 'the spanned segment can be several deep')?;
    return Result.Ok(void);
}
