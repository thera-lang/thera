// Tests for the JSON-RPC framing helpers (the pure parts of the transport).

import std.testing;
import std.io;

import 'jsonrpc' as _;

// An in-memory `Reader` that hands out `data` in `max`-sized chunks, so the
// read loop can be driven without a real stream (empty read = EOF).
struct FakeReader { data: Bytes, mut pos: Int }
impl io.Reader for FakeReader {
    pub fn read(self, max: Int) -> Result<Bytes, Error> {
        let end = (self.pos + max).min(self.data.len());
        let chunk = self.data.slice(self.pos, end);
        self.pos = end;
        return Result.Ok(chunk);
    }
}

@test
fn test_read_message_loop() -> Result<Void, Error> {
    // Two framed messages back to back, then EOF.
    let input = '${frame('{"a":1}')}${frame('{"b":2}')}';
    let reader = FakeReader { data: input.bytes(), pos: 0 };
    let buf = new_buffer();
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.Some('{"a":1}'))?;
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.Some('{"b":2}'))?;
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_find_header_end_locates_body() -> Result<Void, Error> {
    let buf = 'Content-Length: 5\r\n\r\nhello'.bytes();
    match find_header_end(buf) {
        Some(pos) => {
            let body = buf.slice(pos, buf.len()).to_string().unwrap_or('');
            testing.assert_eq(actual: body, expected: 'hello')?;
        },
        None => {
            testing.assert(false, message: 'header terminator not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_find_header_end_incomplete() -> Result<Void, Error> {
    // No blank line yet -> the header isn't complete.
    testing.assert_eq(actual: find_header_end('Content-Length: 5\r\n'.bytes()),
        expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_parse_content_length() -> Result<Void, Error> {
    testing.assert_eq(actual: parse_content_length('Content-Length: 42\r\n'),
        expected: Option.Some(42))?;
    // The header name is case-insensitive.
    testing.assert_eq(actual: parse_content_length('content-length: 7'),
        expected: Option.Some(7))?;
    // No Content-Length present.
    testing.assert_eq(actual: parse_content_length('Content-Type: x\r\n'),
        expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_frame_prefixes_byte_length() -> Result<Void, Error> {
    testing.assert_eq(actual: frame('hi'), expected: 'Content-Length: 2\r\n\r\nhi')?;
    return Result.Ok(void);
}

// A header block that can never frame a body (unparseable, negative, or
// missing Content-Length) is dropped and the next message still gets through
// — previously it wedged the stream forever, buffering input without ever
// yielding a message (LS9).
@test
fn test_malformed_content_length_recovers() -> Result<Void, Error> {
    let input = 'Content-Length: abc\r\n\r\n${frame('{"a":1}')}';
    let reader = FakeReader { data: input.bytes(), pos: 0 };
    let buf = new_buffer();
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.Some('{"a":1}'))?;
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_missing_content_length_recovers() -> Result<Void, Error> {
    let input = 'Content-Type: application/json\r\n\r\n${frame('{"b":2}')}';
    let reader = FakeReader { data: input.bytes(), pos: 0 };
    let buf = new_buffer();
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.Some('{"b":2}'))?;
    return Result.Ok(void);
}

@test
fn test_negative_content_length_is_malformed() -> Result<Void, Error> {
    testing.assert_eq(actual: parse_content_length('Content-Length: -5\r\n'),
        expected: Option.None)?;
    let input = 'Content-Length: -5\r\n\r\n${frame('{"c":3}')}';
    let reader = FakeReader { data: input.bytes(), pos: 0 };
    let buf = new_buffer();
    testing.assert_eq(actual: buf.read_message(reader), expected: Option.Some('{"c":3}'))?;
    return Result.Ok(void);
}
