// Tests for workspace file discovery: the pure prune predicate, plus a real
// on-disk walk under a temp tree to confirm `.thera` files are found and the
// `build`/dot-directory subtrees are skipped.

import std.testing;
import std.fs;
import std.path;

import 'workspace' as _;

// A fresh, empty directory under the system temp dir (pre-cleaned).
fn workspace_dir(_ name: String) -> Result<String, Error> {
    let dir = path.join(fs.temp_dir(), name);
    match fs.remove_dir_all(dir) {
        Ok(_) => void,
        Err(_) => void,
    }
    fs.create_dir_all(dir)?;
    return Result.Ok(dir);
}

@test
fn test_skip_dir_prunes_build_and_dot_dirs() -> Result<Void, Error> {
    testing.assert(skip_dir('build'), message: 'build output')?;
    testing.assert(skip_dir('.git'), message: 'version control')?;
    testing.assert(skip_dir('.dart_tool'), message: 'tool cache')?;
    testing.assert(!skip_dir('src'), message: 'a normal source dir')?;
    testing.assert(!skip_dir('runtime'), message: 'a normal dir')?;
    return Result.Ok(void);
}

@test
fn test_thera_files_walks_and_prunes() -> Result<Void, Error> {
    let root = workspace_dir('thera_ws_scan')?;
    // A nested source tree, plus noise directories that must be pruned.
    fs.create_dir_all(path.join(root, 'sub'))?;
    fs.create_dir_all(path.join(root, 'build'))?;
    fs.create_dir_all(path.join(root, '.git'))?;
    fs.write_text(path.join(root, 'a.thera'), 'fn a() {}')?;
    fs.write_text(path.join(path.join(root, 'sub'), 'b.thera'), 'fn b() {}')?;
    fs.write_text(path.join(root, 'notes.txt'), 'not thera')?;
    fs.write_text(path.join(path.join(root, 'build'), 'gen.thera'), 'fn g() {}')?;
    fs.write_text(path.join(path.join(root, '.git'), 'hook.thera'), 'fn h() {}')?;

    let files = thera_files([root], prune: no_prune);
    testing.assert_eq(actual: files.len(), expected: 2)?;
    let found: Set<String> = Set.new();
    for f in files { found.add(f); }
    testing.assert(found.has(path.join(root, 'a.thera')), message: 'top-level source')?;
    testing.assert(found.has(path.join(path.join(root, 'sub'), 'b.thera')), message: 'nested source')?;

    fs.remove_dir_all(root)?;
    return Result.Ok(void);
}

/// A caller's `prune` skips a whole subtree — what `thera.exclude` uses to keep a
/// build tree out of the walk rather than walking it and discarding every file.
@test
fn test_thera_files_honors_caller_prune() -> Result<Void, Error> {
    let root = workspace_dir('thera_ws_prune')?;
    fs.create_dir_all(path.join(root, 'keep'))?;
    fs.create_dir_all(path.join(path.join(root, 'skipped'), 'nested'))?;
    fs.write_text(path.join(path.join(root, 'keep'), 'a.thera'), 'fn a() {}')?;
    fs.write_text(path.join(path.join(root, 'skipped'), 'b.thera'), 'fn b() {}')?;
    fs.write_text(path.join(path.join(path.join(root, 'skipped'), 'nested'), 'c.thera'),
        'fn c() {}')?;

    // Pruned by full path, and the whole subtree goes — `nested/c.thera` too.
    let files = thera_files([root], prune: (d) => path.basename(d) == 'skipped');
    testing.assert_eq(actual: files.len(), expected: 1)?;
    testing.assert(files[0].ends_with('a.thera'), message: 'only the unpruned source')?;

    fs.remove_dir_all(root)?;
    return Result.Ok(void);
}

@test
fn test_thera_files_dedupes_overlapping_roots() -> Result<Void, Error> {
    let root = workspace_dir('thera_ws_dedupe')?;
    fs.write_text(path.join(root, 'x.thera'), 'fn x() {}')?;
    // The same root twice yields the file once, not twice.
    let files = thera_files([root, root], prune: no_prune);
    testing.assert_eq(actual: files.len(), expected: 1)?;
    fs.remove_dir_all(root)?;
    return Result.Ok(void);
}

@test
fn test_thera_files_empty_when_no_roots() -> Result<Void, Error> {
    testing.assert_eq(actual: thera_files([], prune: no_prune).len(), expected: 0)?;
    return Result.Ok(void);
}
