// Tests for the LSP dispatch: drive `Server.handle` with a request/notification
// body and capture the framed output through an in-memory `StringWriter`, so the
// real JSON-RPC + diagnostics path runs end to end without a process or sockets.

import std.testing;
import std.io;
import std.fs;
import std.json;

import 'server' as _;
import 'jsonrpc';
import 'paths';
import '../loader';
import '../lexer/lexer';
import '../parser/parser';

// A one-shot in-memory `Reader`: hands out `data` in `max`-sized chunks, then
// EOF — so `serve`'s read loop can be driven without a real stream.
struct BurstReader { let data: Bytes; let mut pos: Int; }
impl io.Reader for BurstReader {
    pub fn read(self, max: Int) -> Result<Bytes, Error> {
        let end = (self.pos + max).min(self.data.len());
        let chunk = self.data.slice(self.pos, end);
        self.pos = end;
        return Result.Ok(chunk);
    }
}

// Count non-overlapping occurrences of `needle` in `haystack`.
fn count_substr(_ haystack: String, _ needle: String) -> Int {
    if needle.is_empty() {
        return 0;
    }
    let mut count = 0;
    let mut hay = haystack;
    let mut going = true;
    while going {
        match hay.find(needle) {
            Some(i) => {
                count = count + 1;
                hay = hay.slice(i + needle.len(), hay.len());
            },
            None => { going = false; },
        }
    }
    return count;
}

// Drive `serve` over a stream of already-framed messages (a `BurstReader` that
// then EOFs) and return everything the server wrote. Unlike `handled`/`capture`
// (which go through the synchronous `handle`), this runs the real async transport:
// the background workspace worker and the writer fiber, drained on the `exit`/EOF.
fn served(_ frames: String) -> String {
    let reader = BurstReader { data: frames.bytes(), pos: 0 };
    let out = io.StringWriter.new();
    serve(reader, out, Option.None);
    return out.into_string().unwrap_or('');
}

// Run one message through a fresh server and return everything it wrote.
fn handled(_ body: String) -> String {
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, body);
    return out.into_string().unwrap_or('');
}

@test
fn test_initialize_advertises_capabilities() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    testing.assert(out.contains('Content-Length:'), message: 'framed reply')?;
    testing.assert(out.contains('"capabilities"'), message: 'has capabilities')?;
    testing.assert(out.contains('textDocumentSync'), message: 'declares document sync')?;
    testing.assert(out.contains('diagnosticProvider'), message: 'declares pull diagnostics')?;
    testing.assert(out.contains('workspaceDiagnostics'), message: 'declares workspace diagnostics')?;
    testing.assert(out.contains('"id":1') || out.contains('"id": 1'), message: 'echoes the id')?;
    return Result.Ok(void);
}

// A `workspace/diagnostic` pull reports every workspace file's own diagnostics,
// including files that were never opened — the project-wide behavior. A file with
// an error yields a full report with items; a clean file a full report with none.
@test
fn test_workspace_diagnostic_covers_unopened_files() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_ws_diag_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/good.thera', 'fn ok() -> Int { return 1; }\n')?;
    // An undefined name — a pure scope error the checker flags without a prelude.
    fs.write_text(dir + '/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    // No didOpen — the workspace pull must still analyze both files.
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    let body = out.into_string().unwrap_or('');
    testing.assert(body.contains('bad.thera'), message: 'reports the unopened bad.thera')?;
    testing.assert(body.contains('good.thera'), message: 'reports the clean good.thera too')?;
    testing.assert(body.contains('"kind":"full"') || body.contains('"kind": "full"'),
        message: 'full document reports')?;
    // The error text surfaces (bad.thera's report carries a diagnostic item).
    testing.assert(body.contains('"message"'), message: 'bad.thera carries a diagnostic')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The server applies `thera.exclude` (sent in `initializationOptions`): an excluded
// file is omitted from the workspace report — no client-side filtering needed.
@test
fn test_server_side_exclude_hides_diagnostics() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_exclude_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir + '/tests/lang')?;
    fs.write_text(dir + '/good.thera', 'fn ok() -> Int { return 1; }\n')?;
    // Deliberately broken, under the excluded dir — a conformance fixture stand-in.
    fs.write_text(dir + '/tests/lang/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '",'
        + '"initializationOptions":{"exclude":["tests/lang/**"]}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(out.contains('good.thera'), message: 'the normal file is reported')?;
    testing.assert(!out.contains('bad.thera'), message: 'the excluded file is omitted')?;
    testing.assert(!out.contains('undefined name: missing'), message: 'its diagnostic is hidden')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A live `workspace/didChangeConfiguration` updates the exclude set and nudges a
// re-pull; the newly-excluded file then drops out of the workspace report.
@test
fn test_did_change_configuration_updates_exclude() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_exclude_live_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir + '/tests/lang')?;
    fs.write_text(dir + '/tests/lang/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '",'
        + '"capabilities":{"workspace":{"diagnostics":{"refreshSupport":true}}}}}');
    let before = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(before.contains('bad.thera'), message: 'reported before the exclude is set')?;

    let changed = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeConfiguration","params":'
        + '{"settings":{"thera":{"exclude":["tests/lang/**"]}}}}');
    testing.assert(changed.contains('workspace/diagnostic/refresh'), message: 'the change nudges a re-pull')?;
    let after = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!after.contains('bad.thera'), message: 'dropped after the exclude is set')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A refresh-capable client gets a `workspace/diagnostic/refresh` nudge after an
// edit that changes the file's *public surface* — importers' diagnostics may
// change, so the project view must re-pull.
@test
fn test_surface_edit_nudges_refresh_when_supported() -> Result<Void, Error> {
    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"capabilities":{"workspace":{"diagnostics":{"refreshSupport":true}}}}}');
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { return 1; }"}}}');
    // Change the signature (add a parameter) — a public-surface change.
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"contentChanges":[{"text":"fn f(_ n: Int) -> Int { return 1; }"}]}}');
    let body = out.into_string().unwrap_or('');
    testing.assert(body.contains('workspace/diagnostic/refresh'), message: 'a surface edit nudges a re-pull')?;
    return Result.Ok(void);
}

// A body-only edit does NOT nudge a workspace re-pull: it can only change the
// edited file's own diagnostics (which the client re-pulls per document), never an
// importer's, so a project-wide re-check would be wasted. This is the point of
// gating the nudge on a surface change.
@test
fn test_body_edit_does_not_nudge() -> Result<Void, Error> {
    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"capabilities":{"workspace":{"diagnostics":{"refreshSupport":true}}}}}');
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { return 1; }"}}}');
    // Same signature, different body — no importer can observe this.
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"contentChanges":[{"text":"fn f() -> Int { return 2; }"}]}}');
    let body = out.into_string().unwrap_or('');
    testing.assert(!body.contains('workspace/diagnostic/refresh'), message: 'a body edit does not nudge')?;
    return Result.Ok(void);
}

// A client that did not advertise refresh support gets no nudge (it pulls on its
// own cadence) — we don't emit an unsolicited server request.
@test
fn test_no_refresh_nudge_without_support() -> Result<Void, Error> {
    let server = new_server(Option.None);
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { return 1; }"}}}');
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"contentChanges":[{"text":"fn f() -> Int { return 2; }"}]}}');
    let body = out.into_string().unwrap_or('');
    testing.assert(!body.contains('workspace/diagnostic/refresh'), message: 'no unsolicited nudge')?;
    return Result.Ok(void);
}

@test
fn test_initialize_captures_workspace_folders() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"workspaceFolders":[{"uri":"file:///home/proj","name":"proj"},'
        + '{"uri":"file:///home/lib","name":"lib"}]}}');
    let roots = server.analysis.roots();
    testing.assert_eq(actual: roots.len(), expected: 2)?;
    testing.assert_eq(actual: roots[0], expected: '/home/proj')?;
    testing.assert_eq(actual: roots[1], expected: '/home/lib')?;
    return Result.Ok(void);
}

@test
fn test_initialize_falls_back_to_root_uri() -> Result<Void, Error> {
    // A folder-less/older client sends `rootUri` instead of `workspaceFolders`.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file:///home/proj"}}');
    let roots = server.analysis.roots();
    testing.assert_eq(actual: roots.len(), expected: 1)?;
    testing.assert_eq(actual: roots[0], expected: '/home/proj')?;
    return Result.Ok(void);
}

@test
fn test_initialize_without_folders_has_no_roots() -> Result<Void, Error> {
    // A loose single file (no folder) sends neither — references/rename stay
    // scoped to the open documents.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    server.handle(out, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    testing.assert_eq(actual: server.analysis.roots().len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_document_pull_reports_errors() -> Result<Void, Error> {
    // Pull model: didOpen pushes nothing; the client pulls `textDocument/diagnostic`.
    // The program references an undefined name, flagged even without the prelude.
    let server = new_server(Option.None);
    let opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///x.thera","text":"fn f() -> Int { return missing; }"}}}');
    testing.assert(!opened.contains('publishDiagnostics'), message: 'didOpen does not push')?;
    let out = capture(server, '{"jsonrpc":"2.0","id":5,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///x.thera"}}}');
    testing.assert(out.contains('undefined name: missing'), message: 'the pull reports the error')?;
    testing.assert(out.contains('"kind":"full"') || out.contains('"kind": "full"'),
        message: 'a full document report')?;
    return Result.Ok(void);
}

// The value of the first `"resultId":"…"` in a response body (empty if none) —
// so a test can echo the server's resultId back on a re-pull.
fn first_result_id(_ body: String) -> String {
    let key = '"resultId":"';
    return match body.find(key) {
        Some(i) => {
            let rest = body.slice(i + key.len(), body.len());
            match rest.find('"') {
                Some(j) => rest.slice(0, j),
                None => '',
            }
        },
        None => '',
    };
}

// Pull caching (LSP 3.17): re-pulling an unchanged document, echoing the server's
// resultId, returns a light `unchanged` report instead of re-sending the items.
@test
fn test_document_pull_unchanged_on_repull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _o = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///u.thera","text":"fn add(_ a: Int, _ b: Int) -> Int { return a + b; }"}}}');
    let first = capture(server, '{"jsonrpc":"2.0","id":1,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///u.thera"}}}');
    testing.assert(first.contains('"kind":"full"'), message: 'first pull is a full report')?;
    let rid = first_result_id(first);
    testing.assert(!rid.is_empty(), message: 'the full report carries a resultId')?;
    // Re-pull with identical content, echoing the resultId — an unchanged report.
    let second = capture(server, '{"jsonrpc":"2.0","id":2,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///u.thera"},"previousResultId":"' + rid + '"}}');
    testing.assert(second.contains('"kind":"unchanged"'), message: 're-pull of an unchanged doc is unchanged')?;
    testing.assert(!second.contains('"items"'), message: 'an unchanged report omits items')?;
    return Result.Ok(void);
}

// After an edit, the same re-pull (still echoing the *old* resultId) is a full
// report again — the content changed, so the cached resultId no longer matches.
@test
fn test_document_pull_full_again_after_edit() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _o = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///u.thera","text":"fn f() -> Int { return 1; }"}}}');
    let first = capture(server, '{"jsonrpc":"2.0","id":1,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///u.thera"}}}');
    let rid = first_result_id(first);
    // Introduce an error, then re-pull echoing the stale resultId.
    let _c = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///u.thera"},"contentChanges":[{"text":"fn f() -> Int { return missing; }"}]}}');
    let second = capture(server, '{"jsonrpc":"2.0","id":2,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///u.thera"},"previousResultId":"' + rid + '"}}');
    testing.assert(second.contains('"kind":"full"'), message: 'a changed doc re-pulls full')?;
    testing.assert(second.contains('undefined name: missing'), message: 'the new diagnostic is sent')?;
    return Result.Ok(void);
}

// Pull caching for the workspace request: re-pulling with the per-file
// `previousResultIds` returns `unchanged` for a file whose diagnostics didn't move.
@test
fn test_workspace_pull_unchanged_on_repull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _o = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///w.thera","text":"fn ok() -> Int { return 1; }"}}}');
    let first = capture(server, '{"jsonrpc":"2.0","id":1,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(first.contains('w.thera'), message: 'first workspace pull reports the file')?;
    testing.assert(first.contains('"kind":"full"'), message: 'as a full report')?;
    let rid = first_result_id(first);
    let second = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[{"uri":"file:///w.thera","value":"' + rid + '"}]}}');
    testing.assert(second.contains('"kind":"unchanged"'), message: 're-pull of the unchanged file is unchanged')?;
    return Result.Ok(void);
}

@test
fn test_document_pull_is_empty_when_clean() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _o = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///ok.thera","text":"fn add(_ a: Int, _ b: Int) -> Int { return a + b; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":6,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///ok.thera"}}}');
    testing.assert(out.contains('"items":[]') || out.contains('"items": []'),
        message: 'a clean document reports no items')?;
    return Result.Ok(void);
}

@test
fn test_document_symbol_outline() -> Result<Void, Error> {
    // didOpen populates the document store; documentSymbol then reads it back.
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///s.thera",'
        + '"text":"pub fn greet() -> Int { return 1; }\\nenum Color { Red, Green }"}}}');

    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":3,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///s.thera"}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('selectionRange'), message: 'is a symbol response')?;
    testing.assert(out.contains('"greet"'), message: 'has the function')?;
    testing.assert(out.contains('"Color"'), message: 'has the enum')?;
    testing.assert(out.contains('"Red"'), message: 'nests the enum variant')?;
    return Result.Ok(void);
}

@test
fn test_document_symbol_unknown_doc_is_empty() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":4,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///nope.thera"}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'empty outline for an unopened document')?;
    return Result.Ok(void);
}

@test
fn test_hover_shows_declaration_signature() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///h.thera",'
        + '"text":"pub fn greet(_ n: String) -> String { return n; }"}}}');

    // Hover on `greet` (line 0, character 8 falls inside the name).
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":5,"method":"textDocument/hover","params":'
        + '{"textDocument":{"uri":"file:///h.thera"},"position":{"line":0,"character":8}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('fn greet'), message: 'shows the signature')?;
    testing.assert(out.contains('String'), message: 'shows the types')?;
    return Result.Ok(void);
}

@test
fn test_hover_on_a_keyword_is_null() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///h.thera","text":"pub fn greet() -> Int { return 1; }"}}}');

    // Character 0 is the `pub` keyword — not an identifier, so no hover.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":6,"method":"textDocument/hover","params":'
        + '{"textDocument":{"uri":"file:///h.thera"},"position":{"line":0,"character":0}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'no hover on a keyword')?;
    return Result.Ok(void);
}

@test
fn test_definition_jumps_to_declaration() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///d.thera",'
        + '"text":"fn helper() -> Int { return 1; }\\nfn main() -> Int { return helper(); }"}}}');

    // Go-to-definition on the `helper` call (line 1, inside the name) lands on
    // the `helper` declaration up on line 0.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":7,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///d.thera"},"position":{"line":1,"character":28}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('file:///d.thera'), message: 'returns a location in the file')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'points at the declaration on line 0')?;
    return Result.Ok(void);
}

@test
fn test_definition_on_unknown_is_null() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///d.thera","text":"fn main() -> Int { return 1; }"}}}');
    // Character 0 is the `fn` keyword — no identifier, no definition.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":8,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///d.thera"},"position":{"line":0,"character":0}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'no definition for a keyword')?;
    return Result.Ok(void);
}

@test
fn test_references_are_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    // Two functions, each with a local `x`; `f`'s `x` is used twice, `g`'s once.
    // A references request on `f`'s `x` must return only `f`'s three occurrences
    // (decl + 2 uses) — NOT `g`'s, which a lexical match would wrongly include.
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera",'
        + '"text":"fn f() -> Int { let x = 1; return x + x; }\\nfn g() -> Int { let x = 9; return x; }"}}}');

    // References on `f`'s `x` in `return x + x` (line 0, character 34).
    let with_decl = io.StringWriter.new();
    server.handle(with_decl, '{"jsonrpc":"2.0","id":20,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":34},'
        + '"context":{"includeDeclaration":true}}}');
    let out = with_decl.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(out, '"range"'), expected: 3)?;

    // Excluding the declaration: the two uses only.
    let no_decl = io.StringWriter.new();
    server.handle(no_decl, '{"jsonrpc":"2.0","id":21,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":34},'
        + '"context":{"includeDeclaration":false}}}');
    testing.assert_eq(actual: count_substr(no_decl.into_string().unwrap_or(''), '"range"'), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_rename_is_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera",'
        + '"text":"fn f() -> Int { let x = 1; return x + x; }\\nfn g() -> Int { let x = 9; return x; }"}}}');

    // Rename `f`'s `x` (line 0, character 34) to `y`: its declaration + two uses
    // = three edits; `g`'s `x` is a different binding and must be untouched.
    let renamed = io.StringWriter.new();
    server.handle(renamed, '{"jsonrpc":"2.0","id":30,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":34},"newName":"y"}}');
    let out = renamed.into_string().unwrap_or('');
    testing.assert(out.contains('"changes"'), message: 'returns a WorkspaceEdit')?;
    testing.assert_eq(actual: count_substr(out, '"newText"'), expected: 3)?;
    return Result.Ok(void);
}

@test
fn test_definition_navigates_to_a_field() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///f.thera",'
        + '"text":"struct S { let n: Int; }\\nimpl S { fn get(self) -> Int { return self.n; } }"}}}');
    // Go-to-definition on the `n` of `self.n` (line 1, char 43) lands on the field
    // declaration up on line 0.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":40,"method":"textDocument/definition","params":'
        + '{"textDocument":{"uri":"file:///f.thera"},"position":{"line":1,"character":43}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('file:///f.thera'), message: 'returns a location in the file')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'points at the field declaration on line 0')?;
    return Result.Ok(void);
}

@test
fn test_rename_renames_a_field() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///f.thera",'
        + '"text":"struct S { let n: Int; }\\nfn mk() -> S { return S { n: 1 }; }'
        + '\\nimpl S { fn get(self) -> Int { return self.n; } }"}}}');
    // A field now has full symbol identity, so renaming one rewrites its whole
    // identity in one edit: the declaration (line 0), the `S { n: … }` literal use
    // (line 1), and the `self.n` member access (line 2) — no longer declined.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":41,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///f.thera"},"position":{"line":2,"character":43},"newName":"m"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(!out.contains('"result":null') && !out.contains('"result": null'),
        message: 'a field rename is not declined')?;
    testing.assert(out.contains('"line":0') || out.contains('"line": 0'),
        message: 'rewrites the field declaration on line 0')?;
    testing.assert(out.contains('"line":1') || out.contains('"line": 1'),
        message: 'rewrites the struct-literal field on line 1')?;
    testing.assert(out.contains('"line":2') || out.contains('"line": 2'),
        message: 'rewrites the member access on line 2')?;
    return Result.Ok(void);
}

@test
fn test_references_to_a_field_are_semantic() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    // Two structs each with a field `n`; only `A`'s is referenced (`a.n`). A
    // references request on `A.n` must return just `A`'s occurrences (decl + the
    // member access) — NOT `B.n`, which a lexical match would wrongly include.
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera",'
        + '"text":"struct A { let n: Int; }\\nstruct B { let n: Int; }'
        + '\\nfn use_a(_ a: A) -> Int { return a.n; }"}}}');
    // References on `A`'s field declaration (line 0, character 15 — the `n` in
    // `struct A { let n: Int; }`).
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":22,"method":"textDocument/references","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":15},'
        + '"context":{"includeDeclaration":true}}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(out, '"range"'), expected: 2)?;
    return Result.Ok(void);
}

@test
fn test_rename_collision_is_an_error() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera",'
        + '"text":"fn foo() -> Int { return 1; }\\nfn bar() -> Int { return 2; }"}}}');
    // Rename the top-level `foo` (line 0, character 4) onto the existing `bar`:
    // an error response, not a silent null result, so the editor shows the reason.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":32,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":4},"newName":"bar"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"error"'), message: 'a collision is an error response')?;
    testing.assert(!out.contains('"result"'), message: 'no WorkspaceEdit result is emitted')?;
    testing.assert(out.contains('already bound'), message: 'the reason names the collision')?;
    return Result.Ok(void);
}

@test
fn test_rename_to_a_keyword_is_rejected() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let opened = io.StringWriter.new();
    server.handle(opened, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { let x = 1; return x; }"}}}');
    // `x`'s declaration is at line 0, character 20; renaming it to `fn` is invalid.
    let asked = io.StringWriter.new();
    server.handle(asked, '{"jsonrpc":"2.0","id":31,"method":"textDocument/rename","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},"position":{"line":0,"character":20},"newName":"fn"}}');
    let out = asked.into_string().unwrap_or('');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'renaming to a keyword yields no edit')?;
    return Result.Ok(void);
}

@test
fn test_shutdown_responds_null() -> Result<Void, Error> {
    let out = handled('{"jsonrpc":"2.0","id":9,"method":"shutdown"}');
    testing.assert(out.contains('"result":null') || out.contains('"result": null'),
        message: 'null result')?;
    return Result.Ok(void);
}

// Handle one message on an existing server (preserving its document state) and
// return everything it wrote — for multi-message flows (open, then edit/close).
fn capture(_ server: Server, _ body: String) -> String {
    let out = io.StringWriter.new();
    server.handle(out, body);
    return out.into_string().unwrap_or('');
}

@test
fn test_edit_reflected_in_document_pull() -> Result<Void, Error> {
    // Open a clean document, edit it (full-sync `didChange`) to introduce an error;
    // a fresh pull must reflect the new text.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///e.thera","text":"fn add(_ a: Int, _ b: Int) -> Int { return a + b; }"}}}');
    let _changed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///e.thera"},'
        + '"contentChanges":[{"text":"fn f() -> Int { return missing; }"}]}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":7,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///e.thera"}}}');
    testing.assert(out.contains('undefined name: missing'), message: 'the pull reflects the edited text')?;
    return Result.Ok(void);
}

@test
fn test_workspace_report_echoes_open_version() -> Result<Void, Error> {
    // A client-supplied document version rides on that file's workspace report
    // item, so the client can discard results for a superseded revision (LS9).
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///v.thera","version":3,"text":"fn f() -> Int { return 1; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":8,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(out.contains('"version":3') || out.contains('"version": 3'),
        message: 'the open buffer version rides on its workspace report item')?;
    return Result.Ok(void);
}

@test
fn test_did_close_removes_document() -> Result<Void, Error> {
    // After `didClose` the document is forgotten, so a later documentSymbol over
    // it yields the empty (unknown-document) outline.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///g.thera","text":"fn solo() -> Int { return 1; }"}}}');
    let _closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"file:///g.thera"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":10,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///g.thera"}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'closed document has no outline')?;
    return Result.Ok(void);
}

@test
fn test_exit_stops_the_serve_loop() -> Result<Void, Error> {
    // The `exit` notification returns false, which is how `serve` leaves its loop.
    let server = new_server(Option.None);
    let out = io.StringWriter.new();
    let keep_going = server.handle(out, '{"jsonrpc":"2.0","method":"exit"}');
    testing.assert(!keep_going, message: 'exit stops serving')?;
    return Result.Ok(void);
}

@test
fn test_serve_coalesces_a_burst_of_edits() -> Result<Void, Error> {
    // An initialize (advertising refresh support) plus a didOpen and five didChange
    // for one document, all in a single read. `serve` drains the whole burst,
    // applying each edit but deferring the refresh, then nudges once — not per
    // message.
    let uri = 'file:///burst.thera';
    let mut stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"capabilities":{"workspace":{"diagnostics":{"refreshSupport":true}}}}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
            + '{"textDocument":{"uri":"' + uri + '","text":"fn f() -> Int { return 0; }"}}}');
    let mut i = 1;
    while i <= 5 {
        // Each edit renames the function — a public-surface change, so each on its
        // own would warrant a nudge; the burst must still collapse to exactly one.
        stream = stream + jsonrpc.frame('{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
            + '{"textDocument":{"uri":"' + uri + '"},'
            + '"contentChanges":[{"text":"fn f${i}() -> Int { return 0; }"}]}}');
        i = i + 1;
    }
    let reader = BurstReader { data: stream.bytes(), pos: 0 };
    let out = io.StringWriter.new();
    serve(reader, out, Option.None);
    let text = out.into_string().unwrap_or('');
    testing.assert_eq(actual: count_substr(text, 'workspace/diagnostic/refresh'), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_did_change_evicts_the_parse_cache() -> Result<Void, Error> {
    // The cross-request parse cache keeps imported files parsed across keystrokes,
    // but an edited file's entry must be dropped so a later check (where the file
    // is someone's import) sees the change. Seed the cache as if `c.thera` had been
    // loaded as an import, then edit it: the stale seed must be gone — and a
    // subsequent pull re-caches the *edit's* parse (R1: the primary parses through
    // the cache).
    let server = new_server(Option.None);
    let path = paths.uri_to_path('file:///c.thera');
    let seed_lex = lexer.tokenize('fn g() -> Int { return 1; }');
    let prog = parser.parse_tokens(seed_lex.tokens).program;
    server.analysis.session.parse_cache[path] =
        loader.ParsedFile { program: prog, tokens: seed_lex.tokens, diagnostics: [] };
    testing.assert(server.analysis.session.parse_cache.get(path).is_some(), message: 'seed is cached')?;

    server.handle(io.StringWriter.new(),
        '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///c.thera"},'
        + '"contentChanges":[{"text":"fn h() -> Int { return 2; }"}]}}');
    // Pull model: the re-parse happens when the client pulls, not on the edit.
    let _pulled = capture(server, '{"jsonrpc":"2.0","id":9,"method":"textDocument/diagnostic","params":'
        + '{"textDocument":{"uri":"file:///c.thera"}}}');
    match server.analysis.session.parse_cache.get(path) {
        Some(pf) => {
            testing.assert_eq(actual: pf.program.decls.len(), expected: 1)?;
            match pf.program.decls[0] {
                Fn(f) => { testing.assert_eq(actual: f.name, expected: 'h')?; },
                _ => { testing.assert(false, message: 'expected a fn decl')?; },
            }
        },
        None => { testing.assert(false, message: 'the pull re-caches the new parse')?; },
    }
    return Result.Ok(void);
}

@test
fn test_unknown_request_gets_method_not_found() -> Result<Void, Error> {
    // An unhandled *request* (has an id) gets a MethodNotFound error, so the
    // client never hangs waiting (and never mistakes it for a null result);
    // a notification (no id) is silently dropped.
    let out = handled('{"jsonrpc":"2.0","id":11,"method":"textDocument/completion","params":{}}');
    testing.assert(out.contains('"id":11') || out.contains('"id": 11'), message: 'echoes the id')?;
    testing.assert(out.contains('-32601'), message: 'replies with MethodNotFound')?;
    testing.assert(out.contains('textDocument/completion'), message: 'names the method')?;
    let dropped = handled('{"jsonrpc":"2.0","method":"textDocument/somethingNew","params":{}}');
    testing.assert_eq(actual: dropped, expected: '')?;
    return Result.Ok(void);
}

@test
fn test_unparseable_body_gets_parse_error() -> Result<Void, Error> {
    // A body that isn't JSON gets a ParseError response (id null) rather than
    // a silent drop.
    let out = handled('{oops');
    testing.assert(out.contains('-32700'), message: 'replies with ParseError')?;
    testing.assert(out.contains('"id":null') || out.contains('"id": null'),
        message: 'null id: the request id is unknowable')?;
    return Result.Ok(void);
}

@test
fn test_requests_after_shutdown_are_rejected() -> Result<Void, Error> {
    // Between `shutdown` and `exit` only `exit` is meaningful: further
    // requests are answered with InvalidRequest, and `exit` still stops the
    // loop.
    let server = new_server(Option.None);
    let _down = capture(server, '{"jsonrpc":"2.0","id":12,"method":"shutdown"}');
    let out = capture(server, '{"jsonrpc":"2.0","id":13,"method":"textDocument/documentSymbol","params":'
        + '{"textDocument":{"uri":"file:///x.thera"}}}');
    testing.assert(out.contains('-32600'), message: 'request after shutdown is invalid')?;
    let keep_going = server.handle(io.StringWriter.new(), '{"jsonrpc":"2.0","method":"exit"}');
    testing.assert(!keep_going, message: 'exit still stops serving')?;
    return Result.Ok(void);
}

@test
fn test_close_drops_a_loose_file_from_the_workspace_pull() -> Result<Void, Error> {
    // Pull model: closing doesn't push an empty clear. A loose (un-rooted) file is
    // in the workspace report only while open; closing nudges a re-pull and the
    // file drops out — so the editor releases its squiggles via the pull lifecycle.
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"capabilities":{"workspace":{"diagnostics":{"refreshSupport":true}}}}}');
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///stale.thera","text":"fn f() -> Int { return missing; }"}}}');
    let before = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(before.contains('stale.thera'), message: 'the open loose file is reported')?;
    let closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"file:///stale.thera"}}}');
    testing.assert(closed.contains('workspace/diagnostic/refresh'), message: 'close nudges a re-pull')?;
    let after = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!after.contains('stale.thera'), message: 'the closed loose file drops out')?;
    return Result.Ok(void);
}

// The async path: `workspace/diagnostic` runs on a background fiber under `serve`,
// and the writer fiber flushes its report on drain. This exercises the real
// scheduler (not the synchronous `handle` join): the worker must complete and its
// reply reach the wire.
@test
fn test_serve_backgrounds_the_workspace_scan() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_serve_ws_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[]}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert(out.contains('bad.thera'), message: 'the backgrounded scan reports bad.thera')?;
    testing.assert(out.contains('undefined name: missing'), message: 'its diagnostic reaches the wire')?;
    testing.assert(out.contains('"id":2') || out.contains('"id": 2'), message: 'replies to the pull id')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The scan cache reuses the last result only while the workspace reads back
// identical, and it is keyed on content — so an edit through *any* route (here an
// open buffer, which the cache is never told about) simply doesn't match. The
// cache is what keeps a re-pull cheap; this pins that it can't serve a stale one.
@test
fn test_workspace_scan_cache_never_serves_a_stale_result() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_scan_cache_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let file = dir + '/subject.thera';
    fs.write_text(file, 'fn ok() -> Int { return 1; }\n')?;
    let uri = 'file://' + file;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    let first = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!first.contains('undefined name'), message: 'clean to begin with')?;
    // A second pull with nothing changed: the cache reuses, same answer.
    let second = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!second.contains('undefined name'), message: 'an unchanged re-pull stays clean')?;

    // Now the content changes (via a buffer). The cache must miss and re-check.
    let _open = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"' + uri + '","text":"fn f() -> Int { return missing; }"}}}');
    let dirty = capture(server, '{"jsonrpc":"2.0","id":4,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(dirty.contains('undefined name: missing'),
        message: 'the edit is reported, not the cached clean result')?;

    // And back: reverting to the original text must clear it, not stick.
    let _revert = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"' + uri + '"},"contentChanges":'
        + '[{"text":"fn ok() -> Int { return 1; }\\n"}]}}');
    let healed = capture(server, '{"jsonrpc":"2.0","id":5,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!healed.contains('undefined name'), message: 'reverting clears the diagnostic')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// An unchanged re-pull is answered by the generation fast tier — without even
// the per-file byte-compare. Pinned by poisoning: the cached diagnostics are
// replaced with a marker AND the cached contents are made non-matching, so the
// two tiers disagree — the compare tier would miss (contents differ) and
// recompute, only the generation tier can serve the marker. An edit must then
// break the stamp: the re-pull recomputes and the marker is gone.
@test
fn test_unchanged_repull_takes_the_generation_fast_tier() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_gen_tier_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let file = dir + '/subject.thera';
    fs.write_text(file, 'fn ok() -> Int { return 1; }\n')?;
    let uri = 'file://' + file;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    let _warm = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    if let Some(cache) = server.analysis.scan_cache {
        cache.contents[loader.canonical_path(file)] = 'NOT THE REAL TEXT';
        cache.by_file[loader.canonical_path(file)] = [json.str('POISON')];
    }
    let repull = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(repull.contains('POISON'),
        message: 'nothing changed: the poisoned cache is served without a compare')?;

    // Any input mutation breaks the stamp; the poisoned contents then fail the
    // compare tier too, and the scan recomputes the real diagnostics.
    let _open = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"' + uri + '","text":"fn ok() -> Int { return 2; }\\n"}}}');
    let fresh = capture(server, '{"jsonrpc":"2.0","id":4,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!fresh.contains('POISON'), message: 'an edit invalidates the fast tier')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// *Un*-excluding a file must report it, even though nothing on disk moved. This
// is the one case content-keying cannot catch on its own, so it pins why
// `set_exclude` drops the cache: the file's text is identical, the scanned set is
// identical (a per-file glob prunes no directory, unlike `<base>/**`), so the
// fingerprint matches perfectly — but the cached result was computed while this
// file was skipped as a primary, and reusing it would report the file clean.
@test
fn test_un_excluding_a_file_drops_the_scan_cache() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_exclude_cache_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir + '/hidden')?;
    fs.write_text(dir + '/hidden/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    // A per-file pattern, deliberately not `hidden/**`: the directory is still
    // walked, so the scanned file set is the same before and after.
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '","initializationOptions":'
        + '{"exclude":["**/*bad.thera"]}}}');
    let before = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!before.contains('undefined name: missing'),
        message: 'hidden while excluded')?;

    let _cfg = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeConfiguration",'
        + '"params":{"settings":{"thera":{"exclude":[]}}}}');
    let after = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(after.contains('undefined name: missing'),
        message: 'un-excluding reports it, though no file content changed')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A file edited on disk with no buffer open must re-report. Nothing else tells
// the server: `didChange` speaks only for open documents, so the session would
// serve the parse it cached the first time it read the file — for the rest of the
// session. That was a real bug (a branch switch left stale squiggles); the watcher
// notification is what closes it.
@test
fn test_watched_file_change_invalidates_the_cached_parse() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_watched_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let file = dir + '/watched.thera';
    fs.write_text(file, 'fn ok() -> Int { return 1; }\n')?;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '","capabilities":{"workspace":'
        + '{"didChangeWatchedFiles":{"dynamicRegistration":true}}}}}');
    let clean = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(!clean.contains('undefined name'), message: 'starts clean')?;

    // The edit lands on disk, and the client reports it (type 2 = Changed).
    fs.write_text(file, 'fn oops() -> Int { return missing; }\n')?;
    let _notice = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeWatchedFiles",'
        + '"params":{"changes":[{"uri":"file://' + file + '","type":2}]}}');
    let after = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');
    testing.assert(after.contains('undefined name: missing'),
        message: 'the on-disk edit is re-analyzed, not served from the cached parse')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The disk scan is cached across pulls, so it holds the file *set* as well as the
// contents: a file created or deleted on disk is only noticed because the watcher
// says so. (Before the cache a re-walk found new files unaided — this pins the
// behavior that replaced it.)
@test
fn test_watched_create_and_delete_update_the_scanned_set() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_watched_set_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/first.thera', 'fn first() -> Int { return 1; }\n')?;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '","capabilities":{"workspace":'
        + '{"didChangeWatchedFiles":{"dynamicRegistration":true}}}}}');
    let _warm = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[]}}');

    // A file appears (type 1 = Created).
    let born = dir + '/second.thera';
    fs.write_text(born, 'fn second() -> Int { return missing; }\n')?;
    let _created = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeWatchedFiles",'
        + '"params":{"changes":[{"uri":"file://' + born + '","type":1}]}}');
    let after_create = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic",'
        + '"params":{"previousResultIds":[]}}');
    testing.assert(after_create.contains('second.thera'),
        message: 'a created file joins the scan')?;

    // And goes away again (type 3 = Deleted).
    fs.remove(born)?;
    let _deleted = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeWatchedFiles",'
        + '"params":{"changes":[{"uri":"file://' + born + '","type":3}]}}');
    let after_delete = capture(server, '{"jsonrpc":"2.0","id":4,"method":"workspace/diagnostic",'
        + '"params":{"previousResultIds":[]}}');
    testing.assert(!after_delete.contains('second.thera'),
        message: 'a deleted file leaves the scan')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// The watcher only exists if we ask for it — there is no static capability for
// `didChangeWatchedFiles`, so `initialized` must send the registration.
@test
fn test_initialized_registers_a_file_watcher() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"capabilities":{"workspace":{"didChangeWatchedFiles":'
        + '{"dynamicRegistration":true}}}}}');
    let out = capture(server, '{"jsonrpc":"2.0","method":"initialized","params":{}}');
    testing.assert(out.contains('client/registerCapability'), message: 'registers')?;
    testing.assert(out.contains('workspace/didChangeWatchedFiles'), message: 'for watched files')?;
    testing.assert(out.contains('**/*.thera'), message: 'watching the files we analyze')?;
    return Result.Ok(void);
}

// A client without dynamic registration gets no request it cannot honor.
@test
fn test_initialized_skips_the_watcher_when_unsupported() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    let out = capture(server, '{"jsonrpc":"2.0","method":"initialized","params":{}}');
    testing.assert(!out.contains('client/registerCapability'),
        message: 'no registration without dynamicRegistration support')?;
    return Result.Ok(void);
}

// A second `workspace/diagnostic` supersedes the first: the older scan bails and
// settles as ServerCancelled (-32802) with `retriggerRequest: false` — the newer
// pull is already in hand, so the client needn't re-ask. The client keeps the
// latest — eventual consistency, no lost report.
@test
fn test_serve_supersedes_the_older_workspace_pull() -> Result<Void, Error> {
    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[]}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[]}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert_eq(actual: count_substr(out, '-32802'), expected: 1)?;
    testing.assert(out.contains('"retriggerRequest":false'), message: 'the client needn\'t re-ask')?;
    testing.assert(out.contains('"id":2') || out.contains('"id": 2'), message: 'the superseded pull is answered')?;
    testing.assert(out.contains('"id":3') || out.contains('"id": 3'), message: 'the newer pull is answered')?;
    return Result.Ok(void);
}

// A `$/cancelRequest` naming the in-flight scan's request stops it; the request
// settles with RequestCancelled (-32800), the advised code for a client cancel.
@test
fn test_serve_cancels_the_workspace_scan() -> Result<Void, Error> {
    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[]}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"$/cancelRequest","params":{"id":2}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert(out.contains('-32800'), message: 'the cancelled scan replies RequestCancelled')?;
    return Result.Ok(void);
}

// A cancel for some *other* request (already answered inline — the protocol says
// to ignore it) must not kill the scan: the pull still produces its report.
@test
fn test_an_unrelated_cancel_does_not_kill_the_scan() -> Result<Void, Error> {
    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[]}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"$/cancelRequest","params":{"id":99}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert(out.contains('"id":2') || out.contains('"id": 2'), message: 'the pull is answered')?;
    testing.assert(out.contains('"items"'), message: 'with its report')?;
    testing.assert(!out.contains('-32800') && !out.contains('-32802'),
        message: 'not with a cancellation error')?;
    return Result.Ok(void);
}

@test
fn test_code_action_offers_if_let() -> Result<Void, Error> {
    // A convertible `match` in the range yields a `refactor.rewrite` code action
    // whose workspace edit rewrites it to `if let`.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///a.thera","text":'
        + '"fn f(_ o: Option<Int>) { match o { Some(v) => { g(v); }, None => {} } }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":20,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///a.thera"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('Convert `match` to `if let`'), message: 'offers the rewrite')?;
    testing.assert(out.contains('refactor.rewrite'), message: 'is a rewrite action')?;
    testing.assert(out.contains('if let Some(v) = o'), message: 'edit rewrites to if let')?;
    return Result.Ok(void);
}

@test
fn test_code_action_empty_when_nothing_convertible() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///b.thera","text":"fn f() -> Int { return 1; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":21,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///b.thera"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":20}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'no actions offered')?;
    return Result.Ok(void);
}

@test
fn test_code_action_offers_unwrap_or() -> Result<Void, Error> {
    // A value-fallback `match` yields an `unwrap_or` rewrite.
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///c.thera","text":'
        + '"fn f(_ o: Option<Int>) -> Int { return match o { Some(v) => v, None => 0 }; }"}}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":22,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///c.thera"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[]}}}');
    testing.assert(out.contains('Convert `match` to `unwrap_or`'), message: 'offers unwrap_or')?;
    testing.assert(out.contains('o.unwrap_or(0)'), message: 'edit rewrites to unwrap_or')?;
    return Result.Ok(void);
}

// A convertible document + a codeAction request narrowed by `context.only`.
fn code_action_with_only(_ only: String) -> String {
    let server = new_server(Option.None);
    let _opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///only.thera","text":'
        + '"fn f(_ o: Option<Int>) { match o { Some(v) => { g(v); }, None => {} } }"}}}');
    return capture(server, '{"jsonrpc":"2.0","id":30,"method":"textDocument/codeAction","params":'
        + '{"textDocument":{"uri":"file:///only.thera"},'
        + '"range":{"start":{"line":0,"character":0},"end":{"line":0,"character":80}},'
        + '"context":{"diagnostics":[],"only":[' + only + ']}}}');
}

@test
fn test_code_action_only_refactor_ancestor_offers() -> Result<Void, Error> {
    // `refactor` is a `.`-separated ancestor of our `refactor.rewrite` kind.
    let out = code_action_with_only('"refactor"');
    testing.assert(out.contains('refactor.rewrite'), message: 'ancestor kind admits the rewrite')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_exact_kind_offers() -> Result<Void, Error> {
    let out = code_action_with_only('"refactor.rewrite"');
    testing.assert(out.contains('refactor.rewrite'), message: 'exact kind admits the rewrite')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_quickfix_is_empty() -> Result<Void, Error> {
    // An unrelated requested kind filters out our refactor.
    let out = code_action_with_only('"quickfix"');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'quickfix-only request offers nothing')?;
    return Result.Ok(void);
}

@test
fn test_code_action_only_sibling_kind_is_empty() -> Result<Void, Error> {
    // A sibling under `refactor` is not an ancestor of `refactor.rewrite`.
    let out = code_action_with_only('"refactor.extract"');
    testing.assert(out.contains('"result":[]') || out.contains('"result": []'),
        message: 'sibling refactor kind offers nothing')?;
    return Result.Ok(void);
}

// --- the held-open workspace pull (partial-result streaming) ---
//
// A client that sends a `partialResultToken` gets its workspace report as a
// `$/progress` notification and NO response: the request stays open, because a
// completed workspace pull is what re-arms the client's periodic re-pull (2s in
// vscode-languageclient) — holding it open is what makes an idle server idle.
// Workspace changes then stream as delta batches; the request settles only on
// supersession, cancel, or shutdown.

@test
fn test_token_pull_streams_and_holds_the_request_open() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_stream_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    let out = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-1"}}');
    testing.assert(out.contains('$/progress'), message: 'the report streams as progress')?;
    testing.assert(out.contains('"token":"tok-1"'), message: 'under the client token')?;
    testing.assert(out.contains('bad.thera'), message: 'carrying the workspace report')?;
    testing.assert(out.contains('undefined name: missing'), message: 'with its diagnostics')?;
    testing.assert(!out.contains('"id":2'), message: 'and the request is left open — no response')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A change streams a delta batch to the open pull: only the files whose
// diagnostics changed, no `unchanged` chatter — and a body-only edit (which the
// client re-pulls per document) streams nothing at all. The refresh nudge cannot
// stand in for this: on it the client re-pulls open documents only, never the
// workspace, so with the pull held open the stream is closed files' only channel.
@test
fn test_changes_stream_deltas_to_the_open_pull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    let first = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-2"}}');
    testing.assert(!first.contains('"id":2'), message: 'the pull is held open')?;

    // Opening a document is a workspace change (a new file joins the scan): its
    // report streams as a delta.
    let opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { return missing; }"}}}');
    testing.assert(opened.contains('$/progress'), message: 'the open streams a delta')?;
    testing.assert(opened.contains('r.thera'), message: 'reporting the opened file')?;
    testing.assert(opened.contains('undefined name: missing'), message: 'with its diagnostics')?;

    // A body-only edit is the document pull's business — nothing streams.
    let edited = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didChange","params":'
        + '{"textDocument":{"uri":"file:///r.thera"},'
        + '"contentChanges":[{"text":"fn f() -> Int { return other; }"}]}}');
    testing.assert(!edited.contains('$/progress'), message: 'a body edit streams nothing')?;

    // Closing the loose file drops it from the scan: a retraction (an empty full
    // report) streams, so the client releases its squiggles.
    let closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"file:///r.thera"}}}');
    testing.assert(closed.contains('$/progress'), message: 'the close streams a delta')?;
    testing.assert(closed.contains('r.thera'), message: 'naming the closed file')?;
    testing.assert(closed.contains('"items":[]'), message: 'as a retraction — empty items')?;
    return Result.Ok(void);
}

// An on-disk delete (reported by the watcher) streams a retraction for exactly
// the deleted file; the untouched file is omitted from the batch entirely.
@test
fn test_watched_delete_streams_a_retraction() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_stream_delete_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/keep.thera', 'fn keep() -> Int { return 1; }\n')?;
    let gone = dir + '/gone.thera';
    fs.write_text(gone, 'fn gone() -> Int { return missing; }\n')?;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    let _pull = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-3"}}');

    fs.remove(gone)?;
    let out = capture(server, '{"jsonrpc":"2.0","method":"workspace/didChangeWatchedFiles",'
        + '"params":{"changes":[{"uri":"file://' + gone + '","type":3}]}}');
    testing.assert(out.contains('$/progress'), message: 'the delete streams a delta')?;
    testing.assert(out.contains('gone.thera'), message: 'retracting the deleted file')?;
    testing.assert(out.contains('"items":[]'), message: 'with empty items')?;
    testing.assert(!out.contains('keep.thera'), message: 'the unchanged file is omitted')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A `$/cancelRequest` for the held-open pull settles it — a cancelled request
// cannot be left hanging (JSON-RPC), and RequestCancelled (-32800) is the advised
// code. After it, nothing streams: the pull is gone.
@test
fn test_cancel_settles_the_open_pull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    let _pull = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-4"}}');
    let cancelled = capture(server, '{"jsonrpc":"2.0","method":"$/cancelRequest","params":{"id":2}}');
    testing.assert(cancelled.contains('"id":2'), message: 'the open pull is answered')?;
    testing.assert(cancelled.contains('-32800'), message: 'with RequestCancelled')?;

    let opened = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"file:///r.thera","text":"fn f() -> Int { return missing; }"}}}');
    testing.assert(!opened.contains('$/progress'), message: 'nothing streams after the cancel')?;
    return Result.Ok(void);
}

// A new workspace pull supersedes a held-open one: the old request settles with
// an empty final result (its streamed reports stand — the spec's shape after
// partial results), and the new pull is the one held open.
@test
fn test_new_pull_settles_the_previous_open_pull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    let _first = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-5"}}');
    let second = capture(server, '{"jsonrpc":"2.0","id":3,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-6"}}');
    testing.assert(second.contains('"id":2'), message: 'the old pull settles')?;
    testing.assert(second.contains('"items":[]'), message: 'with an empty final result')?;
    testing.assert(second.contains('"token":"tok-6"'), message: 'the new pull streams')?;
    testing.assert(!second.contains('"id":3'), message: 'and is held open in turn')?;
    return Result.Ok(void);
}

// Closing a buffer makes the client discard that file's diagnostics along with
// it, so the workspace stream must re-send them even though they did not change —
// the eviction in `close_document` is what forces the re-send.
@test
fn test_close_restreams_an_unchanged_files_diagnostics() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_stream_close_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    let file = dir + '/subject.thera';
    let text = 'fn f() -> Int { return missing; }\n';
    fs.write_text(file, text)?;
    let uri = 'file://' + file;

    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}');
    let _pull = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-7"}}');
    // Open with the on-disk text (no content change), then close: the buffer text
    // never differed, but the close must still re-stream the file in full.
    let _open = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didOpen","params":'
        + '{"textDocument":{"uri":"' + uri + '","text":"fn f() -> Int { return missing; }\\n"}}}');
    let closed = capture(server, '{"jsonrpc":"2.0","method":"textDocument/didClose","params":'
        + '{"textDocument":{"uri":"' + uri + '"}}}');
    testing.assert(closed.contains('$/progress'), message: 'the close streams a delta')?;
    testing.assert(closed.contains('subject.thera'), message: 'naming the closed file')?;
    testing.assert(closed.contains('undefined name: missing'),
        message: 're-sending its unchanged diagnostics in full')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A shutdown settles the held-open pull (empty final result) — the request must
// not outlive the session.
@test
fn test_shutdown_settles_the_open_pull() -> Result<Void, Error> {
    let server = new_server(Option.None);
    let _init = capture(server, '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}');
    let _pull = capture(server, '{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
        + '{"previousResultIds":[],"partialResultToken":"tok-9"}}');
    let down = capture(server, '{"jsonrpc":"2.0","id":3,"method":"shutdown"}');
    testing.assert(down.contains('"id":2'), message: 'the open pull is answered')?;
    testing.assert(down.contains('"items":[]'), message: 'with an empty final result')?;
    testing.assert(down.contains('"id":3'), message: 'and shutdown itself is answered')?;
    return Result.Ok(void);
}

// A shutdown racing the *initial* scan (all messages in one burst, so the worker
// never runs before shutdown is dispatched) still settles the pull: superseding
// the scan makes it answer ServerCancelled before it would ever stream.
@test
fn test_shutdown_settles_a_pull_whose_scan_never_ran() -> Result<Void, Error> {
    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[],"partialResultToken":"tok-10"}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":3,"method":"shutdown"}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert(out.contains('"id":2'), message: 'the pull is answered')?;
    testing.assert(out.contains('-32802'), message: 'as ServerCancelled — it never streamed')?;
    testing.assert(out.contains('"retriggerRequest":false'), message: 'the session is ending')?;
    testing.assert(out.contains('"id":3'), message: 'and shutdown is answered')?;
    return Result.Ok(void);
}

// The async path: under `serve`, a token pull's report reaches the wire as
// progress and the request is still open at exit — no response for its id.
@test
fn test_serve_holds_the_token_pull_open() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/thera_lsp_serve_stream_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs.create_dir_all(dir)?;
    fs.write_text(dir + '/bad.thera', 'fn oops() -> Int { return missing; }\n')?;

    let stream = jsonrpc.frame('{"jsonrpc":"2.0","id":1,"method":"initialize","params":'
        + '{"rootUri":"file://' + dir + '"}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","id":2,"method":"workspace/diagnostic","params":'
            + '{"previousResultIds":[],"partialResultToken":"tok-8"}}')
        + jsonrpc.frame('{"jsonrpc":"2.0","method":"exit"}');
    let out = served(stream);
    testing.assert(out.contains('$/progress'), message: 'the report streams')?;
    testing.assert(out.contains('bad.thera'), message: 'and reaches the wire on drain')?;
    testing.assert(!out.contains('"id":2'), message: 'the request is never answered')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}
