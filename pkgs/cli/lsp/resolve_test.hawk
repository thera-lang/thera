// Tests for the shared cursor resolver (resolve.hawk) — specifically the
// navigation half (`def_span`/`def_file`) that go-to-definition renders. Hover's
// render half is covered by hover_test.hawk. Each case resolves at a *use* site
// and asserts the definition span lands on the *declaration*.

import std.testing;

import '../ast/ast' as _; // Program
import '../element/element' as _; // LibraryNamespace
import '../lexer/lexer';
import '../parser/parser';
import '../checker/checker';
import 'resolve' as _;

fn program_of(_ src: String) -> Program {
    let p = parser.parse_tokens(lexer.tokenize(src).tokens).program;
    p.file_path = Option.Some('t.hawk');
    return p;
}

// A resolution context with the primary's committed-type record populated the
// way `analyze_at` does (straight from the hermetic checker) — so inferred-
// receiver resolution can consult it.
fn typed_ctx(_ program: Program) -> ResolveCtx {
    let nss: Map<String, Map<String, LibraryNamespace>> = {};
    let bare: Map<String, Map<String, String>> = {};
    return ResolveCtx {
        program: program,
        imports: [],
        file_namespaces: nss,
        file_bare_surface: bare,
        primary_types: checker.check(program, [], {}, {}).records,
    };
}

// A hermetic single-file resolution context (no imports, empty surfaces).
fn ctx_of(_ program: Program, _ imports: List<Program>) -> ResolveCtx {
    let nss: Map<String, Map<String, LibraryNamespace>> = {};
    let bare: Map<String, Map<String, String>> = {};
    return ResolveCtx {
        program: program,
        imports: imports,
        file_namespaces: nss,
        file_bare_surface: bare,
        primary_types: [],
    };
}

// The offset `delta` code points past the first occurrence of `marker`.
fn at(_ src: String, _ marker: String, _ delta: Int) -> Int {
    return src.find(marker).unwrap_or(0) + delta;
}

// The def-span offset resolved at `use_offset`, or -1 when nothing navigable.
fn def_offset(_ src: String, _ use_offset: Int) -> Int {
    let program = program_of(src);
    let imports: List<Program> = [];
    return match resolve.resolve_at(ctx_of(program, imports), src, use_offset) {
        Some(r) => match r.def_span() {
            Some(s) => s.offset,
            None => -1,
        },
        None => -1,
    };
}

const SRC: String = 'struct S { count: Int }\n'
    + 'impl S {\n'
    + '    fn helper(self, _ n: Int) -> Int { return self.count + n; }\n'
    + '    fn go(self) -> Int { return self.helper(self.count); }\n'
    + '}\n'
    + 'enum Color { Red, Green(Int) }\n'
    + 'fn paint() -> Color { return Color.Green(1); }\n';

@test
fn test_definition_of_self_method() -> Result<Void, Error> {
    // `self.helper(...)` navigates to the `helper` method declaration.
    let use_off = at(SRC, 'self.helper(self', 5);
    let decl_off = at(SRC, 'fn helper', 3);
    testing.assert_eq(actual: def_offset(SRC, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_definition_of_parameter() -> Result<Void, Error> {
    // `n` used in the body navigates to its parameter declaration.
    let use_off = at(SRC, 'self.count + n', 13);
    let decl_off = at(SRC, '_ n: Int', 2);
    testing.assert_eq(actual: def_offset(SRC, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_definition_of_enum_variant() -> Result<Void, Error> {
    // `Color.Green(1)` navigates to the `Green` variant declaration.
    let use_off = at(SRC, 'Color.Green(1)', 6);
    let decl_off = at(SRC, 'Red, Green', 5);
    testing.assert_eq(actual: def_offset(SRC, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_definition_of_self_type() -> Result<Void, Error> {
    // `self` navigates to the enclosing type's declaration.
    let use_off = at(SRC, 'return self.helper', 7);
    let decl_off = at(SRC, 'struct S', 7);
    testing.assert_eq(actual: def_offset(SRC, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_field_access_is_not_navigable() -> Result<Void, Error> {
    // A struct field carries no name span — renderable (hover) but not navigable.
    let use_off = at(SRC, 'self.count + n', 5);
    testing.assert_eq(actual: def_offset(SRC, use_off), expected: -1)?;
    return Result.Ok(void);
}

@test
fn test_generic_impl_self_type_renders_and_navigates() -> Result<Void, Error> {
    // Inside `impl Box<T>`, `self` renders with its type params and `self.method`
    // navigates via the bare type name — no round-trip through the display string.
    let src = 'struct Box<T> { value: T }\n'
        + 'impl Box<T> {\n'
        + '    fn get(self) -> T { return self.value; }\n'
        + '    fn go(self) -> T { return self.get(); }\n'
        + '}\n';
    let program = program_of(src);
    let imports: List<Program> = [];
    // `self` renders `self: Box<T>` and navigates to the struct declaration.
    let self_off = at(src, 'return self.value', 7);
    match resolve.resolve_at(ctx_of(program, imports), src, self_off) {
        Some(r) => {
            testing.assert_eq(actual: r.render, expected: 'self: Box<T>')?;
            let def_off = match r.def_span() { Some(s) => s.offset, None => -1 };
            testing.assert_eq(actual: def_off, expected: at(src, 'struct Box', 7))?;
        },
        None => { testing.assert(false, message: 'self did not resolve')?; },
    }
    // `self.get()` navigates to the `get` method.
    let use_off = at(src, 'self.get()', 5);
    testing.assert_eq(actual: def_offset(src, use_off), expected: at(src, 'fn get', 3))?;
    return Result.Ok(void);
}

@test
fn test_identifier_inside_interpolation_resolves() -> Result<Void, Error> {
    // An identifier inside a `${...}` interpolation is not a standalone token in
    // the outer stream; the resolver must descend into it (LS9). Here a local
    // `name` used in `'hi ${name}'` navigates to its `let`.
    let src = 'fn greet() -> String {\n'
        + '    let name = \'bob\';\n'
        + '    return \'hi \${name}!\';\n'
        + '}\n';
    let use_off = at(src, '\${name}', 2);
    let decl_off = at(src, 'let name', 4);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_self_member_inside_interpolation_resolves() -> Result<Void, Error> {
    // `self.count` inside an interpolation resolves through the receiver path —
    // the interpolation redirect must feed `receiver_at` too, not just `name_at`.
    let src = 'struct S { count: Int }\n'
        + 'impl S {\n'
        + '    fn show(self) -> String { return \'n=\${self.count}\'; }\n'
        + '}\n';
    // The `count` member renders (a field: renderable, not navigable).
    let use_off = at(src, '\${self.count}', 8);
    let program = program_of(src);
    let imports: List<Program> = [];
    match resolve.resolve_at(ctx_of(program, imports), src, use_off) {
        Some(r) => { testing.assert(r.render.starts_with('count:'), message: 'renders the field')?; },
        None => { testing.assert(false, message: 'self.count in interp did not resolve')?; },
    }
    return Result.Ok(void);
}

// --- inferred-receiver member resolution (value receiver, recorded type) ---

@test
fn test_inferred_receiver_method_resolves() -> Result<Void, Error> {
    // `p.scaled()` where `p`'s type is inferred (not written): the member
    // resolves on the receiver's committed type and navigates to the method decl.
    let src = 'struct Point { x: Int }\n'
        + 'impl Point {\n'
        + '    fn scaled(self) -> Point { return self; }\n'
        + '}\n'
        + 'fn f() -> Point {\n'
        + '    let p = Point { x: 1 };\n'
        + '    return p.scaled();\n'
        + '}\n';
    let program = program_of(src);
    let use_off = at(src, 'p.scaled()', 2);
    let decl_off = at(src, 'fn scaled', 3);
    match resolve.resolve_at(typed_ctx(program), src, use_off) {
        Some(r) => {
            let off = match r.def_span() { Some(s) => s.offset, None => -1 };
            testing.assert_eq(actual: off, expected: decl_off)?;
        },
        None => { testing.assert(false, message: 'p.scaled() did not resolve')?; },
    }
    return Result.Ok(void);
}

@test
fn test_inferred_receiver_field_renders() -> Result<Void, Error> {
    // A field on an inferred-typed receiver renders (hover) but isn't navigable.
    let src = 'struct Point { x: Int }\n'
        + 'fn f() -> Int {\n'
        + '    let p = Point { x: 1 };\n'
        + '    return p.x;\n'
        + '}\n';
    let program = program_of(src);
    let use_off = at(src, 'p.x;', 2);
    match resolve.resolve_at(typed_ctx(program), src, use_off) {
        Some(r) => { testing.assert(r.render.starts_with('x:'), message: 'renders the field type')?; },
        None => { testing.assert(false, message: 'p.x did not resolve')?; },
    }
    return Result.Ok(void);
}

// The def-span offset resolved at `use_offset` with the committed-type record
// populated (for inferred/computed receivers), or -1 when nothing navigable.
fn typed_def_offset(_ src: String, _ use_offset: Int) -> Int {
    let program = program_of(src);
    return match resolve.resolve_at(typed_ctx(program), src, use_offset) {
        Some(r) => match r.def_span() { Some(s) => s.offset, None => -1 },
        None => -1,
    };
}

// A struct with a method, reachable through a call result, a field chain, and an
// index — the three *computed* receiver shapes a token stream can't delimit.
const COMP_SRC: String = 'struct Point { x: Int }\n'
    + 'struct Box { p: Point }\n'
    + 'impl Point {\n'
    + '    fn scaled(self) -> Point { return self; }\n'
    + '}\n'
    + 'fn make() -> Point { return Point { x: 1 }; }\n'
    + 'fn use_call() -> Point { return make().scaled(); }\n'
    + 'fn use_chain(_ b: Box) -> Point { return b.p.scaled(); }\n'
    + 'fn use_index(_ xs: List<Point>) -> Point { return xs[0].scaled(); }\n';

@test
fn test_computed_call_receiver_member_resolves() -> Result<Void, Error> {
    // `make().scaled()` — a member on a call result navigates to the method decl.
    let decl = at(COMP_SRC, 'fn scaled', 3);
    testing.assert_eq(actual: typed_def_offset(COMP_SRC, at(COMP_SRC, 'make().scaled()', 7)), expected: decl)?;
    return Result.Ok(void);
}

@test
fn test_value_chain_receiver_member_resolves() -> Result<Void, Error> {
    // `b.p.scaled()` — a value chain (misclassified as `ns.Type.member` at the
    // token level) resolves on the receiver `b.p`'s committed type.
    let decl = at(COMP_SRC, 'fn scaled', 3);
    testing.assert_eq(actual: typed_def_offset(COMP_SRC, at(COMP_SRC, 'b.p.scaled()', 4)), expected: decl)?;
    return Result.Ok(void);
}

@test
fn test_indexed_receiver_member_resolves() -> Result<Void, Error> {
    // `xs[0].scaled()` — a member on an index result navigates to the method decl.
    let decl = at(COMP_SRC, 'fn scaled', 3);
    testing.assert_eq(actual: typed_def_offset(COMP_SRC, at(COMP_SRC, 'xs[0].scaled()', 6)), expected: decl)?;
    return Result.Ok(void);
}

// --- owner-correct cross-file resolution (LS1/LS3/LS8) ---

fn program_at(_ src: String, _ path: String) -> Program {
    let p = parser.parse_tokens(lexer.tokenize(src).tokens).program;
    p.file_path = Option.Some(path);
    return p;
}

// A two-library closure where BOTH imports declare `pub fn helper`, but the
// primary's bare surface attributes the name to lib_b (an `as _` import) and
// its `util` namespace maps to lib_a. The maps are hand-rolled stand-ins for
// what the loader computes.
fn cross_ctx(_ primary: Program) -> ResolveCtx {
    let a = program_at('pub fn helper(_ n: Int) -> Int { return n; }\n'
        + 'pub const width: Int = 4;\n', '/libs/a.hawk');
    let b = program_at('pub fn helper(_ s: String) -> String { return s; }\n', '/libs/b.hawk');
    let bare: Map<String, Map<String, String>> = {};
    bare['/app/main.hawk'] = { 'helper': '/libs/b.hawk' };
    let surface = LibraryNamespace {
        names: Set.from(['helper', 'width']),
        collisions: Set.new(),
        origin: { 'helper': '/libs/a.hawk', 'width': '/libs/a.hawk' },
    };
    let ns_map: Map<String, LibraryNamespace> = {};
    ns_map['util'] = surface;
    let nss: Map<String, Map<String, LibraryNamespace>> = {};
    nss['/app/main.hawk'] = ns_map;
    return ResolveCtx {
        program: primary,
        imports: [a, b],
        file_namespaces: nss,
        file_bare_surface: bare,
        primary_types: [],
    };
}

@test
fn test_bare_name_resolves_via_the_bare_surface_owner() -> Result<Void, Error> {
    // Bare `helper` must go to the file the surface attributes it to (b),
    // not the first import that happens to declare the name (a).
    let src = 'import \'b\' as _;\nfn main() -> Void { helper(\'x\'); }\n';
    let primary = program_at(src, '/app/main.hawk');
    let use_off = src.find('helper(\'x\'').unwrap_or(0);
    match resolve.resolve_at(cross_ctx(primary), src, use_off) {
        Some(r) => {
            testing.assert_eq(actual: r.def_file().unwrap_or(''), expected: '/libs/b.hawk')?;
        },
        None => { testing.assert(false, message: 'bare helper did not resolve')?; },
    }
    return Result.Ok(void);
}

@test
fn test_ns_member_resolves_on_the_namespace_surface() -> Result<Void, Error> {
    // `util.helper` resolves through util's surface origin — lib_a — even
    // though the bare surface points the same name at lib_b.
    let src = 'import \'a\' as util;\nfn main() -> Void { util.helper(1); }\n';
    let primary = program_at(src, '/app/main.hawk');
    let use_off = src.find('.helper(1').unwrap_or(0) + 1;
    match resolve.resolve_at(cross_ctx(primary), src, use_off) {
        Some(r) => {
            testing.assert_eq(actual: r.def_file().unwrap_or(''), expected: '/libs/a.hawk')?;
        },
        None => { testing.assert(false, message: 'util.helper did not resolve')?; },
    }
    return Result.Ok(void);
}

@test
fn test_namespace_itself_resolves_to_its_import() -> Result<Void, Error> {
    // Hovering the `util` of `util.helper` lands on the import declaration.
    let src = 'import \'a\' as util;\nfn main() -> Void { util.helper(1); }\n';
    let primary = program_at(src, '/app/main.hawk');
    let use_off = src.find('util.helper').unwrap_or(0);
    match resolve.resolve_at(cross_ctx(primary), src, use_off) {
        Some(r) => {
            testing.assert_eq(actual: r.def_file().unwrap_or(''), expected: '/app/main.hawk')?;
            testing.assert(r.render.starts_with('import'), message: 'renders the import')?;
        },
        None => { testing.assert(false, message: 'namespace did not resolve')?; },
    }
    return Result.Ok(void);
}

@test
fn test_member_of_computed_receiver_does_not_guess() -> Result<Void, Error> {
    // `paint().bar` — the member of a call result needs inference; it must NOT
    // resolve `bar` against an unrelated same-named top-level declaration.
    let src = 'fn bar() -> Int { return 1; }\n'
        + 'fn paint() -> Int { return 2; }\n'
        + 'fn main() -> Void { let x = paint().bar; }\n';
    let use_off = src.find(').bar').unwrap_or(0) + 2;
    testing.assert_eq(actual: def_offset(src, use_off), expected: -1)?;
    return Result.Ok(void);
}

@test
fn test_unimported_name_does_not_resolve() -> Result<Void, Error> {
    // `width` exists in lib_a but the primary neither declares it nor has it on
    // its bare surface — a whole-closure name scan would find it; the
    // owner-correct resolver must not.
    let src = 'fn main() -> Void { let w = width; }\n';
    let primary = program_at(src, '/app/main.hawk');
    let use_off = src.find('width;').unwrap_or(0);
    match resolve.resolve_at(cross_ctx(primary), src, use_off) {
        Some(_) => { testing.assert(false, message: 'unimported width must not resolve')?; },
        None => {},
    }
    return Result.Ok(void);
}

// --- local bindings (LS2/LS4) ---

@test
fn test_local_let_shadows_a_toplevel_name() -> Result<Void, Error> {
    // `let error = …` then `error` — must resolve to the local binding, not a
    // same-named top-level function (previously the prelude's `error()`).
    let src = 'fn error() -> Int { return 1; }\n'
        + 'fn main() -> Void {\n'
        + '    let error = 2;\n'
        + '    let x = error;\n'
        + '}\n';
    let use_off = at(src, 'let x = error', 8);
    let decl_off = at(src, 'let error = 2', 4);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_shadowing_let_beats_the_parameter() -> Result<Void, Error> {
    // A `let n` after the parameter `n` shadows it — nearest binding wins (LS4).
    let src = 'fn f(_ n: Int) -> Int {\n'
        + '    let n = 10;\n'
        + '    return n;\n'
        + '}\n';
    let use_off = at(src, 'return n', 7);
    let decl_off = at(src, 'let n = 10', 4);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_inner_block_binding_not_visible_after_the_block() -> Result<Void, Error> {
    // A binding inside an if-block is out of scope after it: the reference
    // resolves to the outer binding, not the (nearer) inner one.
    let src = 'fn f(_ c: Bool) -> Int {\n'
        + '    let v = 1;\n'
        + '    if c {\n'
        + '        let v = 2;\n'
        + '        let w = v + 0;\n'
        + '    }\n'
        + '    return v;\n'
        + '}\n';
    let use_off = at(src, 'return v', 7);
    let decl_off = at(src, 'let v = 1', 4);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    // Inside the block, the inner binding wins.
    let inner_use = at(src, 'v + 0', 0);
    let inner_decl = at(src, 'let v = 2', 4);
    testing.assert_eq(actual: def_offset(src, inner_use), expected: inner_decl)?;
    return Result.Ok(void);
}

@test
fn test_match_arm_binding_resolves_within_the_arm() -> Result<Void, Error> {
    let src = 'fn f(_ o: Option<Int>) -> Int {\n'
        + '    return match o {\n'
        + '        Some(inner) => inner + 1,\n'
        + '        None => 0,\n'
        + '    };\n'
        + '}\n';
    let use_off = at(src, 'inner + 1', 2);
    let decl_off = at(src, 'Some(inner)', 5);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_for_variable_resolves_in_the_loop_body() -> Result<Void, Error> {
    let src = 'fn f(_ xs: List<Int>) -> Int {\n'
        + '    let mut total = 0;\n'
        + '    for x in xs {\n'
        + '        total = total + x;\n'
        + '    }\n'
        + '    return total;\n'
        + '}\n';
    let use_off = at(src, '+ x;', 2);
    let decl_off = at(src, 'for x in', 4);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}

@test
fn test_lambda_param_resolves_in_the_lambda_body() -> Result<Void, Error> {
    let src = 'fn f(_ xs: List<Int>) -> List<Int> {\n'
        + '    return xs.map((v) => v * 2);\n'
        + '}\n';
    let use_off = at(src, 'v * 2', 0);
    let decl_off = at(src, '(v) =>', 1);
    testing.assert_eq(actual: def_offset(src, use_off), expected: decl_off)?;
    return Result.Ok(void);
}
