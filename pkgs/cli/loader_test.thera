// Tests for the loader's namespace layer (the public-surface / barrel logic),
// exercised on hand-built `LibrarySource`s so they need no file system, plus
// the canonical-identity contract (`canonical_path`), which uses a real
// fixture tree under the temp dir. The rest of the file-resolution +
// import-closure walk is covered end-to-end by the driver (the Hawk CLI emits
// byte-identical `.thera-bc` for a std-using program).

import std.testing;
import std.fs;
import std.env;
import std.process;

import 'ast/ast' as _;
import 'lexer/lexer' as _;
import 'parser/parser' as _;
import 'loader' as _;

// Parse `src`, stamping a distinct `path` as its `file_path` — the loader keys
// re-export-cycle detection on `file_path` (Hawk has no object identity), which
// `parse_file_or_null` sets for every real file.
fn prog_of(_ src: String, _ path: String) -> Program {
    let prog = parse_tokens(tokenize(src).tokens).program;
    prog.file_path = Option.Some(path);
    return prog;
}

@test
fn test_public_surface_collects_only_pub_decls() -> Result<Void, Error> {
    let prog = prog_of('pub fn a() { }\n'
        + 'fn b() { }\n'
        + 'pub struct T { let x: Int; }\n'
        + 'pub const C: Int = 1;\n'
        + 'const D: Int = 2;', 'lib.thera');
    let surface = public_surface_of(LibrarySource { program: prog, imports: [:] });
    testing.assert(surface.names.has('a'), message: 'pub fn a is exposed')?;
    testing.assert(!surface.names.has('b'), message: 'private fn b is hidden')?;
    testing.assert(surface.names.has('T'), message: 'pub type T is exposed')?;
    testing.assert(surface.names.has('C'), message: 'pub const C is exposed')?;
    testing.assert(!surface.names.has('D'), message: 'private const D is hidden')?;
    return Result.Ok(void);
}

@test
fn test_namespaces_for_binds_import_to_surface() -> Result<Void, Error> {
    let child = LibrarySource {
        program: prog_of('pub fn helper() { }\nfn secret() { }', 'util.thera'),
        imports: [:],
    };
    let main_src = LibrarySource {
        program: prog_of('import \'util\';\nfn main() { }', 'main.thera'),
        imports: [:],
    };
    main_src.imports['util'] = child;
    match namespaces_for(main_src).get('util') {
        Some(surface) => {
            testing.assert(surface.names.has('helper'), message: 'util exposes helper')?;
            testing.assert(!surface.names.has('secret'), message: 'util hides secret')?;
        },
        None => {
            testing.assert(false, message: 'expected a util namespace')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_canonical_path_absolutizes_and_normalizes() -> Result<Void, Error> {
    // Absolute paths are normalized lexically.
    testing.assert_eq(actual: canonical_path('/a/b/../c.thera'), expected: '/a/c.thera')?;
    testing.assert_eq(actual: canonical_path('/a//./b.thera'), expected: '/a/b.thera')?;
    // Relative paths are resolved against the current directory.
    let cwd = match env.current_dir() {
        Ok(d) => d,
        Err(e) => { return Result.Err(error('no current dir: ${e.message()}')); },
    };
    testing.assert_eq(actual: canonical_path('x/./y.thera'), expected: cwd + '/x/y.thera')?;
    // display_path is the inverse for paths under the current directory —
    // and leaves everything else canonical.
    testing.assert_eq(actual: display_path(canonical_path('x.thera')), expected: 'x.thera')?;
    testing.assert_eq(actual: display_path('/somewhere/else.thera'), expected: '/somewhere/else.thera')?;
    return Result.Ok(void);
}

// The loader keys the closure on canonical identity, so the same root reached
// under different spellings — absolute, `./root.thera`, bare `root.thera` — loads
// one identical closure, an import cycle back to the root reuses the in-memory
// root (no duplicate unit), and a bare filename's imports resolve against the
// invocation directory (the old `dirname('root.thera') == ''` sent them to the
// filesystem root).
@test
fn test_canonical_identity_across_root_spellings() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_canonical_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    fs_ok(fs.create_dir_all(dir + '/sub'), 'create fixture dir')?;
    fs_ok(fs.write_text(dir + '/root.thera',
        'import \'sub/child\';\npub fn ping() -> Int { return 1; }\n'), 'write root')?;
    fs_ok(fs.write_text(dir + '/sub/child.thera',
        'import \'../root\';\npub fn pong() -> Int { return 1; }\n'), 'write child')?;

    // Absolute spelling, from wherever the suite runs.
    check_root_closure(load_root(dir + '/root.thera')?)?;

    // Relative spellings, from inside the fixture directory. Collect results
    // before restoring the cwd so a failure can't leave it switched.
    let saved = match env.current_dir() {
        Ok(d) => d,
        Err(e) => { return Result.Err(error('no current dir: ${e.message()}')); },
    };
    if let Err(e) = env.set_current_dir(dir) {
        return Result.Err(error('cannot chdir to fixture: ${e.message()}'));
    }
    let by_dot = load_root('./root.thera');
    let by_bare = load_root('root.thera');
    if let Err(e) = env.set_current_dir(saved) {
        return Result.Err(error('cannot restore cwd: ${e.message()}'));
    }
    check_root_closure(by_dot?)?;
    check_root_closure(by_bare?)?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// Read + parse `path`'s file and load its closure (no SDK — no prelude), also
// asserting the root program's `file_path` is re-stamped canonical.
fn load_root(_ path: String) -> Result<LoadedImports, Error> {
    return match fs.read_text(path) {
        Ok(src) => {
            let prog = parse_tokens(tokenize(src).tokens).program;
            let loaded = load_imports(path, prog, Option.None);
            match prog.file_path {
                Some(p) => {
                    if !p.starts_with('/') || !p.ends_with('/root.thera') {
                        return Result.Err(error('root file_path not canonical: ${p}'));
                    }
                },
                None => { return Result.Err(error('root file_path not stamped')); },
            }
            Result.Ok(loaded)
        },
        Err(e) => Result.Err(error('read ${path}: ${e.message()}')),
    };
}

// The fixture closure, loaded under any root spelling: exactly one imported
// program (the child — the cycle back to the root must hit the cache, not load
// a duplicate root unit), and both files' namespaces resolved.
fn check_root_closure(_ loaded: LoadedImports) -> Result<Void, Error> {
    testing.assert_eq(actual: loaded.programs.len(), expected: 1)?;
    let child_path = loaded.programs[0].file_path.unwrap_or('');
    testing.assert(child_path.starts_with('/') && child_path.ends_with('/sub/child.thera'),
        message: 'child key is canonical: ${child_path}')?;
    testing.assert_eq(actual: loaded.file_namespaces.len(), expected: 2)?;
    for key in loaded.file_namespaces.keys() {
        let ns = loaded.file_namespaces[key];
        if key.ends_with('/root.thera') {
            testing.assert(ns.get('child').map((s) => s.names.has('pong')).unwrap_or(false),
                message: 'root sees child.pong')?;
        } else {
            testing.assert(key.ends_with('/sub/child.thera'), message: 'unexpected key ${key}')?;
            testing.assert(ns.get('root').map((s) => s.names.has('ping')).unwrap_or(false),
                message: 'child sees root.ping through the cycle')?;
        }
    }
    // The import graph carries both edges of the cycle, keyed canonically.
    testing.assert_eq(actual: loaded.file_imports.len(), expected: 2)?;
    for key in loaded.file_imports.keys() {
        let edges = loaded.file_imports[key];
        testing.assert_eq(actual: edges.len(), expected: 1)?;
        if key.ends_with('/root.thera') {
            testing.assert(edges[0].ends_with('/sub/child.thera'),
                message: 'root imports child: ${edges[0]}')?;
        } else {
            testing.assert(edges[0].ends_with('/root.thera'),
                message: 'child imports root: ${edges[0]}')?;
        }
    }
    return Result.Ok(void);
}

fn fs_ok(_ r: Result<Void, fs.FsError>, _ what: String) -> Result<Void, Error> {
    return match r {
        Ok(_) => Result.Ok(void),
        Err(e) => Result.Err(error('${what}: ${e.message()}')),
    };
}

// A broken import is a located diagnostic at the import decl, attributed to the
// importer — a resolve failure ("no such module") and a read failure (an
// unreadable file) each surface their root cause instead of degrading to a
// downstream "undefined name" (or, for an unused import, passing silently).
@test
fn test_broken_imports_are_diagnosed() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_broken_import_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    let secret = dir + '/secret.thera';
    fs_ok(fs.write_text(secret, 'pub fn s() -> Int { return 1; }\n'), 'write secret')?;
    fs_ok(fs.write_text(dir + '/main.thera',
        'import \'nonexistent\';\nimport \'secret\';\nfn main() -> Void { }\n'), 'write main')?;

    // Make `secret.thera` unreadable (restored below so cleanup can remove it).
    if let Err(e) = process.run('chmod', args: ['000', secret]) {
        return Result.Err(error('chmod: ${e.message()}'));
    }
    let src = match fs.read_text(dir + '/main.thera') {
        Ok(s) => s,
        Err(e) => { return Result.Err(error('read main: ${e.message()}')); },
    };
    let prog = parse_tokens(tokenize(src).tokens).program;
    let loaded = load_imports(dir + '/main.thera', prog, Option.None);
    match process.run('chmod', args: ['644', secret]) { Ok(_) => void, Err(_) => void }

    testing.assert_eq(actual: loaded.diagnostics.len(), expected: 2)?;
    let resolve_d = loaded.diagnostics[0];
    let read_d = loaded.diagnostics[1];
    testing.assert(resolve_d.message.contains('cannot resolve import \'nonexistent\''),
        message: 'resolve failure surfaced: ${resolve_d.message}')?;
    testing.assert_eq(actual: resolve_d.span.line, expected: 1)?;
    testing.assert(read_d.message.contains('cannot read import \'secret\''),
        message: 'read failure surfaced: ${read_d.message}')?;
    testing.assert_eq(actual: read_d.span.line, expected: 2)?;
    for d in loaded.diagnostics {
        let file = d.file.unwrap_or('');
        testing.assert(file.ends_with('/main.thera'),
            message: 'attributed to the importer: ${file}')?;
    }

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// Surface collisions are the exposing file's error (one name space per scope,
// at the import/export surface): a barrel whose `pub import` re-exposes a name
// it already exposes from another file, and two `as _` imports exposing the
// same unqualified name, are each diagnosed at the offending import decl.
// Same-origin re-exposure (a diamond) is not a collision.
@test
fn test_surface_collisions_are_diagnosed() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_surface_collision_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    fs_ok(fs.write_text(dir + '/inner_a.thera', 'pub fn deep() -> Int { return 1; }\n'), 'write inner_a')?;
    fs_ok(fs.write_text(dir + '/inner_b.thera', 'pub fn deep() -> Int { return 2; }\n'), 'write inner_b')?;
    // A colliding barrel (line 2 is the offending pub import) …
    fs_ok(fs.write_text(dir + '/barrel.thera',
        'pub import \'inner_a\';\npub import \'inner_b\';\n'), 'write barrel')?;
    // … a diamond (both routes reach inner_a — not a collision) …
    fs_ok(fs.write_text(dir + '/route.thera', 'pub import \'inner_a\';\n'), 'write route')?;
    fs_ok(fs.write_text(dir + '/diamond.thera',
        'pub import \'inner_a\';\npub import \'route\';\n'), 'write diamond')?;
    // … and a main whose two `as _` imports collide (line 3).
    fs_ok(fs.write_text(dir + '/main.thera',
        'import \'diamond\';\nimport \'inner_a\' as _;\nimport \'inner_b\' as _;\n'
        + 'import \'barrel\';\nfn main() -> Void { }\n'), 'write main')?;

    let loaded = match fs.read_text(dir + '/main.thera') {
        Ok(src) => load_imports(dir + '/main.thera',
            parse_tokens(tokenize(src).tokens).program, Option.None),
        Err(e) => { return Result.Err(error('read main: ${e.message()}')); },
    };
    testing.assert_eq(actual: loaded.diagnostics.len(), expected: 2)?;
    let mut barrel_seen = false;
    let mut bare_seen = false;
    for d in loaded.diagnostics {
        let file = d.file.unwrap_or('');
        if d.message.contains('barrel') {
            barrel_seen = true;
            testing.assert(d.message.contains('`deep`'), message: 'barrel names the name: ${d.message}')?;
            testing.assert(file.ends_with('/barrel.thera'),
                message: 'barrel collision attributed to the barrel: ${file}')?;
            testing.assert_eq(actual: d.span.line, expected: 2)?;
        }
        if d.message.contains('as _') {
            bare_seen = true;
            testing.assert(file.ends_with('/main.thera'),
                message: 'bare collision attributed to the importer: ${file}')?;
            testing.assert_eq(actual: d.span.line, expected: 3)?;
        }
    }
    testing.assert(barrel_seen && bare_seen, message: 'both collision kinds diagnosed')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A `std.*` import that can't resolve says why: no SDK at all vs a module the
// SDK doesn't have.
@test
fn test_unresolved_std_import_says_why() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_std_import_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    let main_path = dir + '/main.thera';
    fs_ok(fs.write_text(main_path, 'import \'std.nonexistent\';\nfn main() -> Void { }\n'),
        'write main')?;
    let src = match fs.read_text(main_path) {
        Ok(s) => s,
        Err(e) => { return Result.Err(error('read main: ${e.message()}')); },
    };

    // No SDK (the hermetic mode): the diagnostic names the missing SDK.
    let no_sdk = load_imports(main_path, parse_tokens(tokenize(src).tokens).program, Option.None);
    testing.assert_eq(actual: no_sdk.diagnostics.len(), expected: 1)?;
    testing.assert(no_sdk.diagnostics[0].message.contains('no Thera SDK found'),
        message: 'missing SDK named: ${no_sdk.diagnostics[0].message}')?;

    // A real SDK: the module itself is the problem.
    if let Some(root) = find_sdk_root() {
        let with_sdk = load_imports(main_path, parse_tokens(tokenize(src).tokens).program,
            Option.Some(root));
        testing.assert_eq(actual: with_sdk.diagnostics.len(), expected: 1)?;
        testing.assert(with_sdk.diagnostics[0].message.contains('not in the SDK'),
            message: 'missing module named: ${with_sdk.diagnostics[0].message}')?;
    }

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// A file living *inside* an SDK's std tree resolves its `std.*` imports from that
// same tree — even when the configured SDK root is elsewhere (or None). This is
// what keeps the LSP from loading a second copy of the core types when it edits
// the repo's own sdk/std against a different installed SDK.
@test
fn test_std_import_resolves_from_the_file_s_own_sdk() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_perfile_sdk_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    // A minimal SDK tree: a `greet` std lib in its own named subdir, and a file
    // that lives beside it under `std/` and imports it.
    fs_ok(fs.create_dir_all(dir + '/std/greet'), 'create greet lib dir')?;
    fs_ok(fs.create_dir_all(dir + '/std/app'), 'create app dir')?;
    fs_ok(fs.write_text(dir + '/std/greet/greet.thera', 'pub fn hi() -> Int { return 1; }\n'),
        'write greet')?;
    let app_path = dir + '/std/app/app.thera';
    let app_src = 'import \'std.greet\';\nfn main() -> Int { return greet.hi(); }\n';
    fs_ok(fs.write_text(app_path, app_src), 'write app')?;

    // Configured SDK root is None — yet `std.greet` resolves, because app.thera is
    // itself inside `<dir>/std`, so per-file resolution finds greet next door. The
    // only diagnostic tolerated is a missing auto-imported `std.core` (this tree
    // has none); `std.greet` must NOT be among the failures.
    let loaded = load_imports(app_path, parse_tokens(tokenize(app_src).tokens).program, Option.None);
    for d in loaded.diagnostics {
        testing.assert(!d.message.contains('std.greet'),
            message: 'std.greet should resolve from the file\'s own SDK, but: ${d.message}')?;
    }

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

@test
fn test_pub_import_reexports_through_barrel() -> Result<Void, Error> {
    // A barrel: `pub import 'inner'` re-exports inner's public surface alongside
    // the barrel's own public declarations.
    let inner = LibrarySource { program: prog_of('pub fn deep() { }', 'inner.thera'), imports: [:] };
    let barrel = LibrarySource {
        program: prog_of('pub import \'inner\';\npub fn own() { }', 'barrel.thera'),
        imports: [:],
    };
    barrel.imports['inner'] = inner;
    let surface = public_surface_of(barrel);
    testing.assert(surface.names.has('own'), message: 'barrel exposes its own fn')?;
    testing.assert(surface.names.has('deep'), message: 're-exports inner deep fn')?;
    return Result.Ok(void);
}

@test
fn test_pub_import_diamond_is_not_a_collision() -> Result<Void, Error> {
    // A diamond of re-exports reaching one declaring file: the barrel
    // pub-imports `left` and `right`, which both pub-import `deep`. `deep`'s
    // names must appear once with no collision — the shared-visited walk sees
    // the deep file once. (Pins the semantics the loader's per-call surface
    // memo must preserve: naively merging per-child surfaces would flag a
    // false collision here.)
    let deep = LibrarySource { program: prog_of('pub fn shared() { }', 'deep.thera'), imports: [:] };
    let left = LibrarySource { program: prog_of('pub import \'deep\';', 'left.thera'), imports: [:] };
    left.imports['deep'] = deep;
    let right = LibrarySource { program: prog_of('pub import \'deep\';', 'right.thera'), imports: [:] };
    right.imports['deep'] = deep;
    let barrel = LibrarySource {
        program: prog_of('pub import \'left\';\npub import \'right\';', 'barrel.thera'),
        imports: [:],
    };
    barrel.imports['left'] = left;
    barrel.imports['right'] = right;
    let surface = public_surface_of(barrel);
    testing.assert(surface.names.has('shared'), message: 'diamond name is exposed')?;
    testing.assert(!surface.collisions.has('shared'), message: 'one declaring file: no collision')?;
    testing.assert_eq(actual: surface.origin.get('shared'), expected: Option.Some('deep.thera'))?;
    return Result.Ok(void);
}

// A shared surface cache: the second load fills its tables from the cache
// (proven by mutating the cached entry between calls), and collision
// diagnostics replay identically on a hit.
@test
fn test_surface_cache_round_trip() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_surface_cache_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    fs_ok(fs.write_text(dir + '/util.thera', 'pub fn helper() -> Int { return 1; }\n'), 'write util')?;
    let main_src = 'import \'util\';\nfn main() -> Int { return util.helper(); }\n';
    fs_ok(fs.write_text(dir + '/main.thera', main_src), 'write main')?;

    let cache: Map<String, FileSurface> = [:];
    let first = load_imports(dir + '/main.thera',
        parse_tokens(tokenize(main_src).tokens).program, Option.None, surface_cache: cache);
    testing.assert_eq(actual: first.diagnostics.len(), expected: 0)?;
    let main_key = canonical_path(dir + '/main.thera');
    testing.assert(cache.has(main_key), message: 'main surface cached')?;
    testing.assert(cache.has(canonical_path(dir + '/util.thera')), message: 'util surface cached')?;

    // Prove the hit path: plant a marker in main's cached bare surface and
    // check the second load reflects it.
    if let Some(entry) = cache.get(main_key) {
        entry.bare_surface['__marker'] = 'planted';
    }
    let second = load_imports(dir + '/main.thera',
        parse_tokens(tokenize(main_src).tokens).program, Option.None, surface_cache: cache);
    let served = second.file_bare_surface.get(main_key)
        .map((m) => m.has('__marker')).unwrap_or(false);
    testing.assert(served, message: 'second load serves the cached entry')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}

// Surface-collision diagnostics replay from the cache: a load with a warm
// cache reports the same collision the cold load did.
@test
fn test_surface_collision_diagnostics_replay_on_hit() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/thera_loader_collision_replay_test');
    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void } // stale fixture
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    fs_ok(fs.write_text(dir + '/a.thera', 'pub fn clash() -> Int { return 1; }\n'), 'write a')?;
    fs_ok(fs.write_text(dir + '/b.thera', 'pub fn clash() -> Int { return 2; }\n'), 'write b')?;
    let main_src = 'import \'a\' as _;\nimport \'b\' as _;\nfn main() -> Void { }\n';
    fs_ok(fs.write_text(dir + '/main.thera', main_src), 'write main')?;

    let cache: Map<String, FileSurface> = [:];
    let cold = load_imports(dir + '/main.thera',
        parse_tokens(tokenize(main_src).tokens).program, Option.None, surface_cache: cache);
    let warm = load_imports(dir + '/main.thera',
        parse_tokens(tokenize(main_src).tokens).program, Option.None, surface_cache: cache);
    testing.assert(cold.diagnostics.len() > 0, message: 'cold load reports the collision')?;
    testing.assert_eq(actual: warm.diagnostics.len(), expected: cold.diagnostics.len())?;
    testing.assert(warm.diagnostics[0].message.contains('clash'),
        message: 'replayed diagnostic names the colliding fn')?;

    match fs.remove_dir_all(dir) { Ok(_) => void, Err(_) => void }
    return Result.Ok(void);
}
