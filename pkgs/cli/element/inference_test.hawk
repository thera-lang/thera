// Tests for the typing engine: build an element model from a small program,
// then infer the type of a parsed expression in a constructed scope. Exercises
// literals, collections, identifier/const lookup, enum construction (incl.
// generic recovery), struct literals, field access, and method dispatch.

import std.testing;

import '../ast/ast' as _;
import '../lexer/lexer' as _;
import '../parser/parser' as _;
import 'types' as _;
import 'element' as _;
import 'resolver' as _;
import 'inference' as _;

fn lib_of(_ src: String) -> LibraryElement {
    return build_library(parse_tokens(tokenize(src).tokens).program, [], {}, {});
}

fn type_of(_ src: String, _ scope: Map<String, Type>, _ ctx: InferCtx) -> Type {
    return infer_in(parse_expression(tokenize(src).tokens), scope, ctx);
}

fn empty_scope() -> Map<String, Type> {
    let s: Map<String, Type> = {};
    return s;
}

// An expected named type built the way inference builds one — owner stamped from
// the registry — so structural equality matches the inferred type's `TypeId`.
fn mk_iface(_ ctx: InferCtx, _ name: String, _ args: List<Type>) -> Type {
    return named_type(ctx.library.type_defs, name, args);
}

@test
fn test_arithmetic_is_int() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(actual: type_of('1 + 2', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_comparison_is_bool() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(actual: type_of('1 < 2', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Bool))?;
    return Result.Ok(void);
}

@test
fn test_list_literal_is_list_of_element() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(actual: type_of('[1, 2, 3]', empty_scope(), ctx),
        expected: mk_iface(ctx, 'List', [Type.Primitive(Primitive.Int)]))?;
    return Result.Ok(void);
}

@test
fn test_map_literal_is_map_of_key_value() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(actual: type_of('{ 1: true }', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Map', [
            Type.Primitive(Primitive.Int),
            Type.Primitive(Primitive.Bool),
    ]))?;
    return Result.Ok(void);
}

@test
fn test_identifier_from_scope() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    let scope = empty_scope();
    scope['x'] = Type.Primitive(Primitive.Double);
    testing.assert_eq(actual: type_of('x', scope, ctx),
        expected: Type.Primitive(Primitive.Double))?;
    return Result.Ok(void);
}

@test
fn test_const_lookup() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('const MAX: Int = 100;'));
    testing.assert_eq(actual: type_of('MAX', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_bare_enum_variant() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('enum Color { Red, Green, Blue }'));
    testing.assert_eq(actual: type_of('Color.Red', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Color', []))?;
    return Result.Ok(void);
}

@test
fn test_generic_enum_construction_recovers_arg() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('enum Box<T> { Of(T), Empty }'));
    testing.assert_eq(actual: type_of('Box.Of(5)', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Box', [Type.Primitive(Primitive.Int)]))?;
    return Result.Ok(void);
}

@test
fn test_generic_struct_literal_recovers_arg() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('struct Wrap<T> { value: T }'));
    testing.assert_eq(actual: type_of('Wrap { value: true }', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Wrap', [Type.Primitive(Primitive.Bool)]))?;
    return Result.Ok(void);
}

@test
fn test_struct_field_access() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('struct Point { x: Int, y: Double }'));
    let scope = empty_scope();
    scope['p'] = mk_iface(ctx, 'Point', []);
    testing.assert_eq(actual: type_of('p.x', scope, ctx),
        expected: Type.Primitive(Primitive.Int))?;
    testing.assert_eq(actual: type_of('p.y', scope, ctx),
        expected: Type.Primitive(Primitive.Double))?;
    return Result.Ok(void);
}

@test
fn test_method_return_type() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('struct Point { x: Int, y: Int }\n'
        + 'impl Point { pub fn sum(self) -> Int { return self.x + self.y; } }'));
    let scope = empty_scope();
    scope['p'] = mk_iface(ctx, 'Point', []);
    testing.assert_eq(actual: type_of('p.sum()', scope, ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_generic_method_instantiates_from_receiver() -> Result<Void, Error> {
    // A `List<Int>` indexes to `Int`, exercising receiver-type-arg binding.
    let ctx = new_ctx(lib_of(''));
    let scope = empty_scope();
    scope['xs'] = mk_iface(ctx, 'List', [Type.Primitive(Primitive.Int)]);
    testing.assert_eq(actual: type_of('xs[0]', scope, ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_free_function_call_return_type() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of('fn twice(_ n: Int) -> Int { return n + n; }'));
    testing.assert_eq(actual: type_of('twice(21)', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_match_arm_binds_variant_payload() -> Result<Void, Error> {
    // Matching a `Box<Int>` binds the payload to `Int`; the arm's value is that.
    let ctx = new_ctx(lib_of('enum Box<T> { Of(T), Empty }'));
    let scope = empty_scope();
    scope['b'] = mk_iface(ctx, 'Box', [Type.Primitive(Primitive.Int)]);
    testing.assert_eq(
        actual: type_of('match b { Of(v) => v, Empty => 0 }', scope, ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_block_tail_sees_let_bindings() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let n = 5; n }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

// ---- forward-flow inference ----
// An empty literal / `None` binding is underdetermined at its initializer; these
// assert the element type is recovered from the binding's first pinning use later
// in the block (a push, an indexed assignment, or a reassignment).

@test
fn test_forward_flow_empty_list_pinned_by_push() -> Result<Void, Error> {
    // `let xs = []` then `xs.push(5)` makes `xs` a `List<Int>`, so the tail
    // `xs[0]` is `Int` (rather than the `Unknown` an empty literal alone gives).
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let xs = []; xs.push(5); xs[0] }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_empty_list_pinned_by_reassignment() -> Result<Void, Error> {
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let mut xs = []; xs = [1, 2]; xs[0] }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_empty_map_pinned_by_index_assign() -> Result<Void, Error> {
    // An indexed assignment recovers both the key and value type of an empty map.
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let m = {}; m[\'a\'] = 10; m[\'a\'] }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_none_pinned_by_reassignment() -> Result<Void, Error> {
    // `let mut x = Opt.Nope` is `Opt<Unknown>`; the reassignment pins it to
    // `Opt<Int>`, so the matched payload `v` is `Int`.
    let ctx = new_ctx(lib_of('enum Opt<T> { Some(T), Nope }'));
    testing.assert_eq(
        actual: type_of('{ let mut x = Opt.Nope; x = Opt.Some(5); match x { Some(v) => v, Nope => 0 } }',
            empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_first_pinning_use_wins() -> Result<Void, Error> {
    // The first `push` determines the element type; a later inconsistent push does
    // not change it (it becomes a mismatch the checker reports separately).
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let xs = []; xs.push(1); xs.push(\'a\'); xs[0] }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_unpinned_stays_unknown() -> Result<Void, Error> {
    // With no pinning use, the binding keeps its lenient `Unknown` element — the
    // refinement never guesses.
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let xs = []; xs[0] }', empty_scope(), ctx),
        expected: Type.Unknown)?;
    return Result.Ok(void);
}

// ---- enum construction recovers parameters from the expected type ----

fn type_of_expecting(_ src: String, _ ctx: InferCtx, _ expected: Type) -> Type {
    return infer_expr(parse_expression(tokenize(src).tokens), empty_scope(), ctx, Option.Some(expected));
}

@test
fn test_enum_construction_recovers_param_from_expected() -> Result<Void, Error> {
    // `Res.Ok(0)` fixes `T` from the payload; `E` (the un-constructed `Err`'s
    // parameter, which the payload can't determine) is recovered from the
    // expected type — the `Result.Ok(x)` -> `Result<T, Unknown>` precision gap.
    let ctx = new_ctx(lib_of('enum Res<T, E> { Ok(T), Err(E) }'));
    let expected = mk_iface(ctx, 'Res', [Type.Primitive(Primitive.Int), Type.Primitive(Primitive.Bool)]);
    testing.assert_eq(actual: type_of_expecting('Res.Ok(0)', ctx, expected), expected: expected)?;
    return Result.Ok(void);
}

@test
fn test_enum_construction_payload_wins_over_expected() -> Result<Void, Error> {
    // The payload is authoritative for the parameter it determines: `Res.Ok(0)`
    // is `Res<Int, _>` even if the expected `T` disagrees (the mismatch is a
    // separate diagnostic); only the un-determined `E` comes from the expected.
    let ctx = new_ctx(lib_of('enum Res<T, E> { Ok(T), Err(E) }'));
    let expected = mk_iface(ctx, 'Res', [Type.Primitive(Primitive.Str), Type.Primitive(Primitive.Bool)]);
    testing.assert_eq(actual: type_of_expecting('Res.Ok(0)', ctx, expected),
        expected: mk_iface(ctx, 'Res', [Type.Primitive(Primitive.Int), Type.Primitive(Primitive.Bool)]))?;
    return Result.Ok(void);
}

@test
fn test_enum_construction_without_expected_leaves_param_unknown() -> Result<Void, Error> {
    // No expected type: the un-determined parameter stays `Unknown` (unchanged,
    // load-bearing behavior — see the roadmap's Unknown-hole finding).
    let ctx = new_ctx(lib_of('enum Res<T, E> { Ok(T), Err(E) }'));
    testing.assert_eq(actual: type_of('Res.Ok(0)', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Res', [Type.Primitive(Primitive.Int), Type.Unknown]))?;
    return Result.Ok(void);
}

// ---- forward-flow descends into nested blocks ----

@test
fn test_forward_flow_pins_through_if_block() -> Result<Void, Error> {
    // A reassignment inside an `if` still pins the binding's type (it holds that
    // type when the branch runs) — the parser's `let mut type_ann = Option.None;
    // if … { type_ann = Option.Some(…) }` shape that was the last `Unknown` hole.
    let ctx = new_ctx(lib_of('enum Opt<T> { Some(T), Nope }'));
    testing.assert_eq(
        actual: type_of('{ let mut x = Opt.Nope; if true { x = Opt.Some(5); } x }', empty_scope(), ctx),
        expected: mk_iface(ctx, 'Opt', [Type.Primitive(Primitive.Int)]))?;
    return Result.Ok(void);
}

@test
fn test_forward_flow_pins_through_for_loop_push() -> Result<Void, Error> {
    // A `push` inside a `for` pins the element, with the loop variable in scope so
    // `xs.push(i)` types against the iteration element rather than `Unknown`.
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(
        actual: type_of('{ let xs = []; for i in 0..3 { xs.push(i); } xs[0] }', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}

// ---- the committed-type memo (CH19) ----

@test
fn test_memo_hit_wins_regardless_of_expected() -> Result<Void, Error> {
    // A committed record answers for its node no matter what the caller
    // expects — the committed value was computed with the correct expectation.
    let expr = parse_expression(tokenize('1 + 2').tokens);
    let types: Map<Int, Type> = {};
    types[span_key(expr_span(expr))] = Type.Primitive(Primitive.Str);
    let ctx = new_ctx(lib_of(''), types: types);
    testing.assert_eq(actual: infer_in(expr, empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Str))?;
    testing.assert_eq(
        actual: infer_expr(expr, empty_scope(), ctx, Option.Some(Type.Primitive(Primitive.Int))),
        expected: Type.Primitive(Primitive.Str))?;
    return Result.Ok(void);
}

@test
fn test_empty_memo_leaves_inference_untouched() -> Result<Void, Error> {
    // The codegen-safety pin: a default ctx has an empty record, inference
    // derives normally and never writes to it.
    let ctx = new_ctx(lib_of(''));
    testing.assert_eq(actual: type_of('1 + 2', empty_scope(), ctx),
        expected: Type.Primitive(Primitive.Int))?;
    testing.assert_eq(actual: ctx.types.len(), expected: 0)?;
    return Result.Ok(void);
}
