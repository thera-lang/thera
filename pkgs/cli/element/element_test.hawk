import std.testing;

import 'types' as _;
import 'element' as _;

fn defs() -> Map<String, TypeDefElement> {
    let m: Map<String, TypeDefElement> = {};
    m['List'] = new_builtin('t', 'List', ['T']);
    m['Display'] = new_interface('t', 'Display', []);
    m['Error'] = new_interface('t', 'Error', []);
    return m;
}

// Wrap a by-name def map into a minimal LibraryElement whose defs are all owned
// by file key 't' (matching the fixture TypeIds) — `is_assignable` resolves
// identities through the per-file tables.
fn lib_with(_ m: Map<String, TypeDefElement>) -> LibraryElement {
    let file_type_defs: Map<String, Map<String, TypeDefElement>> = {};
    file_type_defs['t'] = m;
    let file_functions: Map<String, Map<String, FunctionElement>> = {};
    let file_consts: Map<String, Map<String, ConstElement>> = {};
    let file_namespaces: Map<String, Map<String, LibraryNamespace>> = {};
    let file_bare_surface: Map<String, Map<String, String>> = {};
    let file_owned: Map<String, Set<String>> = {};
    return LibraryElement {
        type_defs: m,
        file_functions: file_functions,
        file_type_defs: file_type_defs,
        file_consts: file_consts,
        file_namespaces: file_namespaces,
        file_bare_surface: file_bare_surface,
        file_owned: file_owned,
    };
}

@test
fn test_primitive_type_lookup() -> Result<Void, Error> {
    testing.assert_eq(actual: primitive_type('Int'),
        expected: Option.Some(Type.Primitive(Primitive.Int)))?;
    testing.assert_eq(actual: primitive_type('Nope'), expected: Option.None)?;
    return Result.Ok(void);
}

@test
fn test_type_to_string() -> Result<Void, Error> {
    let list_int = Type.Interface(TypeId { owner: 't', name: 'List' }, [Type.Primitive(Primitive.Int)]);
    testing.assert_eq(actual: type_to_string(list_int), expected: 'List<Int>')?;
    testing.assert_eq(actual: type_to_string(Type.Unknown), expected: '?')?;
    return Result.Ok(void);
}

@test
fn test_is_assignable_basics() -> Result<Void, Error> {
    let d = lib_with(defs());
    let int_t = Type.Primitive(Primitive.Int);
    // Unknown / TypeParameter are lenient on either side.
    testing.assert(is_assignable(Type.Unknown, int_t, d))?;
    testing.assert(is_assignable(int_t, Type.TypeParameter('T'), d))?;
    // Same type assignable; different primitives not.
    testing.assert(is_assignable(int_t, int_t, d))?;
    testing.assert(!is_assignable(int_t, Type.Primitive(Primitive.Bool), d))?;
    return Result.Ok(void);
}

@test
fn test_is_assignable_interface_subtyping() -> Result<Void, Error> {
    let m = defs();
    let d = lib_with(m);
    // Error extends Display (transitive supers stored on the element, by
    // identity).
    m['Error'].super_interfaces.push(TypeId { owner: 't', name: 'Display' });
    // A struct that impls Error.
    m['Boom'] = new_struct('t', 'Boom', []);
    m['Boom'].interfaces.push(TypeId { owner: 't', name: 'Error' });
    let boom = Type.Interface(TypeId { owner: 't', name: 'Boom' }, []);
    let err = Type.Interface(TypeId { owner: 't', name: 'Error' }, []);
    let disp = Type.Interface(TypeId { owner: 't', name: 'Display' }, []);
    testing.assert(is_assignable(boom, err, d), message: 'Boom -> Error')?;
    // Error value assignable where Display (a super) is expected.
    testing.assert(is_assignable(err, disp, d), message: 'Error -> Display')?;
    return Result.Ok(void);
}

@test
fn test_is_assignable_owner_distinct() -> Result<Void, Error> {
    // Two libraries' same-named generic types are distinct: element identity is
    // the full TypeId (owner + name), so `a.Box<Int>` is NOT assignable to
    // `b.Box<Int>` even though the names and args match. An owner-blind compare
    // would unify them — a soundness hole under lifted type-name uniqueness.
    let d = lib_with(defs());
    let int_t = Type.Primitive(Primitive.Int);
    let a_box = Type.Interface(TypeId { owner: 'a', name: 'Box' }, [int_t]);
    let b_box = Type.Interface(TypeId { owner: 'b', name: 'Box' }, [int_t]);
    let a_box2 = Type.Interface(TypeId { owner: 'a', name: 'Box' }, [int_t]);
    testing.assert(!is_assignable(a_box, b_box, d), message: 'a.Box<Int> not assignable to b.Box<Int>')?;
    testing.assert(is_assignable(a_box, a_box2, d), message: 'a.Box<Int> assignable to a.Box<Int>')?;
    return Result.Ok(void);
}

@test
fn test_substitute_and_unify() -> Result<Void, Error> {
    let bindings: Map<String, Type> = {};
    unify(Type.Interface(TypeId { owner: 't', name: 'List' }, [Type.TypeParameter('T')]),
        Type.Interface(TypeId { owner: 't', name: 'List' }, [Type.Primitive(Primitive.Int)]), bindings);
    testing.assert_eq(actual: bindings.get('T'),
        expected: Option.Some(Type.Primitive(Primitive.Int)))?;
    // substitute applies the binding.
    testing.assert_eq(
        actual: substitute(Type.TypeParameter('T'), bindings),
        expected: Type.Primitive(Primitive.Int))?;
    return Result.Ok(void);
}
