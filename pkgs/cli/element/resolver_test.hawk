// Tests for the resolver: parse a program, build the element model, and check
// that member types, signatures, enum variants, impl methods, and the flattened
// interface closure resolve as expected.

import std.testing;

import '../lexer/lexer' as _;
import '../parser/parser' as _;
import 'types' as _;
import 'element' as _;
import 'resolver' as _;
import 'scope' as _;

fn lib_of(_ src: String) -> LibraryElement {
    return build_library(parse_tokens(tokenize(src).tokens).program, [], {}, {});
}

@test
fn test_struct_fields_resolve() -> Result<Void, Error> {
    let lib = lib_of('struct Point { x: Int, y: Double }');
    match lib.type_defs.get('Point') {
        Some(pt) => {
            testing.assert_eq(actual: pt.kind, expected: TypeDefKind.Struct)?;
            testing.assert_eq(actual: pt.fields.get('x'),
                expected: Option.Some(Type.Primitive(Primitive.Int)))?;
            testing.assert_eq(actual: pt.fields.get('y'),
                expected: Option.Some(Type.Primitive(Primitive.Double)))?;
        },
        None => {
            testing.assert(false, message: 'Point not in type_defs')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_function_signature_resolves() -> Result<Void, Error> {
    let lib = lib_of('struct Point { x: Int, y: Int }\n'
        + 'fn origin(_ p: Point) -> Int { return p.x; }');
    match file_scope(lib, Option.None).resolve_function('origin') {
        Some(f) => {
            testing.assert_eq(actual: f.return_type,
                expected: Type.Primitive(Primitive.Int))?;
            testing.assert_eq(actual: f.parameters.len(), expected: 1)?;
            testing.assert_eq(actual: f.parameters[0].ty,
                expected: named_type(lib.type_defs, 'Point', []))?;
        },
        None => {
            testing.assert(false, message: 'origin not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_generic_struct_field_is_type_parameter() -> Result<Void, Error> {
    let lib = lib_of('struct Box<T> { value: T }');
    match lib.type_defs.get('Box') {
        Some(b) => {
            testing.assert_eq(actual: b.type_parameters, expected: ['T'])?;
            testing.assert_eq(actual: b.fields.get('value'),
                expected: Option.Some(Type.TypeParameter('T')))?;
        },
        None => {
            testing.assert(false, message: 'Box not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_enum_variants_resolve() -> Result<Void, Error> {
    let lib = lib_of('enum Shape { Circle(Double), Rect(Int, Int) }');
    match lib.type_defs.get('Shape') {
        Some(sh) => {
            testing.assert_eq(actual: sh.variants.len(), expected: 2)?;
            match find_variant(sh, 'Rect') {
                Some(rect) => {
                    testing.assert_eq(actual: rect.fields, expected: [
                        Type.Primitive(Primitive.Int),
                        Type.Primitive(Primitive.Int),
                    ])?;
                },
                None => {
                    testing.assert(false, message: 'Rect variant not found')?;
                },
            }
        },
        None => {
            testing.assert(false, message: 'Shape not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_impl_methods_attach() -> Result<Void, Error> {
    let lib = lib_of('struct Point { x: Int, y: Int }\n'
        + 'impl Point {\n'
        + '  pub fn x_of(self) -> Int { return self.x; }\n'
        + '  pub fn make() -> Point { return Point { x: 0, y: 0 }; }\n'
        + '}');
    match lib.type_defs.get('Point') {
        Some(pt) => {
            match find_method(pt, 'x_of') {
                Some(m) => {
                    testing.assert(!m.is_static, message: 'x_of has self')?;
                    testing.assert_eq(actual: m.return_type,
                        expected: Type.Primitive(Primitive.Int))?;
                },
                None => {
                    testing.assert(false, message: 'x_of not attached')?;
                },
            }
            match find_method(pt, 'make') {
                Some(m) => {
                    testing.assert(m.is_static, message: 'make is static')?;
                },
                None => {
                    testing.assert(false, message: 'make not attached')?;
                },
            }
        },
        None => {
            testing.assert(false, message: 'Point not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_per_file_tables_populated() -> Result<Void, Error> {
    // The per-file type/const tables (Phase 2e S1) record each declaration under its
    // declaring file, referencing the same element as the flat tables. The anonymous
    // program keys under '' (file_key of None).
    let lib = lib_of('struct Point { x: Int }\nconst K: Int = 1\n'
        + 'fn f() -> Int { return 0; }');
    match lib.file_type_defs.get('') {
        Some(types) => {
            testing.assert(types.has('Point'), message: 'Point recorded per-file')?;
            // Same object as the flat table (member fills are visible through both).
            testing.assert_eq(actual: types.get('Point').is_some(),
                expected: lib.type_defs.get('Point').is_some())?;
        },
        None => { testing.assert(false, message: 'no per-file types for anon program')?; },
    }
    match lib.file_consts.get('') {
        Some(cs) => { testing.assert(cs.has('K'), message: 'K recorded per-file')?; },
        None => { testing.assert(false, message: 'no per-file consts for anon program')?; },
    }
    return Result.Ok(void);
}

@test
fn test_interface_inheritance_flattens() -> Result<Void, Error> {
    let lib = lib_of('interface Display { fn show(self) -> String; }\n'
        + 'interface Debug { fn dbg(self) -> String; }\n'
        + 'interface Pretty: Display + Debug { fn pretty(self) -> String; }');
    match lib.type_defs.get('Pretty') {
        Some(p) => {
            // The closure carries both supers; the methods are flattened in.
            testing.assert(str_list_has(p.super_interfaces, 'Display'))?;
            testing.assert(str_list_has(p.super_interfaces, 'Debug'))?;
            testing.assert(match find_method(p, 'show') {
                Some(_) => true,
                None => false,
            }, message: 'inherited show flattened in')?;
            testing.assert(match find_method(p, 'dbg') {
                Some(_) => true,
                None => false,
            }, message: 'inherited dbg flattened in')?;
            // Its own method stays listed as own.
            testing.assert(str_list_has(p.own_methods, 'pretty'))?;
        },
        None => {
            testing.assert(false, message: 'Pretty not found')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_reserved_flat_entry_pinned_to_first_registration() -> Result<Void, Error> {
    // A reserved core name's flat registry entry is pinned to its first real
    // registration (EL8): a later — illegal, but possibly *unchecked* (an open
    // LSP buffer) — declaration must not steal core identity. `is_core_id`
    // therefore keeps pointing at the first owner.
    let core = parse_tokens(tokenize('pub enum Result { Good, Bad }').tokens).program;
    core.file_path = Option.Some('/core/result.hawk');
    let user = parse_tokens(tokenize('struct Result { x: Int }').tokens).program;
    user.file_path = Option.Some('/app/main.hawk');
    let lib = build_library(user, [core], {}, {});
    match lib.type_defs.get('Result') {
        Some(d) => {
            testing.assert_eq(actual: d.owner_file, expected: '/core/result.hawk')?;
            testing.assert_eq(actual: d.kind, expected: TypeDefKind.Enum)?;
        },
        None => {
            testing.assert(false, message: 'Result not in type_defs')?;
        },
    }
    testing.assert(is_core_id(lib,
        TypeId { owner: '/core/result.hawk', name: 'Result' }, 'Result'))?;
    testing.assert(!is_core_id(lib,
        TypeId { owner: '/app/main.hawk', name: 'Result' }, 'Result'))?;
    // The user file's own table still holds its (illegal) declaration — only
    // the shared flat entry is protected.
    match lib.file_type_defs.get('/app/main.hawk') {
        Some(m) => { testing.assert(m.has('Result'))?; },
        None => { testing.assert(false, message: 'no /app/main.hawk table')?; },
    }
    // A non-reserved name keeps last-wins in the flat table.
    let a = parse_tokens(tokenize('pub struct Config { x: Int }').tokens).program;
    a.file_path = Option.Some('/a.hawk');
    let b = parse_tokens(tokenize('pub struct Config { y: Int }').tokens).program;
    b.file_path = Option.Some('/b.hawk');
    let lib2 = build_library(b, [a], {}, {});
    match lib2.type_defs.get('Config') {
        Some(d) => { testing.assert_eq(actual: d.owner_file, expected: '/b.hawk')?; },
        None => { testing.assert(false, message: 'Config not in type_defs')?; },
    }
    return Result.Ok(void);
}
