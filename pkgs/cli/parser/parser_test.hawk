// Tests for the parser. Expressions are checked by rendering the parsed tree
// with `describe_expr` (the canonical span-free form, matching Dart's
// `Expr.describe()`); declarations and error recovery are checked structurally.

import std.testing;

import '../lexer/token' as _;
import '../lexer/lexer' as _;
import '../ast/ast' as _;
import '../ast/describe' as _;
import 'parser' as _;

// Parse `src` as a single expression and render it canonically.
fn expr_str(_ src: String) -> String {
    return describe_expr(parse_expression(tokenize(src).tokens));
}

fn parse_src(_ src: String) -> ParseResult {
    return parse_tokens(tokenize(src).tokens);
}

fn decl_name(_ d: Decl) -> String {
    return match d {
        Import(x) => x.path,
        Fn(x) => x.name,
        Type(x) => x.name,
        Impl(x) => x.type_name,
        Interface(x) => x.name,
        Const(x) => x.name,
        Let(x) => x.name,
        Enum(x) => x.name,
    };
}

fn decl_has(_ r: ParseResult, _ name: String) -> Bool {
    for d in r.program.decls {
        if decl_name(d) == name {
            return true;
        }
    }
    return false;
}

// Parse every token-prefix of `src` (each re-terminated with the EOF token),
// returning the count. The point is that each parse *returns*: a non-advancing
// recovery loop would hang (or a stray index would trap) instead — exactly the
// mid-edit input the LSP feeds the parser on every keystroke. In-process, so a
// few hundred prefixes cost microseconds.
fn parse_all_prefixes(_ src: String) -> Int {
    let toks = tokenize(src).tokens;
    let eof = toks[toks.len() - 1]; // tokenize always ends with an EOF token
    let mut count = 0;
    let mut n = 1;
    while n < toks.len() {
        let prefix = toks.slice(0, n);
        prefix.push(eof);
        let _r = parse_tokens(prefix);
        count = count + 1;
        n = n + 1;
    }
    return count;
}

@test
fn test_arithmetic_precedence() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('1 + 2 * 3'), expected: '(1 + (2 * 3))')?;
    testing.assert_eq(actual: expr_str('1 * 2 + 3'), expected: '((1 * 2) + 3)')?;
    testing.assert_eq(actual: expr_str('(1 + 2) * 3'), expected: '((1 + 2) * 3)')?;
    return Result.Ok(void);
}

@test
fn test_logical_and_bitwise_precedence() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('a || b && c'),
        expected: '(a || (b && c))')?;
    // C-family bitwise: | looser than ^ looser than &, all looser than equality
    // (the classic C gotcha: `&` binds looser than `==`).
    testing.assert_eq(actual: expr_str('1 | 2 ^ 3 & 4'),
        expected: '(1 | (2 ^ (3 & 4)))')?;
    testing.assert_eq(actual: expr_str('a == b & c'),
        expected: '((a == b) & c)')?;
    return Result.Ok(void);
}

@test
fn test_unary_and_shift() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('-x'), expected: '(-x)')?;
    testing.assert_eq(actual: expr_str('!a'), expected: '(!a)')?;
    testing.assert_eq(actual: expr_str('~b'), expected: '(~b)')?;
    // Adjacent `<`/`>` combine into shift operators.
    testing.assert_eq(actual: expr_str('1 << 2'), expected: '(1 << 2)')?;
    testing.assert_eq(actual: expr_str('a >> b >>> c'),
        expected: '((a >> b) >>> c)')?;
    return Result.Ok(void);
}

@test
fn test_postfix_chains() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('a.b.c'), expected: 'a.b.c')?;
    testing.assert_eq(actual: expr_str('f(a, b)'), expected: 'f(a, b)')?;
    testing.assert_eq(actual: expr_str('obj.method(x)'),
        expected: 'obj.method(x)')?;
    testing.assert_eq(actual: expr_str('xs[0]'), expected: 'xs[0]')?;
    testing.assert_eq(actual: expr_str('compute()?'), expected: 'compute()?')?;
    // A labeled call argument and a generic call.
    testing.assert_eq(actual: expr_str('f(x: 1, y: 2)'),
        expected: 'f(x: 1, y: 2)')?;
    testing.assert_eq(actual: expr_str('parse<Int>(s)'),
        expected: 'parse<Int>(s)')?;
    return Result.Ok(void);
}

@test
fn test_range() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('0..n'), expected: '0..n')?;
    return Result.Ok(void);
}

@test
fn test_collections_and_struct() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('[1, 2, 3]'), expected: '[1, 2, 3]')?;
    testing.assert_eq(actual: expr_str("{'a': 1, 'b': 2}"),
        expected: '{"a": 1, "b": 2}')?;
    testing.assert_eq(actual: expr_str('Point { x: 1, y: 2 }'),
        expected: 'Point { x: 1, y: 2 }')?;
    // A namespace-qualified construction of an imported type.
    testing.assert_eq(actual: expr_str('geo.Point { x: 1, y: 2 }'),
        expected: 'geo.Point { x: 1, y: 2 }')?;
    return Result.Ok(void);
}

@test
fn test_lambdas() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('n => n + 1'),
        expected: 'n => (n + 1)')?;
    testing.assert_eq(actual: expr_str('(a, b) => a'), expected: '(a, b) => a')?;
    testing.assert_eq(actual: expr_str('(a: Int) => a'),
        expected: '(a: Int) => a')?;
    return Result.Ok(void);
}

@test
fn test_match_and_if_expr() -> Result<Void, Error> {
    testing.assert_eq(actual: expr_str('match x { Some(n) => n, None => 0 }'),
        expected: 'match x { Some(n) => n, None => 0 }')?;
    testing.assert_eq(actual: expr_str('if a { 1 } else { 2 }'),
        expected: 'if a {...} else {...}')?;
    return Result.Ok(void);
}

@test
fn test_string_interpolation() -> Result<Void, Error> {
    // The text/interp segments split; the interpolated expression is parsed.
    testing.assert_eq(actual: expr_str("'a' + 'b'"),
        expected: '("a" + "b")')?;
    let parsed = expr_str("'n = ${1 + 2}!'");
    testing.assert_eq(actual: parsed, expected: '"n = ${(1 + 2)}!"')?;
    return Result.Ok(void);
}

// Render a parsed string's parts, tagging each as text (`T:`) or interpolation
// (`I:`) so a literal `${…}` (text) is distinguishable from a real one.
fn parts_desc(_ src: String) -> String {
    let parts = match parse_expression(tokenize(src).tokens) {
        Str(_, ps) => ps,
        _ => [],
    };
    return parts.map((p) => part_tag(p)).join('|');
}

fn part_tag(_ p: StringPart) -> String {
    return match p {
        Text(_, t) => 'T:' + t,
        Interp(_, e) => 'I:' + describe_expr(e),
    };
}

@test
fn test_escaped_dollar_is_literal() -> Result<Void, Error> {
    // Sources are built from code points so the test file's own string handling
    // can't pre-mangle a literal `${`. 39=' 92=\\ 36=$ 123={ 120=x 125=} 97=a 98=b
    //   '${x}'  → interpolation of x
    testing.assert_eq(
        actual: parts_desc(String.from_chars([39, 36, 123, 120, 125, 39])),
        expected: 'I:x')?;
    //   '\${x}' → the literal text "${x}" (the `\$` genuinely escapes)
    testing.assert_eq(
        actual: parts_desc(String.from_chars([39, 92, 36, 123, 120, 125, 39])),
        expected: 'T:' + String.from_chars([36, 123, 120, 125]))?;
    //   'a\$b'  → literal text "a$b" (escaped dollar, not before a brace)
    testing.assert_eq(
        actual: parts_desc(String.from_chars([39, 97, 92, 36, 98, 39])),
        expected: 'T:a$b')?;
    //   'a\\b'  → literal text "a\b" (escaped backslash)
    testing.assert_eq(
        actual: parts_desc(String.from_chars([39, 97, 92, 92, 98, 39])),
        expected: 'T:a\\b')?;
    return Result.Ok(void);
}

@test
fn test_unterminated_interpolation_does_not_crash() -> Result<Void, Error> {
    // A malformed `'${'` (no closing brace) must not overrun the splitter — it
    // used to crash the Dart parser with a RangeError. Here it parses to a string.
    let e = parse_expression(tokenize(String.from_chars([39, 36, 123, 39])).tokens);
    testing.assert(match e {
        Str(_, _) => true,
        _ => false,
    }, message: 'expected a string expression')?;
    return Result.Ok(void);
}

@test
fn test_hex_literal_value() -> Result<Void, Error> {
    // 0xFF parses to 255; the describe form is just the decimal value.
    testing.assert_eq(actual: expr_str('0xFF'), expected: '255')?;
    return Result.Ok(void);
}

@test
fn test_parse_function_program() -> Result<Void, Error> {
    let r = parse_src('fn main() -> Int { return 1 + 2; }');
    testing.assert(!r.has_errors(), message: 'unexpected parse errors')?;
    testing.assert_eq(actual: r.program.decls.len(), expected: 1)?;
    testing.assert_eq(actual: decl_name(r.program.decls[0]), expected: 'main')?;
    return Result.Ok(void);
}

@test
fn test_parse_each_declaration_kind() -> Result<Void, Error> {
    let src = 'import std.io;\n'
        + 'pub const MAX: Int = 10;\n'
        + 'struct Point { x: Int, y: Int }\n'
        + 'enum Color { Red, Green, Blue }\n'
        + 'interface Shape { fn area(self) -> Double; }\n'
        + 'fn area(_ s: Shape) -> Double { return s.area(); }\n'
        + 'impl Point { pub fn origin() -> Point { return Point { x: 0, y: 0 }; } }';
    let r = parse_src(src);
    testing.assert(!r.has_errors(), message: 'unexpected parse errors')?;
    testing.assert_eq(actual: r.program.decls.len(), expected: 7)?;
    testing.assert_eq(actual: decl_name(r.program.decls[3]), expected: 'Color')?;
    return Result.Ok(void);
}

@test
fn test_parse_optional_let_on_struct_fields() -> Result<Void, Error> {
    // The migration phase: an optional `let` before a struct field (`let x: T`,
    // `let mut x: T`) parses and mixes freely with the bare form. `let` carries no
    // semantic payload — mutability stays with `mut`.
    let src = 'struct S { let a: Int, let mut b: String, c: Bool, mut d: Int }\n';
    let r = parse_src(src);
    testing.assert(!r.has_errors(), message: 'optional let on fields should parse')?;
    match r.program.decls[0] {
        Type(t) => {
            testing.assert_eq(actual: t.fields.len(), expected: 4)?;
            testing.assert_eq(actual: t.fields[0].name, expected: 'a')?;
            testing.assert(!t.fields[0].is_mut, message: '`let a` is not mut')?;
            testing.assert(t.fields[1].is_mut, message: '`let mut b` is mut')?;
            testing.assert(!t.fields[2].is_mut, message: '`c` is not mut')?;
            testing.assert(t.fields[3].is_mut, message: '`mut d` is mut')?;
        },
        _ => { testing.assert(false, message: 'expected a struct decl')?; },
    }
    return Result.Ok(void);
}

@test
fn test_parse_impl_nested_interface_arg() -> Result<Void, Error> {
    // A nested generic in an `impl` header's interface argument
    // (`Iterator<Indexed<T>>`) — the form that gates the `enumerate` adapter.
    let src = 'struct Indexed<T> { index: Int, value: T }\n'
        + 'struct EnumIter<T> { mut i: Int }\n'
        + 'impl Iterator<Indexed<T>> for EnumIter<T> {\n'
        + '  pub fn next(self) -> Option<Indexed<T>> { return Option.None; }\n'
        + '}';
    let r = parse_src(src);
    testing.assert(!r.has_errors(), message: 'nested interface arg should parse')?;
    return Result.Ok(void);
}

@test
fn test_parse_impl_bounded_inherent_param() -> Result<Void, Error> {
    // The other arm of the same `<…>`: a bounded type-parameter declaration on an
    // inherent impl must still parse (no `for`).
    let src = 'struct Box<T> { v: T }\n'
        + 'impl Box<T: Display> { pub fn show(self) -> String { return \'box\'; } }';
    let r = parse_src(src);
    testing.assert(!r.has_errors(), message: 'bounded inherent impl param should parse')?;
    return Result.Ok(void);
}

@test
fn test_error_recovery_skips_to_next_decl() -> Result<Void, Error> {
    // The first declaration is malformed (no function name); the parser records
    // an error, resyncs to the next `fn`, and parses the good one.
    let r = parse_src('fn { } fn good() -> Int { return 1; }');
    testing.assert(r.has_errors(), message: 'expected a parse error')?;
    testing.assert_eq(actual: r.program.decls.len(), expected: 1)?;
    testing.assert_eq(actual: decl_name(r.program.decls[0]), expected: 'good')?;
    return Result.Ok(void);
}

@test
fn test_recovery_terminates_on_unfinished_let() -> Result<Void, Error> {
    // Regression: a `let` with no `=` before a `return`/`throw` once looped
    // forever — in recovery the cursor is frozen, and `parse_primary` for
    // `return`/`throw` recursed into `parse_expr` with no progress. Each parse
    // must terminate (this test would otherwise hang), record an error, and
    // recover to the next declaration. Covers normal `let`, the uppercase
    // `let … else` head, and `throw`.
    let r1 = parse_src('fn f() -> Int { let x return 1; } fn good() -> Int { return 2; }');
    testing.assert(r1.has_errors(), message: 'expected a parse error')?;
    testing.assert(decl_has(r1, 'good'), message: 'should recover to the next decl')?;

    let r2 = parse_src('fn f() -> Int { let Foo return 1; } fn good() -> Int { return 2; }');
    testing.assert(r2.has_errors(), message: 'expected a parse error (let-else head)')?;
    testing.assert(decl_has(r2, 'good'), message: 'should recover (let-else head)')?;

    let r3 = parse_src('fn f() -> Int { let x throw 1; } fn good() -> Int { return 2; }');
    testing.assert(r3.has_errors(), message: 'expected a parse error (throw)')?;
    testing.assert(decl_has(r3, 'good'), message: 'should recover (throw)')?;
    return Result.Ok(void);
}

@test
fn test_token_prefixes_terminate() -> Result<Void, Error> {
    // Standing guard against non-advancing recovery loops: every token-prefix of
    // each snippet must parse to completion. The LSP parses such mid-edit
    // fragments on every keystroke, so a hang here is a hang there. Snippets
    // exercise the constructs whose recovery is easiest to get wrong — a
    // `return`/`throw` operand, an unfinished `let`, `if let`/`let … else` heads,
    // `?`, match arms, lambdas, and nested blocks. Add a snippet when adding a
    // construct. A regression hangs or traps this test rather than returning.
    let samples: List<String> = [
        'fn f() -> Int { let x return 1; }',
        'fn f() -> Int { let x: Int = g(a, b); return x; }',
        'fn f() -> Int { if let Some(x) = a { return x; } else { return 0; } }',
        'fn f() -> Int { let Some(x) = a else { return 0; } return x; }',
        'fn f() -> Result<Int, Error> { let y = a? + b; throw err }',
        'fn f() -> Int { return match x { Some(v) => v, None => { throw e } }; }',
        'fn f() -> Int { let g = (z) => z + 1; return g(2); }',
        'fn f() -> Int { while c { if d { return 1; } } return 0; }',
        'struct P { x: Int, mut y: Int } fn f() -> Int { let p = P { x: 1, y: 2 }; return p.x; }',
    ];
    let mut total = 0;
    for s in samples {
        total = total + parse_all_prefixes(s);
    }
    testing.assert(total > 0, message: 'expected token-prefixes to be parsed')?;
    return Result.Ok(void);
}

@test
fn test_trailing_semicolon_after_block_statement() -> Result<Void, Error> {
    // A `;` trailing a block-form statement (`if`/`for`/`while`/`match`) is a
    // tolerated empty statement in a statement block, matching how match arms /
    // block expressions already parse it. (Regression: this used to be a hard
    // error only in statement blocks, which — in an imported file — silently
    // dropped the file's declarations.)
    let r = parse_src('fn f(_ x: Int) -> Int {\n'
        + '  let mut a = 0;\n'
        + '  for i in 0..x {\n'
        + '    if i > 0 { match i { _ => { a = a + i; } } };\n'
        + '  }\n'
        + '  return a;\n'
        + '}');
    testing.assert(!r.has_errors(), message: 'trailing ; after block-if should parse')?;
    testing.assert_eq(actual: r.program.decls.len(), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_empty_statements_are_tolerated() -> Result<Void, Error> {
    let r = parse_src('fn f() -> Int { ; let a = 1;; return a; }');
    testing.assert(!r.has_errors(), message: 'stray semicolons should be ignored')?;
    return Result.Ok(void);
}

@test
fn test_binary_precedence_ladder() -> Result<Void, Error> {
    // One expression spanning the whole table-driven ladder, loosest to tightest:
    // || < && < | < ^ < & < == < (comparison) < + < *. Asserts the nesting the
    // `parse_binary` precedence match produces.
    testing.assert_eq(
        actual: expr_str('a || b && c | d ^ e & f == g < h + i * j'),
        expected: '(a || (b && (c | (d ^ (e & (f == (g < (h + (i * j)))))))))')?;
    return Result.Ok(void);
}

@test
fn test_import_alias_and_unqualified() -> Result<Void, Error> {
    // `as <ident>` sets an alias; `as _` marks the import unqualified (no alias).
    let aliased = parse_src('import std.fs as fs;');
    testing.assert(!aliased.has_errors(), message: 'alias import should parse')?;
    let unq = parse_src("import 'ast' as _;");
    testing.assert(!unq.has_errors(), message: 'as _ import should parse')?;
    match unq.program.decls[0] {
        Import(x) => {
            testing.assert(x.unqualified, message: 'as _ should set unqualified')?;
            testing.assert(match x.alias { Some(_) => false, None => true },
                message: 'as _ leaves alias None')?;
        },
        _ => { testing.assert(false, message: 'expected an import decl')?; },
    }
    return Result.Ok(void);
}

@test
fn test_stmt_spans_cover_statement() -> Result<Void, Error> {
    // A `Stmt.Expr`/`Stmt.Assign` span covers the whole statement through the
    // `;` (like Let/Return), not just the first token (PA7).
    let r = parse_src('fn f() { g(1); x = 2 + 3; x += 1; }');
    let texts: List<String> = [];
    if let Fn(fd) = r.program.decls[0] {
        if let Some(b) = fd.body {
            for s in b.stmts {
                texts.push(match s {
                    Expr(sp, _) => sp.text(),
                    Assign(sp, _, _) => sp.text(),
                    _ => '?',
                });
            }
        }
    }
    testing.assert_eq(actual: texts, expected: ['g(1);', 'x = 2 + 3;', 'x += 1;'])?;
    return Result.Ok(void);
}

@test
fn test_describe_reescapes_string_text() -> Result<Void, Error> {
    // describe strings are one-line diff keys: decoded control characters and
    // the backslash render back as escapes rather than raw text (PA14).
    testing.assert_eq(actual: expr_str("'a\\nb'"), expected: "\"a\\nb\"")?;
    testing.assert_eq(actual: expr_str("'a\\tb'"), expected: "\"a\\tb\"")?;
    testing.assert_eq(actual: expr_str("'c\\\\d'"), expected: "\"c\\\\d\"")?;
    return Result.Ok(void);
}

@test
fn test_import_path_interpolation_rejected() -> Result<Void, Error> {
    // An import path is a literal; interpolation is a parse error (PA9).
    let r = parse_src("import '\${x}/lib';");
    testing.assert(r.has_errors(), message: 'interpolated import should error')?;
    testing.assert_eq(actual: r.errors[0].message,
        expected: 'an import path cannot be interpolated')?;
    return Result.Ok(void);
}

@test
fn test_impl_param_must_be_bare_name() -> Result<Void, Error> {
    // In the type-parameter view (`impl Type<…>`, no `for`) each element must
    // be a bare name — `impl Box<Pair<T>>` used to lower `Pair` as a parameter
    // and silently drop `<T>` (PA10).
    let r = parse_src('impl Box<Pair<T>> { fn f(self) -> Int { return 1; } }');
    testing.assert(r.has_errors(), message: 'generic impl param should error')?;
    // The interface-argument view is untouched: nesting is fine before `for`.
    let ok = parse_src('impl Iterator<Indexed<T>> for Zip<T> { }');
    testing.assert(!ok.has_errors(), message: 'nested interface args should parse')?;
    return Result.Ok(void);
}

@test
fn test_name_spans_recorded() -> Result<Void, Error> {
    // PA11: the previously missing name spans — field decls/inits, import
    // path/alias, type-param bounds, interface supers, an impl's interface,
    // a NamedType's namespace, a call-arg label — are recorded, each pointing
    // at its exact source token.
    let r = parse_src('import std.fs as f;\n'
        + 'struct P<T: Display> { mut x: fs.Path }\n'
        + 'interface I : Display + Debug { fn go(self); }\n'
        + 'impl Display for P { fn show(self) -> String { return d(v: 1); } }');
    testing.assert(!r.has_errors(), message: 'fixture should parse')?;
    if let Import(im) = r.program.decls[0] {
        testing.assert_eq(actual: im.path_span.text(), expected: 'std.fs')?;
        testing.assert_eq(actual: im.alias_span.map((s) => s.text()),
            expected: Option.Some('f'))?;
    }
    if let Type(td) = r.program.decls[1] {
        testing.assert_eq(actual: td.type_params[0].bound_spans[0].text(), expected: 'Display')?;
        testing.assert_eq(actual: td.fields[0].name_span.text(), expected: 'x')?;
        if let Named(nt) = td.fields[0].type_ann {
            testing.assert_eq(actual: nt.namespace_span.map((s) => s.text()),
                expected: Option.Some('fs'))?;
        }
    }
    if let Interface(idecl) = r.program.decls[2] {
        testing.assert_eq(actual: idecl.super_spans.map((s) => s.text()),
            expected: ['Display', 'Debug'])?;
    }
    if let Impl(imp) = r.program.decls[3] {
        testing.assert_eq(actual: imp.interface_name_span.map((s) => s.text()),
            expected: Option.Some('Display'))?;
    }
    // A member access carries the member's own Identifier span.
    if let Field(_, _, member) = parse_expression(tokenize('obj.value').tokens) {
        testing.assert_eq(actual: member.name, expected: 'value')?;
        testing.assert_eq(actual: member.span.text(), expected: 'value')?;
    } else {
        testing.assert(false, message: 'expected a Field expr')?;
    }
    return Result.Ok(void);
}

// The first statement of `fn f() { ... }`'s body in `src` — for the
// desugar-fidelity tests.
fn first_body_stmt(_ src: String) -> Option<Stmt> {
    let r = parse_src(src);
    if let Fn(f) = r.program.decls[0] {
        if let Some(b) = f.body {
            if b.stmts.len() > 0 {
                return Option.Some(b.stmts[0]);
            }
        }
    }
    return Option.None;
}

// A compound assignment keeps its shape (PA5): the operator rides on the
// statement and the RHS stays raw — no synthesized Binary aliasing the target
// node into the value.
@test
fn test_compound_assign_keeps_shape() -> Result<Void, Error> {
    match first_body_stmt('fn f() { let mut x = 1; }') {
        Some(_) => {},
        None => { return Result.Err(error('no body stmt')); },
    }
    let r = parse_src('fn f(_ m: Int) { m += 2; }');
    testing.assert_eq(actual: r.errors.len(), expected: 0)?;
    if let Fn(f) = r.program.decls[0] {
        if let Some(b) = f.body {
            if let Assign(_, target, op, value) = b.stmts[0] {
                testing.assert_eq(actual: op, expected: Option.Some('+'))?;
                testing.assert_eq(actual: expr_span(target).text(), expected: 'm')?;
                // The RHS is the raw literal, not `m + 2`.
                testing.assert_eq(actual: expr_span(value).text(), expected: '2')?;
                return Result.Ok(void);
            }
        }
    }
    return Result.Err(error('expected an Assign stmt'));
}

// A plain assignment carries no operator.
@test
fn test_plain_assign_has_no_op() -> Result<Void, Error> {
    if let Some(s) = first_body_stmt('fn f(_ m: Int) { m = 2; }') {
        if let Assign(_, _, op, _) = s {
            testing.assert_eq(actual: op, expected: Option.None)?;
            return Result.Ok(void);
        }
    }
    return Result.Err(error('expected an Assign stmt'));
}

// The if-let desugar fabricates a wildcard arm (and, with no `else`, an empty
// block): both carry zero-length synthetic spans so offset queries skip them,
// and the block is marked synthetic (PA6).
@test
fn test_if_let_desugar_spans_are_synthetic() -> Result<Void, Error> {
    if let Some(s) = first_body_stmt(
        'fn f(_ o: Option<Int>) { if let Some(v) = o { g(v); } }') {
        if let Expr(_, e) = s {
            if let Match(m) = e {
                testing.assert_eq(actual: m.arms.len(), expected: 2)?;
                testing.assert_eq(actual: pattern_span(m.arms[1].pattern).length, expected: 0)?;
                if let Block(bs, blk) = m.arms[1].body {
                    testing.assert_eq(actual: bs.length, expected: 0)?;
                    testing.assert(blk.synthetic, message: 'missing-else block is synthetic')?;
                    return Result.Ok(void);
                }
            }
        }
    }
    return Result.Err(error('expected the desugared match'));
}

// The let-else desugar's success body references the binding through a
// fabricated Ident: zero-length at the binding, so it never duplicates the
// pattern's real node (PA6); the wildcard is synthetic too.
@test
fn test_let_else_desugar_spans_are_synthetic() -> Result<Void, Error> {
    if let Some(s) = first_body_stmt(
        'fn f(_ o: Option<Int>) -> Int { let Some(v) = o else { return 0; }; return v; }') {
        if let Let(l) = s {
            if let Match(m) = l.value {
                if let Ident(is, name) = m.arms[0].body {
                    testing.assert_eq(actual: name, expected: 'v')?;
                    testing.assert_eq(actual: is.length, expected: 0)?;
                    testing.assert_eq(actual: is.offset, expected: l.name_span.offset)?;
                }
                testing.assert_eq(actual: pattern_span(m.arms[1].pattern).length, expected: 0)?;
                return Result.Ok(void);
            }
        }
    }
    return Result.Err(error('expected the desugared let'));
}

// An `else if` chain's wrapper block is marked synthetic; a source
// `else { if … }` is not (PA8 — the marker replaces span sniffing).
@test
fn test_else_if_wrapper_is_synthetic() -> Result<Void, Error> {
    if let Some(s) = first_body_stmt(
        'fn f(_ a: Bool, _ b: Bool) { if a { } else if b { } }') {
        if let If(x) = s {
            testing.assert_eq(actual: x.else_block.map((b) => b.synthetic),
                expected: Option.Some(true))?;
        } else {
            return Result.Err(error('expected an If stmt'));
        }
    }
    if let Some(s) = first_body_stmt(
        'fn f(_ a: Bool, _ b: Bool) { if a { } else { if b { } } }') {
        if let If(x) = s {
            testing.assert_eq(actual: x.else_block.map((b) => b.synthetic),
                expected: Option.Some(false))?;
            return Result.Ok(void);
        }
    }
    return Result.Err(error('expected an If stmt'));
}
