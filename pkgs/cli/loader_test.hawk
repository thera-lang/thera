// Tests for the loader's namespace layer (the public-surface / barrel logic),
// exercised on hand-built `LibrarySource`s so they need no file system, plus
// the canonical-identity contract (`canonical_path`), which uses a real
// fixture tree under the temp dir. The rest of the file-resolution +
// import-closure walk is covered end-to-end by the driver (the Hawk CLI emits
// byte-identical `.hawkbc` for a std-using program).

import std.testing;
import std.fs;
import std.env;
import std.process;

import 'ast/ast' as _;
import 'lexer/lexer' as _;
import 'parser/parser' as _;
import 'loader' as _;

// Parse `src`, stamping a distinct `path` as its `file_path` — the loader keys
// re-export-cycle detection on `file_path` (Hawk has no object identity), which
// `parse_file_or_null` sets for every real file.
fn prog_of(_ src: String, _ path: String) -> Program {
    let prog = parse_tokens(tokenize(src).tokens).program;
    prog.file_path = Option.Some(path);
    return prog;
}

@test
fn test_public_surface_collects_only_pub_decls() -> Result<Void, Error> {
    let prog = prog_of('pub fn a() { }\n'
        + 'fn b() { }\n'
        + 'pub struct T { x: Int }\n'
        + 'pub const C: Int = 1;\n'
        + 'const D: Int = 2;', 'lib.hawk');
    let surface = public_surface_of(LibrarySource { program: prog, imports: {} });
    testing.assert(surface.names.has('a'), message: 'pub fn a is exposed')?;
    testing.assert(!surface.names.has('b'), message: 'private fn b is hidden')?;
    testing.assert(surface.names.has('T'), message: 'pub type T is exposed')?;
    testing.assert(surface.names.has('C'), message: 'pub const C is exposed')?;
    testing.assert(!surface.names.has('D'), message: 'private const D is hidden')?;
    return Result.Ok(void);
}

@test
fn test_namespaces_for_binds_import_to_surface() -> Result<Void, Error> {
    let child = LibrarySource {
        program: prog_of('pub fn helper() { }\nfn secret() { }', 'util.hawk'),
        imports: {},
    };
    let main_src = LibrarySource {
        program: prog_of('import \'util\';\nfn main() { }', 'main.hawk'),
        imports: {},
    };
    main_src.imports['util'] = child;
    match namespaces_for(main_src).get('util') {
        Some(surface) => {
            testing.assert(surface.names.has('helper'), message: 'util exposes helper')?;
            testing.assert(!surface.names.has('secret'), message: 'util hides secret')?;
        },
        None => {
            testing.assert(false, message: 'expected a util namespace')?;
        },
    }
    return Result.Ok(void);
}

@test
fn test_canonical_path_absolutizes_and_normalizes() -> Result<Void, Error> {
    // Absolute paths are normalized lexically.
    testing.assert_eq(actual: canonical_path('/a/b/../c.hawk'), expected: '/a/c.hawk')?;
    testing.assert_eq(actual: canonical_path('/a//./b.hawk'), expected: '/a/b.hawk')?;
    // Relative paths are resolved against the current directory.
    let cwd = match env.current_dir() {
        Ok(d) => d,
        Err(e) => { return Result.Err(error('no current dir: ${e.message()}')); },
    };
    testing.assert_eq(actual: canonical_path('x/./y.hawk'), expected: cwd + '/x/y.hawk')?;
    // display_path is the inverse for paths under the current directory —
    // and leaves everything else canonical.
    testing.assert_eq(actual: display_path(canonical_path('x.hawk')), expected: 'x.hawk')?;
    testing.assert_eq(actual: display_path('/somewhere/else.hawk'), expected: '/somewhere/else.hawk')?;
    return Result.Ok(void);
}

// The loader keys the closure on canonical identity, so the same root reached
// under different spellings — absolute, `./root.hawk`, bare `root.hawk` — loads
// one identical closure, an import cycle back to the root reuses the in-memory
// root (no duplicate unit), and a bare filename's imports resolve against the
// invocation directory (the old `dirname('root.hawk') == ''` sent them to the
// filesystem root).
@test
fn test_canonical_identity_across_root_spellings() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/hawk_loader_canonical_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} } // stale fixture
    fs_ok(fs.create_dir_all(dir + '/sub'), 'create fixture dir')?;
    fs_ok(fs.write_text(dir + '/root.hawk',
        'import \'sub/child\';\npub fn ping() -> Int { return 1; }\n'), 'write root')?;
    fs_ok(fs.write_text(dir + '/sub/child.hawk',
        'import \'../root\';\npub fn pong() -> Int { return 1; }\n'), 'write child')?;

    // Absolute spelling, from wherever the suite runs.
    check_root_closure(load_root(dir + '/root.hawk')?)?;

    // Relative spellings, from inside the fixture directory. Collect results
    // before restoring the cwd so a failure can't leave it switched.
    let saved = match env.current_dir() {
        Ok(d) => d,
        Err(e) => { return Result.Err(error('no current dir: ${e.message()}')); },
    };
    if let Err(e) = env.set_current_dir(dir) {
        return Result.Err(error('cannot chdir to fixture: ${e.message()}'));
    }
    let by_dot = load_root('./root.hawk');
    let by_bare = load_root('root.hawk');
    if let Err(e) = env.set_current_dir(saved) {
        return Result.Err(error('cannot restore cwd: ${e.message()}'));
    }
    check_root_closure(by_dot?)?;
    check_root_closure(by_bare?)?;

    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    return Result.Ok(void);
}

// Read + parse `path`'s file and load its closure (no SDK — no prelude), also
// asserting the root program's `file_path` is re-stamped canonical.
fn load_root(_ path: String) -> Result<LoadedImports, Error> {
    return match fs.read_text(path) {
        Ok(src) => {
            let prog = parse_tokens(tokenize(src).tokens).program;
            let loaded = load_imports(path, prog, Option.None);
            match prog.file_path {
                Some(p) => {
                    if !p.starts_with('/') || !p.ends_with('/root.hawk') {
                        return Result.Err(error('root file_path not canonical: ${p}'));
                    }
                },
                None => { return Result.Err(error('root file_path not stamped')); },
            }
            Result.Ok(loaded)
        },
        Err(e) => Result.Err(error('read ${path}: ${e.message()}')),
    };
}

// The fixture closure, loaded under any root spelling: exactly one imported
// program (the child — the cycle back to the root must hit the cache, not load
// a duplicate root unit), and both files' namespaces resolved.
fn check_root_closure(_ loaded: LoadedImports) -> Result<Void, Error> {
    testing.assert_eq(actual: loaded.programs.len(), expected: 1)?;
    let child_path = loaded.programs[0].file_path.unwrap_or('');
    testing.assert(child_path.starts_with('/') && child_path.ends_with('/sub/child.hawk'),
        message: 'child key is canonical: ${child_path}')?;
    testing.assert_eq(actual: loaded.file_namespaces.len(), expected: 2)?;
    for key in loaded.file_namespaces.keys() {
        let ns = loaded.file_namespaces[key];
        if key.ends_with('/root.hawk') {
            testing.assert(ns.get('child').map((s) => s.names.has('pong')).unwrap_or(false),
                message: 'root sees child.pong')?;
        } else {
            testing.assert(key.ends_with('/sub/child.hawk'), message: 'unexpected key ${key}')?;
            testing.assert(ns.get('root').map((s) => s.names.has('ping')).unwrap_or(false),
                message: 'child sees root.ping through the cycle')?;
        }
    }
    return Result.Ok(void);
}

fn fs_ok(_ r: Result<Void, fs.FsError>, _ what: String) -> Result<Void, Error> {
    return match r {
        Ok(_) => Result.Ok(void),
        Err(e) => Result.Err(error('${what}: ${e.message()}')),
    };
}

// A broken import is a located diagnostic at the import decl, attributed to the
// importer — a resolve failure ("no such module") and a read failure (an
// unreadable file) each surface their root cause instead of degrading to a
// downstream "undefined name" (or, for an unused import, passing silently).
@test
fn test_broken_imports_are_diagnosed() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/hawk_loader_broken_import_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} } // stale fixture
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    let secret = dir + '/secret.hawk';
    fs_ok(fs.write_text(secret, 'pub fn s() -> Int { return 1; }\n'), 'write secret')?;
    fs_ok(fs.write_text(dir + '/main.hawk',
        'import \'nonexistent\';\nimport \'secret\';\nfn main() -> Void { }\n'), 'write main')?;

    // Make `secret.hawk` unreadable (restored below so cleanup can remove it).
    if let Err(e) = process.run('chmod', args: ['000', secret]) {
        return Result.Err(error('chmod: ${e.message()}'));
    }
    let src = match fs.read_text(dir + '/main.hawk') {
        Ok(s) => s,
        Err(e) => { return Result.Err(error('read main: ${e.message()}')); },
    };
    let prog = parse_tokens(tokenize(src).tokens).program;
    let loaded = load_imports(dir + '/main.hawk', prog, Option.None);
    match process.run('chmod', args: ['644', secret]) { Ok(_) => {}, Err(_) => {} }

    testing.assert_eq(actual: loaded.diagnostics.len(), expected: 2)?;
    let resolve_d = loaded.diagnostics[0];
    let read_d = loaded.diagnostics[1];
    testing.assert(resolve_d.message.contains('cannot resolve import \'nonexistent\''),
        message: 'resolve failure surfaced: ${resolve_d.message}')?;
    testing.assert_eq(actual: resolve_d.span.line, expected: 1)?;
    testing.assert(read_d.message.contains('cannot read import \'secret\''),
        message: 'read failure surfaced: ${read_d.message}')?;
    testing.assert_eq(actual: read_d.span.line, expected: 2)?;
    for d in loaded.diagnostics {
        testing.assert(d.file.ends_with('/main.hawk'),
            message: 'attributed to the importer: ${d.file}')?;
    }

    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    return Result.Ok(void);
}

// A `std.*` import that can't resolve says why: no SDK at all vs a module the
// SDK doesn't have.
@test
fn test_unresolved_std_import_says_why() -> Result<Void, Error> {
    let dir = canonical_path(fs.temp_dir() + '/hawk_loader_std_import_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    fs_ok(fs.create_dir_all(dir), 'create fixture dir')?;
    let main_path = dir + '/main.hawk';
    fs_ok(fs.write_text(main_path, 'import \'std.nonexistent\';\nfn main() -> Void { }\n'),
        'write main')?;
    let src = match fs.read_text(main_path) {
        Ok(s) => s,
        Err(e) => { return Result.Err(error('read main: ${e.message()}')); },
    };

    // No SDK (the hermetic mode): the diagnostic names the missing SDK.
    let no_sdk = load_imports(main_path, parse_tokens(tokenize(src).tokens).program, Option.None);
    testing.assert_eq(actual: no_sdk.diagnostics.len(), expected: 1)?;
    testing.assert(no_sdk.diagnostics[0].message.contains('no Hawk SDK found'),
        message: 'missing SDK named: ${no_sdk.diagnostics[0].message}')?;

    // A real SDK: the module itself is the problem.
    match find_sdk_root() {
        Some(root) => {
            let with_sdk = load_imports(main_path, parse_tokens(tokenize(src).tokens).program,
                Option.Some(root));
            testing.assert_eq(actual: with_sdk.diagnostics.len(), expected: 1)?;
            testing.assert(with_sdk.diagnostics[0].message.contains('not in the SDK'),
                message: 'missing module named: ${with_sdk.diagnostics[0].message}')?;
        },
        None => {}, // no SDK on this machine — the first half still covered it
    }

    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    return Result.Ok(void);
}

@test
fn test_pub_import_reexports_through_barrel() -> Result<Void, Error> {
    // A barrel: `pub import 'inner'` re-exports inner's public surface alongside
    // the barrel's own public declarations.
    let inner = LibrarySource { program: prog_of('pub fn deep() { }', 'inner.hawk'), imports: {} };
    let barrel = LibrarySource {
        program: prog_of('pub import \'inner\';\npub fn own() { }', 'barrel.hawk'),
        imports: {},
    };
    barrel.imports['inner'] = inner;
    let surface = public_surface_of(barrel);
    testing.assert(surface.names.has('own'), message: 'barrel exposes its own fn')?;
    testing.assert(surface.names.has('deep'), message: 're-exports inner deep fn')?;
    return Result.Ok(void);
}
