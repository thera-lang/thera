// Tests for the front-end driver: the source-to-bytecode pipeline as one call.
// `compile_source` is diffed byte-for-byte against the Dart oracle, confirming
// the whole Hawk front-end lowers a program identically end to end. The
// `*_source_at` closure-checking tests use a real fixture tree under the temp
// dir (like loader_test).

import std.testing;
import std.fs;

import 'driver' as _;
import 'loader';

@test
fn test_check_clean_source_has_no_diagnostics() -> Result<Void, Error> {
    let diags = check_source('fn add(_ a: Int, _ b: Int) -> Int { return a + b; }');
    testing.assert_eq(actual: diags.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_check_reports_type_error() -> Result<Void, Error> {
    let diags = check_source('fn f() -> Int { return true; }');
    testing.assert_eq(actual: diags.len(), expected: 1)?;
    testing.assert_eq(actual: diags[0].message,
        expected: 'return type mismatch: expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_check_reports_parse_error_with_location() -> Result<Void, Error> {
    // A parse error short-circuits (no type-checking), and carries a location.
    let diags = check_source('fn f() -> Int { return ');
    testing.assert(diags.len() > 0, message: 'expected a parse diagnostic')?;
    // Formatted as `file:line:col: message`.
    let line = format_diagnostic(diags[0], 'demo.hawk');
    testing.assert(line.starts_with('demo.hawk:'),
        message: 'diagnostic should be prefixed with the file path')?;
    return Result.Ok(void);
}

// A primary with a lex error reports it (first — root cause), alongside any
// parse errors from the recovered token stream: the session parses the primary
// best-effort through its parse cache (R1), exactly as imported files behave.
@test
fn test_primary_lex_error_reports_lex_first() -> Result<Void, Error> {
    // '`' is not a Hawk token (lex error); the dangling 'fn g(' is a parse error.
    let src = 'fn f() -> Int { return 1; }\n`\nfn g( {\n';
    let diags = check_source_at(src, '/mem/lexbad.hawk', Option.None);
    testing.assert(diags.len() >= 2, message: 'lex and parse diagnostics: ${diags.len()}')?;
    testing.assert(diags[0].message.contains('unexpected character'),
        message: 'lex error first: ${diags[0].message}')?;
    return Result.Ok(void);
}

// A check error in an *imported* file surfaces when checking the importer —
// attributed to the imported file — and blocks compilation (previously only the
// primary was checked: `hawk check importer.hawk` exited 0 and `hawk run`
// shipped the broken import to bytecode).
@test
fn test_imported_file_check_errors_surface() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_driver_closure_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} } // stale fixture
    if let Err(e) = fs.create_dir_all(dir) {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    let broken = 'pub fn bad() -> Int { return missing_name; }\n';
    if let Err(e) = fs.write_text(dir + '/dep.hawk', broken) {
        return Result.Err(error('write dep: ${e.message()}'));
    }
    let main_src = 'import \'dep\';\nfn main() -> Void { }\n';
    let main_path = dir + '/main.hawk';
    if let Err(e) = fs.write_text(main_path, main_src) {
        return Result.Err(error('write main: ${e.message()}'));
    }

    // check: the dep's error is reported, attributed to dep.hawk.
    let diags = check_source_at(main_src, main_path, Option.None);
    testing.assert_eq(actual: diags.len(), expected: 1)?;
    testing.assert(diags[0].message.contains('undefined name: missing_name'),
        message: 'dep error surfaced: ${diags[0].message}')?;
    testing.assert(diags[0].file.map((f) => f.ends_with('/dep.hawk')).unwrap_or(false),
        message: 'attributed to the dep: ${diags[0].file.unwrap_or('<none>')}')?;

    // compile: the same error blocks codegen — nothing ships to bytecode.
    let outcome = compile_source_at(main_src, main_path, Option.None);
    testing.assert(outcome.diagnostics.len() > 0, message: 'compile is blocked')?;
    match outcome.bytes {
        Some(_) => { testing.assert(false, message: 'no bytes for a broken closure')?; },
        None => {},
    }

    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    return Result.Ok(void);
}

// The caller-shared `checked` set: clean files are recorded and skipped on
// later calls (batch linearity + report-once); files with errors are never
// marked, so they re-check per importer.
@test
fn test_checked_set_records_only_clean_files() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_driver_checked_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    if let Err(e) = fs.create_dir_all(dir) {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    if let Err(e) = fs.write_text(dir + '/clean.hawk', 'pub fn ok() -> Int { return 1; }\n') {
        return Result.Err(error('write clean: ${e.message()}'));
    }
    if let Err(e) = fs.write_text(dir + '/broken.hawk', 'pub fn bad() -> Int { return missing_name; }\n') {
        return Result.Err(error('write broken: ${e.message()}'));
    }
    let main_src = 'import \'clean\';\nimport \'broken\';\nfn main() -> Void { }\n';
    let main_path = dir + '/main.hawk';
    if let Err(e) = fs.write_text(main_path, main_src) {
        return Result.Err(error('write main: ${e.message()}'));
    }

    let checked: Set<String> = Set.new();
    let first = check_source_at(main_src, main_path, Option.None, checked: checked);
    testing.assert_eq(actual: first.len(), expected: 1)?;
    testing.assert(checked.has(dir + '/clean.hawk'), message: 'clean dep marked checked')?;
    testing.assert(checked.has(main_path), message: 'clean primary marked checked')?;
    testing.assert(!checked.has(dir + '/broken.hawk'), message: 'broken dep never marked')?;

    // A second pass with the same set: the clean files (incl. the primary) are
    // skipped; the broken dep re-reports.
    let second = check_source_at(main_src, main_path, Option.None, checked: checked);
    testing.assert_eq(actual: second.len(), expected: 1)?;
    testing.assert(second[0].message.contains('undefined name: missing_name'),
        message: 'broken dep re-reported: ${second[0].message}')?;

    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} }
    return Result.Ok(void);
}

@test
fn test_compile_source_byte_identical() -> Result<Void, Error> {
    // The full pipeline (tokenize → parse → check → codegen → encode) as one
    // call, byte-identical to the Dart oracle for the same program.
    let outcome = compile_source('fn add(_ a: Int, _ b: Int) -> Int { return a + b; }\n'
        + 'fn main() -> Int {\n'
        + '    let x = add(2, 3);\n'
        + '    let mut sum = 0;\n'
        + '    let mut i = 0;\n'
        + '    while i < x {\n'
        + '        sum = sum + i;\n'
        + '        i = i + 1;\n'
        + '    }\n'
        + '    return sum;\n'
        + '}');
    testing.assert_eq(actual: outcome.diagnostics.len(), expected: 0)?;
    match outcome.bytes {
        Some(bytes) => {
            testing.assert_eq(actual: bytes.to_list(), expected: [72, 65, 87, 75, 2, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 56, 2, 2, 2, 4, 6, 0, 6, 1, 8, 45, 0, 3, 23, 1, 2, 1, 3, 36, 0, 2, 7, 0, 1, 0, 7, 1, 1, 0, 7, 2, 6, 2, 6, 0, 21, 44, 21, 6, 1, 6, 2, 8, 7, 1, 6, 2, 1, 1, 8, 7, 2, 42, 8, 6, 1, 45, 7, 10, 2, 3, 97, 100, 100, 4, 109, 97, 105, 110, 6, 2, 2, 0])?;
        },
        None => {
            testing.assert(false, message: 'expected bytes for a clean program')?;
        },
    }
    return Result.Ok(void);
}

// Two imported files with **identical source text** attribute independently —
// the exact LD7 failure: attribution used to reverse-map a span's source text
// to a path, so byte-identical files collided on one entry and an error in
// either was pinned to whichever registered last. Spans now carry their file.
@test
fn test_identical_imports_attribute_independently() -> Result<Void, Error> {
    let dir = loader.canonical_path(fs.temp_dir() + '/hawk_driver_ld7_test');
    match fs.remove_dir_all(dir) { Ok(_) => {}, Err(_) => {} } // stale fixture
    if let Err(e) = fs.create_dir_all(dir + '/a') {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    if let Err(e) = fs.create_dir_all(dir + '/b') {
        return Result.Err(error('create fixture dir: ${e.message()}'));
    }
    // Byte-identical broken sources in two different files.
    let broken = 'pub fn bad() -> Int { return missing_name; }\n';
    if let Err(e) = fs.write_text(dir + '/a/dep.hawk', broken) {
        return Result.Err(error('write a/dep: ${e.message()}'));
    }
    if let Err(e) = fs.write_text(dir + '/b/dep.hawk', broken) {
        return Result.Err(error('write b/dep: ${e.message()}'));
    }
    let main_src = 'import \'a/dep\' as da;\nimport \'b/dep\' as db;\nfn main() -> Void { }\n';
    let main_path = dir + '/main.hawk';
    if let Err(e) = fs.write_text(main_path, main_src) {
        return Result.Err(error('write main: ${e.message()}'));
    }

    let diags = check_source_at(main_src, main_path, Option.None);
    testing.assert_eq(actual: diags.len(), expected: 2)?;
    let files: List<String> = [];
    for d in diags {
        files.push(d.file.unwrap_or('<none>'));
    }
    testing.assert(str_list_has_suffix(files, '/a/dep.hawk'),
        message: 'one error attributed to a/dep.hawk: ${files}')?;
    testing.assert(str_list_has_suffix(files, '/b/dep.hawk'),
        message: 'one error attributed to b/dep.hawk: ${files}')?;
    return Result.Ok(void);
}

fn str_list_has_suffix(_ xs: List<String>, _ suffix: String) -> Bool {
    for x in xs {
        if x.ends_with(suffix) {
            return true;
        }
    }
    return false;
}
