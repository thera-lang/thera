// Tests for the front-end driver: the source-to-bytecode pipeline as one call.
// `compile_source` is diffed byte-for-byte against the Dart oracle, confirming
// the whole Hawk front-end lowers a program identically end to end.

import std.testing;

import 'driver';

@test
fn test_check_clean_source_has_no_diagnostics() -> Result<Void, Error> {
    let diags = check_source('fn add(_ a: Int, _ b: Int) -> Int { return a + b; }');
    testing.assert_eq(actual: diags.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_check_reports_type_error() -> Result<Void, Error> {
    let diags = check_source('fn f() -> Int { return true; }');
    testing.assert_eq(actual: diags.len(), expected: 1)?;
    testing.assert_eq(actual: diags[0].message,
        expected: 'return type mismatch: expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_check_reports_parse_error_with_location() -> Result<Void, Error> {
    // A parse error short-circuits (no type-checking), and carries a location.
    let diags = check_source('fn f() -> Int { return ');
    testing.assert(diags.len() > 0, message: 'expected a parse diagnostic')?;
    // Formatted as `file:line:col: message`.
    let line = format_diagnostic(diags[0], 'demo.hawk');
    testing.assert(line.starts_with('demo.hawk:'),
        message: 'diagnostic should be prefixed with the file path')?;
    return Result.Ok(void);
}

@test
fn test_compile_source_byte_identical() -> Result<Void, Error> {
    // The full pipeline (tokenize → parse → check → codegen → encode) as one
    // call, byte-identical to the Dart oracle for the same program.
    let outcome = compile_source('fn add(_ a: Int, _ b: Int) -> Int { return a + b; }\n'
        + 'fn main() -> Int {\n'
        + '    let x = add(2, 3);\n'
        + '    let mut sum = 0;\n'
        + '    let mut i = 0;\n'
        + '    while i < x {\n'
        + '        sum = sum + i;\n'
        + '        i = i + 1;\n'
        + '    }\n'
        + '    return sum;\n'
        + '}');
    testing.assert_eq(actual: outcome.diagnostics.len(), expected: 0)?;
    match outcome.bytes {
        Some(bytes) => {
            testing.assert_eq(actual: bytes.to_list(), expected: [
                72, 65, 87, 75, 1, 0, 0, 0, 2, 1, 0, 3, 1, 0, 1, 65, 2, 3, 97,
                100, 100, 2, 2, 4, 6, 0, 6, 1, 8, 45, 4, 109, 97, 105, 110, 0, 3,
                23, 1, 2, 1, 3, 36, 0, 2, 7, 0, 1, 0, 7, 1, 1, 0, 7, 2, 6, 2, 6,
                0, 21, 44, 21, 6, 1, 6, 2, 8, 7, 1, 6, 2, 1, 1, 8, 7, 2, 42, 8,
                6, 1, 45,
            ])?;
        },
        None => {
            testing.assert(false, message: 'expected bytes for a clean program')?;
        },
    }
    return Result.Ok(void);
}
