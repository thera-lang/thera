// Tests for the type checker: parse a program, check it, and assert on the
// diagnostics produced (count and messages). Covers name/type/field resolution,
// type-mismatch (let/return/condition/argument), call arity & labels, generic
// bounds, lambda-parameter inferability, and interface/conformance checks.

import std.testing;

import '../ast/ast' as _;
import '../lexer/lexer' as _;
import '../parser/parser' as _;
import '../element/element' as _;
import '../element/inference' as _;
import '../element/types' as _;
import '../diagnostic' as _; // Diagnostic
import 'checker' as _;

fn errors_of(_ src: String) -> List<Diagnostic> {
    return check(parse_tokens(tokenize(src).tokens).program, [], [:], [:]).errors;
}

fn first_message(_ errs: List<Diagnostic>) -> String {
    if errs.len() == 0 {
        return '<no errors>';
    }
    return errs[0].message;
}

// Reserved-name diagnostics from a full closure check (`check_files`, the path
// that runs the reserved-name check — `check` alone does not).
fn reserved_errors(_ primary: Program, _ imports: List<Program>) -> List<Diagnostic> {
    let out: List<Diagnostic> = [];
    for e in check_files(primary, imports, [:], [:]).errors {
        if e.message.contains('is a reserved type name') {
            out.push(e);
        }
    }
    return out;
}

@test
fn test_clean_program_has_no_errors() -> Result<Void, Error> {
    let errs = errors_of('fn add(_ a: Int, _ b: Int) -> Int { return a + b; }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_list_literal_tail_is_checked() -> Result<Void, Error> {
    // A heterogeneous list literal is a check error (was an unchecked runtime
    // trap): every element must match the first's inferred type.
    let errs = errors_of('fn main() -> Void { let _xs = [1, \'two\', 3]; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'list element: expected Int, found String')?;
    return Result.Ok(void);
}

@test
fn test_homogeneous_list_and_map_are_clean() -> Result<Void, Error> {
    testing.assert_eq(actual: errors_of('fn main() -> Void { let _xs = [1, 2, 3]; }').len(),
        expected: 0)?;
    testing.assert_eq(actual: errors_of('fn main() -> Void { let _m = [\'a\': 1, \'b\': 2]; }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_map_literal_value_tail_is_checked() -> Result<Void, Error> {
    let errs = errors_of('fn main() -> Void { let _m = [\'a\': 1, \'b\': \'two\']; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'map value: expected Int, found String')?;
    return Result.Ok(void);
}

@test
fn test_undefined_name() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { return missing; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'undefined name: missing')?;
    return Result.Ok(void);
}

@test
fn test_unknown_type() -> Result<Void, Error> {
    let errs = errors_of('fn f(_ x: Foo) -> Int { return 0; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'unknown type: Foo')?;
    return Result.Ok(void);
}

@test
fn test_unknown_field() -> Result<Void, Error> {
    let errs = errors_of('struct P { let x: Int; }\n'
        + 'fn f() -> P { return P { x: 1, y: 2 }; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'unknown field "y" on type P')?;
    return Result.Ok(void);
}

@test
fn test_field_access_missing_field() -> Result<Void, Error> {
    let errs = errors_of('struct P { let x: Int; }\n'
        + 'fn f() { let p = P { x: 1 }; let _q = p.z; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'no such field "z" on type P')?;
    return Result.Ok(void);
}

@test
fn test_field_access_valid() -> Result<Void, Error> {
    let errs = errors_of('struct P { let x: Int; }\n'
        + 'fn f() -> Int { let p = P { x: 1 }; return p.x; }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_method_call_missing() -> Result<Void, Error> {
    let errs = errors_of('struct B { let v: Int; }\n'
        + 'impl B { fn get(self) -> Int { return self.v; } }\n'
        + 'fn f() { let b = B { v: 1 }; let _r = b.missing(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'no method "missing" on B')?;
    return Result.Ok(void);
}

@test
fn test_method_call_valid() -> Result<Void, Error> {
    let errs = errors_of('struct B { let v: Int; }\n'
        + 'impl B { fn get(self) -> Int { return self.v; } }\n'
        + 'fn f() -> Int { let b = B { v: 1 }; return b.get(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_let_binding_mismatch() -> Result<Void, Error> {
    let errs = errors_of('fn f() { let _x: Int = true; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'binding \'_x\': expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_return_type_mismatch() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { return true; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'return type mismatch: expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_implicit_ok_return_is_clean() -> Result<Void, Error> {
    // Returning a bare `T` from a `Result<T, E>` function is allowed.
    let errs = errors_of('fn f() -> Result<Int, Error> { return 5; }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_condition_not_bool() -> Result<Void, Error> {
    let errs = errors_of('fn f() { while 5 { } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'condition must be Bool, found Int')?;
    return Result.Ok(void);
}

@test
fn test_call_arity() -> Result<Void, Error> {
    let errs = errors_of('fn g(_ a: Int) { }\n'
        + 'fn f() { g(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: '"g" expects 1 argument, got 0')?;
    return Result.Ok(void);
}

@test
fn test_unknown_argument_label() -> Result<Void, Error> {
    let errs = errors_of('fn g(_ a: Int) { }\n'
        + 'fn f() { g(b: 1); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'unknown argument label "b" for "g"')?;
    return Result.Ok(void);
}

@test
fn test_argument_type_mismatch() -> Result<Void, Error> {
    let errs = errors_of('fn g(_ a: Int) { }\n'
        + 'fn f() { g(true); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'argument to "g": expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_lambda_param_not_inferable() -> Result<Void, Error> {
    let errs = errors_of('fn f() { let _g = (x) => x; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'cannot infer the type of lambda parameter \'x\'; '
        + 'add a type annotation, e.g. (x: Int) => ...')?;
    return Result.Ok(void);
}

@test
fn test_elseless_if_tail_unit_is_clean() -> Result<Void, Error> {
    // A side-effecting else-less `if` as a block tail yields Unit — no `else`
    // required (the relaxed tail-expression rule).
    let errs = errors_of('fn log(_ s: String) { }\n'
        + 'fn f(_ c: Bool) -> Int { let _u = { if c { log("hi") } }; return 0; }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_elseless_if_tail_with_value_needs_else() -> Result<Void, Error> {
    // But an else-less `if` whose then-branch yields a real value still needs an
    // `else` — the missing branch can't supply that value.
    let errs = errors_of('fn f(_ c: Bool) -> Int { let _u = { if c { 5 } }; return 0; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'an `if` used as a value needs an `else` branch')?;
    return Result.Ok(void);
}

@test
fn test_unknown_super_interface() -> Result<Void, Error> {
    let errs = errors_of('interface Foo: Bar { }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'unknown super-interface: Bar')?;
    return Result.Ok(void);
}

@test
fn test_conformance_missing_method() -> Result<Void, Error> {
    let errs = errors_of('interface Show { fn show(self) -> String; }\n'
        + 'struct P { let v: Int; }\n'
        + 'impl Show for P { }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'missing method \'show\' required by interface \'Show\'')?;
    return Result.Ok(void);
}

@test
fn test_default_method_optional() -> Result<Void, Error> {
    // A defaulted interface method (a body in the interface) need not be
    // provided by an impl — the interface supplies it.
    let errs = errors_of('interface Show { fn id(self) -> Int; '
        + 'fn show(self) -> Int { return self.id(); } }\n'
        + 'struct P { let v: Int; }\n'
        + 'impl Show for P { fn id(self) -> Int { return self.v; } }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_default_method_override_signature_checked() -> Result<Void, Error> {
    // An impl may override a default, but the override's signature must match.
    let errs = errors_of('interface Show { fn id(self) -> Int; '
        + 'fn show(self) -> Int { return self.id(); } }\n'
        + 'struct P { let v: Int; }\n'
        + 'impl Show for P { fn id(self) -> Int { return self.v; } '
        + 'fn show(self) -> String { return \'x\'; } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'method \'show\' does not match its declaration in interface \'Show\'')?;
    return Result.Ok(void);
}

@test
fn test_generic_bound_violation() -> Result<Void, Error> {
    let errs = errors_of('interface Show { fn show(self) -> String; }\n'
        + 'struct P { let v: Int; }\n'
        + 'fn need<T: Show>(_ x: T) { }\n'
        + 'fn f() { need(P { v: 1 }); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'type argument `P` for `T` does not implement `Show` '
        + '(required by "need")')?;
    return Result.Ok(void);
}

@test
fn test_rich_generic_program_is_clean() -> Result<Void, Error> {
    // A false-positive guard: generic enum + struct, an impl method, and a
    // generic function whose lambda argument is typed bidirectionally from the
    // (recovered) type arguments — all of which must check cleanly.
    let errs = errors_of('enum Opt<T> { Some(T), Nope }\n'
        + 'struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn get(self) -> T { return self.value; } }\n'
        + 'fn map_opt<T, U>(_ o: Opt<T>, _ f: (T) -> U) -> Opt<U> {\n'
        + '  return match o { Some(v) => Opt.Some(f(v)), Nope => Opt.Nope };\n'
        + '}\n'
        + 'fn main() -> Int {\n'
        + '  let b = Box { value: 10 };\n'
        + '  let doubled = map_opt(Opt.Some(b.get()), (x) => x + x);\n'
        + '  return match doubled { Some(v) => v, Nope => 0 };\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_generic_bound_satisfied_by_primitive_is_clean() -> Result<Void, Error> {
    // Primitives satisfy the built-in Display/Eq/Debug bounds.
    let errs = errors_of('fn need<T: Display>(_ x: T) { }\n'
        + 'fn f() { need(5); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- method-call argument checking ----

@test
fn test_method_arg_type_mismatch() -> Result<Void, Error> {
    let errs = errors_of('struct Counter { let n: Int; }\n'
        + 'impl Counter { fn bump(self, _ by: Int) -> Int { return self.n + by; } }\n'
        + 'fn f() -> Int { let c = Counter { n: 0 }; return c.bump(\'x\'); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'argument to "bump": expected Int, found String')?;
    return Result.Ok(void);
}

@test
fn test_method_arg_valid_is_clean() -> Result<Void, Error> {
    let errs = errors_of('struct Counter { let n: Int; }\n'
        + 'impl Counter { fn bump(self, _ by: Int) -> Int { return self.n + by; } }\n'
        + 'fn f() -> Int { let c = Counter { n: 0 }; return c.bump(5); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_method_wrong_arity() -> Result<Void, Error> {
    let errs = errors_of('struct Counter { let n: Int; }\n'
        + 'impl Counter { fn bump(self, _ by: Int) -> Int { return self.n + by; } }\n'
        + 'fn f() -> Int { let c = Counter { n: 0 }; return c.bump(1, 2); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: '"bump" expects 1 argument, got 2')?;
    return Result.Ok(void);
}

@test
fn test_generic_method_arg_substitutes_receiver() -> Result<Void, Error> {
    // `put`'s parameter is the receiver's `T`; on a `Box<Int>` a `String`
    // argument is a mismatch (receiver generics are made concrete first).
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn put(self, _ v: T) -> T { return v; } }\n'
        + 'fn f() -> Int { let b = Box { value: 1 }; return b.put(\'x\'); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'argument to "put": expected Int, found String')?;
    return Result.Ok(void);
}

@test
fn test_generic_method_arg_matching_is_clean() -> Result<Void, Error> {
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn put(self, _ v: T) -> T { return v; } }\n'
        + 'fn f() -> Int { let b = Box { value: 1 }; return b.put(7); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- match-arm unification ----

@test
fn test_match_arms_incompatible_value_types() -> Result<Void, Error> {
    let errs = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let _x = match n { 0 => \'a\', _ => 1 };\n'
        + '  return n;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'match arms have incompatible types: expected String, found Int')?;
    return Result.Ok(void);
}

@test
fn test_match_arms_consistent_is_clean() -> Result<Void, Error> {
    let errs = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let x = match n { 0 => 10, _ => 20 };\n'
        + '  return x;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_match_later_arm_violates_expected_type() -> Result<Void, Error> {
    // Under an annotated context (the function's return type), a wrong *later*
    // arm is caught even though the first arm matches — the old whole-match
    // inference (first arm wins) missed this.
    let errs = errors_of('fn f(_ n: Int) -> String {\n'
        + '  return match n { 0 => \'zero\', _ => 1 };\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'match arms have incompatible types: expected String, found Int')?;
    return Result.Ok(void);
}

@test
fn test_match_void_arm_in_value_match_is_flagged() -> Result<Void, Error> {
    // A non-diverging `Void` arm in a value-producing match flows its unit
    // value out and traps only at the use site — a check error, both spellings.
    let errs = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let _x = match n { 0 => 1, _ => {} };\n'
        + '  return n;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert(first_message(errs).contains('produces no value'),
        message: 'the void-arm diagnostic names the problem')?;
    let errs2 = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let _x = match n { 0 => 1, _ => void };\n'
        + '  return n;\n'
        + '}');
    testing.assert_eq(actual: errs2.len(), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_match_all_void_arms_is_clean() -> Result<Void, Error> {
    // A side-effecting match whose arms all produce nothing stays clean — the
    // match produces no value, so there is nothing a `Void` arm can corrupt.
    let errs = errors_of('fn g() -> Void {}\n'
        + 'fn f(_ n: Int) -> Int {\n'
        + '  match n { 0 => g(), _ => void }\n'
        + '  return n;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_match_diverging_block_arm_is_exempt() -> Result<Void, Error> {
    // A block-bodied diverging arm infers `Unit` (a tail-less block), but it
    // exits the function — the syntactic always-exits view keeps it exempt.
    let errs = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let x = match n { 0 => 1, _ => { return 0; } };\n'
        + '  return x;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_if_let_discarded_value_is_clean() -> Result<Void, Error> {
    // A statement `if let` whose then-branch tail is a discarded value desugars
    // to a match with a fabricated Unit wildcard arm — never flagged (the
    // diagnostic is Source-origin only).
    let errs = errors_of('enum E { A(Int), B }\n'
        + 'fn f(_ e: E) -> Int {\n'
        + '  if let A(v) = e { v }\n'
        + '  return 0;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_match_return_arm_is_exempt() -> Result<Void, Error> {
    // An arm that is a bare `return` is `Unknown`-typed and exempt from
    // unification (it diverges rather than producing the match's value).
    let errs = errors_of('fn f(_ n: Int) -> Int {\n'
        + '  let x = match n { 0 => 1, _ => return 0 };\n'
        + '  return x;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- return-context-only generic inference ----

@test
fn test_generic_call_unpinnable_is_diagnosed() -> Result<Void, Error> {
    // `T` appears only in `mk`'s return; with no annotation, type argument, or
    // surrounding context it can't be inferred — a located "annotate" error.
    let errs = errors_of('fn mk<T>() -> List<T> { return []; }\n'
        + 'fn f() { let _v = mk(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert(first_message(errs).contains('cannot infer type argument `T` for "mk"'),
        message: 'names the uninferable parameter')?;
    return Result.Ok(void);
}

@test
fn test_generic_call_pinned_by_annotation_is_clean() -> Result<Void, Error> {
    let errs = errors_of('fn mk<T>() -> List<T> { return []; }\n'
        + 'fn f() { let _v: List<Int> = mk(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_generic_call_pinned_by_type_args_is_clean() -> Result<Void, Error> {
    let errs = errors_of('fn mk<T>() -> List<T> { return []; }\n'
        + 'fn f() { let _v = mk<Int>(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_generic_call_pinned_by_return_context_is_clean() -> Result<Void, Error> {
    // The enclosing function's return type flows in as the expected type and pins T.
    let errs = errors_of('fn mk<T>() -> List<T> { return []; }\n'
        + 'fn g() -> List<Int> { return mk(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_generic_call_pinned_by_argument_is_clean() -> Result<Void, Error> {
    // `T` also appears in a parameter, so the argument pins it — never reported.
    let errs = errors_of('fn id<T>(_ x: T) -> T { return x; }\n'
        + 'fn f() { let _v = id(5); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_generic_call_pinned_by_surrounding_argument_is_clean() -> Result<Void, Error> {
    // Passed where a `List<Int>` is expected: the argument context pins T. (The
    // callee body avoids prelude methods, which don't resolve in this harness.)
    let errs = errors_of('fn mk<T>() -> List<T> { return []; }\n'
        + 'fn take(_ xs: List<Int>) -> Int { return 0; }\n'
        + 'fn f() -> Int { return take(mk()); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- static-method call checking ----
// (Namespace-function calls share the same `check_call_args` /
// `check_inferable_type_args` path. They're exercised end to end by the rest of
// the suite — the whole front-end is namespace calls — but need an import + a
// namespace map to set up hermetically, so the focused unit tests use static
// methods, which `errors_of` builds directly.)

@test
fn test_static_method_wrong_arity() -> Result<Void, Error> {
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn empty() -> Int { return 0; } }\n'
        + 'fn f() -> Int { return Box.empty(1, 2); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: '"empty" expects 0 arguments, got 2')?;
    return Result.Ok(void);
}

@test
fn test_static_method_generic_unpinnable_is_diagnosed() -> Result<Void, Error> {
    // `T` is the owner's parameter and shows up only in the static method's
    // return — unannotated, it can't be inferred.
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn make() -> Box<T> { return Box { value: 0 }; } }\n'
        + 'fn f() { let _b = Box.make(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert(first_message(errs).contains('cannot infer type argument `T` for "make"'),
        message: 'diagnoses the owner type parameter')?;
    return Result.Ok(void);
}

@test
fn test_static_method_generic_pinned_by_annotation_is_clean() -> Result<Void, Error> {
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn make() -> Box<T> { return Box { value: 0 }; } }\n'
        + 'fn f() { let _b: Box<Int> = Box.make(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- assignment target supplies the expected type ----

@test
fn test_reassignment_target_pins_generic() -> Result<Void, Error> {
    // `b`'s declared type is the expected type for the RHS, so the unannotated
    // `Box.make()` is pinned — not flagged as an uninferable generic.
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn make() -> Box<T> { return Box { value: 0 }; } }\n'
        + 'fn f() { let mut b: Box<Int> = Box.make(); b = Box.make(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_index_assignment_target_pins_generic() -> Result<Void, Error> {
    // The map's value type (`Box<Int>`) is the expected type for `m[k] = ...`,
    // pinning the constructor's parameter (the module_scope.hawk:245 shape).
    let errs = errors_of('struct Box<T> { let value: T; }\n'
        + 'impl Box<T> { fn make() -> Box<T> { return Box { value: 0 }; } }\n'
        + 'fn f() { let m: Map<String, Box<Int>> = [:]; m[\'a\'] = Box.make(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// --- duplicate top-level definitions ---

fn program_at(_ src: String, _ path: String) -> Program {
    let p = parse_tokens(tokenize(src).tokens).program;
    p.file_path = Option.Some(path);
    return p;
}

// Whether any diagnostic mentions `needle`.
fn any_message_contains(_ errs: List<Diagnostic>, _ needle: String) -> Bool {
    for e in errs {
        if e.message.contains(needle) {
            return true;
        }
    }
    return false;
}

@test
fn test_pub_function_shared_across_files_is_allowed() -> Result<Void, Error> {
    // Two libraries may each define a `pub` function of the same name: value
    // resolution is owner-correct (a bare reference reaches its own file; a
    // qualified `ns.fn` reaches within the named library), so this is no longer a
    // collision. This is the Phase 2e value-uniqueness lift — what previously made
    // `std.json.parse` and `std.toml.parse` impossible to coexist.
    let a = program_at('pub fn parse() -> Int { return 1; }', 'a.hawk');
    let b = program_at('pub fn parse() -> Int { return 2; }', 'b.hawk');
    let main = program_at('fn run() -> Int { return 0; }', 'main.hawk');
    let errs = check(main, [a, b], [:], [:]).errors;
    testing.assert(!any_message_contains(errs, 'duplicate function `parse`'),
        message: 'two libraries sharing a pub function name must not collide')?;
    return Result.Ok(void);
}

@test
fn test_pathless_programs_do_not_alias() -> Result<Void, Error> {
    // Two in-memory (path-less) programs used to share one `<anon>` identity
    // (LD8), merging their name spaces — a same-named private helper in each
    // read as a same-file duplicate. Distinct stamped identities keep them the
    // ordinary cross-file case (same-file-first, no collision).
    let dep = parse_tokens(tokenize('fn helper() -> Int { return 1; }').tokens).program;
    let main = parse_tokens(tokenize('fn helper() -> Int { return 2; }\n'
        + 'fn run() -> Int { return helper(); }').tokens).program;
    let errs = check(main, [dep], [:], [:]).errors;
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_private_function_collision_across_files_is_allowed() -> Result<Void, Error> {
    // Two *private* same-named helpers in different files resolve same-file-first,
    // so they don't collide — leniency the policy must keep.
    let lib = program_at('fn helper() -> Int { return 1; }', 'lib.hawk');
    let main = program_at('fn helper() -> Int { return 2; }\n'
        + 'fn run() -> Int { return helper(); }', 'main.hawk');
    let errs = check(main, [lib], [:], [:]).errors;
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_duplicate_type_across_files_is_allowed() -> Result<Void, Error> {
    // Two libraries may each define `Point`: type resolution is owner-correct (a
    // `Type` carries its owning-library `TypeId`), so a qualified `ns.Point`
    // reaches its own library's type and the two coexist. This is the Phase 1
    // type-uniqueness lift, the type-side analogue of the value lift above.
    let lib = program_at('pub struct Point { let x: Int; }', 'lib.hawk');
    let main = program_at('struct Point { let y: Int; }\n'
        + 'fn run() -> Int { return 0; }', 'main.hawk');
    let errs = check(main, [lib], [:], [:]).errors;
    testing.assert(!any_message_contains(errs, 'duplicate type `Point`'),
        message: 'two libraries sharing a type name must not collide')?;
    return Result.Ok(void);
}

@test
fn test_duplicate_type_same_file_is_flagged() -> Result<Void, Error> {
    // A same-file redefinition is still a collision — scope can't tell the two
    // `Point`s apart within one file.
    let errs = errors_of('struct Point { let x: Int; }\n'
        + 'struct Point { let y: Int; }\n'
        + 'fn run() -> Int { return 0; }');
    testing.assert(any_message_contains(errs, 'duplicate type `Point`'),
        message: 'expected a same-file duplicate-type diagnostic')?;
    return Result.Ok(void);
}

@test
fn test_redefinition_in_same_file_is_flagged() -> Result<Void, Error> {
    let errs = errors_of('fn dup() -> Int { return 1; }\n'
        + 'fn dup() -> Int { return 2; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert(any_message_contains(errs, 'duplicate function `dup`'),
        message: 'expected a same-file redefinition diagnostic')?;
    return Result.Ok(void);
}

// ---- the committed-type record (CH19) ----

fn records_of(_ src: String) -> List<TypeRecord> {
    return check(parse_tokens(tokenize(src).tokens).program, [], [:], [:]).records;
}

// The rendered committed type of the first occurrence of `text` in `src`.
// Scans the whole record; a later entry supersedes (the refinement override).
fn record_for(_ rec: List<TypeRecord>, _ src: String, _ text: String) -> String {
    return match src.find(text) {
        Some(off) => {
            let mut found = '<no record>';
            for r in rec {
                if r.offset == off && r.length == text.len() {
                    found = type_to_string(r.ty);
                }
            }
            found
        },
        None => '<text not found>',
    };
}

@test
fn test_record_covers_expressions_and_let_names() -> Result<Void, Error> {
    let src = 'fn f() -> Int { let y = 1 + 2; return y; }';
    let rec = records_of(src);
    testing.assert_eq(actual: record_for(rec, src, '1 + 2'), expected: 'Int')?;
    testing.assert_eq(actual: record_for(rec, src, '2'), expected: 'Int')?;
    // `let` name spans are stamped for declaration-site type queries.
    testing.assert_eq(actual: record_for(rec, src, 'y'), expected: 'Int')?;
    return Result.Ok(void);
}

@test
fn test_record_let_value_holds_the_refined_type() -> Result<Void, Error> {
    // Forward-flow pins `xs` to List<Int>; the refined type supersedes the
    // value's pre-refinement `List<?>` record.
    let src = 'fn f() -> Void { let xs = []; xs.push(1); }';
    let rec = records_of(src);
    testing.assert_eq(actual: record_for(rec, src, '[]'), expected: 'List<Int>')?;
    testing.assert_eq(actual: record_for(rec, src, 'xs'), expected: 'List<Int>')?;
    return Result.Ok(void);
}

@test
fn test_record_compound_assign_is_first_write_wins() -> Result<Void, Error> {
    // The compound-assign transient (`total + 2` synthesized over the
    // `total += 2` span) records once; the re-synthesis in later probes hits
    // the same key.
    let src = 'fn f() -> Int { let mut total = 1; total += 2; return total; }';
    let rec = records_of(src);
    testing.assert_eq(actual: record_for(rec, src, 'total += 2'), expected: 'Int')?;
    testing.assert_eq(actual: record_for(rec, src, 'total'), expected: 'Int')?;
    return Result.Ok(void);
}

@test
fn test_record_skips_synthesized_desugar_nodes() -> Result<Void, Error> {
    // The if-let desugar fabricates zero-length-span nodes (PA6); none of them
    // may be recorded (no real token has length 0).
    let src = 'fn f(_ o: Option<Int>) -> Int {\n'
        + '    if let Some(x) = o { return x; }\n'
        + '    return 0;\n'
        + '}';
    let rec = records_of(src);
    for r in rec {
        testing.assert_ne(actual: r.length, unexpected: 0)?;
    }
    return Result.Ok(void);
}

// ---- boundary annotations (hard at the boundaries; see language.md) ----

@test
fn test_param_needs_type_annotation() -> Result<Void, Error> {
    let errs = errors_of('fn f(x) -> Int { return x; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'parameter \'x\' needs a type annotation, e.g. x: Int')?;
    return Result.Ok(void);
}

@test
fn test_self_and_typed_params_are_clean() -> Result<Void, Error> {
    let errs = errors_of('struct S { let n: Int; }\n'
        + 'impl S { fn add(self, _ k: Int) -> Int { return self.n + k; } }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_value_return_needs_return_type() -> Result<Void, Error> {
    let errs = errors_of('fn f(_ x: Int) { return x; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'this function returns a value but has no return type; add one, e.g. -> Int')?;
    return Result.Ok(void);
}

@test
fn test_value_return_reported_once_per_function() -> Result<Void, Error> {
    // Two value-returns, one omitted return type — a single diagnostic.
    let errs = errors_of('fn f(_ x: Int) { if x > 0 { return x; } else { return 0 - x; } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_missing_return_on_a_path() -> Result<Void, Error> {
    // Definite return: a value-returning fn whose body can fall off the end.
    let errs = errors_of('fn f(_ b: Bool) -> Int { if b { return 1; } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'missing return: not every path through \'f\' returns a value (declared `-> Int`)')?;
    return Result.Ok(void);
}

@test
fn test_missing_return_no_return_at_all() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { let _x = 1; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_bare_return_in_value_fn() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { return; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: '`return` needs a value: the function returns Int')?;
    return Result.Ok(void);
}

@test
fn test_all_paths_exit_is_clean() -> Result<Void, Error> {
    // Every path returns or throws; `while true` without a break never
    // completes normally (and with a break, the fall-through is back).
    let errs = errors_of('fn f(_ b: Bool) -> Int { if b { return 1; } else { return 2; } }\n'
        + 'fn g() -> Int { while true { return 1; } }\n'
        + 'fn t(_ b: Bool) -> Int { if b { throw 0 - 1; } else { return 2; } }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    let breaks = errors_of('fn f() -> Int { while true { break; } }');
    testing.assert_eq(actual: breaks.len(), expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_void_returns_are_clean() -> Result<Void, Error> {
    // Bare `return;`, `return void;`, and no return at all all stay `Void`.
    let errs = errors_of('fn a(_ x: Int) { if x > 0 { return; } }\n'
        + 'fn b() { return void; }\n'
        + 'fn c() { }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_value_returning_lambda_in_void_fn_is_clean() -> Result<Void, Error> {
    // A `return` inside a lambda returns from the lambda, not the enclosing
    // (return-type-less) function, so it must not trip the diagnostic.
    let errs = errors_of('fn f() { let g = (n: Int) => n + 1; g(1); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_module_let_needs_type_annotation() -> Result<Void, Error> {
    let errs = errors_of('let X = 5;');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'module-level \'X\' needs a type annotation, e.g. X: Int')?;
    return Result.Ok(void);
}

@test
fn test_module_const_needs_type_annotation() -> Result<Void, Error> {
    let errs = errors_of('const K = 5;');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'module-level \'K\' needs a type annotation, e.g. K: Int')?;
    return Result.Ok(void);
}

@test
fn test_annotated_globals_are_clean() -> Result<Void, Error> {
    let errs = errors_of('const K: Int = 5;\nlet X: Int = K + 1;');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- reserved core type names: identity-based exemption ----

@test
fn test_reserved_name_exempt_for_its_core_owner() -> Result<Void, Error> {
    // A reserved type declared by the file that owns the core type is allowed —
    // the SDK's own `sdk/std/core` sources. Exemption is by owner *identity*
    // (`core_owner`), not a path heuristic, so it holds on every analysis path
    // (check/LSP/test) regardless of how the file path was spelled.
    let core = program_at('pub enum Result { Ok, Err }', '/core/result.hawk');
    testing.assert_eq(actual: reserved_errors(core, []).len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_reserved_name_flagged_for_non_owner() -> Result<Void, Error> {
    // A different file declaring the same reserved type is flagged: the core
    // owner arrives as an import, the redeclaration as the primary.
    let core = program_at('pub enum Result { Ok, Err }', '/core/result.hawk');
    let user = program_at('struct Result { let x: Int; }', '/app/main.hawk');
    let errs = reserved_errors(user, [core]);
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert(errs[0].message.contains('`Result`'))?;
    return Result.Ok(void);
}

@test
fn test_reserved_name_exempt_across_sdk_locations() -> Result<Void, Error> {
    // The same core source at a different absolute path — an installed SDK the
    // prelude was loaded from vs the repo copy being edited — is still the owner:
    // keys agreeing from the last `/std/` segment on are the same stdlib source.
    // Guards the LSP-editing-the-repo case.
    let installed = program_at('pub enum Result { Ok, Err }', '/opt/hawk/std/core/result.hawk');
    let repo = program_at('pub enum Result { Ok, Err }', '/home/me/hawk/sdk/std/core/result.hawk');
    testing.assert_eq(actual: reserved_errors(repo, [installed]).len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_conformance_type_args_must_match() -> Result<Void, Error> {
    // An `impl Box<Int>` does not satisfy an expected `Box<String>`: the
    // conformance's type arguments must agree, not just the interface identity.
    let src = 'interface Box<T> { fn get(self) -> T; }\n'
        + 'struct IntBox { let v: Int; }\n'
        + 'impl Box<Int> for IntBox { fn get(self) -> Int { return self.v; } }\n'
        + 'fn wants(_ b: Box<String>) -> Int { return 0; }\n'
        + 'fn use_it() -> Int { return wants(IntBox { v: 1 }); }';
    let errs = errors_of(src);
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'argument to "wants": expected Box<String>, found IntBox')?;
    return Result.Ok(void);
}

@test
fn test_conformance_matching_type_args_clean() -> Result<Void, Error> {
    let src = 'interface Box<T> { fn get(self) -> T; }\n'
        + 'struct IntBox { let v: Int; }\n'
        + 'impl Box<Int> for IntBox { fn get(self) -> Int { return self.v; } }\n'
        + 'fn wants(_ b: Box<Int>) -> Int { return 0; }\n'
        + 'fn use_it() -> Int { return wants(IntBox { v: 1 }); }';
    testing.assert_eq(actual: errors_of(src).len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- method calls on a bounded type parameter (T: Iface) ----

@test
fn test_bounded_type_param_bad_method_errors() -> Result<Void, Error> {
    let errs = errors_of('interface W { fn weight(self) -> Int; }\n'
        + 'fn f<T: W>(_ x: T) -> Int { return x.nope(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'no method "nope" on T')?;
    return Result.Ok(void);
}

@test
fn test_bounded_type_param_good_method_clean() -> Result<Void, Error> {
    let errs = errors_of('interface W { fn weight(self) -> Int; }\n'
        + 'fn f<T: W>(_ x: T) -> Int { return x.weight(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_unbounded_type_param_method_is_a_definitive_miss() -> Result<Void, Error> {
    // An unbounded `T` has no methods, so a (non-universal) method call on it is
    // a definitive miss — `check` catches it, matching codegen (which used to be
    // the only phase to reject it).
    let errs = errors_of('fn f<T>(_ x: T) -> Int { return x.anything(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'no method "anything" on T')?;
    return Result.Ok(void);
}

@test
fn test_universal_method_on_type_param_is_clean() -> Result<Void, Error> {
    // `display`/`debug` are universal — callable on any parameter, bounded or
    // not (total rendering resolves impl-or-fallback at runtime).
    testing.assert_eq(actual: errors_of('fn f<T>(_ x: T) -> String { return x.debug(); }').len(),
        expected: 0)?;
    testing.assert_eq(actual: errors_of('interface W { fn wt(self) -> Int; }\n'
        + 'fn f<T: W>(_ x: T) -> String { return x.display(); }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

// ---- member uniqueness + pattern arity (diagnostics punchlist item 2) ----

@test
fn test_duplicate_members_are_errors() -> Result<Void, Error> {
    // Struct fields, enum variants, type parameters, impl/interface methods.
    testing.assert_eq(actual: first_message(errors_of('struct P { let x: Int; let x: Int; }')),
        expected: 'duplicate field `x`')?;
    testing.assert_eq(actual: first_message(errors_of('enum E { Red, Red }')),
        expected: 'duplicate variant `Red`')?;
    testing.assert_eq(actual: first_message(errors_of('fn f<T, T>(_ x: Int) -> Int { return x; }')),
        expected: 'duplicate type parameter `T`')?;
    testing.assert_eq(actual: first_message(errors_of('struct S { let n: Int; }\n'
        + 'impl S { fn f(self) -> Int { return 1; } fn f(self) -> Int { return 2; } }')),
        expected: 'duplicate method `f`')?;
    testing.assert_eq(actual: first_message(errors_of('interface I { fn f(self) -> Int; fn f(self) -> Int; }')),
        expected: 'duplicate method `f`')?;
    return Result.Ok(void);
}

@test
fn test_duplicate_params_and_labels() -> Result<Void, Error> {
    let errs = errors_of('fn f(a: Int, a: Int) -> Int { return a; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?; // one error, as the name
    testing.assert_eq(actual: first_message(errs), expected: 'duplicate parameter `a`')?;
    testing.assert_eq(actual: first_message(errors_of('fn f(k a: Int, k b: Int) -> Int { return a + b; }')),
        expected: 'duplicate parameter label `k`')?;
    // Distinct labels over distinct names: clean.
    testing.assert_eq(actual: errors_of('fn f(a: Int, b: Int) -> Int { return a + b; }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_duplicate_struct_literal_field() -> Result<Void, Error> {
    let errs = errors_of('struct P { let x: Int; let y: Int; }\n'
        + 'fn f() -> Int { let p = P { x: 1, x: 2, y: 3 }; return p.x; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'duplicate field `x`')?;
    return Result.Ok(void);
}

@test
fn test_pattern_arity_is_checked() -> Result<Void, Error> {
    let src = 'enum E { Two(Int, Int), None }\n';
    // Too few, bare (0 args), too many; correct arity is clean.
    testing.assert_eq(actual: first_message(errors_of(src
        + 'fn f(_ e: E) -> Int { return match e { Two(a) => a, _ => 0 }; }')),
        expected: 'variant `Two` has 2 fields, but the pattern binds 1; match it as `Two(_, _)`')?;
    testing.assert_eq(actual: first_message(errors_of(src
        + 'fn f(_ e: E) -> Int { return match e { Two => 1, _ => 0 }; }')),
        expected: 'variant `Two` has 2 fields, but the pattern binds 0; match it as `Two(_, _)`')?;
    testing.assert_eq(actual: first_message(errors_of(src
        + 'fn f(_ e: E) -> Int { return match e { None(x) => x, _ => 0 }; }')),
        expected: 'variant `None` has 0 fields, but the pattern binds 1; match it as `None`')?;
    testing.assert_eq(actual: errors_of(src
        + 'fn f(_ e: E) -> Int { return match e { Two(a, b) => a + b, _ => 0 }; }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_duplicate_pattern_binding() -> Result<Void, Error> {
    let errs = errors_of('enum E { Two(Int, Int) }\n'
        + 'fn f(_ e: E) -> Int { return match e { Two(a, a) => a }; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'duplicate binding `a` in pattern')?;
    // The same name in *different* arms is fine.
    testing.assert_eq(actual: errors_of('enum E { L(Int), R(Int) }\n'
        + 'fn f(_ e: E) -> Int { return match e { L(a) => a, R(a) => a }; }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

// ---- emit→check promotion + default-method bodies (punchlist item 3) ----

@test
fn test_interface_default_body_is_checked() -> Result<Void, Error> {
    let errs = errors_of('interface G { fn a(self) -> Int; fn b(self) -> Int { return missing(); } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'undefined name: missing')?;
    // A clean default body — including a sibling call through interface-typed
    // `self` and definite-return — checks clean.
    testing.assert_eq(actual: errors_of('interface G { fn a(self) -> Int; '
        + 'fn b(self) -> Int { return self.a() + 1; } }').len(),
        expected: 0)?;
    // Definite-return applies to default bodies too.
    testing.assert_eq(actual: first_message(errors_of('interface G { fn a(self) -> Int; '
        + 'fn b(self) -> Int { let _x = 1; } }')),
        expected: 'missing return: not every path through \'b\' returns a value (declared `-> Int`)')?;
    return Result.Ok(void);
}

@test
fn test_for_iterable_is_checked() -> Result<Void, Error> {
    let errs = errors_of('fn f() { for x in 5 { } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'cannot iterate Int (only ranges, lists, and Iterators are supported)')?;
    testing.assert_eq(actual: errors_of('fn f() { for x in [1, 2] { } for i in 0..3 { } }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_range_only_in_for_head() -> Result<Void, Error> {
    let errs = errors_of('fn f() { let _r = 1..5; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'a range is only valid as a for-loop iterable')?;
    // Bounds are still checked in the for-head position.
    testing.assert_eq(actual: first_message(errors_of('fn f() { for i in 0..\'z\' { } }')),
        expected: 'range bound: expected Int, found String')?;
    return Result.Ok(void);
}

@test
fn test_index_receiver_is_checked() -> Result<Void, Error> {
    let errs = errors_of('struct P { let x: Int; }\n'
        + 'fn f() -> Int { let p = P { x: 1 }; return p[0]; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'indexing on P is not supported')?;
    // Indexed assignment routes through the same check.
    testing.assert_eq(actual: first_message(errors_of('struct P { let x: Int; }\n'
        + 'fn f() { let p = P { x: 1 }; p[0] = 2; }')),
        expected: 'indexing on P is not supported')?;
    testing.assert_eq(actual: errors_of('fn f() -> Int { let xs = [1]; xs[0] = 2; return xs[0]; }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_call_of_non_function_local() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { let x = 5; return x(3); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'cannot call `x`: it has type Int, not a function')?;
    testing.assert_eq(actual: errors_of('fn f() -> Int { let g = (n: Int) => n; return g(3); }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_impl_target_must_exist() -> Result<Void, Error> {
    let errs = errors_of('impl Ghost { fn f(self) -> Int { return 1; } }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs), expected: 'unknown type: Ghost')?;
    testing.assert_eq(actual: errors_of('struct S { let n: Int; }\n'
        + 'impl S { fn f(self) -> Int { return self.n; } }').len(),
        expected: 0)?;
    return Result.Ok(void);
}

// ---- unused Result + `let _ =` discard (diagnostics punchlist item 4) ----

@test
fn test_unused_result_is_an_error() -> Result<Void, Error> {
    let errs = errors_of('fn g() -> Result<Int, Error> { return Result.Ok(1); }\n'
        + 'fn f() { g(); }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: 'unused `Result`: handle it (`?`, `match`, `if let`) or discard it explicitly with `let _ = …`')?;
    return Result.Ok(void);
}

@test
fn test_unused_option_is_legal() -> Result<Void, Error> {
    // Deliberately Result-only: pop/remove-style mutators return the removed
    // value as a convenience, and dropping it is idiomatic.
    let errs = errors_of('fn g() -> Option<Int> { return Option.None; }\n'
        + 'fn f() { g(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_wildcard_let_discards() -> Result<Void, Error> {
    // `let _ = …` is the explicit discard: no binding, no unused-Result error.
    let errs = errors_of('fn g() -> Result<Int, Error> { return Result.Ok(1); }\n'
        + 'fn f() { let _ = g(); }');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    // An annotation on the wildcard is still checked.
    let bad = errors_of('fn f() { let _: Int = true; }');
    testing.assert_eq(actual: bad.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(bad),
        expected: 'binding \'_\': expected Int, found Bool')?;
    return Result.Ok(void);
}

@test
fn test_handled_result_forms_are_clean() -> Result<Void, Error> {
    let errs = errors_of('fn g() -> Result<Int, Error> { return Result.Ok(1); }\n'
        + 'fn f() -> Result<Void, Error> {\n'
        + '    g()?;\n'
        + '    if let Err(_) = g() { let _n = 0; }\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- same-block rebinding (diagnostics punchlist wrinkle) ----

@test
fn test_same_block_rebinding_is_an_error() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int { let x = 1; let x = 2; return x; }');
    testing.assert_eq(actual: errs.len(), expected: 1)?;
    testing.assert_eq(actual: first_message(errs),
        expected: '`x` is already bound in this block; rename it (an inner block may shadow)')?;
    return Result.Ok(void);
}

@test
fn test_inner_scope_shadowing_is_legal() -> Result<Void, Error> {
    // A nested block/arm/loop is its own scope; a param may be shadowed by a
    // body `let`; `_` binds nothing so repeating it never collides.
    let errs = errors_of('fn f(_ x: Int) -> Int {\n'
        + '    let x = x + 1;\n'
        + '    let y = 1;\n'
        + '    if x > 0 { let y = 2; return y; }\n'
        + '    let _ = 1;\n'
        + '    let _ = 2;\n'
        + '    return y;\n'
        + '}');
    testing.assert_eq(actual: errs.len(), expected: 0)?;
    return Result.Ok(void);
}

// ---- warnings: unused-import + `// ignore:` suppression ----

// The error-severity count of a mixed list (mirrors diagnostic.error_count;
// local so the test file needs no extra import surface).
fn diag_error_count(_ errs: List<Diagnostic>) -> Int {
    let mut n = 0;
    for e in errs {
        if let Error = e.severity {
            n = n + 1;
        }
    }
    return n;
}

fn warning_messages(_ errs: List<Diagnostic>) -> List<String> {
    let out: List<String> = [];
    for e in errs {
        if let Warning = e.severity {
            out.push(e.message);
        }
    }
    return out;
}

@test
fn test_unused_import_warns() -> Result<Void, Error> {
    let errs = errors_of('import \'helper\';\nfn f() -> Int { return 1; }');
    testing.assert_eq(actual: warning_messages(errs),
        expected: ['unused import: `helper` is never referenced'])?;
    // Warnings are not errors: the check result carries no error-severity entry.
    testing.assert_eq(actual: diag_error_count(errs), expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_used_imports_are_clean() -> Result<Void, Error> {
    // Qualified value use, qualified type use, and an alias each count.
    testing.assert_eq(actual: warning_messages(errors_of(
        'import \'helper\';\nfn f() -> Int { return helper.go(); }')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'import \'helper\';\nfn f(_ x: helper.Thing) -> Int { return 1; }')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'import \'helper\' as h;\nfn f() -> Int { return h.go(); }')).len(),
        expected: 0)?;
    // `pub import` (a re-export) and `as _` (bare surface) are exempt.
    testing.assert_eq(actual: warning_messages(errors_of('pub import \'helper\';')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of('import \'helper\' as _;')).len(),
        expected: 0)?;
    return Result.Ok(void);
}

// ---- warnings: unreachable-code + unreachable-arm ----

@test
fn test_unreachable_code_warns() -> Result<Void, Error> {
    // Two dead statements after the `return`, but one warning per block —
    // on the first.
    let errs = errors_of('fn f() -> Int {\n  return 1;\n  let x = 2;\n  return x;\n}');
    testing.assert_eq(actual: warning_messages(errs),
        expected: ['unreachable code: the statement above always exits'])?;
    // After a `break`, and after an `if` whose branches both return.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f() -> Int {\n  let mut i = 0;\n  while true {\n    break;\n    i = i + 1;\n  }\n  return i;\n}')).len(),
        expected: 1)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ b: Bool) -> Int {\n  if b { return 1; } else { return 2; }\n  return 3;\n}')).len(),
        expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_reachable_code_is_clean() -> Result<Void, Error> {
    // An else-less `if` falls through, so the following return is live.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ b: Bool) -> Int {\n  if b { return 1; }\n  return 2;\n}')).len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_unreachable_arm_warns() -> Result<Void, Error> {
    // A catch-all first shadows everything after it.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ n: Int) -> Int {\n  return match n {\n    _ => 0,\n    1 => 1,\n  };\n}')),
        expected: ['unreachable match arm: an arm above already matches every value'])?;
    // A repeated literal.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ n: Int) -> Int {\n  return match n {\n    1 => 1,\n    1 => 2,\n    _ => 0,\n  };\n}')),
        expected: ['unreachable match arm: this literal is already matched above'])?;
    // A variant fully matched by an all-binding constructor arm.
    testing.assert_eq(actual: warning_messages(errors_of(
        'enum E { A(Int), B }\nfn f(_ e: E) -> Int {\n  return match e {\n    A(x) => x,\n    A(y) => y,\n    B => 0,\n  };\n}')),
        expected: ['unreachable match arm: variant `A` is already matched above'])?;
    // Full coverage counts as a catch-all: both bools, or every variant.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ b: Bool) -> Int {\n  return match b {\n    true => 1,\n    false => 0,\n    _ => 9,\n  };\n}')).len(),
        expected: 1)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'enum E { A, B }\nfn f(_ e: E) -> Int {\n  return match e {\n    A => 0,\n    B => 1,\n    _ => 2,\n  };\n}')).len(),
        expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_refutable_constructor_arm_claims_nothing() -> Result<Void, Error> {
    // `A(1)` matches only one value of the payload, so a later `A(x)` is live.
    testing.assert_eq(actual: warning_messages(errors_of(
        'enum E { A(Int), B }\nfn f(_ e: E) -> Int {\n  return match e {\n    A(1) => 9,\n    A(x) => x,\n    B => 0,\n  };\n}')).len(),
        expected: 0)?;
    return Result.Ok(void);
}

// ---- warnings: unused-variable ----

@test
fn test_unused_variable_warns() -> Result<Void, Error> {
    let errs = errors_of('fn f() -> Int {\n  let x = 1;\n  return 2;\n}');
    testing.assert_eq(actual: warning_messages(errs),
        expected: ['unused variable: `x` is never referenced'])?;
    testing.assert_eq(actual: diag_error_count(errs), expected: 0)?;
    // An unused inner shadow is flagged even when the outer binding is used —
    // the pass is per block, and a use before the inner `let` can only refer
    // to the outer binding.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f(_ b: Bool) -> Int {\n  let x = 1;\n  if b { let x = 9; return 0; }\n  return x;\n}')).len(),
        expected: 1)?;
    return Result.Ok(void);
}

@test
fn test_used_variables_are_clean() -> Result<Void, Error> {
    // Interpolation, lambda capture, and a later assignment target all count.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f() -> String {\n  let name = \'hawk\';\n  return \'hi \${name}\';\n}')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f() -> Int {\n  let base = 10;\n  let g = (n: Int) => n + base;\n  return g(1);\n}')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f() -> Int {\n  let mut x = 0;\n  x = 5;\n  return 1;\n}')).len(),
        expected: 0)?;
    // `_` and `_`-prefixed names are the intentional-discard escape.
    testing.assert_eq(actual: warning_messages(errors_of(
        'fn f() -> Int {\n  let _ = 1;\n  let _scratch = 2;\n  return 3;\n}')).len(),
        expected: 0)?;
    return Result.Ok(void);
}

@test
fn test_ignore_comment_suppresses_warning() -> Result<Void, Error> {
    // Same line, and the line above.
    testing.assert_eq(actual: warning_messages(errors_of(
        'import \'helper\'; // ignore: unused-import\nfn f() -> Int { return 1; }')).len(),
        expected: 0)?;
    testing.assert_eq(actual: warning_messages(errors_of(
        '// ignore: unused-import\nimport \'helper\';\nfn f() -> Int { return 1; }')).len(),
        expected: 0)?;
    // A different rule name does not suppress it.
    testing.assert_eq(actual: warning_messages(errors_of(
        'import \'helper\'; // ignore: other-rule\nfn f() -> Int { return 1; }')).len(),
        expected: 1)?;
    return Result.Ok(void);
}
