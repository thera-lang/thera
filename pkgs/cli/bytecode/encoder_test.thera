// Tests for the Hawk `.thera-bc` encoder, diffed byte-for-byte against golden
// arrays. The headline test rebuilds a `double`/`main` module and asserts the
// encoded bytes exactly — pinning the Hawk encoder to the runtime's `codec.rs`
// (the round-trip oracle). Two smaller hand-derived goldens cover the type
// table, the dispatch section, and the numeric/bool/negative-immediate opcodes
// the demo doesn't exercise.

import std.testing;

import 'instr' as _;
import 'module' as _;
import 'encoder' as _;

// The runtime's demo:
//   fn double(x) { return x * 2; }
//   fn main() { println('double(21) = ' + stringify(double(21))); return 0; }
// `main` is function index 0, `double` is index 1 (so `Call(1, 1)`).
fn demo_module() -> Module {
    let main_fn = FuncDef {
        name: 'main',
        param_count: 0,
        local_count: 0,
        code: [
            Instr.ConstStr('double(21) = '),
            Instr.ConstInt(21),
            Instr.Call(1, 1),
            Instr.CallNative('stringify', 1),
            Instr.CallNative('str_concat', 2),
            Instr.CallNative('println', 1),
            Instr.Simple(Op.Pop),
            Instr.ConstInt(0),
            Instr.Simple(Op.Return),
        ],
    };
    let double_fn = FuncDef {
        name: 'double',
        param_count: 1,
        local_count: 1,
        code: [
            Instr.Load(0),
            Instr.ConstInt(2),
            Instr.Simple(Op.MulI64),
            Instr.Simple(Op.Return),
        ],
    };
    return Module { functions: [main_fn, double_fn], types: [], enums: [], dispatch: [], global_count: 0 };
}

@test
fn test_demo_is_byte_identical_to_runtime() -> Result<Void, Error> {
    // The v3 wire form: names moved to the Symbols section (7) and a trailing
    // Entry section (6) points at `main` (index 0, encoded as `index + 1`).
    let expected = [
        84, 72, 69, 82, 65, 3, 0, 0, 0,
        // constants: 4 strings
        2, 44, 4, 13, 100, 111, 117, 98, 108, 101, 40, 50, 49, 41, 32, 61, 32,
        9, 115, 116, 114, 105, 110, 103, 105, 102, 121,
        10, 115, 116, 114, 95, 99, 111, 110, 99, 97, 116,
        7, 112, 114, 105, 110, 116, 108, 110,
        // types: none
        3, 1, 0,
        // functions: 2 fns (no names), main (0/0, 9 instrs) then double (1/1, 4)
        1, 33, 2, 0, 0, 9,
        5, 0, 1, 21, 36, 1, 1, 37, 1, 1, 37, 2, 2, 37, 3, 1, 34, 1, 0, 45,
        1, 1, 4, 6, 0, 1, 2, 10, 45,
        // symbols: "main", "double"
        7, 13, 2, 4, 109, 97, 105, 110, 6, 100, 111, 117, 98, 108, 101,
        // entry: main index 0 (+1), no init
        6, 2, 1, 0,
    ];
    testing.assert_eq(actual: encode_module(demo_module()).to_list(),
        expected: expected)?;
    return Result.Ok(void);
}

@test
fn test_types_and_dispatch_sections() -> Result<Void, Error> {
    // A module with a type (Point, 2 fields) and a dispatch row (show -> f).
    // The pool interns "Point" first (types pass), then "show" (dispatch pass).
    let f = FuncDef {
        name: 'f',
        param_count: 0,
        local_count: 0,
        code: [Instr.Simple(Op.ConstUnit), Instr.Simple(Op.Return)],
    };
    let m = Module {
        functions: [f],
        types: [TypeDef { name: 'Point', field_count: 2, field_names: ['x', 'y'] }],
        enums: [],
        dispatch: [DispatchEntry { type_id: 0, selector: 'show', func: 0 }],
        global_count: 0,
    };
    // Field names are interned right after the type name (types pass), before the
    // dispatch selector — so the pool is [Point, x, y, show].
    let expected = [
        84, 72, 69, 82, 65, 3, 0, 0, 0,
        // constants: 4 strings — "Point"(0), "x"(1), "y"(2), "show"(3)
        2, 16, 4, 5, 80, 111, 105, 110, 116, 1, 120, 1, 121, 4, 115, 104, 111, 119,
        // types: 1 type, name-index 0, field-count 2, name-count 2, [x=1, y=2]
        3, 6, 1, 0, 2, 2, 1, 2,
        // functions: 1 fn (no name), 0/0, 2 instrs (const.unit=4, return=45)
        1, 6, 1, 0, 0, 2, 4, 45,
        // symbols: "f"
        7, 3, 1, 1, 102,
        // dispatch: 1 row — type 0, selector-index 3, func 0
        4, 4, 1, 0, 3, 0,
    ];
    testing.assert_eq(actual: encode_module(m).to_list(), expected: expected)?;
    return Result.Ok(void);
}

@test
fn test_double_bool_and_negative_int() -> Result<Void, Error> {
    // const.double(1.5), const.bool(true), const.int(-1), return.
    let g = FuncDef {
        name: 'g',
        param_count: 0,
        local_count: 0,
        code: [
            Instr.ConstDouble(1.5),
            Instr.ConstBool(true),
            Instr.ConstInt(-1),
            Instr.Simple(Op.Return),
        ],
    };
    let m = Module { functions: [g], types: [], enums: [], dispatch: [], global_count: 0 };
    let expected = [
        84, 72, 69, 82, 65, 3, 0, 0, 0,
        2, 1, 0, // no pooled strings
        3, 1, 0, // no types
        1, 18, 1, 0, 0, 4,             // functions: 1 fn (no name), 0/0, 4 instrs
        2, 0, 0, 0, 0, 0, 0, 248, 63, // const.double 1.5 (IEEE-754 LE)
        3, 1,                          // const.bool true
        1, 127,                        // const.int -1 (signed LEB128)
        45,                            // return
        7, 3, 1, 1, 103,               // symbols: "g"
    ];
    testing.assert_eq(actual: encode_module(m).to_list(), expected: expected)?;
    return Result.Ok(void);
}

@test
fn test_empty_dispatch_section_is_omitted() -> Result<Void, Error> {
    // No dispatch rows → the dispatch section is omitted, leaving the exact
    // 112-byte demo output (the byte-for-byte test above pins its contents).
    testing.assert_eq(actual: encode_module(demo_module()).to_list().len(),
        expected: 112)?;
    return Result.Ok(void);
}
