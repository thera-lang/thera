// Tests for the calc evaluator (spike stage 3) — full lex → parse → eval.

import std.testing;

import 'lexer';
import 'parser';
import 'eval';

// The whole pipeline, surfacing any stage's error as the common Error.
fn calc(_ src: String) -> Result<Double, Error> {
    let toks = tokenize(src)?;
    let expr = parse(toks)?;
    return Result.Ok(eval(expr)?);
}

@test
fn test_arithmetic_and_precedence() -> Result<Void, Error> {
    testing.assert_eq(actual: calc('1 + 2 * 3')?, expected: 7.0)?;
    testing.assert_eq(actual: calc('(1 + 2) * 3')?, expected: 9.0)?;
    testing.assert_eq(actual: calc('10 - 4 - 3')?, expected: 3.0)?;  // left-assoc
    return Result.Ok(void);
}

@test
fn test_unary_and_decimals() -> Result<Void, Error> {
    testing.assert_eq(actual: calc('-2 * 3')?, expected: -6.0)?;
    testing.assert_eq(actual: calc('10 / 4')?, expected: 2.5)?;
    testing.assert_eq(actual: calc('-(1 + 2)')?, expected: -3.0)?;
    return Result.Ok(void);
}

@test
fn test_divide_by_zero() -> Result<Void, Error> {
    testing.assert_err(calc('1 / 0'))?;
    testing.assert_err(calc('5 / (3 - 3)'))?;
    return Result.Ok(void);
}
