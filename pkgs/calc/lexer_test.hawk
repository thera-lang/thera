// Tests for the calc lexer (spike stage 1).

import std.testing;

import 'lexer';

@test
fn test_operators_and_parens() -> Result<Void, Error> {
    let toks = tokenize('+ - * / ( )')?;
    testing.assert_eq(actual: toks, expected: [
        Token.Plus, Token.Minus, Token.Star, Token.Slash,
        Token.LParen, Token.RParen, Token.Eof,
    ])?;
    return Result.Ok(void);
}

@test
fn test_numbers_integer_and_decimal() -> Result<Void, Error> {
    let toks = tokenize('12 3.5')?;
    testing.assert_eq(actual: toks, expected: [
        Token.Number(12.0), Token.Number(3.5), Token.Eof,
    ])?;
    return Result.Ok(void);
}

@test
fn test_whitespace_only_is_just_eof() -> Result<Void, Error> {
    testing.assert_eq(actual: tokenize('   ')?, expected: [Token.Eof])?;
    testing.assert_eq(actual: tokenize('')?, expected: [Token.Eof])?;
    return Result.Ok(void);
}

@test
fn test_expression_token_count() -> Result<Void, Error> {
    // 1 + 2 * 3  ->  Number + Number Star Number Eof  = 6 tokens.
    testing.assert_eq(actual: tokenize('1 + 2 * 3')?.len(), expected: 6)?;
    return Result.Ok(void);
}

@test
fn test_lex_errors() -> Result<Void, Error> {
    testing.assert_err(tokenize('1 @ 2'))?;  // unexpected character
    testing.assert_err(tokenize('1.'))?;      // '.' with no trailing digit
    testing.assert_err(tokenize('.5'))?;      // grammar requires a leading digit
    return Result.Ok(void);
}
