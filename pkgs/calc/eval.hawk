// calc spike — the evaluator (stage 3 of lex → parse → eval).
//
// A recursive walk over the AST — the `match`-as-only-branching idiom over a
// self-referential enum. Division by zero is the one runtime error.

import 'parser';

pub enum EvalError {
    DivByZero,
}

impl Error for EvalError {
    pub fn message(self) -> String {
        return match self {
            DivByZero => 'division by zero',
        };
    }
}

impl Display for EvalError {
    pub fn display(self) -> String {
        return self.message();
    }
}

// Evaluate an expression to a Double. Nested patterns let each operator be its
// own arm (`Bin(Add, l, r)`, …), so the operator dispatch folds into the tree
// walk — no separate `apply` helper. Each arm yields its value as a tail
// expression; `?` propagates a div-by-zero out of the recursion.
pub fn eval(_ e: Expr) -> Result<Double, EvalError> {
    return match e {
        Num(n) => Result.Ok(n),
        Neg(inner) => Result.Ok(-eval(inner)?),
        Bin(Add, l, r) => Result.Ok(eval(l)? + eval(r)?),
        Bin(Sub, l, r) => Result.Ok(eval(l)? - eval(r)?),
        Bin(Mul, l, r) => Result.Ok(eval(l)? * eval(r)?),
        Bin(Div, l, r) => {
            let rv = eval(r)?;
            if rv == 0.0 { Result.Err(EvalError.DivByZero) } else { Result.Ok(eval(l)? / rv) }
        },
    };
}
